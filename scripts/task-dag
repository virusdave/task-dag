                taskdag_migration_status_json
            else
                echo "Usage: task-dag migration-status --json" >&2; return 2
            fi ;;
        frontier) cmd_frontier "$@" ;;
        claim) cmd_claim "$@" ;;
        claim-root) cmd_claim_root "$@" ;;
        release) cmd_release "$@" ;;
        release-root) cmd_release_root "$@" ;;
        reap) cmd_reap "$@" ;;
        roots) cmd_roots "$@" ;;
