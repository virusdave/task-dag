        materialise-producer-enable) cmd_materialise_producer_enable "$@" ;;
        materialise-reconcile) cmd_materialise_reconcile "$@" ;;
        activation) cmd_activation "$@" ;;
        comment-watchdog) cmd_comment_watchdog "$@" ;;
        validate) cmd_validate "$@" ;;
        chain-read) cmd_chain_read "$@" ;;
        chain-write) cmd_chain_write "$@" ;;
        reconcile-lease) cmd_reconcile_lease "$@" ;;
        repair-retire) cmd_repair_retire "$@" ;;
