#!/usr/bin/env bash
# Git-DAG Task Management CLI
# See docs/INVARIANTS.md, docs/REF_LIFECYCLE.md, docs/DESIGN_PRINCIPLES.md,
# and docs/MIGRATION.md.
#
# CANONICAL SOURCE (single runtime): virusdave/task-dag : scripts/task-dag
# (+ scripts/task-dag.d/). This repo is the ONE home for the implementation
# (operator decision A'-new; see README.md + docs/MIGRATION.md). Do NOT edit
# or fork it per-repo. All git operations bind to the caller's CWD and the
# helpers are sourced relative to THIS file, so the canonical script runs
# correctly against any peer repo when invoked by absolute path from that
# repo's working directory.
#
# MIGRATION (B1, in progress): peer repos historically vendored a verbatim
# copy + a shared-workflows task-dag-drift-guard.yml. Workflow consolidation
# is DONE (every peer carries one logic-free .github/workflows/task-dag.yml
# caller into this repo's reusable workflows). CLI consolidation is in
# progress: the per-repo vendored copies + the drift-guard are being retired
# in favour of this single runtime. Until that lands, any remaining vendored
# copy is a transitional fallback. Rationale + phased plan:
# virusdave/top-level:docs/task_dag/CLI_DISTRIBUTION.md and this repo's
# docs/MIGRATION.md.
#
# This canonical copy is the UNION of every peer's feature set:
#   - cross-repo coordination + block/unblock/blocked/drop (from top-level)
#   - the cross-host atomic claim subsystem claim/release/active (CAS on
#     origin via --force-with-lease + double-checked readback; originally
#     developed in the automation fork). Keep claim/release/active intact:
#     the github-worker shell claim (lib/state.sh) is per-host only, so
#     these refs are what protect against duplicate work ACROSS hosts.
#   - breakdown: decompose an epic/task into child tasks from a JSON spec
#     (was a stub until 2026-06-16). Creates child commits (DAG edges =
#     git parents), atomically publishes their frontier refs, create-only.
#
# ═══════════════════════════════════════════════════════════════════════
# ⛔ DO NOT change the commit/ref FORMAT this tool mints until you FULLY
#    understand docs/INVARIANTS.md. task-dag's entire state is git refs +
#    commit messages with load-bearing invariants (every task/gh ref is an
#    empty-tree commit; namespaces are exact; claims are an atomic CAS;
#    completion is a specific merge shape; closure rides on trailers). A
#    well-meaning tweak to a message body, a new ref namespace, or a
#    "quick" manual `git commit-tree`/`update-ref` fix WILL silently break
#    dispatch dedup, claim safety, or issue closure across the whole fleet.
#
#    Enforcement (see docs/INVARIANTS.md):
#      • `task-dag validate --strict` audits every task/gh ref against the
#        grandfather-safe invariant floor (empty-tree + known namespace).
#        Any NEW ref namespace must be added to TASKDAG_KNOWN_*_NS below AND
#        get a golden fixture in tests/task-dag/ FIRST, or the audit (and CI)
#        will correctly reject it.
#      • Format changes are versioned by a `Task-Dag-Format:` trailer so a
#        tighter rule binds only to commits that declare the new version —
#        that is how "permanently backwards-compatible" is kept mechanical.
#    Changing any of this is a critical-infra change: operator approval +
#    an Oracle design/architecture review are REQUIRED. If the tool can't
#    express what you need, `block` the task + `page-dave`; do NOT improvise.
# ═══════════════════════════════════════════════════════════════════════

set -euo pipefail

VERSION="0.1.0"
EMPTY_TREE="4b825dc642cb6eb9a060e54bf8d69288fbee4904"

TASKDAG_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=task-dag.d/semantic-migration.sh
source "$TASKDAG_SCRIPT_DIR/task-dag.d/semantic-migration.sh"
# shellcheck source=task-dag.d/materialise.sh
source "$TASKDAG_SCRIPT_DIR/task-dag.d/materialise.sh"
# shellcheck source=task-dag.d/materialise-census-capture.sh
source "$TASKDAG_SCRIPT_DIR/task-dag.d/materialise-census-capture.sh"
# shellcheck source=task-dag.d/materialise-producer.sh
source "$TASKDAG_SCRIPT_DIR/task-dag.d/materialise-producer.sh"
# shellcheck source=task-dag.d/materialise-reconcile.sh
source "$TASKDAG_SCRIPT_DIR/task-dag.d/materialise-reconcile.sh"
# shellcheck source=task-dag.d/activation.sh
source "$TASKDAG_SCRIPT_DIR/task-dag.d/activation.sh"

# Colors for output (if supported)
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    BOLD='\033[1m'
    RESET='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' BOLD='' RESET=''
fi

# Helper: resolve ref or SHA to full SHA
resolve_sha() {
    local ref_or_sha="$1"
    git rev-parse "$ref_or_sha" 2>/dev/null || {
        echo "Error: Cannot resolve '$ref_or_sha'" >&2
        return 1
    }
}

# Helper: parse commit message metadata
parse_commit_metadata() {
    local sha="$1"
    git log -1 --format='%B' "$sha"
}

# Helper: extract field from commit message
extract_field() {
    local message="$1"
    local field="$2"
    # Missing field -> empty output + SUCCESS. grep exits non-zero when the
    # field is absent, and under `set -euo pipefail` that non-zero would
    # otherwise abort any caller that runs this in the main shell (not a
    # subshell). A missing field is a normal, expected case, so swallow it.
    echo "$message" | grep "^${field}:" | sed "s/^${field}: *//" | head -1 || true
}

# Helper: true only for the exact human GitHub comment task dialect used by
# issue-comment ingestion. These tasks are created specifically to wake the
# DAG up when an operator replies under a parked/blocked work item, so they
# must remain dispatchable even if their structural parent is blocked. Keep
# this fail-closed: ordinary task children, bot/system messages, and malformed
# messages still inherit structural blocks.
is_human_comment_task() {
    local sha="$1" msg
    msg=$(parse_commit_metadata "$sha" 2>/dev/null) || return 1
    [ "$(extract_field "$msg" "kind")" = "message" ] &&
    [ "$(extract_field "$msg" "role")" = "human" ] &&
    [ "$(extract_field "$msg" "intent")" = "comment" ]
}

# Helper: get task title (first line minus "Task: " prefix)
get_task_title() {
    local sha="$1"
    git log -1 --format='%s' "$sha" | sed 's/^Task: *//'
}

# Helper: get commit parents
get_parents() {
    local sha="$1"
    git rev-list --parents -1 "$sha" | awk '{for(i=2;i<=NF;i++) print $i}'
}

# Helper: get first parent (breakdown parent)
get_first_parent() {
    local sha="$1"
    get_parents "$sha" | head -1
}

# Helper: get dependency parents (2nd+)
get_dep_parents() {
    local sha="$1"
    get_parents "$sha" | tail -n +2
}

# Helper: check if task is completed (appears as non-primary parent in
# HEAD history). Uses EXACT parent-field matching, not a substring grep:
# a substring match would (a) false-positive when a short SHA is a prefix
# of an unrelated commit's parent and (b) silently widen to any commit
# mentioning the sha. We walk each commit's parent list and require an
# exact whole-token match.
#
# IMPORTANT: awk must NOT `exit` on the first match. Under `set -o
# pipefail`, an early awk exit closes the pipe while `git log` is still
# writing, killing it with SIGPIPE (exit 141); pipefail then makes the
# whole pipeline return 141, so a task that IS completed (and is matched
# on the very first line — e.g. HEAD's own 2nd parent) would be reported
# NOT completed intermittently (a real dispatch/epic-close correctness
# bug). Scanning the full stream keeps the producer's exit status 0.
# Helper: is <task_sha> completed *as seen from an arbitrary tip*? Same exact
# whole-token parent-field match as is_task_completed, but against a caller-
# supplied commit instead of HEAD. guard-pre-push needs this to ask "is this
# task already linked in the history I'm about to PUSH (local_sha)?" without
# depending on HEAD (a pre-push hook may push an explicit SHA, not HEAD).
task_is_completed_at_commit() {
    local tip="$1" task_sha="$2"
    taskdag_task_completed_at_tip "$tip" "$task_sha"
}

is_task_completed() {
    local task_sha="$1"
    task_is_completed_at_commit HEAD "$task_sha"
}

# Helper: true iff every dependency parent of <sha> is completed, i.e.
# the task is "ready" to be picked up. A task with no dependency parents
# is trivially ready (a dependency-free root). Mirrors the readiness
# logic of `cmd_deps` (get_dep_parents + is_task_completed) so `frontier`
# and `deps` never disagree about whether a task is pickable.
deps_satisfied() {
    local sha="$1"
    [ "$TASKDAG_CONSUMER_READY" = true ] || taskdag_consumer_prepare requirements || return 2
    taskdag_requirements_status_json "task:${TASKDAG_RECON_CUR}@${sha}" | jq -e '.requirementsSatisfied == true' >/dev/null
}

# Helper: same dependency predicate as deps_satisfied, but evaluated against a
# caller-supplied master tip. Commands that build directly on origin/master use
# this so they do not accidentally make a readiness decision from a stale or
# unrelated local HEAD.
deps_satisfied_at_commit() {
    local tip="$1" sha="$2"
    taskdag_consumer_prepare requirements-at-tip --tip "$tip" || return 2
    taskdag_requirements_status_json "task:${TASKDAG_RECON_CUR}@${sha}" | jq -e '.requirementsSatisfied == true' >/dev/null
}

taskdag_completion_allowed() { # <task-sha>, against prepared snapshot
    local status
    status=$(taskdag_task_status_json "task:${TASKDAG_RECON_CUR}@$1" --include-claimed) || return 2
    [ "$(jq -r '(.complete|not) and .requirementsSatisfied' <<<"$status")" = true ]
}

taskdag_task_is_complete_prepared() { # <task-sha>
    local status
    status=$(taskdag_task_status_json "task:${TASKDAG_RECON_CUR}@$1" --include-claimed) || return 2
    [ "$(jq -r .complete <<<"$status")" = true ]
}

taskdag_consumer_fenced_scheduling_push() { # <operation> <actor> <updates-json>
    local operation=$1 actor=$2 updates=$3 token timestamp
    [ "$TASKDAG_CONSUMER_MODE" = canonical ] || return 2
    token=$(taskdag_activation_snapshot_token) || return 3
    [ "$(jq -r .authorityTip <<<"$token")" = "$(jq -r .authorityTip <<<"$TASKDAG_CONSUMER_ACTIVATION")" ] || return 3
    updates=$(jq -cS 'sort_by(.ref)' <<<"$updates") || return 3
    timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    taskdag_activation_fenced_multi_push "$token" scheduling "$operation" "$actor" "$timestamp" "$updates"
}

# Helper: find the first reachable completion merge whose parent list includes
# <task_sha>. Authoritative completion is parentage; callers inspect the
# message only for audit/idempotency notes.
completion_merge_for_task_at_commit() {
    local tip="$1" task_sha="$2"
    taskdag_task_completion_witness_at_tip "$tip" "$task_sha"
}

print_completion_push_instruction() {
    echo "Completion prepared locally; origin/master and task scheduling refs are unchanged."
    echo "Run exactly:"
    echo "task-dag publish"
}

# Helper: is <sha> a task commit? Every task commit (epic/task/leaf, and
# the comment/message/issue-root commits the workflows mint) is created
# with the canonical EMPTY_TREE (see `breakdown`'s commit-tree call and
# the cmd_validate "Check 1" invariant). A commit with any other tree is
# real master/branch history — the boundary of the live task DAG. We use
# the tree, NOT `merge-base --is-ancestor HEAD`, to detect that boundary:
# completing one child lands a completion commit that pulls a still-live
# (possibly blocked) structural parent into HEAD history, so "ancestor of
# HEAD" is NOT a reliable "no longer a live task" signal, whereas the
# empty tree is stable for the commit's whole life.
is_task_commit() {
    local sha="$1" tree
    tree=$(git rev-parse "$sha^{tree}" 2>/dev/null) || return 1
    [ "$tree" = "$EMPTY_TREE" ]
}

# Helper: true iff <subject> uses a Conventional-Commits `type(scope):` prefix,
# which canon forbids (rules/WORKFLOW.md 'Commit messages' — subjects must be a
# plain, capitalized, imperative sentence). Single source of truth for the
# match, shared by the commit-msg guard AND the complete-time backstop. The
# pattern is deliberately narrow (high-signal only): a leading lowercase type,
# optional `(scope)` and/or `!`, immediately followed by `: `. So capitalized
# subjects, `fixup!`/`squash!` (no colon), git `Revert "..."`/`Merge ...`
# subjects, and `word://…` (no space after the colon) never match.
subject_is_conventional_commits() {
    grep -qE '^[a-z][a-z0-9-]*(\([^)]+\))?!?: ' <<<"$1"
}

# Helper: true iff <sha> is a SANCTIONED task-dag "tip" shape that legitimately
# lands on master WITHOUT being plain implementation work — i.e. a shape the
# tooling itself mints as the push tip:
#   • a completion/link MERGE: has a 2nd parent that is a task commit
#     (empty-tree) and whose own tree equals its first parent's tree (adds only
#     the parent edge, never file changes) — this covers `complete`,
#     `complete --leaves`, `complete-ops`, and `complete-historical` link commits;
#   • an epic-close commit: carries a `Closes-Epic:` trailer and is tree-equal
#     to its first parent.
# Used by guard-pre-push to allow a properly-completed push through. Never keys
# off HEAD — the caller passes the exact commit being pushed.
is_sanctioned_tip_commit() {
    local sha="$1" first second first_tree self_tree parent_count close_count has_close=false
    self_tree=$(git rev-parse "$sha^{tree}" 2>/dev/null) || return 1
    parent_count=$(get_parents "$sha" 2>/dev/null | wc -l)
    [ "$parent_count" -eq 2 ] || return 1
    first=$(get_first_parent "$sha" 2>/dev/null || true)
    [ -n "$first" ] || return 1
    first_tree=$(git rev-parse "$first^{tree}" 2>/dev/null) || return 1
    second=$(get_parents "$sha" 2>/dev/null | sed -n '2p')
    [ -n "$second" ] && [ "$self_tree" = "$first_tree" ] && is_task_commit "$second" || return 1
    git log -1 --format='%B' "$sha" 2>/dev/null | grep -qE '^Closes-Epic:' && has_close=true
    close_count=$(git log -1 --format='%B' "$sha" 2>/dev/null | grep -cE '^Closes-Epic:[[:space:]]*#[0-9]+[[:space:]]*$' || true)
    if [ "$has_close" = false ]; then
        return 0
    fi
    if [ "$close_count" -eq 1 ]; then
        return 0
    fi
    return 1
}

# Helper: walk the FIRST-parent (breakdown/structural) lineage of <sha>
# and, if any structural ancestor is blocked, print that ancestor's SHA
# and return 0; otherwise return 1.
#
# WHY: blocking must be transitive over the structural lineage. A child
# created by `breakdown <parent>` carries <parent> as its FIRST parent,
# which `get_dep_parents` deliberately strips — so the parent is NOT a
# dependency and `deps_satisfied` is trivially true for the child. Without
# this walk, blocking a parent/epic (e.g. an "awaiting operator feedback"
# task) would NOT withhold the subtasks decomposed under it, and the
# dispatcher would spawn no-op workers on them (the over-dispatch the
# block mechanism exists to prevent). Explicit DEPENDENCY edges to a
# blocked task are already handled (a blocked task is not completed, so
# deps_satisfied fails); this closes the structural-lineage gap.
#
# The walk stops at the first non-task-commit first-parent (the master
# base the root epic was minted on) — bounded to the few hops of the
# decomposition depth. <sha> itself is NOT checked here (frontier/claim
# check it directly via is_task_blocked); we start from its first parent.
blocked_structural_ancestor() {
    local cur="$1" parent
    while :; do
        parent="$(get_first_parent "$cur" 2>/dev/null || true)"
        [ -n "$parent" ] || return 1
        # Left the live task DAG (reached real history) — no blocked
        # structural ancestor.
        is_task_commit "$parent" || return 1
        if is_task_blocked "$parent"; then
            printf '%s\n' "$parent"
            return 0
        fi
        cur="$parent"
    done
}

# NOTE: the former is_epic_complete() helper was removed. It enumerated
# children with a fragile `git log --all | grep "$epic_sha"` substring
# match (which also miscounted claim/completion commits) and was only used
# by the rogue direct-REST epic close in `complete`. Epic completeness is
# now decided by epic_subtree_complete() (exact parent matching, recursive
# over the breakdown tree) and closure goes through the canonical
# Closes-Epic trailer merge — see maybe_emit_local_epic_close().

# Helper: list all task refs
list_task_refs() {
    git for-each-ref refs/heads/tasks/ --format='%(objectname) %(refname:short)'
}

# ─────────────────────────────────────────────────────────────────────
# Task-ref invariants (see docs/INVARIANTS.md)
#
# Every ref the task-dag system creates points at an EMPTY-TREE commit and
# lives under a KNOWN namespace. These two facts have held for every
# task/gh ref since the tool existed, so asserting them never false-flags
# legacy history — they are the "grandfather-safe" invariant floor. Deeper,
# kind-specific rules (required trailers per commit kind, the #34 naming/
# format migration, etc.) are versioned via a `Task-Dag-Format:` trailer so
# tightening them later binds only to commits that declare the new version;
# see docs/INVARIANTS.md § "Format versioning".
#
# The PRIMARY value of the namespace check is catching a hand-crafted ref
# at a path the tool would never mint — i.e. exactly the "I'll just do the
# ref surgery by hand" mistake this whole subsystem exists to prevent.
# ─────────────────────────────────────────────────────────────────────
TASKDAG_KNOWN_TASK_NS="pending root-active frontier active blocked blocked-meta delegated delegated-close completions ci-chains repair-superseded"
TASKDAG_KNOWN_GH_NS="issues comments child-epics child-epic-slots materialisation-markers"

# ─────────────────────────────────────────────────────────────────────
# The dependency-graph index branch (issue #13 north-star, Phase 2).
#
# `refs/heads/tasks/v1/graph` is the ONE task-namespace ref that is NOT an
# empty-tree commit: its latest tree IS the active dependency-edge set, a
# content-addressed collection of blobs at `edges/<edge-id>.json`. It is a
# NEW ref KIND with its OWN invariant (a commit whose tree contains only
# `edges/<64-hex>.json` blobs), NOT a loosening of the empty-tree floor for
# everything under `tasks/v1/*`. We deliberately do NOT add `v1` to
# TASKDAG_KNOWN_TASK_NS — that would legitimise arbitrary `tasks/v1/*` hand
# surgery. Only this EXACT ref is recognised; a hand-crafted `tasks/v1/junk`
# still fails the namespace check. Operator-approved bounded-ref namespace
# (issue #13 Phase 0); see docs/INVARIANTS.md § "The dependency-graph index".
TASKDAG_GRAPH_REF="refs/heads/tasks/v1/graph"

# Immutable materialisation reservations have one exact data-in-tree ref.
# Never broaden this exception to tasks/v1/*.
TASKDAG_MATERIALISATION_REF="refs/heads/tasks/v1/materialisation"
TASKDAG_ACTIVATION_REF="refs/heads/tasks/v1/activation"
TASKDAG_MATERIALISE_PRODUCER_REF="refs/heads/tasks/v1/materialisation-producer"
TASKDAG_COMMENT_WATCHDOG_REF="refs/heads/tasks/v1/comment-watchdog"

taskdag_is_activation_ref() {
    case "$1" in
        refs/heads/tasks/v1/activation|tasks/v1/activation) return 0 ;;
        *) return 1 ;;
    esac
}

taskdag_is_materialisation_ref() {
    case "$1" in
        refs/heads/tasks/v1/materialisation|tasks/v1/materialisation) return 0 ;;
        *) return 1 ;;
    esac
}

taskdag_is_materialisation_producer_ref() {
    case "$1" in
        refs/heads/tasks/v1/materialisation-producer|tasks/v1/materialisation-producer) return 0 ;;
        *) return 1 ;;
    esac
}

taskdag_is_comment_watchdog_ref() {
    case "$1" in
        refs/heads/tasks/v1/comment-watchdog|tasks/v1/comment-watchdog) return 0 ;;
        *) return 1 ;;
    esac
}

# taskdag_is_graph_ref <ref>: true iff <ref> is EXACTLY the graph index
# branch, in either the fully-qualified or short (`tasks/v1/graph`) form.
taskdag_is_graph_ref() {
    case "$1" in
        refs/heads/tasks/v1/graph|tasks/v1/graph) return 0 ;;
        *) return 1 ;;
    esac
}

# taskdag_graph_tree_violations <commit-sha>: echo one human-readable line
# per graph-index shape violation (nothing when well-formed). The graph
# index tree may contain ONLY regular blobs named `edges/<64-hex>.json`
# (the content-addressed active edge set) or `tombstones/<64-hex>.json`
# (explicit witnessed removals — issue #13 satisfied-edge-pruning sibling).
# Any other path, a non-blob entry, or a malformed edge-id filename is a
# violation. An empty tree (zero edges) is valid. This checks tree SHAPE
# only; the reader (taskdag_read_edges) is the content validator. Never
# mutates anything; returns 0 always.
taskdag_graph_tree_violations() {
    local sha="$1" mode type obj path
    while read -r mode type obj path; do
        [ -n "$type" ] || continue
        if [ "$type" != blob ]; then
            echo "✗ ${TASKDAG_GRAPH_REF} tree entry '${path}' is a ${type}, expected a blob (edges/<edge-id>.json or tombstones/<edge-id>.json)"
            continue
        fi
        # A regular file only — reject symlinks (120000) and executables
        # (100755), which git also reports as type 'blob'.
        if [ "$mode" != 100644 ]; then
            echo "✗ ${TASKDAG_GRAPH_REF} tree entry '${path}' has mode ${mode}, expected a regular file (100644)"
            continue
        fi
        case "$path" in
            edges/[0-9a-f]*.json)
                # Assert the exact edge-id shape: edges/<64 lowercase hex>.json
                local base="${path#edges/}"; base="${base%.json}"
                if ! [[ "$base" =~ ^[0-9a-f]{64}$ ]]; then
                    echo "✗ ${TASKDAG_GRAPH_REF} edge blob '${path}' has a malformed edge-id (expected edges/<64-hex>.json)"
                fi
                ;;
            tombstones/[0-9a-f]*.json)
                # Same content-addressed edge-id shape for a tombstone.
                local tbase="${path#tombstones/}"; tbase="${tbase%.json}"
                if ! [[ "$tbase" =~ ^[0-9a-f]{64}$ ]]; then
                    echo "✗ ${TASKDAG_GRAPH_REF} tombstone blob '${path}' has a malformed edge-id (expected tombstones/<64-hex>.json)"
                fi
                ;;
            *)
                echo "✗ ${TASKDAG_GRAPH_REF} tree contains unexpected path '${path}' (only edges/<edge-id>.json and tombstones/<edge-id>.json blobs are allowed)"
                ;;
        esac
    done < <(git ls-tree -r "$sha" 2>/dev/null)
    return 0
}

# ─────────────────────────────────────────────────────────────────────
# The cross-repo mailbox shards (issue #13 north-star, Phase 3).
#
# `refs/heads/tasks/v1/mailbox/00` .. `/0f` are the SECOND data-in-tree task
# ref kind (after the graph index): exactly 16 fixed shard branches whose
# trees carry cross-repo notification messages as `msg/<message-id>.json`
# blobs. This keeps the live mirrored ref count O(1)=16 regardless of
# in-flight message count (the bounded-ref invariant) — a message costs a
# tree blob, not a ref. Like the graph index they are EXEMPT from the
# empty-tree floor but have their OWN shape invariant, and ONLY these exact
# 16 refs are recognised: a hand-crafted `tasks/v1/mailbox/10` or
# `tasks/v1/mailbox/0g` still fails the namespace check. We deliberately do
# NOT add `v1` to TASKDAG_KNOWN_TASK_NS. Operator-approved bounded-ref
# namespace (issue #13 Phase 0); see docs/INVARIANTS.md § "The cross-repo
# mailbox shards".
TASKDAG_MAILBOX_REF_GLOB="refs/heads/tasks/v1/mailbox"

# taskdag_is_mailbox_ref <ref>: true iff <ref> is EXACTLY one of the 16 fixed
# mailbox shard branches (00..0f), in either the fully-qualified or short
# (`tasks/v1/mailbox/0f`) form.
taskdag_is_mailbox_ref() {
    case "$1" in
        refs/heads/tasks/v1/mailbox/0[0-9a-f]|tasks/v1/mailbox/0[0-9a-f]) return 0 ;;
        *) return 1 ;;
    esac
}

# taskdag_mailbox_tree_violations <commit-sha> <full-refname>: echo one
# human-readable line per mailbox-shard shape violation (nothing when
# well-formed). A shard tree may contain ONLY regular blobs named
# `msg/<64-hex>.json` (the content-addressed in-flight message set), AND each
# message MUST live in the shard its id derives to (the first hex nibble,
# formatted %02x → 00..0f); a mis-sharded blob is corruption. Any other path,
# a non-blob entry, a malformed message-id filename, or a wrong-shard blob is
# a violation. An empty tree (zero messages) is valid. Never mutates anything;
# returns 0 always.
taskdag_mailbox_tree_violations() {
    local sha="$1" ref="$2" mode type obj path shard
    shard="${ref##*/}"
    while read -r mode type obj path; do
        [ -n "$type" ] || continue
        if [ "$type" != blob ]; then
            echo "✗ ${TASKDAG_MAILBOX_REF_GLOB} shard tree entry '${path}' is a ${type}, expected a blob (msg/<message-id>.json)"
            continue
        fi
        if [ "$mode" != 100644 ]; then
            echo "✗ ${TASKDAG_MAILBOX_REF_GLOB} shard tree entry '${path}' has mode ${mode}, expected a regular file (100644)"
            continue
        fi
        case "$path" in
            msg/[0-9a-f]*.json)
                local base="${path#msg/}"; base="${base%.json}"
                if ! [[ "$base" =~ ^[0-9a-f]{64}$ ]]; then
                    echo "✗ ${TASKDAG_MAILBOX_REF_GLOB} message blob '${path}' has a malformed message-id (expected msg/<64-hex>.json)"
                    continue
                fi
                local want_shard
                want_shard=$(printf '%02x' "$((16#${base:0:1}))")
                if [ "$want_shard" != "$shard" ]; then
                    echo "✗ ${ref} message ${base} is in shard ${shard} but derives to shard ${want_shard} (mis-sharded blob is corruption)"
                fi
                ;;
            *)
                echo "✗ ${TASKDAG_MAILBOX_REF_GLOB} shard tree contains unexpected path '${path}' (only msg/<message-id>.json blobs are allowed in schema v1)"
                ;;
        esac
    done < <(git ls-tree -r "$sha" 2>/dev/null)
    return 0
}

# taskdag_ref_violations <objectname> <full-refname>
# Echoes one human-readable line per invariant violation (nothing when the
# ref is well-formed). Never mutates anything. Returns 0 always; the caller
# counts the emitted lines. A mutable scheduling ref whose object has vanished
# mid-walk (concurrent claim/complete/drop) yields no lines, so the audit never
# flaps. The immutable materialisation authority instead fails closed.
taskdag_ref_violations() {
    local sha="$1" ref="$2" activation_authority=${3:-} expected_repository=${4:-}
    local objtype tree rest ns
    objtype=$(git cat-file -t "$sha" 2>/dev/null) || {
        { taskdag_is_materialisation_ref "$ref" || taskdag_is_materialisation_producer_ref "$ref" || taskdag_is_comment_watchdog_ref "$ref" || taskdag_is_activation_ref "$ref"; } \
            && echo "✗ ${ref} → ${sha} is missing or unreadable"
        return 0
    }
    if [ "$objtype" != commit ]; then
        echo "✗ ${ref} → ${sha} is a ${objtype}, expected an (empty-tree) commit"
        return 0
    fi
    # Repair-retirement audits have an exact path and typed commit protocol,
    # not merely a broadly accepted namespace. The validator is defined by
    # ci-repair.sh and checks the complete semantic identity and chain parent.
    if [[ "$ref" = refs/heads/tasks/repair-superseded \
        || "$ref" = refs/heads/tasks/repair-superseded/* ]]; then
        taskdag_repair_superseded_violations "$sha" "$ref"
        return 0
    fi
    # The dependency-graph index branch is the ONE known exception to the
    # empty-tree floor: its tree IS the active edge set (see the
    # TASKDAG_GRAPH_REF block above). It is EXEMPT from the empty-tree rule
    # but must still be a commit (checked above) whose tree obeys the
    # graph-index shape (only edges/<edge-id>.json blobs). Nothing else
    # under tasks/v1/* is recognised, so `tasks/v1/junk` still fails below.
    if taskdag_is_graph_ref "$ref"; then
        taskdag_graph_tree_violations "$sha"
        return 0
    fi
    if taskdag_is_materialisation_ref "$ref"; then
        taskdag_materialisation_tree_violations "$sha" "$activation_authority" "$expected_repository"
        return 0
    fi
    if taskdag_is_materialisation_producer_ref "$ref"; then
        _taskdag_materialise_producer_validate_tip "$sha" \
            || echo "✗ ${ref} has malformed materialisation producer authority"
        return 0
    fi
    if taskdag_is_comment_watchdog_ref "$ref"; then
        taskdag_comment_watchdog_validate_tip "$sha" \
            || echo "✗ ${ref} has malformed comment-watchdog authority"
        return 0
    fi
    if taskdag_is_activation_ref "$ref"; then
        taskdag_activation_validate_history "$sha" >/dev/null \
            || echo "✗ ${ref} has malformed activation history or guard"
        return 0
    fi
    # The cross-repo mailbox shards are the other data-in-tree exception: a
    # commit (checked above) whose tree obeys the mailbox shape (only
    # msg/<message-id>.json blobs). Only the 16 exact 00..0f refs match, so
    # tasks/v1/mailbox/junk still falls through to the unknown-namespace check.
    if taskdag_is_mailbox_ref "$ref"; then
        taskdag_mailbox_tree_violations "$sha" "$ref"
        return 0
    fi
    tree=$(git rev-parse "${sha}^{tree}" 2>/dev/null) || return 0   # vanished → skip
    if [ "$tree" != "$EMPTY_TREE" ]; then
        echo "✗ ${ref} → ${sha} has a non-empty tree (${tree}); every task/gh ref MUST point at an empty-tree commit"
    fi
    case "$ref" in
        refs/heads/tasks/*)
            rest="${ref#refs/heads/tasks/}"; ns="${rest%%/*}"
            case " $TASKDAG_KNOWN_TASK_NS " in
                *" $ns "*) ;;
                *) echo "✗ ${ref} is under UNKNOWN tasks namespace '${ns}' (hand-crafted ref? do NOT do ref surgery by hand — see docs/INVARIANTS.md). Known: ${TASKDAG_KNOWN_TASK_NS}" ;;
            esac ;;
        refs/heads/gh/*)
            rest="${ref#refs/heads/gh/}"; ns="${rest%%/*}"
            case " $TASKDAG_KNOWN_GH_NS " in
                *" $ns "*) ;;
                *) echo "✗ ${ref} is under UNKNOWN gh namespace '${ns}' (hand-crafted ref? do NOT do ref surgery by hand — see docs/INVARIANTS.md). Known: ${TASKDAG_KNOWN_GH_NS}" ;;
            esac ;;
    esac
    # Receipt v1 opts into a stronger shape contract. Historical comment
    # provenance remains governed by the grandfather-safe floor above.
    if [[ "$ref" = refs/heads/gh/comments/* ]] \
        && git log -1 --format=%B "$sha" | grep -q '^Receipt-Version: '; then
        if [[ ! "$ref" =~ ^refs/heads/gh/comments/([1-9][0-9]*)/([1-9][0-9]*)$ ]]; then
            echo "✗ ${ref} → ${sha}: malformed comment-receipt ref; expected refs/heads/gh/comments/<issue>/<comment-id> with positive decimal IDs"
            return 0
        fi
        local receipt_issue="${BASH_REMATCH[1]}" receipt_comment="${BASH_REMATCH[2]}" receipt_repo
        receipt_repo=$(printf '%s' "$(_xrepo_current_repo_offline)" | tr '[:upper:]' '[:lower:]')
        if ! _xrepo_validate_receipt "$sha" "$receipt_repo" "$receipt_issue" "$receipt_comment" >/dev/null; then
            echo "✗ ${ref} → ${sha}: invalid GitHub comment receipt v1; expected Repository=${receipt_repo}, Issue=${receipt_issue}, Comment-ID=${receipt_comment}, and a valid receipt/effect shape"
        fi
    fi
    return 0
}

# Helper: fetch task refs from origin so local view reflects remote.
# Safe to call repeatedly. Quiet on success; failure is non-fatal —
# offline callers can still see whatever they fetched last.
#
# The `blocked` overlay MUST be fetched here too: `is_task_blocked` (used
# by `frontier` and `claim`) reads the LOCAL blocked ref, so a fresh
# worker that never syncs the overlay would treat parked tasks as
# pickable and re-dispatch them — the exact comment→task dispatch loop
# the block mechanism exists to prevent (issue #22). `--prune` scoped to
# these namespaces drops local refs that origin has since removed
# (completed/claimed/unblocked) so long-lived checkouts don't show stale
# frontier/blocked entries.
# fetch_task_refs_strict: the same namespace sync but RETURNS git's exit
# status (not masked). Callers that must NOT act on a partial/stale local
# DAG view — e.g. the epic auto-close completeness check — use this and
# fail CLOSED on a non-zero return. Most callers want the non-fatal
# `fetch_task_refs` wrapper below instead.
fetch_task_refs_strict() {
    git fetch --quiet --prune origin \
        '+refs/heads/tasks/frontier/*:refs/heads/tasks/frontier/*' \
        '+refs/heads/tasks/active/*:refs/heads/tasks/active/*' \
        '+refs/heads/tasks/blocked/*:refs/heads/tasks/blocked/*' \
        '+refs/heads/tasks/blocked-meta/*:refs/heads/tasks/blocked-meta/*' \
        '+refs/heads/tasks/root-active/*:refs/heads/tasks/root-active/*' \
        '+refs/heads/tasks/pending/*:refs/heads/tasks/pending/*' \
        '+refs/heads/tasks/v1/*:refs/heads/tasks/v1/*' \
        '+refs/heads/gh/issues/*:refs/heads/gh/issues/*'
}

fetch_task_refs() {
    fetch_task_refs_strict 2>/dev/null || true
}

# normalize_task_ref: validate + normalize a task ref before it is ever
# interpolated into a git refspec. Accepts either the short namespace form
# (`tasks/<ns>/<short>`) or the fully-qualified `refs/heads/tasks/<ns>/<short>`
# and prints the normalized short form (`tasks/<ns>/<short>`) on stdout.
# Returns non-zero for anything outside the `tasks/*` namespace or containing
# refspec/rev metacharacters — NEVER feed an unchecked manifest/user value
# straight into `git fetch` (design §3 Layer A step 1, §5 risk 3).
normalize_task_ref() {
    local ref="$1"
    ref="${ref#refs/heads/}"
    case "$ref" in
        tasks/*) : ;;
        *) return 1 ;;
    esac
    # Reject refspec-injection / rev-metacharacter payloads and empty
    # trailing components. A well-formed task ref is a plain slash path.
    case "$ref" in
        *' '*|*'	'*|*'*'*|*'..'*|*'~'*|*'^'*|*':'*|*'?'*|*'['*|*'\'*|*'+'*) return 1 ;;
        */) return 1 ;;
    esac
    printf '%s\n' "$ref"
}

# fetch_task_ref_exact: fetch exactly one already-normalized task ref into the
# LOCAL refs/heads/tasks/* namespace (the same namespace the CLI enumerates —
# NOT refs/remotes/origin/tasks/*, per design §5 risk 4). No --prune (we are
# fetching a single ref, not syncing a namespace) and no --depth (dependency
# completeness needs full parent history, design §2 / §5 risk 6). Returns
# git's exit status so callers can fall back.
fetch_task_ref_exact() {
    local ref="$1"
    git fetch --quiet --no-tags origin "+refs/heads/${ref}:refs/heads/${ref}"
}

# Helper: print 'yes' iff the remote currently has a tasks/active/<short>
# ref. The remote is the source of truth for claim state — local refs may
# lag if another worker just won the CAS.
task_is_claimed_on_remote() {
    local short_sha="$1"
    git ls-remote --exit-code origin "refs/heads/tasks/active/$short_sha" \
        >/dev/null 2>&1 && echo "yes" || echo "no"
}

# Helper: read the SHA that origin currently has at tasks/active/<short>,
# bypassing every local cache (no fetch + no use of local refs). Empty
# string means "ref does not exist on origin".
#
# Used by the post-push double-check in `cmd_claim` / `cmd_release` /
# `cmd_complete` so we can verify our git-push-CAS actually landed
# OUR commit on origin and wasn't immediately overwritten by a
# concurrent worker. This is the "verify" in "double-checked
# locking": the lease check on push is the lock; this ls-remote
# round-trip is the readback that confirms the lock is still ours.
task_active_sha_on_remote() {
    local short_sha="$1"
    git ls-remote origin "refs/heads/tasks/active/$short_sha" 2>/dev/null \
        | awk '{print $1; exit}'
}

# Helper: print 'yes' iff the remote currently has a tasks/frontier/<short>
# ref pointing at the expected task SHA.
task_frontier_on_remote() {
    local short_sha="$1"
    git ls-remote origin "refs/heads/tasks/frontier/$short_sha" 2>/dev/null \
        | awk '{print $1; exit}'
}

# Helper: build the claim-commit metadata block. The active ref points
# at a side-commit whose tree is identical to the task tree and whose
# first parent is the task commit; the commit message holds claim
# attribution. This keeps `git log tasks/active/<short>` readable
# without growing a separate metadata store.
build_claim_commit() {
    local task_sha="$1"
    local claimer="$2"
    local claimer_host="$3"
    local ttl_hours="$4"
    local note="$5"
    # Claimer-PID: OS process id of the claiming worker on Claimer-Host.
    # Recorded so a janitor (or another worker) on that same host can cheaply
    # tell a live claim from an orphaned one — a worker the OS/an error killed
    # before it could `complete` or `release` — via `kill -0 <pid>`, instead of
    # waiting out the (long, advisory) TTL. Optional: legacy/cross-tool callers
    # may omit it, in which case the line is simply not written.
    local claimer_pid="$6"

    local task_title
    task_title=$(get_task_title "$task_sha")
    local task_tree
    task_tree=$(git rev-parse "$task_sha^{tree}")

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Keep the identity fields (who / where / which-process) grouped together,
    # ahead of the timing fields, so a liveness check reads top-to-bottom.
    local msg="Claim: ${task_title}

Task-Commit: ${task_sha}
Claimer: ${claimer}
Claimer-Host: ${claimer_host}"
    if [ -n "$claimer_pid" ]; then
        msg="${msg}
Claimer-PID: ${claimer_pid}"
    fi
    msg="${msg}
Claimed-At: ${now}
TTL-Hours: ${ttl_hours}"
    if [ -n "$note" ]; then
        msg="${msg}
Note: ${note}"
    fi

    git commit-tree "$task_tree" -p "$task_sha" -m "$msg"
}

# ── Epic-root orchestration locking (issue #2) ────────────────────────
#
# An epic root (`tasks/pending/<N>`) is the durable identity of issue N
# (closure / delegation / comment ancestry all anchor to it), so it is
# NEVER moved or renamed. That very durability means the leaf claim CAS
# (frontier->active) cannot protect it, so two hosts could both dispatch
# the same undecomposed root. The fix is a SECOND, parallel lock ref:
#
#   tasks/root-active/<N>  — a cross-host claim on "orchestrate/decompose
#                            issue N". Created by `claim-root <N>` via the
#                            same atomic CAS used for leaves, keyed by
#                            issue number (matching pending/<N>), and
#                            CONSUMED (deleted) by `breakdown` in the same
#                            atomic push that publishes the child leaves.
#
# pending/<N> is left untouched throughout, so identity is preserved.

# Helper: print the SHA origin currently has at <ref>, bypassing local
# caches (no fetch, no local-ref shortcut). Empty string = absent.
remote_ref_sha() {
    git ls-remote origin "$1" 2>/dev/null | awk '{print $1; exit}'
}

# Helper: tri-state remote ref lookup so safety-critical callers can FAIL
# CLOSED on an indeterminate (transport/auth) error instead of mistaking a
# transient failure for "ref absent". Mirrors pending_sha_on_remote_checked.
# Echoes the SHA on success.
#   rc 0 + SHA  -> ref exists on origin
#   rc 2        -> ref cleanly absent
#   rc 3        -> origin unreachable / error (indeterminate)
remote_ref_sha_checked() {
    local out rc
    out=$(git ls-remote --exit-code origin "$1" 2>/dev/null)
    rc=$?
    case "$rc" in
        0) printf '%s\n' "$out" | awk '{print $1; exit}'; return 0 ;;
        2) return 2 ;;   # exit-code 2: ref not found
        *) return 3 ;;   # transport/auth/other
    esac
}

# Helper: SHA of tasks/pending/<N> on origin (epic-root identity).
pending_sha_on_remote() {
    remote_ref_sha "refs/heads/tasks/pending/$1"
}

# Helper: tri-state pending lookup so callers can FAIL CLOSED on an
# indeterminate (transport/auth) error instead of silently treating a
# transient failure as "no root". Echoes the SHA on success.
#   rc 0 + SHA  -> root exists on origin
#   rc 2        -> root cleanly absent
#   rc 3        -> origin unreachable / error (indeterminate)
pending_sha_on_remote_checked() {
    local out rc
    out=$(git ls-remote --exit-code origin "refs/heads/tasks/pending/$1" 2>/dev/null)
    rc=$?
    case "$rc" in
        0) printf '%s\n' "$out" | awk '{print $1; exit}'; return 0 ;;
        2) return 2 ;;   # exit-code 2: ref not found
        *) return 3 ;;   # transport/auth/other
    esac
}

# Helper: SHA of tasks/root-active/<N> on origin (root orchestration lock).
root_active_sha_on_remote() {
    remote_ref_sha "refs/heads/tasks/root-active/$1"
}

# Helper: fetch the refs needed to reason about issue N's epic root —
# the pending root, its orchestration lock, and every namespace a child
# task could live in (so child detection sees active/blocked/delegated
# children, not just freshly-published frontier leaves).
#
# Returns 0 only if the sync actually completed; returns 1 on a transport/
# auth failure. A wildcard refspec that matches nothing on origin still
# succeeds (rc 0), so a non-zero rc means "we could not read origin", not
# "no such refs". Safety-critical callers (claim-root child checks, the
# breakdown double-decompose guard, the complete root-with-children guard)
# MUST fail CLOSED on a non-zero rc rather than treating an unreadable
# origin as "no children" — otherwise a transient failure re-opens the
# exact duplicate-decompose race this lock exists to prevent (#2). Display
# paths (`roots`) may ignore the rc.
fetch_root_refs() {
    local issue="${1:-}"
    # --prune so a local checkout that still carries a frontier/active/etc
    # ref origin has since removed does not give task_has_children a stale
    # false-positive child. (Truly local-only experimental branches are
    # still visible to `git rev-list --all`; origin is the source of truth.)
    git fetch --quiet --prune origin \
        '+refs/heads/tasks/pending/*:refs/heads/tasks/pending/*' \
        '+refs/heads/tasks/root-active/*:refs/heads/tasks/root-active/*' \
        '+refs/heads/tasks/frontier/*:refs/heads/tasks/frontier/*' \
        '+refs/heads/tasks/active/*:refs/heads/tasks/active/*' \
        '+refs/heads/tasks/blocked/*:refs/heads/tasks/blocked/*' \
        2>/dev/null || return 1
    # Also refresh the default branch (master): a COMPLETED child's frontier/
    # active ref is deleted on completion, but the child task commit lives on
    # as the SECOND parent of its completion commit on master. `task_has_children`
    # walks `git rev-list --all`, so if origin/master is stale a long-lived
    # worktree would not see already-completed children and could re-decompose
    # the root (false-negative #2 race). Keep this best-effort: if the default
    # branch ref cannot be resolved, the task-namespace fetch above already
    # succeeded, so do NOT fail the whole sync over it.
    local default_branch
    default_branch=$(git symbolic-ref -q --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##' || true)
    default_branch="${default_branch:-master}"
    git fetch --quiet origin \
        "+refs/heads/${default_branch}:refs/remotes/origin/${default_branch}" \
        2>/dev/null || true
    if [ -n "$issue" ]; then
        git fetch --quiet --prune origin \
            "+refs/heads/tasks/delegated/${issue}/*:refs/heads/tasks/delegated/${issue}/*" \
            2>/dev/null || return 1
    fi
    return 0
}

# Helper: build the root-orchestration claim commit. Mirrors the leaf
# claim commit (so liveness/attribution tooling reads it the same way)
# but tags it `Claim-Kind: root` and records the issue number. Its first
# parent is the root commit, and its subject begins "Claim: " — both so
# `task_has_children` never mistakes the lock commit for a real child.
build_root_claim_commit() {
    local issue="$1" root_sha="$2" claimer="$3" claimer_host="$4"
    local ttl_hours="$5" note="$6" claimer_pid="$7"

    local root_title root_tree now claim_id
    root_title=$(get_task_title "$root_sha")
    root_tree=$(git rev-parse "$root_sha^{tree}")
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    # Per-claim nonce so two same-second / same-identity claims never
    # collapse to the same commit SHA. The claim SHA is the lock token in
    # the --force-with-lease CAS, so distinct lock *epochs* must have
    # distinct tokens (else a stale holder's lease could match a fresh
    # claim). uuidgen when available; otherwise time+pid+random.
    claim_id=$(uuidgen 2>/dev/null || echo "$(date +%s%N)-$$-${RANDOM}")

    local msg="Claim: ${root_title}

Claim-Kind: root
Issue: #${issue}
Claim-ID: ${claim_id}
Task-Commit: ${root_sha}
Claimer: ${claimer}
Claimer-Host: ${claimer_host}"
    if [ -n "$claimer_pid" ]; then
        msg="${msg}
Claimer-PID: ${claimer_pid}"
    fi
    msg="${msg}
Claimed-At: ${now}
TTL-Hours: ${ttl_hours}"
    if [ -n "$note" ]; then
        msg="${msg}
Note: ${note}"
    fi

    git commit-tree "$root_tree" -p "$root_sha" -m "$msg"
}

claim_dead_reason="none"

# Helper: determine whether a claim commit is provably dead.
# Returns: 0 dead, 1 alive, 2 indeterminate (callers fail closed).
claim_is_dead() {
    local claim_sha="$1" msg claimer_host claimer_pid claimed_at ttl_hours
    local this_host env_host pid_path_available=false ttl_path_available=false
    claim_dead_reason="none"
    msg=$(parse_commit_metadata "$claim_sha" 2>/dev/null || true)
    claimer_host=$(extract_field "$msg" "Claimer-Host" 2>/dev/null || true)
    claimer_pid=$(extract_field "$msg" "Claimer-PID" 2>/dev/null || true)
    claimed_at=$(extract_field "$msg" "Claimed-At" 2>/dev/null || true)
    ttl_hours=$(extract_field "$msg" "TTL-Hours" 2>/dev/null || true)
    this_host=$(hostname -s 2>/dev/null || echo unknown)
    env_host="${TASK_DAG_CLAIMER_HOST:-$this_host}"

    if { [ "$claimer_host" = "$this_host" ] || [ "$claimer_host" = "$env_host" ]; } \
        && [[ "$claimer_pid" =~ ^[1-9][0-9]*$ ]]; then
        pid_path_available=true
        if kill -0 "$claimer_pid" 2>/dev/null; then
            return 1
        fi
        local kill_err
        kill_err=$(kill -0 "$claimer_pid" 2>&1 >/dev/null || true)
        if printf '%s' "$kill_err" | grep -qi 'Operation not permitted'; then
            return 1
        fi
        if printf '%s' "$kill_err" | grep -qi 'No such process'; then
            claim_dead_reason="pid"
            return 0
        fi
    fi

    if [ -n "$claimed_at" ] && [[ "$ttl_hours" =~ ^[0-9]+([.][0-9]+)?$ ]] \
        && awk "BEGIN { exit !($ttl_hours > 0) }"; then
        local claimed_epoch expiry_epoch now_epoch
        claimed_epoch=$(date -u -d "$claimed_at" +%s 2>/dev/null || true)
        if [ -n "$claimed_epoch" ]; then
            ttl_path_available=true
            expiry_epoch=$(awk "BEGIN { printf \"%.0f\", $claimed_epoch + ($ttl_hours * 3600) + 300 }")
            now_epoch=$(date -u +%s)
            if [ "$now_epoch" -gt "$expiry_epoch" ]; then
                claim_dead_reason="ttl"
                return 0
            fi
            return 1
        fi
    fi

    if [ "$pid_path_available" = false ] && [ "$ttl_path_available" = false ]; then
        return 2
    fi
    return 1
}

# Helper: print the SHA of the first real child task of <parent_sha> (a
# commit that has <parent_sha> as ANY parent and is itself a task commit
# but NOT a claim commit), and return 0; return 1 if none exist.
#
# This is the authoritative "has this root been decomposed?" check. It
# uses exact parent membership over the fetched task namespaces, NOT a
# substring grep, and it ignores claim commits (leaf `tasks/active/*` and
# root `tasks/root-active/*` claim commits are parented to their task but
# are locks, not children). Callers MUST `fetch_root_refs` first so the
# child refs are present locally.
task_has_children() {
    local parent_sha="$1"
    local commit parents subject
    while read -r commit parents; do
        case " $parents " in
            *" $parent_sha "*) ;;
            *) continue ;;
        esac
        # Skip side commits that are parented to a task/root but are NOT
        # DAG children: claim commits (leaf `tasks/active/*` + root
        # `tasks/root-active/*`) are locks, and `Blocked-Meta:` commits are
        # blocked-task side metadata (tree == task tree, first parent ==
        # task), neither of which is a decomposition child.
        subject=$(git log -1 --format='%s' "$commit" 2>/dev/null || true)
        case "$subject" in
            Claim:*|Blocked-Meta:*) continue ;;
        esac
        # Only count empty-tree task commits as DAG children; real
        # implementation/master commits that happen to list the root are
        # not breakdown children.
        is_task_commit "$commit" || continue
        printf '%s\n' "$commit"
        return 0
    done < <(git rev-list --all --parents 2>/dev/null)
    return 1
}

# Helper: true iff <parent_sha> has a direct STRUCTURAL child. Breakdown
# containment is strictly first-parent; second+ parents are dependencies. Use
# this when deciding whether a node itself is decomposed/intermediate. Do NOT
# use task_has_children here: that intentionally matches any parent slot for
# root/decomposition duplicate guards, where dependency children should also
# make a root non-childless.
task_has_structural_children() {
    local parent_sha="$1"
    local commit parents first subject
    while read -r commit parents; do
        first="${parents%% *}"
        [ "$first" = "$parent_sha" ] || continue
        subject=$(git log -1 --format='%s' "$commit" 2>/dev/null || true)
        case "$subject" in
            Claim:*|Blocked-Meta:*) continue ;;
        esac
        is_task_commit "$commit" || continue
        printf '%s\n' "$commit"
        return 0
    done < <(git rev-list --all --parents 2>/dev/null)
    return 1
}

# Helper: list ALL direct DAG children (breakdown child task commits) of a
# node, one full SHA per line. Same membership/filtering rules as
# task_has_children (exact whole-token parent match; skip Claim:/
# Blocked-Meta: side commits and non-empty-tree commits), but enumerates
# every child rather than short-circuiting at the first. Callers that care
# about origin state must fetch the relevant task namespaces first.
list_dag_children() {
    local parent_sha="$1" commit parents subject
    while read -r commit parents; do
        case " $parents " in
            *" $parent_sha "*) ;;
            *) continue ;;
        esac
        subject=$(git log -1 --format='%s' "$commit" 2>/dev/null || true)
        case "$subject" in
            Claim:*|Blocked-Meta:*) continue ;;
        esac
        is_task_commit "$commit" || continue
        printf '%s\n' "$commit"
    done < <(git rev-list --all --parents 2>/dev/null)
}

# Helper: recursively decide whether the entire subtree rooted at <node>
# is complete. A node with NO DAG children is a LEAF: complete iff its
# completion commit is on HEAD (is_task_completed). A node WITH children
# is complete iff every child subtree is complete. Intermediate epic nodes
# never receive their own completion commit (the root-completion guard
# refuses to complete a decomposed node), so completeness is derived from
# the leaves, not from the intermediate node itself.
epic_subtree_complete() {
    local node="$1" cur
    taskdag_recon_prepare --no-fetch || return 2
    cur=$(taskdag_current_repo) || return 2
    taskdag_node_complete "task:${cur}@${node}"
}

# Helper: does epic issue <N> have any cross-repo delegated children
# (refs under tasks/delegated/<N>/*)? Purely-local epics have none and
# close via `complete`; epics with delegations close via `close-epic`
# (gated on cross-repo completion signals), so `complete` must NOT emit a
# local close for them.
#
# This is a SAFETY GATE for emitting a close commit, so it FAILS CLOSED:
# we consult ORIGIN directly (ls-remote tri-state), not stale local refs,
# and on an indeterminate origin we report "has delegated children" so the
# caller defers to close-epic rather than risk closing a delegated epic
# before its cross-repo children are satisfied.
#   return 0  -> delegated children exist (OR origin indeterminate)
#   return 1  -> confirmed NONE (purely local)
epic_has_delegated_children() {
    local issue="$1" rc
    git ls-remote --exit-code origin "refs/heads/tasks/delegated/$issue/*" >/dev/null 2>&1
    rc=$?
    case "$rc" in
        0) return 0 ;;   # delegated refs present on origin
        2) return 1 ;;   # ls-remote confirms: no matching refs
        *) return 0 ;;   # transport/auth error → fail closed (assume delegated)
    esac
}

# Helper: is there already a trailer-bearing Closes-Epic merge for issue
# <N> with <epic_sha> as a parent, reachable from <base_ref>? Mirrors the
# exact gate close-completed-issues.yml enforces (epic-as-parent AND a
# matching `Closes-Epic: #<N>` trailer), so we never emit a duplicate
# close commit. An ordinary `complete` attach-merge also lists the epic as
# a parent but carries NO trailer, so the trailer check is required.
epic_already_closed_on() {
    local issue="$1" epic_sha="$2" base_ref="$3"
    taskdag_issue_closed_at_tip "$base_ref" "$issue" "$epic_sha"
}

# After a successful leaf completion, auto-close the epic it belongs to IFF
# that epic is a purely-local, top-level pending root whose ENTIRE subtree
# is now complete. We append the canonical additive close commit to local
# HEAD:
#   tree    = HEAD's tree (no diff)
#   parent1 = HEAD (the completion commit just created)
#   parent2 = the epic root SHA (== tasks/pending/<N>)
#   message = "...\n\nCloses-Epic: #<N>"
# The worker's subsequent `task-dag publish` carries this commit together
# with its semantic generation, and close-completed-issues.yml then closes the issue and cleans
# the pending/root-active refs. This keeps ONE closure mechanism (the
# trailer-gated server workflow); the old direct REST close was removed
# because it bypassed that gate and needed a token workers don't have.
# All failure paths are non-fatal: a completion must never be blocked by a
# best-effort auto-close.
maybe_emit_local_epic_close() {
    local task_sha="$1"

    local root_sha
    root_sha=$(get_first_parent "$task_sha" 2>/dev/null || true)
    [ -n "$root_sha" ] || return 0
    is_task_commit "$root_sha" || return 0

    # Walk the structural (first-parent) lineage up to the TOP pending
    # root. A leaf whose first parent is an intermediate sub-epic is not
    # the root, but completing it can still finish the whole tree.
    local node="$root_sha" issue="" up
    while :; do
        issue=$(task_is_pending_root "$node" 2>/dev/null || true)
        [ -n "$issue" ] && break
        up=$(get_first_parent "$node" 2>/dev/null || true)
        [ -n "$up" ] || return 0
        is_task_commit "$up" || return 0
        node="$up"
    done
    root_sha="$node"

    # Purely-local epics only; defer delegated/mixed epics to close-epic.
    epic_has_delegated_children "$issue" && return 0

    # Sync the FULL task-ref namespace (and origin/master) BEFORE judging
    # completeness. epic_subtree_complete -> list_dag_children reads the
    # LOCAL ref view (git rev-list --all); a worker's ephemeral checkout
    # typically tracks ONLY master and inherited a pre-claim (it never ran
    # claim/frontier, so it never fetched the sibling task refs). Without
    # this sync it sees a PARTIAL DAG — just the leaf being completed — and
    # wrongly concludes the whole epic is done, appending a spurious
    # Closes-Epic commit that prematurely closes the issue and abandons the
    # still-pending leaves. origin/master is needed too: a sibling whose
    # task refs were already pruned on completion is only reachable via
    # master history. FAIL CLOSED: if we cannot get an authoritative view,
    # do NOT auto-close (the completion already succeeded; an open-but-done
    # epic is repairable, a premature close is not).
    if ! fetch_task_refs_strict; then
        printf "${YELLOW}⚠ Could not sync task refs from origin; not auto-closing epic #%s. Retry the close after origin is reachable.${RESET}\n" \
            "$issue" >&2
        return 0
    fi
    # Explicit destination refspec so refs/remotes/origin/master is actually
    # updated (a bare `git fetch origin master` only populates FETCH_HEAD);
    # both the rev-list visibility of just-completed siblings and the
    # origin/master duplicate-close check below depend on it being current.
    if ! git fetch --quiet --no-tags origin \
            '+refs/heads/master:refs/remotes/origin/master' >/dev/null 2>&1; then
        printf "${YELLOW}⚠ Could not sync origin/master; not auto-closing epic #%s. Retry the close after origin is reachable.${RESET}\n" \
            "$issue" >&2
        return 0
    fi

    # Whole subtree must be complete (this completion is already on HEAD).
    # After activation consume the canonical root status; parent recursion is
    # retained only by the bounded pre-activation bridge.
    taskdag_consumer_prepare local-epic-close --tip HEAD || return 0
    if [ "$TASKDAG_CONSUMER_MODE" = canonical ]; then
        local root_status
        root_status=$(taskdag_root_status_json "task:${TASKDAG_RECON_CUR}@${root_sha}" "$issue") || return 0
        [ "$(jq -r '.complete and (.blocked|not) and .requirementsSatisfied' <<<"$root_status")" = true ] || return 0
    else
        taskdag_migration_guard epic-close || return $?
        epic_subtree_complete "$root_sha" || return 0
    fi

    # A Materialise-Child-Epic trailer in this local completion range is an
    # obligation declaration even though its marker/delegation/edge are only
    # created after the eventual push. Never turn temporary absence of those
    # asynchronous projections into a close fact.
    if ! taskdag_materialisation_intents_durable "$issue" "$root_sha" HEAD; then
        printf "${YELLOW}⚠ Epic #%s has child-epic materialisation intent that is not durable yet; not auto-closing.${RESET}\n" \
            "$issue" >&2
        return 0
    fi

    # Don't duplicate an existing close (local HEAD or origin/master;
    # origin/master was just synced above).
    epic_already_closed_on "$issue" "$root_sha" "HEAD" && return 0
    if git rev-parse --verify -q origin/master >/dev/null 2>&1; then
        epic_already_closed_on "$issue" "$root_sha" "origin/master" && return 0
    fi

    local head_sha head_tree close_msg close_sha
    head_sha=$(git rev-parse HEAD)
    head_tree=$(git rev-parse "HEAD^{tree}")
    close_msg="Close epic #${issue} (all tasks complete)

All child tasks of this epic have completed.

Closes-Epic: #${issue}"
    close_sha=$(git commit-tree "$head_tree" -p "$head_sha" -p "$root_sha" -m "$close_msg") || return 0
    git update-ref -m 'task-dag: local epic close commit' HEAD "$close_sha" "$head_sha" || return 0
    printf "${GREEN}🎉 Epic #%s complete — appended local Closes-Epic commit %s.${RESET}\n" \
        "$issue" "$(git rev-parse --short "$close_sha")"
}

# Helper: drop OUR own root claim (used by claim-root's post-claim bail
# paths). Deletes tasks/root-active/<N> iff it is still at our claim
# commit, then reads back. Returns 0 if the lock is no longer ours on
# origin (released, or already overwritten by someone else); returns 1 if
# our claim is STILL on origin and we failed to remove it (caller must
# surface that as a stale lock needing manual release-root).
_release_our_root_claim() {
    local issue="$1" claim_commit="$2"
    local ref="refs/heads/tasks/root-active/$issue"
    git push --atomic origin \
        "--force-with-lease=$ref:$claim_commit" \
        ":$ref" >/dev/null 2>&1 || true
    git update-ref -d "$ref" 2>/dev/null || true
    # Tri-state readback against origin (the source of truth). We must NOT
    # report success just because a local/offline read came back empty —
    # an unreadable origin means the delete is UNCONFIRMED and our claim
    # may still be live, so fail (return 1) and let the caller tell the
    # user to run release-root.
    local out rc now
    out=$(git ls-remote origin "$ref" 2>/dev/null); rc=$?
    if [ "$rc" != 0 ]; then
        return 1   # transport error: release not confirmed
    fi
    now=$(printf '%s\n' "$out" | awk '{print $1; exit}')
    # Absent (released) or present at a DIFFERENT SHA (someone else's epoch
    # — no longer ours) both mean our claim is gone: success. Still at our
    # claim commit means the delete did not take: failure.
    [ "$now" != "$claim_commit" ]
}

# Helper: true iff <sha> is SHAPED like a top-level epic root, independent
# of whether tasks/pending/<N> can be confirmed on origin. A canonical root
# (from create-task-commit.sh) is `Type: epic` and parented on real
# repository history; a breakdown-created CHILD epic is `Type: epic` but
# parented on another empty-tree TASK commit. So: epic + first parent is
# NOT a task commit ⇒ root-shaped. Used to FAIL CLOSED when origin can't
# confirm pending identity but the commit could still be a live root.
task_is_root_shaped_epic() {
    local sha="$1" type first
    type=$(extract_field "$(parse_commit_metadata "$sha")" "Type" 2>/dev/null || true)
    [ "$type" = epic ] || return 1
    first=$(get_first_parent "$sha" 2>/dev/null || true)
    # Parented on a task commit ⇒ child/intermediate epic, not a root.
    if [ -n "$first" ] && is_task_commit "$first"; then
        return 1
    fi
    return 0
}

# Helper: classify whether <sha> is the epic-root (pending) commit for its
# issue. Resolved by reading the Issue trailer and confirming
# tasks/pending/<N> points at exactly this commit. Origin is authoritative.
# Echoes the issue number on success.
#
# Exit codes:
#   0  confirmed pending root (issue number echoed)
#   1  confirmed NOT a (current) pending root
#   3  INDETERMINATE: origin unreachable AND the local pending mirror cannot
#      confirm it, but the commit is shaped like a top-level epic root — so
#      we cannot prove it is safe to complete. Callers MUST fail closed.
#
# Note: a cleanly-absent pending on origin (the epic was closed and its
# pending ref deleted) is treated as "not a current root" (rc 1): completing
# such a retired root-shaped commit is the legitimate historical/tombstone
# path, and it has no live leaves to clobber.
task_is_pending_root() {
    local sha="$1" issue remote rc
    issue=$(extract_field "$(parse_commit_metadata "$sha")" "Issue" 2>/dev/null | sed 's/^#//' || true)
    [ -n "$issue" ] || return 1
    remote=$(pending_sha_on_remote_checked "$issue"); rc=$?
    if [ "$rc" = 0 ]; then
        [ "$remote" = "$sha" ] || return 1
    elif [ "$rc" = 2 ]; then
        # Cleanly absent on origin: origin is authoritative, so this is NOT a
        # current pending root (the epic was closed/retired, or never had a
        # root). Do not consult the local mirror here — a stale local
        # refs/heads/tasks/pending/<N> must not resurrect a retired root and
        # spuriously refuse the legitimate historical/tombstone completion.
        return 1
    else
        # rc 3: origin indeterminate (transport/auth). Prefer the local
        # mirror; if it confirms our root, treat as root. Otherwise, if the
        # commit is SHAPED like a top-level epic root we cannot prove it is
        # NOT a live (possibly decomposed) root, so signal indeterminate and
        # let the caller fail closed rather than completing it blindly.
        if [ "$(git rev-parse --verify -q "refs/heads/tasks/pending/$issue" 2>/dev/null)" = "$sha" ]; then
            : # local mirror confirms → root
        elif task_is_root_shaped_epic "$sha"; then
            return 3
        else
            return 1
        fi
    fi
    printf '%s\n' "$issue"
    return 0
}

# Helper: advance HEAD to a completion commit WITHOUT destroying the
# worktree. Replaces the old `git reset --hard` in cmd_complete, which —
# because task-dag binds git ops to the CALLER'S cwd (the peer repo
# worktree) — would silently discard any uncommitted/staged changes there.
#
#   $1 = base_commit   (the commit the completion was built on; == HEAD by
#                        default, or the resolved --commit=SHA)
#   $2 = new_commit     (the completion commit: commit-tree -p base -p task)
#
# Contract: new_commit's tree MUST equal base_commit's tree (the completion
# adds only a second parent + metadata, never file changes). We assert that.
#
#   * base == HEAD (the normal path, incl. detached HEAD): the completion
#     is a first-parent fast-forward of HEAD with an identical tree, so we
#     just move the ref with `git update-ref HEAD <new> <old>`. The old
#     value is a CAS guard (refuse if HEAD moved). The index/worktree are
#     left untouched, so dirty/staged changes are PRESERVED.
#   * base != HEAD (only with --commit=SHA): updating the checkout could
#     change tracked files, so we require (a) base is a ff descendant of
#     HEAD and (b) no dirty tracked changes, then `git merge --ff-only`.
#     Otherwise we refuse and tell the caller to use a fresh worktree.
advance_head_to_completion() {
    local base="$1" new="$2"
    local current base_tree new_tree

    current=$(git rev-parse --verify HEAD^{commit}) || return 1
    base_tree=$(git rev-parse "$base^{tree}") || return 1
    new_tree=$(git rev-parse "$new^{tree}") || return 1
    if [ "$base_tree" != "$new_tree" ]; then
        echo "Error: completion commit tree differs from base tree; refusing to advance HEAD." >&2
        return 1
    fi

    if [ "$base" = "$current" ]; then
        # Identical tree + first-parent ff: move the ref only, preserving
        # any uncommitted work in the worktree/index.
        git update-ref -m 'task-dag complete: advance HEAD to completion commit' \
            HEAD "$new" "$current" || {
            echo "Error: HEAD moved during complete; refusing to overwrite (rerun)." >&2
            return 1
        }
        return 0
    fi

    # --commit=SHA path where SHA != HEAD: this can change checked-out
    # files, so it requires a clean tracked worktree + a fast-forward.
    if ! git merge-base --is-ancestor "$current" "$base"; then
        echo "Error: --commit=$base is not a fast-forward descendant of HEAD ($current)." >&2
        echo "Refusing to move this checkout (could discard work). Check that commit out in a fresh ephemeral worktree and rerun." >&2
        return 1
    fi
    if ! git diff --quiet --ignore-submodules -- || \
       ! git diff --cached --quiet --ignore-submodules --; then
        echo "Error: --commit is not HEAD and completing it would update a dirty tracked worktree." >&2
        echo "Commit/stash your changes or use a fresh ephemeral checkout, then rerun." >&2
        return 1
    fi
    git merge --ff-only "$new" >/dev/null || {
        echo "Error: failed to fast-forward to completion commit." >&2
        return 1
    }
}

# Helper: canonical "blocked" ref name for a task.
#
# Blocked refs are an OVERLAY: they point directly at the task commit and
# live in their own namespace alongside (not instead of) the task's
# pending/frontier ref. A task is BLOCKED iff such a ref exists. We name
# the ref by the task's FULL SHA (not the short SHA that frontier/active
# use) so there is never a short-prefix collision.
blocked_ref_for() {
    local sha="$1"
    echo "refs/heads/tasks/blocked/$sha"
}

# Helper: is a task blocked? (its canonical blocked overlay ref exists)
is_task_blocked() {
    local sha="$1"
    git show-ref --verify --quiet "$(blocked_ref_for "$sha")"
}

# Helper: canonical "blocked-meta" ref name for a task.
#
# Side metadata for a blocked task lives at
# refs/heads/tasks/blocked-meta/<FULL-SHA>, alongside (not instead of)
# the blocked overlay ref. It records WHY a task is parked (operator vs
# downstream), the durable reason, an optional operator request URL, the
# source repo/issue, and who/when parked it — so the operator-blocked
# dashboard (top-level#29) can render current blockers without reparsing
# task commit bodies. The blocked overlay ref stays the source of truth
# for "is this task blocked"; this is purely descriptive side data, and a
# blocked task with NO meta ref (a legacy block) is still fully valid.
blocked_meta_ref_for() {
    local sha="$1"
    echo "refs/heads/tasks/blocked-meta/$sha"
}

# Helper: does a task have a blocked-meta side ref?
has_blocked_meta() {
    local sha="$1"
    git show-ref --verify --quiet "$(blocked_meta_ref_for "$sha")"
}

# Helper: read one field from a task's blocked-meta commit body. Prints
# nothing (rc 0) if the meta ref is absent or the field is unset. Uses
# awk (not grep) so a missing field is rc 0, not a `set -e` abort.
read_blocked_meta_field() {
    local sha="$1" field="$2"
    local ref; ref=$(blocked_meta_ref_for "$sha")
    git show-ref --verify --quiet "$ref" || return 0
    git log -1 --format='%B' "$ref" | awk -v f="$field" '
        index($0, f ":") == 1 { sub("^[^:]+:[[:space:]]*", ""); print; exit }'
}

# Helper: derive (repo, issue-number, source-url) from a task commit.
# Handles BOTH task commit shapes:
#   * regular task commits ("Task: …" with "Issue: #N" / "URL: …"), and
#   * ingested-comment task nodes (YAML "issue:\n number:" + "github:\n
#     url:") and delegated nodes ("issue:\n repo:\n number:").
# Emits one TAB-separated line: "<repo>\t<issue>\t<url>" (fields may be
# empty). repo is owner/repo, parsed from the URL when present.
derive_task_origin() {
    local sha="$1"
    local msg; msg=$(parse_commit_metadata "$sha")
    local issue url repo
    # `|| true` keeps a missing trailer from aborting under `set -e`
    # (extract_field's grep returns non-zero when the field is absent).
    issue=$(extract_field "$msg" "Issue" 2>/dev/null || true); issue="${issue#\#}"
    if [ -z "$issue" ]; then
        issue=$(echo "$msg" | awk '/^issue:[[:space:]]*$/{f=1;next} f&&/number:/{sub(/^[[:space:]]*number:[[:space:]]*/,"");print;exit}')
    fi
    url=$(extract_field "$msg" "URL" 2>/dev/null || true)
    if [ -z "$url" ]; then
        url=$(echo "$msg" | awk '/^github:[[:space:]]*$/{f=1;next} f&&/url:/{sub(/^[[:space:]]*url:[[:space:]]*/,"");print;exit}')
    fi
    repo=""
    # Only parse a repo out of a real github.com URL; never echo back a
    # non-matching URL as if it were owner/repo.
    if [[ "$url" =~ ^https?://github\.com/([^/]+/[^/]+)(/.*)?$ ]]; then
        repo="${BASH_REMATCH[1]}"
    fi
    if [ -z "$repo" ]; then
        # Delegated/ingested nodes can carry an explicit "issue:\n repo:".
        repo=$(echo "$msg" | awk '/^issue:[[:space:]]*$/{f=1;next} f&&/repo:/{sub(/^[[:space:]]*repo:[[:space:]]*/,"");print;exit}')
    fi
    printf '%s\t%s\t%s\n' "$repo" "$issue" "$url"
}

# Resolve owner/repo from a git remote URL. The task-dag DAG is keyed by
# owner/repo, NOT by hostname — but the fleet's prepared/ephemeral checkouts
# rewrite `origin` to an ALIASED SSH host (git@github-<repo>:owner/repo.git)
# that does not contain the literal 'github.com'. Historically the
# issue-facing ops (`comment`, the status-comment poster) matched only a
# literal github.com and so broke in every prepared/aliased worktree,
# forcing a manual --repo=owner/repo (the recurring epic #41 friction).
# Handle every URL form the fleet actually uses:
#   * https://github.com/owner/repo(.git)       (plain HTTPS)
#   * http://host/owner/repo(.git)
#   * git@github.com:owner/repo(.git)           (scp-style, plain host)
#   * git@github-<alias>:owner/repo(.git)       (scp-style, ephemeral SSH alias)
#   * ssh://[user@]host[:port]/owner/repo(.git)
#   * git://host/owner/repo(.git)
# Emits owner/repo on stdout, or nothing when the URL is empty/unparseable
# (callers keep --repo as the explicit override for genuinely ambiguous or
# non-standard remotes; bare local fixture paths deliberately yield nothing).
parse_owner_repo_from_url() {
    local url="$1" stripped
    [ -n "$url" ] || return 0
    # Strip the leading scheme+host (https://host/, http://host/, git@host:,
    # ssh://[user@]host[:port]/, git://host/) and any trailing .git / slash.
    stripped=$(printf '%s' "$url" | sed -E \
        's#^(https?://[^/]+/|git@[^:]+:|ssh://[^/]+/|git://[^/]+/)##; s#\.git/?$##; s#/$##')
    # Keep only the leading owner/repo pair (drop any deeper path) and require
    # exactly that shape, so unparseable inputs yield nothing rather than a
    # bogus repo that would fail downstream validation with a worse message.
    if [[ "$stripped" =~ ^([A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+)(/.*)?$ ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
    fi
}

# Best-effort "is this GitHub issue CLOSED?" used as a defense-in-depth gate
# in claim-root: an orphan tasks/pending/<N> ref for an already-closed issue
# (e.g. left behind by a pre-fix close workflow that lacked contents:write,
# or a repo whose caller hasn't been updated yet) must not let a worker waste
# a full agent run "decomposing" a done issue.
#
# FAILS OPEN by design: if gh is missing, the repo/issue can't be derived, or
# the API call errors (auth/network), we return 1 (treat as "not known
# closed") so offline/low-permission CLI use and transient GitHub hiccups
# never drop real work. Only a confirmed CLOSED state returns 0.
#   args: <repo owner/name> <issue-number>
#   return 0 -> confirmed CLOSED ; 1 -> open/unknown/indeterminate
issue_is_closed_remote() {
    local repo="$1" issue="$2" state
    [ -n "$repo" ] && [ -n "$issue" ] || return 1
    command -v gh >/dev/null 2>&1 || return 1
    state="$(gh issue view "$issue" --repo "$repo" --json state --jq '.state' 2>/dev/null || true)"
    [ "$state" = "CLOSED" ]
}

# Three-valued live GitHub issue state, for the reconcile-closed-issue
# fail-safe. Unlike issue_is_closed_remote (which fails OPEN, conflating
# "open" with "couldn't tell"), this DISTINGUISHES a determined state from
# an undetermined one so reconcile-closed-issue can refuse to mutate on any
# uncertainty (the conservative direction here is "don't delete").
#   args:   <repo owner/name> <issue-number>
#   stdout: the live state (e.g. CLOSED, OPEN) when determined
#   return: 0 -> determined (state printed on stdout)
#           3 -> undetermined (gh missing/unauth/API error/empty state)
issue_state_remote() {
    local repo="$1" issue="$2" state
    [ -n "$repo" ] && [ -n "$issue" ] || return 3
    command -v gh >/dev/null 2>&1 || return 3
    state="$(gh issue view "$issue" --repo "$repo" --json state --jq '.state' 2>/dev/null)" || return 3
    [ -n "$state" ] || return 3
    printf '%s\n' "$state"
    return 0
}

# Helper: build the blocked-meta side-commit (tree == task tree, first
# parent == task commit, body holds the metadata). We pin a CONSTANT
# author/committer identity and use the blocked-at timestamp as the
# commit date so the commit is fully DETERMINISTIC: re-running `block`
# with identical fields yields the identical commit SHA, so the ref does
# not churn (idempotency). The actor that parked the task is recorded in
# the body (Blocked-By), not the commit identity.
build_blocked_meta_commit() {
    local task_sha="$1" kind="$2" reason="$3" request_url="$4" \
          repo="$5" issue="$6" source_url="$7" actor="$8" host="$9" blocked_at="${10}"

    local task_title task_tree
    task_title=$(get_task_title "$task_sha")
    task_tree=$(git rev-parse "$task_sha^{tree}")

    # The body is line-oriented (one "Field: value" per line) and parsed
    # back by read_blocked_meta_field, so collapse any embedded newlines in
    # free-form values to spaces — a stray newline would otherwise inject a
    # bogus field line and break round-tripping.
    reason=$(printf '%s' "$reason" | tr '\n' ' ')
    request_url=$(printf '%s' "$request_url" | tr '\n' ' ')

    local msg="Blocked-Meta: ${task_title}

Task-Commit: ${task_sha}
Blocker-Kind: ${kind}"
    [ -n "$reason" ]      && msg="${msg}
Reason: ${reason}"
    [ -n "$request_url" ] && msg="${msg}
Request-URL: ${request_url}"
    [ -n "$repo" ]        && msg="${msg}
Repo: ${repo}"
    [ -n "$issue" ]       && msg="${msg}
Issue: #${issue}"
    [ -n "$source_url" ]  && msg="${msg}
Source-URL: ${source_url}"
    [ -n "$actor" ]       && msg="${msg}
Blocked-By: ${actor}"
    [ -n "$host" ]        && msg="${msg}
Blocked-Host: ${host}"
    msg="${msg}
Blocked-At: ${blocked_at}"

    GIT_AUTHOR_NAME="task-dag" GIT_AUTHOR_EMAIL="task-dag@localhost" \
    GIT_COMMITTER_NAME="task-dag" GIT_COMMITTER_EMAIL="task-dag@localhost" \
    GIT_AUTHOR_DATE="$blocked_at" GIT_COMMITTER_DATE="$blocked_at" \
        git commit-tree "$task_tree" -p "$task_sha" -m "$msg"
}

# Command: help
cmd_help() {
    cat <<EOF
task-dag - Git-DAG Task Management CLI v${VERSION}

╔══════════════════════════════════════════════════════════════════════╗
║  ⛔  STOP — DO NOT HAND-CRAFT TASK COMMITS OR DO REF SURGERY BY HAND   ║
║                                                                        ║
║  task-dag state lives in git refs/commits with SUBTLE, LOAD-BEARING    ║
║  invariants (empty-tree commits; exact namespaces; claim-CAS;          ║
║  completion-merge shape; closure trailers). A hand-rolled              ║
║  'git commit-tree' / 'git update-ref' / 'git push' — or "just fixing"  ║
║  a prior mistake by editing refs manually — WILL silently corrupt the  ║
║  DAG, break dispatch dedup, or wedge issue closure.                    ║
║                                                                        ║
║  • Use the SUBCOMMANDS below for every mutation.                       ║
║  • If the tool cannot express what you need: 'task-dag block' the      ║
║    task, 'page-dave', and STOP. Do not improvise git surgery.          ║
║  • Do NOT change this tool's commit/ref format until you FULLY         ║
║    understand docs/INVARIANTS.md, docs/REF_LIFECYCLE.md, and           ║
║    docs/DESIGN_PRINCIPLES.md (bounded refs, exact data-ref shapes,     ║
║    direct-CAS writes, facts from master). Changing it needs operator   ║
║    approval + an Oracle critical-infra review.                         ║
║  • Audit any repo's DAG with:  task-dag validate --strict              ║
╚══════════════════════════════════════════════════════════════════════╝

USAGE:
    task-dag <command> [options]

COMMANDS:
    dag <ref>              Show task DAG for epic/task
    frontier               List available leaf tasks (excludes tasks already
                           claimed on origin; pass --include-claimed to show)
    claim <sha>            Atomically claim a frontier task across hosts (run
                           this BEFORE you start working so concurrent agents
                           on other hosts don't duplicate your work)
    claim-root <issue>     Atomically claim an UNDECOMPOSED epic root for
                           orchestration across hosts (run BEFORE breakdown so
                           two hosts can't decompose the same issue). Consumed
                           by breakdown.
    release <sha>          Drop a claim back onto the frontier
    release-root <issue>   Drop a root orchestration claim (never creates a
                           frontier ref)
    reap                   Reclaim provably-dead leaf/root claims safely
    roots                  List epic roots + orchestration state
                           (decomposed/claimed/pickable); --pickable for
                           the dispatch discovery surface
    active                 List currently-claimed (in-flight) tasks
    show <sha>             Show task details (fetches origin task refs first;
                           --no-fetch to skip)
    deps <sha>             Show task dependencies (fetches first; --no-fetch)
    context <sha>          Fetch-then-show YOUR assigned task: guarantees the
                           task object is present, then prints its body,
                           kind/ref, epic + dependency parents, related local
                           refs, and suggested next commands. Start here in a
                           prepared workspace. --ref refs/heads/tasks/<ns>/<short>
                           fetches exactly that ref.
    breakdown <parent>     Create task breakdown
    complete <sha>         Mark task as complete
    publish [<tip>]        Publish an exact completion/close tip with the
                           activated semantic-generation fence
    complete-historical <sha> --commit=<historical-sha>
                           ADMIN RECOVERY ONLY: retroactively link an
                           already-landed historical commit on master to a
                           task (for commits a worker missed linking),
                           without rewriting master history. NOT for normal
                           work — use 'complete' live. Pages the operator.
    block <sha>            Park a task: keep it in the DAG but stop workers
                           from picking it up (NOT closed). Use when stalled
                           awaiting operator/downstream input.
    unblock <sha>          Make a blocked task pickable again
    blocked                List blocked (parked) tasks (--json emits
                           enriched dashboard fields; --operator/--downstream
                           /--kind=<k> filter by blocker kind)
    drop <sha>             Housecleaning: remove an orphaned/irrelevant task
                           from the pickable/blocked sets
    reconcile-closed-issue <issue>
                           Drop the lingering frontier/blocked/blocked-meta
                           refs of tasks whose GitHub issue is CONFIRMED
                           CLOSED (fail-safe: never acts under uncertainty).
                           --dry-run/--json/--yes, --repo=owner/repo.
    edges                  READ the active dependency-edge set from the
                           per-repo graph index branch tasks/v1/graph
                           (read-only plumbing; --json/--no-fetch). See
                           docs/INVARIANTS.md for edge/tombstone blob shape.
    facts                  READ derived done/satisfied facts from master's
                           completion history (in-memory, zero per-fact refs):
                           done(node) + satisfied(edge)=done(.to). Read-only
                           plumbing; --json/--no-fetch/--node. Readiness,
                           closure, and supersede are separate commands.
    reconcile              READ the aggregated complete()/leaf-readiness
                           verdicts over the edge graph (issue #13): complete
                           = done OR superseded OR (obligations met); ready =
                           not-complete + requires satisfied + unclaimed +
                           unblocked. Read-only; --json/--no-fetch/--node/
                           --ready. Never writes; live wiring is separate.
    propagate-completion   MUTATE graph convergence for one durable completion:
                           fold same-repo satisfied edges, synth-complete a
                           superseded local leaf, cascade, and optionally send
                           cross-repo mailbox hints. --node/--witness.
    reconcile-backstop     MUTATE periodic graph convergence: consume mailbox
                           hints, then re-derive satisfied local graph edges
                           from master (including configured peer worktrees).
    graph-converge         Push-reaction entry point: scan a pushed range for
                           completion facts, propagate them, run the graph
                           backstop, then CAS-clean stale completed scheduling
                           refs from origin/master. --range <git-range>.
    migrate-legacy-edges   Backfill legacy dependency encodings (extra task
                           parents, delegated refs, explicit downstream /
                           supersede node fields) into tasks/v1/graph. See
                           docs/MIGRATION.md for rollout/rollback.
    mailbox put|list|consume
                           Cross-repo NOTIFICATION transport (bounded 16-shard
                           set tasks/v1/mailbox/00..0f). put enqueues a hint;
                           list reads in-flight messages; consume folds-then-
                           deletes (ordered) via an injected --fold-cmd. A
                           message is a trigger, not a fact — the reconciler
                           backstop re-derives a lost hint from master.
    supersede <node> --by <node>
                           Record that <node> is superseded/re-scoped by the
                           --by node: mint ONE \`satisfies\` edge (issue #13).
                           complete(<node>) becomes true once the --by node's
                           completion is durable on master — the automation#57
                           zombie in one command. Edge-only; --dry-run/--reason.
    materialise-batch --spec-file FILE
                           Validate and atomically reserve immutable child-epic
                           declarations. Disabled by migration policy (exit 75).
    materialise-child --spec-file FILE
                           One-declaration adapter to materialise-batch. Also
                           disabled by migration policy (exit 75).
    materialise-census --spec-file FILE --artifact FILE --digest-file FILE
                           Freeze and classify the activation registry universe.
    materialise-census-capture --spec-file FILE --output-dir DIR
                           Capture complete read-only census inputs.
    materialise-import --spec-file FILE --artifact FILE --digest-file FILE
                           Re-census exact reviewed bytes, then atomically import.
    materialise-adopt|materialise-rearm --spec-file FILE
                           Audited append-only recovery authorization.
    activation apply|status|check-compatible
                           Manage and inspect the exact canonical semantic
                           activation authority (offline git plus origin).
    comment <issue|sha>    Post an issue comment THROUGH task-dag (the ONLY
                           sanctioned path) — stamps a task-dag:<kind> marker
                           so it can't be re-ingested as a phantom task.
                           --kind=status|operator-decision, --body/--body-file.
                           Do NOT use raw \`gh issue comment\`.
    issue-update <sha>     Update GitHub issue with task progress
    validate               Validate DAG structure; --strict audits EVERY
                           task/gh ref (empty-tree + known namespace) and
                           FAILS on violations — the hand-crafted-ref catcher.
                           --closed-issue-audit surfaces CONFIRMED-CLOSED
                           issues' lingering refs (opt-in, LIVE; the offline
                           default/--strict never hit the network).
    check-workflow         Validate recent commits follow task-dag convention

CROSS-REPO COORDINATION:
    delegate <task-sha> <owner/repo#issue>
                           Delegate a task to a peer repo's issue
    ingest-comment <issue> <comment-file> [--author=<login>]
                           Ingest a human comment from this repo's issue
                           (called by shared-workflows comment sync)
    reconcile-comments --mode recent|complete --ingestion-start-at RFC3339
                           Repair missing durable comment receipts from the
                           GitHub API; supports overlap, allowlists, ceilings,
                           and a non-mutating --dry-run.
    ingest-completion ...  Internal only; direct invocation is rejected.
                           Process every completion comment with ingest-comment;
                           it atomically publishes the durable comment receipt
                           and completion fact to origin.
    close-epic <epic-issue>
                           Close the GitHub issue for an epic once all of
                           its tasks are complete
    close-ops-epic --issue N [--yes] [--reason "..."]
                           Close a single-repo, OPS-ONLY (no-code) epic:
                           one resolved by an out-of-band operations action
                           with no implementation commit and no delegated
                           children (emits the sanctioned Closes-Epic merge)
    close-completed-epic --issue N --reason "..." [--yes]
                           Close a completed DECOMPOSED local epic that has no
                           live frontier/active/blocked/delegated child work
                           but still needs the sanctioned Closes-Epic merge
    complete-ops <sha> --evidence <https-url> --authorization <text> --yes
                           Complete an OPS-ONLY leaf with no implementation
                           commit by emitting a sanctioned tree-equal task
                           completion merge carrying Ops-* audit trailers

CI BROKEN-MASTER AUTO-REPAIR:
    parse-tree-fix [<commit-ish>] [--stdin] [--json]
                           Parse Tree-Fix/Tree-Fix-Chain/Tree-Fix-Mode
                           commit trailers (via git interpret-trailers)
    chain-read <owner/repo> <branch>
                           Read a repo/branch's CI repair-chain state
    chain-write <owner/repo> <branch> --for-sha=<commit>
                           Compare-and-set that state; race-safe and
                           stale-run-safe (rejects superseded CI SHAs)
    reconcile-lease <owner/repo> <branch> --owner=<id> --now=<UTC>
                           Acquire or renew the repair reconciler's five-minute
                           metadata-only lease with a monotonic fencing token
    repair-retire <owner/repo> <branch> --observation=<json> ...
                           Fenced, atomic retirement of one validated repair
                           scheduling projection with an immutable audit
    classify <owner/repo> <branch> --for-sha=<commit> (--result|--gate ...)
                           Classify a commit's aggregate required-gate
                           result green/red/unknown and drive the repair
                           chain (open one chain per red streak, advance
                           Current-Head on continuation reds, close on
                           green only when current); ignores superseded
                           SHAs relative to the live branch HEAD
    tree-fix-outcome <owner/repo> <branch> --for-sha=<commit> --signature=<s>
                           Interpret the outcome of a Tree-Fix commit (design
                           §3): green closes the chain; a continuation red
                           escalates the SAME chain to continue-mode
                           (Repair-Attempt++) and asks the caller to file a
                           continue-mode repair task; a red with a green parent
                           opens a fresh initial chain; repeated same-signature
                           continue failures BLOCK + page after --threshold.
                           Pure: drives chain state + reports hints.
    verify-target <owner/repo> <branch> --target-sha=<sha>
                           Worker preflight: confirm a repair target is still
                           the current, first-red, unclaimed chain head before
                           doing work (read-only, fails closed)
    repair-ticket <owner/repo> <branch>
                           Reconcile the GitHub repair ticket with the CI
                           chain state: keep EXACTLY ONE open ci-broken-master
                           + priority:high ticket per open red chain (creating
                           it is the pickable-task ingestion point), refresh it
                           on continuation, close it on green. Idempotent +
                           concurrency-safe (CAS create-lease).

    help                   Show this help

OPTIONS:
    --json                 Output in JSON format (where supported)
    --help, -h             Show command help

See docs/INVARIANTS.md, docs/REF_LIFECYCLE.md, docs/DESIGN_PRINCIPLES.md,
and docs/MIGRATION.md for the durable task-dag contracts.
EOF
}

# Command: frontier - list available leaf tasks
#
# By default this fetches origin's task refs first so the local view
# reflects what's actually available (and what's actually claimed by
# another worker on a different host). Tasks with a remote
# `tasks/active/<short>` ref are filtered out — they are in-flight on
# some other agent. Pass `--no-fetch` to suppress the network round-trip
# (offline use) and `--include-claimed` to override the active-ref filter.
# Blocked tasks (tasks/blocked overlay) and tasks with unmet dependencies
# are never pickable and are always excluded. Tasks whose structural
# ancestor is blocked (transitive block) are also excluded, except for the
# exact human-comment task dialect: operator comments under a blocked node
# are the wake-up signal that lets a worker reassess or unblock that node.
cmd_frontier() {
    local json=false
    local issue_filter=""
    local status_filter=""
    local do_fetch=true
    local include_claimed=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            --issue=*) issue_filter="${1#*=}"; shift ;;
            --status=*) status_filter="${1#*=}"; shift ;;
            --no-fetch) do_fetch=false; shift ;;
            --include-claimed) include_claimed=true; shift ;;
            *) echo "Unknown option: $1" >&2; return 1 ;;
        esac
    done

    if [ "$do_fetch" = true ]; then
        fetch_task_refs
    fi
    local consumer_args=()
    [ "$do_fetch" = false ] && consumer_args+=(--no-fetch --tip HEAD)
    taskdag_consumer_prepare frontier "${consumer_args[@]}" || return 2

    if [ "$json" = true ]; then
        echo "["
    else
        printf "${BOLD}%-12s %-50s %-12s %-8s${RESET}\n" "SHA" "TITLE" "ISSUE" "STATUS"
        printf "%-12s %-50s %-12s %-8s\n" "$(printf '%.12s' '============')" "$(printf '%.50s' '==================================================')" "$(printf '%.12s' '============')" "$(printf '%.8s' '========')"
    fi

    local first=true
    while read -r sha short_ref; do
        # strip=3 leaves 'frontier/<short>' — drop the prefix.
        short_ref="${short_ref#frontier/}"

        local short_sha=$(git rev-parse --short "$sha")
        local title=$(get_task_title "$sha")
        local msg=$(parse_commit_metadata "$sha")
        local issue=$(extract_field "$msg" "Issue" 2>/dev/null | sed 's/^#//' || true)
        local status=$(extract_field "$msg" "Status" 2>/dev/null || true)

        # Apply filters
        if [ -n "$issue_filter" ] && [ "$issue" != "$issue_filter" ]; then
            continue
        fi
        if [ -n "$status_filter" ] && [ "$status" != "$status_filter" ]; then
            continue
        fi

        local dispatch_status dispatch_args=()
        [ "$include_claimed" = true ] && dispatch_args+=(--include-claimed)
        dispatch_status=$(taskdag_task_status_json "task:${TASKDAG_RECON_CUR}@${sha}" "${dispatch_args[@]}") || return 2
        [ "$(jq -r .ready <<<"$dispatch_status")" = true ] || continue

        if [ "$json" = true ]; then
            [ "$first" = false ] && echo ","
            cat <<JSON
    {
        "sha": $(json_escape "$sha"),
        "shortSha": $(json_escape "$short_sha"),
        "title": $(json_escape "$title"),
        "issue": $(json_int_or_null "$issue"),
        "status": $(json_escape "${status:-pending}")
    }
JSON
            first=false
        else
            printf "%-12s %-50s %-12s %-8s\n" \
                "$short_sha" \
                "${title:0:50}" \
                "${issue:+#$issue}" \
                "${status:-pending}"
        fi
    done < <(git for-each-ref refs/heads/tasks/frontier/ --format='%(objectname) %(refname:strip=3)')

    if [ "$json" = true ]; then
        echo ""
        echo "]"
    fi
}
# Command: claim - atomically take ownership of a frontier task.
#
# The contract:
#   1. We rename `tasks/frontier/<short>` -> `tasks/active/<short>` on
#      ORIGIN in a single atomic git push protected by two
#      compare-and-swap leases:
#        a. `tasks/active/<short>` must NOT yet exist on origin.
#        b. `tasks/frontier/<short>` must still point at the expected
#           task SHA on origin.
#      If either lease fails, the whole push aborts and no refs move.
#      That gives us a true distributed mutex even when concurrent
#      workers race on different hosts.
#   2. The new `tasks/active/<short>` ref points at a "claim commit"
#      whose tree is identical to the task commit's and whose first
#      parent is the task commit. The commit message carries
#      Claimer / Claimer-Host / Claimer-PID / Claimed-At / TTL-Hours so
#      an operator can later see who's holding each claim — and, via
#      Claimer-PID, whether that worker is still alive on its host —
#      without a separate metadata store.
#   3. After a successful claim, the caller MUST eventually either
#      `task-dag complete <sha>` (which deletes both refs and lands
#      the task) or `task-dag release <sha>` (which moves the active
#      ref back to frontier so another worker can pick it up).
#
# Failure modes (exit codes):
#   0 — claim succeeded
#   1 — argument error
#   2 — task already claimed (another worker won the race)
#   3 — frontier ref disappeared (task was completed or moved)
#   4 — push failed for an unrelated reason
cmd_claim() {
    local task_sha=""
    local claimer="${TASK_DAG_CLAIMER:-${USER:-unknown}}"
    local claimer_host="${TASK_DAG_CLAIMER_HOST:-$(hostname -s 2>/dev/null || echo unknown)}"
    local ttl_hours="${TASK_DAG_TTL_HOURS:-12}"
    local note=""
    # PID of the worker that owns this claim, for same-host liveness checks.
    # Default to $PPID: this CLI is short-lived, so $$ would be a dead pid the
    # instant we return; $PPID is the process that invoked us (the worker /
    # its shell). A harness that knows its own long-lived worker pid should
    # export TASK_DAG_CLAIMER_PID (or pass --pid=) so the recorded pid stays
    # alive for as long as the work does.
    local claimer_pid="${TASK_DAG_CLAIMER_PID:-$PPID}"
    local do_force=false
    local json=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --by=*) claimer="${1#*=}"; shift ;;
            --host=*) claimer_host="${1#*=}"; shift ;;
            --pid=*) claimer_pid="${1#*=}"; shift ;;
            --ttl-hours=*) ttl_hours="${1#*=}"; shift ;;
            --note=*) note="${1#*=}"; shift ;;
            --force) do_force=true; shift ;;
            --json) json=true; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag claim <task-sha> [options]

Atomically claim a frontier task so concurrent agents don't duplicate
your work. Run this BEFORE you start implementing — picking a task
off \`task-dag frontier\` is not by itself a claim, it's only an
observation.

Options:
  --by=<id>           Claimer identifier (default: \$TASK_DAG_CLAIMER or \$USER)
  --host=<name>       Claimer hostname (default: \$TASK_DAG_CLAIMER_HOST or hostname -s)
  --pid=<n>           Claiming worker PID, recorded for same-host liveness
                      checks (default: \$TASK_DAG_CLAIMER_PID or \$PPID, the
                      process that invoked this CLI). Export
                      TASK_DAG_CLAIMER_PID to your long-lived worker pid so a
                      janitor can detect a dead worker's orphaned claim.
  --ttl-hours=<n>     Advisory TTL stored in the claim metadata (default: 12)
  --note=<text>       Free-form note recorded in the claim metadata
  --force             Steal an existing claim (only do this if you know
                      the prior claimer is dead; logs a loud warning)
  --json              Emit a machine-readable JSON result

Exit codes:
  0  claim succeeded
  1  argument error
  2  task already claimed by another worker
  3  task frontier ref disappeared (completed or retracted)
  4  push failed for an unrelated reason
EOF
                return 0
                ;;
            *)
                if [ -z "$task_sha" ]; then
                    task_sha="$1"
                else
                    echo "Unknown option: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    if [ -z "$task_sha" ]; then
        echo "Error: task SHA required" >&2
        return 1
    fi

    if [ "$json" = true ]; then require_jq_for_json || return 1; fi

    task_sha=$(resolve_sha "$task_sha") || return 1
    local short_sha
    short_sha=$(git rev-parse --short "$task_sha")

    # Refresh local view so we see other workers' claims AND the blocked
    # overlay (fetch_task_refs now syncs tasks/blocked/*).
    fetch_task_refs
    taskdag_consumer_prepare claim || return 3
    local dispatch_status dispatch_reason
    dispatch_status=$(taskdag_task_status_json "task:${TASKDAG_RECON_CUR}@${task_sha}" --include-claimed) || return 3
    if [ "$(jq -r .complete <<<"$dispatch_status")" = true ]; then
        dispatch_reason=complete
    elif [ "$(jq -r .requirementsSatisfied <<<"$dispatch_status")" != true ]; then
        dispatch_reason=deps-pending
    elif [ "$do_force" = false ] && [ "$(jq -r .blocked <<<"$dispatch_status")" = true ]; then
        dispatch_reason=blocked
    elif [ "$do_force" = false ] && [ "$(jq -r '.blockedAncestor // ""' <<<"$dispatch_status")" != "" ] && ! is_human_comment_task "$task_sha"; then
        dispatch_reason=ancestor-blocked
    else
        dispatch_reason=""
    fi
    if [ -n "$dispatch_reason" ]; then
        if [ "$json" = true ]; then
            jq -nc --arg sha "$task_sha" --arg short "$short_sha" --arg reason "$dispatch_reason" \
                --arg anc "$(jq -r '.blockedAncestor // ""' <<<"$dispatch_status")" \
                '{ok:false,reason:$reason,sha:$sha,shortSha:$short} + (if $anc=="" then {} else {blockedAncestor:$anc} end)'
        else
            printf "${RED}Task %s is not claimable (%s).${RESET}\n" "$short_sha" "$dispatch_reason" >&2
        fi
        return 2
    fi

    local frontier_local_ref="refs/heads/tasks/frontier/$short_sha"
    local active_local_ref="refs/heads/tasks/active/$short_sha"

    local remote_active
    remote_active=$(task_is_claimed_on_remote "$short_sha")
    if [ "$remote_active" = "yes" ] && [ "$do_force" = false ]; then
        # Try to fetch the claim metadata for a friendlier error.
        local existing_claimer="unknown"
        local existing_when="unknown"
        local existing_host="unknown"
        local existing_pid=""
        local existing_first_parent=""
        if git show-ref --verify --quiet "$active_local_ref"; then
            local existing_msg
            existing_msg=$(parse_commit_metadata "$active_local_ref" 2>/dev/null || true)
            existing_claimer=$(extract_field "$existing_msg" "Claimer")
            existing_when=$(extract_field "$existing_msg" "Claimed-At")
            existing_host=$(extract_field "$existing_msg" "Claimer-Host" 2>/dev/null || true)
            existing_pid=$(extract_field "$existing_msg" "Claimer-PID" 2>/dev/null || true)
            existing_first_parent=$(git rev-list --parents -n 1 "$active_local_ref" 2>/dev/null | awk '{print $2}')
        fi

        # Idempotent re-claim: if the live claim is already held by THIS
        # exact worker identity (same Claimer AND Claimer-Host AND
        # Claimer-PID) and actually claims THIS task, treat it as success
        # rather than a race-loss. This is what lets the github-worker
        # dispatcher PRE-CLAIM a task (the authoritative CAS) and then have
        # the agent it spawns — which inherits TASK_DAG_CLAIMER /
        # TASK_DAG_CLAIMER_HOST / TASK_DAG_CLAIMER_PID — VERIFY ownership by
        # re-running `claim`. Matching the pid (not just the username) means
        # only the same still-live worker process can re-confirm; a
        # different worker that merely shares $USER still gets exit 2. The
        # first-parent check stops a short-sha collision from being mistaken
        # for our claim.
        if [ -n "$existing_pid" ] \
           && [ "$existing_claimer" = "$claimer" ] \
           && [ "$existing_host" = "$claimer_host" ] \
           && [ "$existing_pid" = "$claimer_pid" ] \
           && [ "$existing_first_parent" = "$task_sha" ]; then
            if [ "$json" = true ]; then
                jq -nc --arg sha "$task_sha" --arg short "$short_sha" \
                    --arg claimer "$claimer" --arg host "$claimer_host" \
                    --argjson pid "$(json_int_or_null "$claimer_pid")" \
                    '{ok:true,sha:$sha,shortSha:$short,claimer:$claimer,claimerHost:$host,claimerPid:$pid,alreadyHeld:true}'
            else
                printf "${GREEN}✓ Task %s already claimed by you (%s, pid %s on %s) — verified.${RESET}\n" \
                    "$short_sha" "$claimer" "$claimer_pid" "$claimer_host"
            fi
            return 0
        fi
        if [ "$json" = true ]; then
            jq -nc --arg sha "$task_sha" --arg short "$short_sha" \
                --arg claimer "${existing_claimer:-unknown}" \
                --arg host "${existing_host:-unknown}" \
                --argjson pid "$(json_int_or_null "$existing_pid")" \
                --arg when "${existing_when:-unknown}" \
                '{ok:false,reason:"already-claimed",sha:$sha,shortSha:$short,claimer:$claimer,claimerHost:$host,claimerPid:$pid,claimedAt:$when}'
        else
            printf "${RED}Task %s is already claimed by %s (pid %s on %s) at %s${RESET}\n" \
                "$short_sha" "${existing_claimer:-unknown}" "${existing_pid:-?}" \
                "${existing_host:-unknown}" "${existing_when:-unknown}" >&2
            if [ -n "$existing_pid" ]; then
                echo "If you are on ${existing_host:-that host}, 'kill -0 ${existing_pid}' tells you whether that worker is still alive." >&2
            fi
            echo "Re-run with --force ONLY if you know that claim is dead." >&2
        fi
        return 2
    fi

    local remote_frontier_sha
    remote_frontier_sha=$(task_frontier_on_remote "$short_sha")
    if [ -z "$remote_frontier_sha" ] && [ "$do_force" = false ]; then
        if [ "$json" = true ]; then
            jq -nc --arg sha "$task_sha" --arg short "$short_sha" \
                '{ok:false,reason:"no-frontier",sha:$sha,shortSha:$short}'
        else
            printf "${RED}Task %s has no frontier ref on origin — already completed or retracted.${RESET}\n" \
                "$short_sha" >&2
        fi
        return 3
    fi

    # Build the claim commit locally before pushing.
    local claim_commit
    claim_commit=$(build_claim_commit "$task_sha" "$claimer" "$claimer_host" "$ttl_hours" "$note" "$claimer_pid") || {
        echo "Error: failed to build claim commit" >&2
        return 4
    }

    # Atomic CAS: create active iff absent, delete frontier iff at expected SHA.
    local lease_active="--force-with-lease=refs/heads/tasks/active/$short_sha:"
    local lease_frontier="--force-with-lease=refs/heads/tasks/frontier/$short_sha:"
    # Force-update marker for the active refspec. In normal mode the
    # active ref is expected to be absent, so a plain (create) refspec
    # fast-forwards fine. In force mode we are STEALING a known-dead
    # claim, so the active ref already exists and pointing our claim
    # commit at it is a non-fast-forward — without a leading '+' git
    # rejects it ("non-fast-forward") and the steal silently fails
    # (the bug behind every "claim --force can't recover a dead claim"
    # report). Force-update it explicitly.
    local active_force=""
    if [ "$do_force" = true ]; then
        # In force mode we still want atomicity, but we accept whatever
        # is currently on origin (we'll overwrite active and delete
        # frontier regardless of their prior state).
        lease_active=""
        lease_frontier=""
        active_force="+"
    else
        # Frontier lease wants the explicit expected SHA so we don't
        # delete a frontier ref that someone has since rewritten.
        lease_frontier="--force-with-lease=refs/heads/tasks/frontier/$short_sha:$remote_frontier_sha"
    fi

    # Re-attest immediately before the remote CAS. Preparing the claim commit
    # and inspecting an existing holder can take time; never act on that old
    # semantic snapshot if activation, facts, dependencies, or blocks moved.
    taskdag_consumer_prepare claim-pre-cas || return 3
    dispatch_status=$(taskdag_task_status_json "task:${TASKDAG_RECON_CUR}@${task_sha}" --include-claimed) || return 3
    if [ "$(jq -r .complete <<<"$dispatch_status")" = true ] \
      || [ "$(jq -r .requirementsSatisfied <<<"$dispatch_status")" != true ] \
      || { [ "$do_force" = false ] && [ "$(jq -r .blocked <<<"$dispatch_status")" = true ]; } \
      || { [ "$do_force" = false ] && [ "$(jq -r '.blockedAncestor // ""' <<<"$dispatch_status")" != "" ] && ! is_human_comment_task "$task_sha"; }; then
        [ "$json" = true ] && jq -nc --arg sha "$task_sha" --arg short "$short_sha" '{ok:false,reason:"state-changed",sha:$sha,shortSha:$short}'
        [ "$json" = true ] || printf "${RED}Task %s ceased to be claimable before the origin CAS; retry discovery.${RESET}\n" "$short_sha" >&2
        return 2
    fi

    local push_output="" push_ok=false
    if [ "$TASKDAG_CONSUMER_MODE" = canonical ]; then
        local updates active_old
        active_old=$(task_active_sha_on_remote "$short_sha")
        updates=$(jq -ncS \
          --arg ar "refs/heads/tasks/active/$short_sha" --arg ao "$active_old" --arg an "$claim_commit" \
          --arg fr "refs/heads/tasks/frontier/$short_sha" --arg fo "$remote_frontier_sha" \
          '[{ref:$ar,old:$ao,new:$an},{ref:$fr,old:$fo,new:""}]') || return 3
        taskdag_consumer_fenced_scheduling_push claim "$claimer" "$updates" && push_ok=true
    elif push_output=$(git push --atomic origin \
          $lease_active $lease_frontier \
          "${active_force}${claim_commit}:refs/heads/tasks/active/$short_sha" \
          ":refs/heads/tasks/frontier/$short_sha" 2>&1); then
        push_ok=true
    fi
    if [ "$push_ok" = true ]; then

        # ── Double-checked locking ────────────────────────────────────
        # The push reported success, which means the git remote
        # accepted our --force-with-lease CAS. That is *normally*
        # enough — GitHub is the single source of truth and atomic
        # CAS prevents two simultaneous claims from both landing.
        #
        # But we've still observed agents wasting hours implementing
        # the same issue in parallel because:
        #   - claims happen in subscribed/ahead-of-claim agents (the
        #     issue isn't broken into claim-able tasks);
        #   - a forgotten `git fetch` on the caller can hide the
        #     fact that someone else has been working too;
        #   - in pathological CI/CD topologies (mirror, proxy, push
        #     replication) a successful push to one endpoint can be
        #     overwritten by a concurrent push to another before
        #     the workers see each other.
        #
        # So: re-read the active ref straight off origin (no fetch,
        # no local-ref shortcut) and confirm it actually points at
        # OUR claim commit. If it doesn't — somebody overwrote us in
        # the few milliseconds between push-ack and readback — treat
        # this as a lost race and bail out with the same exit code
        # the caller would see for any other race-loss, so the
        # SCRIPT BEHAVIOR is identical to "we got there too late".
        #
        # Cost: one extra ls-remote round-trip per successful claim
        # (~30–80 ms vs GitHub). Cheap insurance against the kind of
        # silent duplicate work we've burned 3+ agent-runs on in the
        # last 12 hours.
        local readback_sha
        readback_sha=$(task_active_sha_on_remote "$short_sha")
        if [ "$readback_sha" != "$claim_commit" ]; then
            # Refresh local refs so we don't keep stale state on disk.
            fetch_task_refs >/dev/null 2>&1 || true
            if [ "$json" = true ]; then
                jq -nc --arg sha "$task_sha" --arg short "$short_sha" \
                    --arg claim "$claim_commit" --arg readback "${readback_sha:-}" \
                    '{ok:false,reason:"claim-not-confirmed",sha:$sha,shortSha:$short,attemptedClaimCommit:$claim,actualActiveSha:$readback}'
            else
                printf "${RED}✗ Claim push appeared to succeed but origin readback shows tasks/active/%s = %s (expected %s).${RESET}\n" \
                    "$short_sha" "${readback_sha:-<missing>}" "$claim_commit" >&2
                printf "${YELLOW}Treating as race-lost; another worker overwrote our claim.${RESET}\n" >&2
            fi
            return 2
        fi

        # Mirror the remote into local refs so subsequent commands see them.
        git update-ref "$active_local_ref" "$claim_commit"
        if git show-ref --verify --quiet "$frontier_local_ref"; then
            git update-ref -d "$frontier_local_ref"
        fi
        if [ "$json" = true ]; then
            jq -nc --arg sha "$task_sha" --arg short "$short_sha" \
                --arg claim "$claim_commit" --arg claimer "$claimer" \
                --arg host "$claimer_host" \
                --argjson pid "$(json_int_or_null "$claimer_pid")" \
                --argjson ttl "$(json_number_or_null "$ttl_hours")" \
                '{ok:true,sha:$sha,shortSha:$short,claimCommit:$claim,claimer:$claimer,claimerHost:$host,claimerPid:$pid,ttlHours:$ttl}'
        else
            printf "${GREEN}✓ Claimed task %s as %s@%s (pid %s, TTL %sh, verified on origin)${RESET}\n" \
                "$short_sha" "$claimer" "$claimer_host" "${claimer_pid:-?}" "$ttl_hours"
        fi
        return 0
    fi

    # Distinguish "lost the CAS race" from "git itself failed". Both
    # surface as "stale info" / "non-fast-forward" / "rejected" in
    # push output.
    if echo "$push_output" | grep -qiE 'rejected|stale info|non-fast-forward|fetch first'; then
        if [ "$json" = true ]; then
            jq -nc --arg sha "$task_sha" --arg short "$short_sha" \
                '{ok:false,reason:"race-lost",sha:$sha,shortSha:$short}'
        else
            printf "${YELLOW}Lost claim race for %s (another worker won).${RESET}\n" "$short_sha" >&2
            echo "$push_output" >&2
        fi
        return 2
    fi

    if [ "$json" = true ]; then
        # Truncate with bash parameter expansion (no pipe): piping into
        # `head -c 500` can hand `printf` a SIGPIPE once head has its 500
        # bytes, and under `set -o pipefail` that would abort the emit
        # (exit 141) before we print the result object.
        local err_snippet="${push_output:0:500}"
        jq -nc --arg sha "$task_sha" --arg short "$short_sha" \
            --arg error "$err_snippet" \
            '{ok:false,reason:"push-failed",sha:$sha,shortSha:$short,error:$error}'
    else
        printf "${RED}Push failed:${RESET}\n%s\n" "$push_output" >&2
    fi
    return 4
}

# Command: release - undo a claim (move active back to frontier).
#
# Use this when a worker is shutting down without completing the task,
# or when an operator determines a claim is stuck and the underlying
# work hasn't actually started. Atomic, like claim.
cmd_release() {
    local task_sha=""
    local do_force=false
    local json=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) do_force=true; shift ;;
            --json) json=true; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag release <task-sha> [options]

Drop a claim back onto the frontier so another worker can pick it
up. Atomically moves tasks/active/<short> back to tasks/frontier/<short>.

Options:
  --force   Release even if the local repo doesn't think it holds the claim
  --json    Emit a machine-readable JSON result
EOF
                return 0
                ;;
            *)
                if [ -z "$task_sha" ]; then
                    task_sha="$1"
                else
                    echo "Unknown option: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    if [ -z "$task_sha" ]; then
        echo "Error: task SHA required" >&2
        return 1
    fi

    if [ "$json" = true ]; then require_jq_for_json || return 1; fi

    task_sha=$(resolve_sha "$task_sha") || return 1
    local short_sha
    short_sha=$(git rev-parse --short "$task_sha")

    fetch_task_refs

    local active_local_ref="refs/heads/tasks/active/$short_sha"
    local frontier_local_ref="refs/heads/tasks/frontier/$short_sha"

    local remote_active_sha
    remote_active_sha=$(git ls-remote origin "refs/heads/tasks/active/$short_sha" 2>/dev/null | awk '{print $1; exit}')
    if [ -z "$remote_active_sha" ]; then
        if [ "$json" = true ]; then
            jq -nc --arg sha "$task_sha" '{ok:false,reason:"not-claimed",sha:$sha}'
        else
            printf "${YELLOW}No active claim on %s — nothing to release.${RESET}\n" "$short_sha" >&2
        fi
        return 1
    fi

    # Atomic: delete active iff at remote_active_sha, create frontier
    # iff absent (we'll never *replace* an existing frontier ref —
    # that would clobber a fresh task definition).
    local lease_active="--force-with-lease=refs/heads/tasks/active/$short_sha:$remote_active_sha"
    local lease_frontier="--force-with-lease=refs/heads/tasks/frontier/$short_sha:"
    if [ "$do_force" = true ]; then
        lease_active=""
        lease_frontier=""
    fi

    local push_output release_rc=0 updates
    taskdag_consumer_prepare release-pre-cas || return 3
    if [ "$TASKDAG_CONSUMER_MODE" = canonical ]; then
        updates=$(jq -ncS --arg ar "$active_local_ref" --arg ao "$remote_active_sha" \
            --arg fr "$frontier_local_ref" --arg task "$task_sha" \
            '[{ref:$ar,old:$ao,new:""},{ref:$fr,old:"",new:$task}] | sort_by(.ref)') || return 3
        taskdag_consumer_fenced_scheduling_push release "${TASK_DAG_CLAIMER:-releaser}" "$updates" || release_rc=$?
        push_output="canonical semantic-generation CAS failed"
    else
        push_output=$(git push --atomic origin \
            $lease_active $lease_frontier \
            "${task_sha}:refs/heads/tasks/frontier/$short_sha" \
            ":refs/heads/tasks/active/$short_sha" 2>&1) || release_rc=$?
    fi
    if [ "$release_rc" -eq 0 ]; then

        # Double-checked locking, mirroring cmd_claim: after the push
        # reports success, re-read origin to confirm the active ref
        # is actually gone. If it isn't (concurrent worker re-claimed
        # before our readback, replication artifact, etc.), we are
        # NOT released and the caller must NOT proceed as if they
        # had freed the task.
        local readback_sha
        readback_sha=$(task_active_sha_on_remote "$short_sha")
        if [ -n "$readback_sha" ]; then
            fetch_task_refs >/dev/null 2>&1 || true
            if [ "$json" = true ]; then
                jq -nc --arg sha "$task_sha" --arg short "$short_sha" \
                    --arg actual "$readback_sha" \
                    '{ok:false,reason:"release-not-confirmed",sha:$sha,shortSha:$short,actualActiveSha:$actual}'
            else
                printf "${RED}✗ Release push appeared to succeed but origin readback shows tasks/active/%s still present (%s).${RESET}\n" \
                    "$short_sha" "$readback_sha" >&2
                printf "${YELLOW}Treating as unreleased; another worker may have re-claimed before our readback.${RESET}\n" >&2
            fi
            return 4
        fi

        git update-ref "$frontier_local_ref" "$task_sha"
        if git show-ref --verify --quiet "$active_local_ref"; then
            git update-ref -d "$active_local_ref"
        fi
        if [ "$json" = true ]; then
            jq -nc --arg sha "$task_sha" '{ok:true,sha:$sha}'
        else
            printf "${GREEN}✓ Released %s back to frontier (verified on origin)${RESET}\n" "$short_sha"
        fi
        return 0
    fi

    if [ "$json" = true ]; then
        jq -nc --arg sha "$task_sha" '{ok:false,reason:"push-failed",sha:$sha}'
    else
        printf "${RED}Release push failed:${RESET}\n%s\n" "$push_output" >&2
    fi
    return 4
}

# Command: claim-root - atomically take the orchestration lock on an
# undecomposed epic root, so only one host decomposes a given issue.
#
# The contract mirrors `claim` but operates on the epic root keyed by
# issue number:
#   1. Create tasks/root-active/<N> on ORIGIN iff it is ABSENT (the real
#      cross-host mutex). A paired no-op refspec/lease for tasks/pending/<N>
#      is included as a BEST-EFFORT client-side stale check, but git skips
#      up-to-date refs so it is NOT a server-side assertion — the
#      authoritative pending-unchanged check is the post-claim readback in
#      step 3. pending/<N> is NEVER moved, so the epic identity is preserved.
#   2. Refuse if the root is already decomposed (has child task refs):
#      orchestration is finished, the leaves are the unit of work now.
#   3. Double-checked locking: read tasks/root-active/<N> back off origin
#      and confirm it is OUR claim commit; then re-check children, because
#      another host could have decomposed (publishing leaves + deleting
#      root-active) between our pre-check and our claim landing.
#
# Exit codes mirror `claim`:
#   0 claimed   1 arg error   2 already-claimed/already-decomposed
#   3 no pending root on origin   4 push failed
cmd_claim_root() {
    local issue=""
    local claimer="${TASK_DAG_CLAIMER:-${USER:-unknown}}"
    local claimer_host="${TASK_DAG_CLAIMER_HOST:-$(hostname -s 2>/dev/null || echo unknown)}"
    local ttl_hours="${TASK_DAG_TTL_HOURS:-12}"
    local claimer_pid="${TASK_DAG_CLAIMER_PID:-$PPID}"
    local note="" do_force=false json=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --by=*) claimer="${1#*=}"; shift ;;
            --host=*) claimer_host="${1#*=}"; shift ;;
            --pid=*) claimer_pid="${1#*=}"; shift ;;
            --ttl-hours=*) ttl_hours="${1#*=}"; shift ;;
            --note=*) note="${1#*=}"; shift ;;
            --force) do_force=true; shift ;;
            --json) json=true; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag claim-root <issue-number> [options]

Atomically claim the orchestration lock on an UNDECOMPOSED epic root so
that only one host decomposes a given issue. This is the root-level
counterpart of \`claim\` (which is leaf-only). Run it BEFORE you run
\`breakdown\`; \`breakdown\` of an epic root requires this lock and
consumes it when it publishes the child leaves.

The lock lives at tasks/root-active/<issue>; the epic identity ref
tasks/pending/<issue> is never moved.

Options:
  --by=<id>         Claimer identifier (default: \$TASK_DAG_CLAIMER or \$USER)
  --host=<name>     Claimer hostname (default: \$TASK_DAG_CLAIMER_HOST or hostname -s)
  --pid=<n>         Claiming worker PID (default: \$TASK_DAG_CLAIMER_PID or \$PPID)
  --ttl-hours=<n>   Advisory TTL stored in the claim metadata (default: 12)
  --note=<text>     Free-form note recorded in the claim metadata
  --force           Steal an existing root claim (only if the prior holder is dead)
  --json            Emit a machine-readable JSON result

Exit codes:
  0  claim succeeded
  1  argument error
  2  root already claimed by another worker, or already decomposed
  3  no pending epic root on origin (unknown/closed issue)
  4  push failed for an unrelated reason
EOF
                return 0
                ;;
            *)
                if [ -z "$issue" ]; then issue="$1"; else
                    echo "Unknown option: $1" >&2; return 1
                fi
                shift
                ;;
        esac
    done

    if [ -z "$issue" ]; then
        echo "Error: issue number required" >&2
        return 1
    fi
    if ! [[ "$issue" =~ ^[0-9]+$ ]]; then
        echo "Error: issue must be a number (got '$issue')" >&2
        return 1
    fi

    if [ "$json" = true ]; then require_jq_for_json || return 1; fi

    # Origin is the source of truth for the root identity + lock state.
    local root_sha
    root_sha=$(pending_sha_on_remote "$issue")
    if [ -z "$root_sha" ]; then
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"no-pending-root",issue:$issue}'
        else
            printf "${RED}No epic root tasks/pending/%s on origin — unknown or closed issue.${RESET}\n" "$issue" >&2
        fi
        return 3
    fi

    # Sync local view (pending root object + child namespaces) so the
    # child detector and claim-commit builder have what they need. FAIL
    # CLOSED if origin is unreadable: the "already decomposed?" check below
    # depends on a fresh child view, and a transient failure must not be
    # mistaken for "no children" (that would let us claim a root someone
    # else already decomposed).
    if ! fetch_root_refs "$issue"; then
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"origin-unreadable",issue:$issue}'
        else
            printf "${RED}Cannot reach origin to verify epic root #%s state — refusing to claim.${RESET}\n" "$issue" >&2
        fi
        return 3
    fi

    # Defense-in-depth: refuse to claim the root of an already-CLOSED issue.
    # An orphan tasks/pending/<N> can linger for a closed issue (historical
    # close workflow without contents:write, or a not-yet-updated caller), and
    # decomposing a done issue is exactly the wasted dispatch we're killing.
    # issue_is_closed_remote FAILS OPEN, so this never blocks real work when
    # gh/network/auth is unavailable.
    local origin_repo origin_issue _ignore_url
    IFS=$'\t' read -r origin_repo origin_issue _ignore_url < <(derive_task_origin "$root_sha")
    if issue_is_closed_remote "$origin_repo" "${origin_issue:-$issue}"; then
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"issue-closed",issue:$issue}'
        else
            printf "${RED}Epic root #%s belongs to a CLOSED issue — refusing to claim (orphan pending ref).${RESET}\n" "$issue" >&2
        fi
        return 3
    fi

    # Roots share the same dispatchability gates as frontier leaves: an
    # operator/downstream block or an incomplete dependency means the root is
    # real but not claimable now. Run this BEFORE the idempotent re-claim path
    # so a root pre-claimed by the dispatcher cannot continue if it was parked
    # before the spawned agent verifies ownership.
    taskdag_consumer_prepare claim-root || return 3
    local root_status
    root_status=$(taskdag_root_status_json "task:${TASKDAG_RECON_CUR}@${root_sha}" "$issue") || return 3
    if [ "$(jq -r .complete <<<"$root_status")" = true ]; then
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"complete",issue:$issue}'
        else
            printf "${RED}Epic root #%s is already canonically complete — refusing a new orchestration claim.${RESET}\n" "$issue" >&2
        fi
        return 2
    elif [ "$(jq -r .blocked <<<"$root_status")" = true ]; then
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"blocked",issue:$issue}'
        else
            printf "${RED}Epic root #%s is blocked — unblock it before claiming/decomposing.${RESET}\n" "$issue" >&2
        fi
        return 2
    fi
    if [ "$(jq -r .requirementsSatisfied <<<"$root_status")" != true ]; then
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"deps-pending",issue:$issue}'
        else
            printf "${RED}Epic root #%s has incomplete dependencies — complete/link them before claiming/decomposing.${RESET}\n" "$issue" >&2
        fi
        return 2
    fi

    # Already claimed by someone else?
    local existing_active
    existing_active=$(root_active_sha_on_remote "$issue")
    if [ -n "$existing_active" ] && [ "$do_force" = false ]; then
        local existing_claimer="unknown" existing_host="unknown" existing_pid="" existing_when="unknown" existing_taskcommit="" emsg
        git fetch --quiet --no-tags origin \
            "+refs/heads/tasks/root-active/$issue:refs/task-dag-tmp/root-active/$issue" 2>/dev/null || true
        if git show-ref --verify --quiet "refs/task-dag-tmp/root-active/$issue"; then
            emsg=$(parse_commit_metadata "refs/task-dag-tmp/root-active/$issue" 2>/dev/null || true)
            existing_claimer=$(extract_field "$emsg" "Claimer" 2>/dev/null || true)
            existing_host=$(extract_field "$emsg" "Claimer-Host" 2>/dev/null || true)
            existing_pid=$(extract_field "$emsg" "Claimer-PID" 2>/dev/null || true)
            existing_when=$(extract_field "$emsg" "Claimed-At" 2>/dev/null || true)
            existing_taskcommit=$(extract_field "$emsg" "Task-Commit" 2>/dev/null || true)
            git update-ref -d "refs/task-dag-tmp/root-active/$issue" 2>/dev/null || true
        fi

        # Idempotent re-claim (mirrors cmd_claim): if the live root lock is
        # already held by THIS exact worker identity (Claimer + Claimer-Host
        # + Claimer-PID) and pins THIS root SHA, treat it as success rather
        # than a race-loss. This is what lets the github-worker dispatcher
        # PRE-CLAIM an epic root and then have the agent it spawns (which
        # inherits TASK_DAG_CLAIMER / *_HOST / *_PID) VERIFY ownership by
        # re-running `claim-root`. Matching the pid means only the same
        # still-live worker process can re-confirm; a different worker that
        # merely shares $USER still gets exit 2. The Task-Commit check stops
        # a stale lock for a since-re-keyed root from being mistaken as ours.
        if [ -n "$existing_pid" ] \
           && [ "$existing_claimer" = "$claimer" ] \
           && [ "$existing_host" = "$claimer_host" ] \
           && [ "$existing_pid" = "$claimer_pid" ] \
           && [ "$existing_taskcommit" = "$root_sha" ]; then
            if [ "$json" = true ]; then
                jq -nc --argjson issue "$(json_int_or_null "$issue")" \
                    --arg claimer "$claimer" --arg host "$claimer_host" \
                    --argjson pid "$(json_int_or_null "$claimer_pid")" \
                    '{ok:true,issue:$issue,claimer:$claimer,claimerHost:$host,claimerPid:$pid,alreadyHeld:true}'
            else
                printf "${GREEN}✓ Epic root #%s already claimed by you (%s, pid %s on %s) — verified.${RESET}\n" \
                    "$issue" "$claimer" "$claimer_pid" "$claimer_host"
            fi
            return 0
        fi
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" \
                --arg claimer "${existing_claimer:-unknown}" \
                --arg host "${existing_host:-unknown}" \
                --argjson pid "$(json_int_or_null "$existing_pid")" \
                --arg when "${existing_when:-unknown}" \
                '{ok:false,reason:"already-claimed",issue:$issue,claimer:$claimer,claimerHost:$host,claimerPid:$pid,claimedAt:$when}'
        else
            printf "${RED}Epic root #%s is already claimed by %s (pid %s on %s) at %s${RESET}\n" \
                "$issue" "${existing_claimer:-unknown}" "${existing_pid:-?}" "${existing_host:-unknown}" "${existing_when:-unknown}" >&2
            echo "Re-run with --force ONLY if you know that claim is dead." >&2
        fi
        return 2
    fi

    # Already decomposed? Then orchestration is done; refuse (the leaves
    # are the unit of work now). Skip when forcing a steal.
    if [ "$do_force" = false ] && task_has_children "$root_sha" >/dev/null; then
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"already-decomposed",issue:$issue}'
        else
            printf "${RED}Epic root #%s is already decomposed — claim its frontier leaves instead.${RESET}\n" "$issue" >&2
        fi
        return 2
    fi

    local claim_commit
    claim_commit=$(build_root_claim_commit "$issue" "$root_sha" "$claimer" "$claimer_host" "$ttl_hours" "$note" "$claimer_pid") || {
        echo "Error: failed to build root claim commit" >&2
        return 4
    }

    local root_active_ref="refs/heads/tasks/root-active/$issue"
    local pending_ref="refs/heads/tasks/pending/$issue"

    # Atomic CAS: create root-active iff absent (or force-overwrite when
    # stealing). The create-only lease on root-active is the real
    # cross-host mutex — two simultaneous claim-roots cannot both land.
    # The pending lease + no-op refspec is a best-effort CLIENT-SIDE stale
    # check (git skips sending up-to-date refs, so it is NOT a server-side
    # atomic assertion); the authoritative pending-unchanged check is the
    # post-claim readback below. An undecomposed root is never closed, so
    # pending cannot legitimately move/delete during this window anyway.
    local lease_active="--force-with-lease=$root_active_ref:"
    local active_force=""
    local lease_pending="--force-with-lease=$pending_ref:$root_sha"
    if [ "$do_force" = true ]; then
        lease_active=""
        active_force="+"
    fi

    taskdag_consumer_prepare claim-root-pre-cas || return 3
    root_status=$(taskdag_root_status_json "task:${TASKDAG_RECON_CUR}@${root_sha}" "$issue") || return 3
    [ "$(jq -r .complete <<<"$root_status")" = false ] || return 2
    [ "$(jq -r .requirementsSatisfied <<<"$root_status")" = true ] || return 2
    [ "$(jq -r .pickable <<<"$root_status")" = true ] || [ "$do_force" = true ] || return 2

    local push_output="" push_ok=false
    if [ "$TASKDAG_CONSUMER_MODE" = canonical ]; then
        local updates active_old
        active_old=$(root_active_sha_on_remote "$issue")
        updates=$(jq -ncS \
          --arg ar "$root_active_ref" --arg ao "$active_old" --arg an "$claim_commit" \
          --arg pr "$pending_ref" --arg po "$root_sha" \
          '[{ref:$ar,old:$ao,new:$an},{ref:$pr,old:$po,new:$po}]') || return 3
        taskdag_consumer_fenced_scheduling_push claim-root "$claimer" "$updates" && push_ok=true
    elif push_output=$(git push --atomic origin \
          $lease_active "$lease_pending" \
          "${active_force}${claim_commit}:$root_active_ref" \
          "$root_sha:$pending_ref" 2>&1); then
        push_ok=true
    fi
    if [ "$push_ok" = true ]; then

        # Double-checked locking: confirm origin holds OUR claim commit.
        local readback
        readback=$(root_active_sha_on_remote "$issue")
        if [ "$readback" != "$claim_commit" ]; then
            fetch_root_refs "$issue" >/dev/null 2>&1 || true
            if [ "$json" = true ]; then
                jq -nc --argjson issue "$(json_int_or_null "$issue")" \
                    --arg claim "$claim_commit" --arg readback "${readback:-}" \
                    '{ok:false,reason:"claim-not-confirmed",issue:$issue,attemptedClaimCommit:$claim,actualActiveSha:$readback}'
            else
                printf "${RED}✗ Root claim push appeared to succeed but origin readback shows tasks/root-active/%s = %s (expected %s).${RESET}\n" \
                    "$issue" "${readback:-<missing>}" "$claim_commit" >&2
            fi
            return 2
        fi

        # Mirror locally so subsequent commands see the lock.
        git update-ref "$root_active_ref" "$claim_commit"

        # Authoritative pending-unchanged check: confirm pending/<N> still
        # points at the root we claimed. (Closes the gap left by the
        # client-side-only pending lease above.) If it moved/vanished,
        # drop our claim and bail.
        local pending_now
        pending_now=$(pending_sha_on_remote "$issue")
        if [ "$do_force" = false ] && [ "$pending_now" != "$root_sha" ]; then
            if ! _release_our_root_claim "$issue" "$claim_commit"; then
                if [ "$json" = true ]; then
                    jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"pending-moved-claim-not-released",issue:$issue}'
                else
                    printf "${RED}Epic root #%s identity changed during claim (pending now %s) but our orchestration claim could NOT be released — run 'task-dag release-root %s'.${RESET}\n" \
                        "$issue" "${pending_now:-<gone>}" "$issue" >&2
                fi
                return 4
            fi
            if [ "$json" = true ]; then
                jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"pending-moved",issue:$issue}'
            else
                printf "${RED}Epic root #%s identity changed during claim (pending now %s); released our claim.${RESET}\n" \
                    "$issue" "${pending_now:-<gone>}" >&2
            fi
            return 2
        fi

        # Post-claim child re-check: another host could have decomposed
        # (published leaves + deleted root-active) between our pre-check
        # and our claim landing, then we'd have re-created a stale lock on
        # an already-decomposed root. If so, release our claim and bail.
        # Skipped under --force: a deliberate steal/re-claim (e.g. to add
        # children to an already-decomposed root via `breakdown --force`)
        # legitimately wants the lock even when children exist.
        #
        # FAIL CLOSED if origin is unreadable for this recheck: we already
        # hold a claim on origin, but we cannot confirm the root wasn't
        # decomposed concurrently. Drop our claim and tell the caller to
        # retry rather than keep a possibly-stale lock on a decomposed root.
        if [ "$do_force" = false ] && ! fetch_root_refs "$issue"; then
            if ! _release_our_root_claim "$issue" "$claim_commit"; then
                if [ "$json" = true ]; then
                    jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"postclaim-unreadable-claim-not-released",issue:$issue}'
                else
                    printf "${RED}Claimed epic root #%s but could not re-verify origin, and our orchestration claim could NOT be released — run 'task-dag release-root %s'.${RESET}\n" "$issue" "$issue" >&2
                fi
                return 4
            fi
            if [ "$json" = true ]; then
                jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"origin-unreadable-postclaim",issue:$issue}'
            else
                printf "${RED}Claimed epic root #%s but could not re-verify origin afterwards; released our claim — retry.${RESET}\n" "$issue" >&2
            fi
            return 3
        fi
        if [ "$do_force" = false ] && task_has_children "$root_sha" >/dev/null; then
            if ! _release_our_root_claim "$issue" "$claim_commit"; then
                # Our claim is still on origin and we could not drop it —
                # surface it loudly so the stale lock gets cleaned up.
                if [ "$json" = true ]; then
                    jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"stale-claim-not-released",issue:$issue}'
                else
                    printf "${RED}Epic root #%s was decomposed concurrently but our orchestration claim could NOT be released — run 'task-dag release-root %s'.${RESET}\n" "$issue" "$issue" >&2
                fi
                return 4
            fi
            if [ "$json" = true ]; then
                jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"already-decomposed",issue:$issue}'
            else
                printf "${RED}Epic root #%s was decomposed concurrently; released our claim. Claim its frontier leaves instead.${RESET}\n" "$issue" >&2
            fi
            return 2
        fi

        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" \
                --arg rootSha "$root_sha" --arg claim "$claim_commit" \
                --arg claimer "$claimer" --arg host "$claimer_host" \
                --argjson pid "$(json_int_or_null "$claimer_pid")" \
                --argjson ttl "$(json_number_or_null "$ttl_hours")" \
                '{ok:true,issue:$issue,rootSha:$rootSha,claimCommit:$claim,claimer:$claimer,claimerHost:$host,claimerPid:$pid,ttlHours:$ttl}'
        else
            printf "${GREEN}✓ Claimed epic root #%s as %s@%s (pid %s, TTL %sh, verified on origin)${RESET}\n" \
                "$issue" "$claimer" "$claimer_host" "${claimer_pid:-?}" "$ttl_hours"
            echo "Run 'task-dag breakdown $root_sha ...' to decompose it (this consumes the lock)."
        fi
        return 0
    fi

    if echo "$push_output" | grep -qiE 'rejected|stale info|non-fast-forward|fetch first'; then
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"race-lost",issue:$issue}'
        else
            printf "${YELLOW}Lost root claim race for #%s (another worker won).${RESET}\n" "$issue" >&2
            echo "$push_output" >&2
        fi
        return 2
    fi
    if [ "$json" = true ]; then
        jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"push-failed",issue:$issue}'
    else
        printf "${RED}Root claim push failed:${RESET}\n%s\n" "$push_output" >&2
    fi
    return 4
}

# Command: release-root - drop a root orchestration claim without
# decomposing. Deletes tasks/root-active/<N> only; it NEVER creates a
# frontier ref (a root is not a leaf). Use when a worker takes the root
# lock but cannot proceed and wants to hand orchestration back.
cmd_release_root() {
    local issue="" do_force=false json=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) do_force=true; shift ;;
            --json) json=true; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag release-root <issue-number> [--force] [--json]

Drop the orchestration lock tasks/root-active/<issue> so another worker
can claim the root. Unlike leaf 'release', this never creates a frontier
ref. By default it verifies the claim references the current pending root
before deleting; --force deletes regardless.
EOF
                return 0
                ;;
            *)
                if [ -z "$issue" ]; then issue="$1"; else
                    echo "Unknown option: $1" >&2; return 1
                fi
                shift
                ;;
        esac
    done

    if [ -z "$issue" ]; then
        echo "Error: issue number required" >&2
        return 1
    fi
    if ! [[ "$issue" =~ ^[0-9]+$ ]]; then
        echo "Error: issue must be a number (got '$issue')" >&2
        return 1
    fi

    if [ "$json" = true ]; then require_jq_for_json || return 1; fi

    local root_active_ref="refs/heads/tasks/root-active/$issue"
    local active_sha
    active_sha=$(root_active_sha_on_remote "$issue")
    if [ -z "$active_sha" ]; then
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"not-claimed",issue:$issue}'
        else
            printf "${YELLOW}Epic root #%s has no orchestration claim to release.${RESET}\n" "$issue" >&2
        fi
        return 2
    fi

    # Sanity guard: the claim must reference this issue's pending root.
    if [ "$do_force" = false ]; then
        git fetch --quiet --no-tags origin \
            "+$root_active_ref:refs/task-dag-tmp/release-root/$issue" 2>/dev/null || true
        if git show-ref --verify --quiet "refs/task-dag-tmp/release-root/$issue"; then
            local cmsg ctask root_sha
            cmsg=$(parse_commit_metadata "refs/task-dag-tmp/release-root/$issue" 2>/dev/null || true)
            ctask=$(extract_field "$cmsg" "Task-Commit" 2>/dev/null || true)
            git update-ref -d "refs/task-dag-tmp/release-root/$issue" 2>/dev/null || true
            root_sha=$(pending_sha_on_remote "$issue")
            if [ -n "$root_sha" ] && [ -n "$ctask" ] && [ "$ctask" != "$root_sha" ]; then
                echo "Error: tasks/root-active/$issue references $ctask, not the current pending root $root_sha. Rerun with --force if intended." >&2
                return 2
            fi
        fi
    fi

    local push_output release_root_rc=0 updates
    taskdag_consumer_prepare release-root-pre-cas || return 3
    if [ "$TASKDAG_CONSUMER_MODE" = canonical ]; then
        updates=$(jq -ncS --arg ref "$root_active_ref" --arg old "$active_sha" '[{ref:$ref,old:$old,new:""}]') || return 3
        taskdag_consumer_fenced_scheduling_push release-root "${TASK_DAG_CLAIMER:-root-releaser}" "$updates" || release_root_rc=$?
        push_output="canonical semantic-generation CAS failed"
    else
        push_output=$(git push --atomic origin \
            "--force-with-lease=$root_active_ref:$active_sha" ":$root_active_ref" 2>&1) || release_root_rc=$?
    fi
    if [ "$release_root_rc" -eq 0 ]; then
        git update-ref -d "$root_active_ref" 2>/dev/null || true
        if [ "$json" = true ]; then
            jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:true,issue:$issue}'
        else
            printf "${GREEN}✓ Released orchestration claim on epic root #%s${RESET}\n" "$issue"
        fi
        return 0
    fi
    if [ "$json" = true ]; then
        jq -nc --argjson issue "$(json_int_or_null "$issue")" '{ok:false,reason:"push-failed",issue:$issue}'
    else
        printf "${RED}Release-root push failed:${RESET}\n%s\n" "$push_output" >&2
    fi
    return 4
}

reap_leaf_claim() {
    local short_sha="$1" task_sha="$2" claim_sha="$3"
    local ref_active ref_frontier
    ref_active="refs/heads/tasks/active/$short_sha"
    ref_frontier="refs/heads/tasks/frontier/$short_sha"
    local readback_sha
    local reap_status
    taskdag_consumer_prepare reap-pre-cas || return 1
    reap_status=$(taskdag_task_status_json "task:${TASKDAG_RECON_CUR}@${task_sha}" --include-claimed) || return 1

    # Never resurrect completed work. If the task already landed on master
    # (its completion commit lists it as a parent) but its active claim ref
    # leaked (worker died after completing but before/while cleaning refs),
    # recreating tasks/frontier/<short> would make finished work pickable
    # again — the exact "wasted dispatch on already-done task" symptom we
    # are fixing. In that case just lease-delete the stale active ref.
    if [ "$(jq -r .complete <<<"$reap_status")" = true ]; then
        local updates
        updates=$(jq -ncS --arg ref "$ref_active" --arg old "$claim_sha" '[{ref:$ref,old:$old,new:""}]') || return 1
        if { [ "$TASKDAG_CONSUMER_MODE" = canonical ] \
             && taskdag_consumer_fenced_scheduling_push reap-complete "${TASK_DAG_CLAIMER:-reaper}" "$updates"; } \
          || { [ "$TASKDAG_CONSUMER_MODE" = legacy ] && git push --atomic origin \
             "--force-with-lease=$ref_active:$claim_sha" ":$ref_active" >/dev/null 2>&1; }; then
            git update-ref -d "$ref_active" 2>/dev/null || true
            [ -z "$(task_active_sha_on_remote "$short_sha")" ] && return 0
        fi
        return 1
    fi

    local updates
    updates=$(jq -ncS --arg ar "$ref_active" --arg ao "$claim_sha" --arg fr "$ref_frontier" --arg task "$task_sha" \
      '[{ref:$ar,old:$ao,new:""},{ref:$fr,old:"",new:$task}]') || return 1
    if { [ "$TASKDAG_CONSUMER_MODE" = canonical ] \
         && taskdag_consumer_fenced_scheduling_push reap-requeue "${TASK_DAG_CLAIMER:-reaper}" "$updates"; } \
      || { [ "$TASKDAG_CONSUMER_MODE" = legacy ] && git push --atomic origin \
         "--force-with-lease=$ref_active:$claim_sha" "--force-with-lease=$ref_frontier:" \
         "$task_sha:$ref_frontier" ":$ref_active" >/dev/null 2>&1; }; then
        readback_sha=$(task_active_sha_on_remote "$short_sha")
        if [ -z "$readback_sha" ]; then
            git update-ref "$ref_frontier" "$task_sha" 2>/dev/null || true
            git update-ref -d "$ref_active" 2>/dev/null || true
            return 0
        fi
    fi
    return 1
}

reap_root_claim() {
    local issue="$1" claim_sha="$2" ref updates
    ref="refs/heads/tasks/root-active/$issue"
    taskdag_consumer_prepare reap-root-pre-cas || return 1
    updates=$(jq -ncS --arg ref "$ref" --arg old "$claim_sha" '[{ref:$ref,old:$old,new:""}]') || return 1
    if { [ "$TASKDAG_CONSUMER_MODE" = canonical ] \
         && taskdag_consumer_fenced_scheduling_push reap-root "${TASK_DAG_CLAIMER:-reaper}" "$updates"; } \
      || { [ "$TASKDAG_CONSUMER_MODE" = legacy ] && git push --atomic origin \
         "--force-with-lease=$ref:$claim_sha" ":$ref" >/dev/null 2>&1; }; then
        git update-ref -d "$ref" 2>/dev/null || true
        [ -z "$(root_active_sha_on_remote "$issue")" ] && return 0
    fi
    return 1
}

# Command: reap - reclaim provably-dead leaf and root claims.
cmd_reap() {
    local json=false dry_run=false issue_filter="" do_fetch=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            --dry-run) dry_run=true; shift ;;
            --issue=*) issue_filter="${1#*=}"; shift ;;
            --no-fetch) do_fetch=false; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag reap [--json] [--dry-run] [--issue=N] [--no-fetch]

Reclaim provably-dead claims. Leaf claims are moved from tasks/active/<short>
back to tasks/frontier/<short> with leased atomic pushes; root claims are
leased-deleted from tasks/root-active/<issue> and never create frontier refs.
EOF
                return 0
                ;;
            *) echo "Unknown option: $1" >&2; return 1 ;;
        esac
    done

    if [ "$json" = true ]; then require_jq_for_json || return 1; fi

    if [ "$do_fetch" = true ]; then
        fetch_task_refs
    fi

    local entries="" count=0
    add_reap_entry() {
        local kind="$1" id_key="$2" id_val="$3" claim_sha="$4" reason="$5" reclaimed="$6" obj
        if [ "$json" = true ]; then
            obj=$(jq -nc --arg kind "$kind" --arg idk "$id_key" --arg idv "$id_val" \
                --arg cc "$claim_sha" --arg dr "$reason" --argjson reclaimed "$reclaimed" \
                '{kind:$kind,($idk):$idv,claimCommit:$cc,deadReason:$dr,reclaimed:$reclaimed}')
            if [ "$count" -gt 0 ]; then
                entries="${entries},${obj}"
            else
                entries="$obj"
            fi
        else
            if [ "$dry_run" = true ]; then
                printf 'Would reap %s %s claim %s (%s)\n' "$kind" "$id_val" "$claim_sha" "$reason"
            elif [ "$reclaimed" = true ]; then
                printf 'Reaped %s %s claim %s (%s)\n' "$kind" "$id_val" "$claim_sha" "$reason"
            fi
        fi
        count=$((count + 1))
    }

    local claim_sha short_ref short_sha task_sha task_msg issue rc reason reclaimed
    while read -r claim_sha short_ref; do
        [ -n "$claim_sha" ] || continue
        short_sha="${short_ref#active/}"
        task_sha=$(get_first_parent "$claim_sha" 2>/dev/null || true)
        if [ -z "$task_sha" ] || ! git cat-file -e "$task_sha^{commit}" 2>/dev/null; then
            [ "$json" = false ] && echo "Skipping malformed active/$short_sha: no task parent" >&2
            continue
        fi
        # Validate by OBJECT IDENTITY, not by reconstructing today's
        # abbreviation: the ref suffix must be a genuine prefix of the
        # claim's first-parent task SHA. Older refs were created at a
        # different `--short` length, so an exact equality check against
        # `git rev-parse --short` would skip (and never reap) them. We
        # keep using the OBSERVED suffix ($short_sha) for the lease/ref
        # names so we act on the exact ref that exists on origin.
        case "$task_sha" in
            "$short_sha"*) : ;;
            *)
                [ "$json" = false ] && echo "Skipping malformed active/$short_sha: not a prefix of parent $task_sha" >&2
                continue
                ;;
        esac
        task_msg=$(parse_commit_metadata "$task_sha" 2>/dev/null || true)
        issue=$(extract_field "$task_msg" "Issue" 2>/dev/null | sed 's/^#//' || true)
        if [ -n "$issue_filter" ] && [ "$issue" != "$issue_filter" ]; then
            continue
        fi
        if claim_is_dead "$claim_sha"; then rc=0; else rc=$?; fi
        reason="$claim_dead_reason"
        if [ "$rc" -eq 0 ]; then
            reclaimed=false
            if [ "$dry_run" = false ] && reap_leaf_claim "$short_sha" "$task_sha" "$claim_sha"; then
                reclaimed=true
            fi
            add_reap_entry leaf shortSha "$short_sha" "$claim_sha" "$reason" "$reclaimed"
        fi
    done < <(git for-each-ref refs/heads/tasks/active/ --format='%(objectname) %(refname:strip=3)')

    local root_ref root_issue
    while read -r claim_sha root_ref; do
        [ -n "$claim_sha" ] || continue
        root_issue="${root_ref#root-active/}"
        if [ -n "$issue_filter" ] && [ "$root_issue" != "$issue_filter" ]; then
            continue
        fi
        if claim_is_dead "$claim_sha"; then rc=0; else rc=$?; fi
        reason="$claim_dead_reason"
        if [ "$rc" -eq 0 ]; then
            reclaimed=false
            if [ "$dry_run" = false ] && reap_root_claim "$root_issue" "$claim_sha"; then
                reclaimed=true
            fi
            add_reap_entry root issue "$root_issue" "$claim_sha" "$reason" "$reclaimed"
        fi
    done < <(git for-each-ref refs/heads/tasks/root-active/ --format='%(objectname) %(refname:strip=3)')

    if [ "$json" = true ]; then
        printf '[%s]\n' "$entries"
    fi
    return 0
}

# Command: roots - list epic roots and their orchestration state.
#
# Each tasks/pending/<N> is shown with whether it is decomposed (has child
# tasks), claimed for orchestration (tasks/root-active/<N>), or PICKABLE
# (undecomposed + unclaimed → a worker should `claim-root <N>` then
# `breakdown`). With --pickable, only the pickable roots are listed —
# the discovery surface the dispatcher uses to spawn a root/decompose
# worker without racing another host.
cmd_roots() {
    local json=false pickable_only=false do_fetch=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            --pickable) pickable_only=true; shift ;;
            --no-fetch) do_fetch=false; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag roots [--pickable] [--json] [--no-fetch]

List epic roots (tasks/pending/<N>) with orchestration state:
  decomposed  — already broken down into child tasks
  claimed     — tasks/root-active/<N> held (orchestration in flight)
  blocked     — root is explicitly parked with tasks/blocked/<root-sha>
  deps-pending — root has incomplete dependency parents
  pickable    — undecomposed AND unclaimed; claim-root then breakdown

--pickable   show only pickable roots (dispatch discovery surface)
EOF
                return 0
                ;;
            *) echo "Unknown option: $1" >&2; return 1 ;;
        esac
    done

    if [ "$do_fetch" = true ]; then
        fetch_task_refs
    fi
    local consumer_args=()
    [ "$do_fetch" = false ] && consumer_args+=(--no-fetch --tip HEAD)
    taskdag_consumer_prepare roots "${consumer_args[@]}" || return 2

    if [ "$json" = true ]; then echo "["; else
        printf "${BOLD}%-8s %-50s %-12s${RESET}\n" "ISSUE" "TITLE" "STATE"
        printf "%-8s %-50s %-12s\n" "========" "$(printf '%.50s' '==================================================')" "============"
    fi

    local first=true ref issue root_sha title state root_status
    while IFS= read -r ref; do
        [ -z "$ref" ] && continue
        issue="${ref##*/}"
        root_sha=$(git rev-parse "$ref" 2>/dev/null) || continue
        root_status=$(taskdag_root_status_json "task:${TASKDAG_RECON_CUR}@${root_sha}" "$issue") || return 2
        if [ "$(jq -r .complete <<<"$root_status")" = true ]; then
            state="complete"
        elif [ "$(jq -r .decomposed <<<"$root_status")" = true ]; then
            state="decomposed"
        elif [ "$(jq -r .claimed <<<"$root_status")" = true ]; then
            state="claimed"
        elif [ "$(jq -r .blocked <<<"$root_status")" = true ]; then
            state="blocked"
        elif [ "$(jq -r .requirementsSatisfied <<<"$root_status")" != true ]; then
            state="deps-pending"
        else
            state="pickable"
        fi
        if [ "$pickable_only" = true ] && [ "$state" != "pickable" ]; then
            continue
        fi
        title=$(get_task_title "$root_sha")
        if [ "$json" = true ]; then
            [ "$first" = false ] && echo ","
            first=false
            printf '    {"issue": %s, "sha": %s, "title": %s, "state": %s}' \
                "$(json_int_or_null "$issue")" "$(json_escape "$root_sha")" "$(json_escape "$title")" "$(json_escape "$state")"
        else
            printf "%-8s %-50s %-12s\n" "#$issue" "${title:0:50}" "$state"
        fi
    done < <(git for-each-ref --format='%(refname)' refs/heads/tasks/pending/ | sort -t/ -k4 -n)

    if [ "$json" = true ]; then echo ""; echo "]"; fi
}

# Command: active - list currently-claimed tasks (from origin).
cmd_active() {
    local json=false
    local issue_filter=""
    local do_fetch=true

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            --issue=*) issue_filter="${1#*=}"; shift ;;
            --no-fetch) do_fetch=false; shift ;;
            *) echo "Unknown option: $1" >&2; return 1 ;;
        esac
    done

    if [ "$do_fetch" = true ]; then
        fetch_task_refs
    fi

    if [ "$json" = true ]; then
        echo "["
    else
        printf "${BOLD}%-12s %-12s %-28s %-8s %-20s %-6s %s${RESET}\n" "SHORT" "ISSUE" "CLAIMER@HOST" "PID" "CLAIMED-AT" "DEAD" "TITLE"
    fi

    local first=true
    # NOTE: every assignment below uses `local NAME=VALUE` (single
    # statement) on purpose. Splitting into `local NAME` + `NAME=$(...)`
    # would cause `set -e` to abort the loop the first time
    # `extract_field` returned non-zero (which happens for any task
    # that has no Issue: trailer, e.g. clarification messages).
    git for-each-ref refs/heads/tasks/active/ \
        --format='%(objectname) %(refname:strip=3)' \
        | while read claim_sha short_ref; do
        local task_sha=$(get_first_parent "$claim_sha" 2>/dev/null || echo "$claim_sha")
        local task_msg=$(parse_commit_metadata "$task_sha" 2>/dev/null || true)
        local title=$(get_task_title "$task_sha" 2>/dev/null || echo "(unknown)")
        local issue=$(extract_field "$task_msg" "Issue" 2>/dev/null | sed 's/^#//' || true)
        # strip refname prefix 'active/' if for-each-ref left it there
        short_ref="${short_ref#active/}"

        if [ -n "$issue_filter" ] && [ "$issue" != "$issue_filter" ]; then
            continue
        fi

        local claim_msg=$(parse_commit_metadata "$claim_sha" 2>/dev/null || true)
        local claimer=$(extract_field "$claim_msg" "Claimer" 2>/dev/null || true)
        local claimer_host=$(extract_field "$claim_msg" "Claimer-Host" 2>/dev/null || true)
        local claimer_pid=$(extract_field "$claim_msg" "Claimer-PID" 2>/dev/null || true)
        local claimed_at=$(extract_field "$claim_msg" "Claimed-At" 2>/dev/null || true)
        local ttl_hours=$(extract_field "$claim_msg" "TTL-Hours" 2>/dev/null || true)
        local dead=false dead_reason="none" live_rc
        if claim_is_dead "$claim_sha"; then live_rc=0; else live_rc=$?; fi
        if [ "$live_rc" -eq 0 ]; then
            dead=true
            dead_reason="$claim_dead_reason"
        fi

        if [ "$json" = true ]; then
            [ "$first" = false ] && echo ","
            cat <<JSON
    {
        "shortSha": $(json_escape "$short_ref"),
        "taskSha": $(json_escape "$task_sha"),
        "claimCommit": $(json_escape "$claim_sha"),
        "issue": $(json_int_or_null "$issue"),
        "title": $(json_escape "$title"),
        "claimer": $(json_escape "${claimer:-unknown}"),
        "claimerHost": $(json_escape "${claimer_host:-unknown}"),
        "claimerPid": $(json_int_or_null "$claimer_pid"),
        "claimedAt": $(json_escape "${claimed_at:-unknown}"),
        "ttlHours": $(json_number_or_null "$ttl_hours"),
        "dead": $dead,
        "deadReason": $(json_escape "$dead_reason")
    }
JSON
            first=false
        else
            printf "%-12s %-12s %-28s %-8s %-20s %-6s %s\n" \
                "$short_ref" \
                "${issue:+#$issue}" \
                "${claimer:-?}@${claimer_host:-?}" \
                "${claimer_pid:-?}" \
                "${claimed_at:-unknown}" \
                "$dead_reason" \
                "${title:0:60}"
        fi
    done

    if [ "$json" = true ]; then
        echo ""
        echo "]"
    fi
}

# Command: show - show task details
cmd_show() {
    local json=false
    local do_fetch=true
    local sha=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            --no-fetch) do_fetch=false; shift ;;
            --help|-h) 
                echo "Usage: task-dag show <sha> [--json] [--no-fetch]"
                return 0
                ;;
            *) 
                if [ -z "$sha" ]; then
                    sha="$1"
                else
                    echo "Unknown option: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done
    
    if [ -z "$sha" ]; then
        echo "Error: SHA required" >&2
        return 1
    fi
    
    # Fetch BEFORE resolve so a prepared/single-branch clone that lacks the
    # task object can still inspect it (design §3 Layer B). Ordering is
    # fetch → resolve_sha, never the reverse. --no-fetch skips the network
    # round-trip for offline / deliberately-stale inspection.
    if [ "$do_fetch" = true ]; then
        fetch_task_refs
    fi
    
    sha=$(resolve_sha "$sha") || return 1
    local consumer_args=(--tip HEAD) task_status
    [ "$do_fetch" = false ] && consumer_args+=(--no-fetch)
    taskdag_consumer_prepare show "${consumer_args[@]}" || return 2
    task_status=$(taskdag_task_status_json "task:${TASKDAG_RECON_CUR}@${sha}" --include-claimed) || return 2
    
    local msg=$(parse_commit_metadata "$sha")
    local title=$(get_task_title "$sha")
    local issue=$(extract_field "$msg" "Issue")
    local author=$(extract_field "$msg" "Author")
    local status=$(extract_field "$msg" "Status")
    local type=$(extract_field "$msg" "Type")
    local parent_task=$(extract_field "$msg" "Parent-Task")
    local first_parent=$(get_first_parent "$sha")
    local deps
    deps=$(jq -r '.requirements[].node' <<<"$task_status")
    
    # Find refs pointing to this task
    local refs=$(git for-each-ref --format='%(refname:short)' --points-at "$sha" | grep '^tasks/' || true)
    
    if [ "$json" = true ]; then
        cat <<JSON
{
    "sha": $(json_escape "$sha"),
    "shortSha": $(json_escape "$(git rev-parse --short "$sha")"),
    "title": $(json_escape "$title"),
    "issue": $(json_str_or_null "$issue"),
    "author": $(json_str_or_null "$author"),
    "status": $(json_escape "${status:-pending}"),
    "type": $(json_escape "${type:-task}"),
    "parentTask": $(json_str_or_null "$parent_task"),
    "firstParent": $(json_str_or_null "$first_parent"),
    "dependencies": $(printf '%s\n' "$deps" | json_str_array),
    "refs": $(printf '%s\n' "$refs" | json_str_array),
    "completed": $(jq -r .complete <<<"$task_status")
}
JSON
    else
        printf "${BOLD}Task: ${RESET}%s\n" "$title"
        printf "${BOLD}SHA:${RESET}  %s\n" "$sha"
        [ -n "$issue" ] && printf "${BOLD}Issue:${RESET} %s\n" "$issue"
        [ -n "$author" ] && printf "${BOLD}Author:${RESET} %s\n" "$author"
        printf "${BOLD}Status:${RESET} %s\n" "${status:-pending}"
        printf "${BOLD}Type:${RESET} %s\n" "${type:-task}"
        
        if [ -n "$refs" ]; then
            printf "${BOLD}Refs:${RESET}\n"
            echo "$refs" | while read r; do echo "  - $r"; done
        fi
        
        if [ -n "$parent_task" ] || [ -n "$first_parent" ]; then
            printf "${BOLD}Parent:${RESET} %s\n" "${parent_task:-$first_parent}"
        fi
        
        if [ -n "$deps" ]; then
            printf "${BOLD}Dependencies:${RESET}\n"
            echo "$deps" | while read dep; do
                local dep_ref=${dep##*@}
                local dep_title=$(get_task_title "$dep_ref" 2>/dev/null || echo "$dep")
                local dep_short=$(git rev-parse --short "$dep_ref" 2>/dev/null || echo "$dep")
                if jq -e --arg n "$dep" '.requirements[]|select(.node==$n and .complete)' <<<"$task_status" >/dev/null; then
                    printf "  ${GREEN}✓${RESET} %s - %s\n" "$dep_short" "$dep_title"
                else
                    printf "  ${RED}✗${RESET} %s - %s\n" "$dep_short" "$dep_title"
                fi
            done
        fi
        
        if [ "$(jq -r .complete <<<"$task_status")" = true ]; then
            printf "\n${GREEN}✓ Task completed${RESET}\n"
        else
            printf "\n${YELLOW}○ Task pending${RESET}\n"
        fi
    fi
}

# Command: deps - show dependencies and check if ready
cmd_deps() {
    local json=false
    local check_complete=false
    local do_fetch=true
    local sha=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            --check-complete) check_complete=true; shift ;;
            --no-fetch) do_fetch=false; shift ;;
            --help|-h)
                echo "Usage: task-dag deps <sha> [--json] [--check-complete] [--no-fetch]"
                echo "  --check-complete: Exit with code 2 if any dependency is not met"
                return 0
                ;;
            *)
                if [ -z "$sha" ]; then
                    sha="$1"
                else
                    echo "Unknown option: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done
    
    if [ -z "$sha" ]; then
        echo "Error: SHA required" >&2
        return 1
    fi
    
    # Fetch BEFORE resolve (fetch → resolve_sha ordering) so dependency
    # parents are present and their completion state is read against a
    # fresh view. --no-fetch skips it (offline, or internal callers that
    # already fetched — e.g. cmd_complete).
    if [ "$do_fetch" = true ]; then
        fetch_task_refs
    fi
    
    sha=$(resolve_sha "$sha") || return 1
    local dependency_status requirements_status deps
    local consumer_args=(--tip HEAD)
    [ "$do_fetch" = false ] && consumer_args+=(--no-fetch)
    local head_oid
    head_oid=$(git rev-parse HEAD^{commit}) || return 2
    if [ "$TASKDAG_CONSUMER_READY" != true ] || [ "$TASKDAG_CONSUMER_TIP" != "$head_oid" ]; then
        taskdag_consumer_prepare deps "${consumer_args[@]}" || return 2
    fi
    requirements_status=$(taskdag_requirements_status_json "task:${TASKDAG_RECON_CUR}@${sha}") || return 2
    dependency_status=$(jq -cS '{dependencies:(.requirements|map({sha:(.node|split("@")[-1]),completed:.complete})),ready:.requirementsSatisfied,reasons}' <<<"$requirements_status") || return 2
    deps=$(printf '%s' "$dependency_status" | jq -r '.dependencies[].sha')

    # Informational: a blocked structural (breakdown) ancestor makes the
    # task un-pickable in `frontier`/`claim` even when its dependency
    # parents are all met. Surface it here so `deps` and `frontier` never
    # appear to disagree. NOTE: this is reported, not folded into
    # `allMet`/the --check-complete exit code, because cmd_complete gates
    # completion of an already-active task on `deps --check-complete`, and
    # a parent blocked mid-flight must not strand an in-progress child.
    local blocking_ancestor blocked_ancestor_json
    blocking_ancestor=$(blocked_structural_ancestor "$sha" || true)
    # json_str_or_null: escaped JSON string for a real ancestor sha, bare
    # `null` when there is none — replacing the old raw `"$blocking_ancestor"`
    # interpolation. (Keeps the surrounding spaced/multiline object as-is;
    # only this value is hardened.)
    blocked_ancestor_json=$(json_str_or_null "$blocking_ancestor")

    if [ -z "$deps" ]; then
        if [ "$json" = true ]; then
            echo "{\"dependencies\": [], \"allMet\": true, \"blockedAncestor\": $blocked_ancestor_json}"
        else
            echo "No dependencies"
            if [ -n "$blocking_ancestor" ]; then
                if is_human_comment_task "$sha"; then
                    printf "${RED}⚠${RESET} structural ancestor %s is BLOCKED (human comment remains claimable)\n" "$(git rev-parse --short "$blocking_ancestor")"
                else
                    printf "${RED}⚠${RESET} structural ancestor %s is BLOCKED (task not pickable until unblocked)\n" "$(git rev-parse --short "$blocking_ancestor")"
                fi
            fi
        fi
        return 0
    fi
    
    local all_met
    all_met=$(printf '%s' "$dependency_status" | jq -r '.ready')
    
    if [ "$json" = true ]; then
        echo "{"
        echo "  \"dependencies\": ["
    fi
    
    local first=true
    while read -r dep; do
        local dep_title=$(get_task_title "$dep" 2>/dev/null || echo "Unknown")
        local dep_short=$(git rev-parse --short "$dep")
        local completed
        completed=$(printf '%s' "$dependency_status" | jq -r --arg dep "$dep" \
            '.dependencies[] | select(.sha == $dep) | .completed')
        
        if [ "$json" = true ]; then
            [ "$first" = false ] && echo ","
            cat <<JSON
    {
        "sha": $(json_escape "$dep"),
        "shortSha": $(json_escape "$dep_short"),
        "title": $(json_escape "$dep_title"),
        "completed": $completed
    }
JSON
            first=false
        else
            if [ "$completed" = "true" ]; then
                printf "${GREEN}✓${RESET} %s - %s\n" "$dep_short" "$dep_title"
            else
                printf "${RED}✗${RESET} %s - %s (PENDING)\n" "$dep_short" "$dep_title"
            fi
        fi
    done <<< "$deps"
    
    if [ "$json" = true ]; then
        echo "  ],"
        echo "  \"allMet\": $all_met,"
        echo "  \"blockedAncestor\": $blocked_ancestor_json"
        echo "}"
    elif [ -n "$blocking_ancestor" ]; then
        if is_human_comment_task "$sha"; then
            printf "${RED}⚠${RESET} structural ancestor %s is BLOCKED (human comment remains claimable)\n" "$(git rev-parse --short "$blocking_ancestor")"
        else
            printf "${RED}⚠${RESET} structural ancestor %s is BLOCKED (task not pickable until unblocked)\n" "$(git rev-parse --short "$blocking_ancestor")"
        fi
    fi
    
    if [ "$check_complete" = true ] && [ "$all_met" = false ]; then
        return 2
    fi
    
    return 0
}

# Command: dag - show task DAG hierarchy
cmd_dag() {
    local json=false
    local depth=-1
    local do_fetch=true
    local sha=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            --depth=*) depth="${1#*=}"; shift ;;
            --no-fetch) do_fetch=false; shift ;;
            --help|-h)
                echo "Usage: task-dag dag <ref> [--json] [--depth=N] [--no-fetch]"
                return 0
                ;;
            *)
                if [ -z "$sha" ]; then
                    sha="$1"
                else
                    echo "Unknown option: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done
    
    if [ -z "$sha" ]; then
        echo "Error: ref/SHA required" >&2
        return 1
    fi
    
    # Fetch BEFORE resolve (fetch → resolve_sha ordering) so both the task
    # object and the refs/heads/tasks/ tips the graph walk decorates are
    # present. --no-fetch skips the network round-trip.
    if [ "$do_fetch" = true ]; then
        fetch_task_refs
    fi
    
    sha=$(resolve_sha "$sha") || return 1
    
    if [ "$json" = true ]; then
        echo "Not yet implemented: JSON output for dag command" >&2
        return 1
    fi
    
    # Use git log with custom format to show the DAG
    printf "${BOLD}Task DAG for: ${RESET}%s\n\n" "$(get_task_title "$sha")"
    
    # Show the task and all its descendants via git log
    git log --graph --oneline --decorate --all --ancestry-path "$sha"..refs/heads/tasks/ 2>/dev/null | head -50 || true
    
    echo ""
    printf "${BOLD}Task Details:${RESET}\n"
    cmd_show "$sha"
}

# Command: context - one blessed "read my assigned task" command (design §3
# Layer B). Guarantees the task object is present (fetch-then-verify), then
# prints the task body + DAG neighbourhood + suggested next commands so an
# agent in a prepared/single-branch workspace never hand-rolls `git fetch`
# just to inspect its own task.
#
#   task-dag context <sha> [--ref refs/heads/tasks/<ns>/<short>] [--no-fetch]
#
# With --ref it fetches EXACTLY that ref (validated/normalized) into the local
# refs/heads/tasks/* namespace, falling back once to the canonical task
# namespaces if the exact-ref fetch fails; without --ref it fetches the
# canonical namespaces. Remote stays authoritative — the fetched local refs
# are an inspection cache only (design §2). Live frontier / dependency-
# completion / blocked state must still be read via the fetch-first commands.
cmd_context() {
    local ref=""
    local do_fetch=true
    local sha=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ref=*) ref="${1#*=}"; shift ;;
            --ref)
                if [ $# -lt 2 ]; then
                    echo "Error: --ref requires a value" >&2
                    return 1
                fi
                ref="$2"; shift 2 ;;
            --no-fetch) do_fetch=false; shift ;;
            --help|-h)
                echo "Usage: task-dag context <sha> [--ref refs/heads/tasks/<ns>/<short>] [--no-fetch]"
                echo "  Fetch-then-show the assigned task: body, kind/ref, epic + dependency"
                echo "  parents, related local refs, and suggested next commands."
                return 0
                ;;
            *)
                if [ -z "$sha" ]; then
                    sha="$1"
                else
                    echo "Unknown option: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    if [ -z "$sha" ]; then
        echo "Error: SHA required" >&2
        return 1
    fi

    # 1. Fetch (fetch → verify → resolve ordering). Exact ref if given, else
    #    the canonical namespaces; a failed exact-ref fetch falls back once.
    if [ "$do_fetch" = true ]; then
        if [ -n "$ref" ]; then
            local norm
            if ! norm=$(normalize_task_ref "$ref"); then
                echo "Error: invalid --ref '$ref'" >&2
                echo "  Expected 'tasks/<ns>/<short>' or 'refs/heads/tasks/<ns>/<short>'." >&2
                return 1
            fi
            if ! fetch_task_ref_exact "$norm" 2>/dev/null; then
                # Exact ref unavailable (moved/deleted/renamed) — fall back
                # once to the canonical namespaces before giving up.
                fetch_task_refs
            fi
        else
            fetch_task_refs
        fi
    fi

    # 2. Verify the object is actually present now (design §3 Layer B step 2).
    if ! git cat-file -e "${sha}^{commit}" 2>/dev/null; then
        echo "Error: task object '$sha' is not present after fetch." >&2
        if [ -z "$ref" ]; then
            echo "  If you know the ref, retry: task-dag context $sha --ref refs/heads/tasks/<ns>/<short>" >&2
        fi
        echo "  (The commit may have been completed/dropped, or the SHA is wrong.)" >&2
        return 1
    fi

    # 3. Resolve + gather details.
    sha=$(resolve_sha "$sha") || return 1
    local consumer_args=(--tip HEAD) task_status
    [ "$do_fetch" = false ] && consumer_args+=(--no-fetch)
    taskdag_consumer_prepare context "${consumer_args[@]}" || return 2
    task_status=$(taskdag_task_status_json "task:${TASKDAG_RECON_CUR}@${sha}" --include-claimed) || return 2
    local short; short=$(git rev-parse --short "$sha")
    local msg; msg=$(parse_commit_metadata "$sha")
    local title; title=$(get_task_title "$sha")
    local body; body=$(git log -1 --format='%b' "$sha")
    local issue; issue=$(extract_field "$msg" "Issue")
    local author; author=$(extract_field "$msg" "Author")
    local status; status=$(extract_field "$msg" "Status")
    local type; type=$(extract_field "$msg" "Type")
    local parent_task; parent_task=$(extract_field "$msg" "Parent-Task")
    local first_parent; first_parent=$(get_first_parent "$sha")
    local deps; deps=$(jq -r '.requirements[].node' <<<"$task_status")
    # Local refs pointing at this task (the "related local refs" surface).
    local refs; refs=$(git for-each-ref --format='%(refname:short)' --points-at "$sha" | grep '^tasks/' || true)

    printf "${BOLD}Task: ${RESET}%s\n" "$title"
    printf "${BOLD}SHA:${RESET}   %s\n" "$sha"
    printf "${BOLD}Short:${RESET} %s\n" "$short"
    [ -n "$issue" ]  && printf "${BOLD}Issue:${RESET}  %s\n" "$issue"
    [ -n "$author" ] && printf "${BOLD}Author:${RESET} %s\n" "$author"
    printf "${BOLD}Status:${RESET} %s\n" "${status:-pending}"
    printf "${BOLD}Kind:${RESET}   %s\n" "${type:-task}"

    if [ -n "$refs" ]; then
        printf "${BOLD}Related local refs:${RESET}\n"
        echo "$refs" | while read -r r; do echo "  - $r"; done
    fi

    # Epic / breakdown parent (first parent) — the structural parent.
    local epic_parent="${parent_task:-$first_parent}"
    if [ -n "$epic_parent" ]; then
        local ep_title ep_short
        ep_title=$(get_task_title "$epic_parent" 2>/dev/null || echo "(not present locally)")
        ep_short=$(git rev-parse --short "$epic_parent" 2>/dev/null || echo "$epic_parent")
        printf "${BOLD}Epic/breakdown parent:${RESET} %s - %s\n" "$ep_short" "$ep_title"
    fi

    # Dependency parents (2nd+) with completion state.
    if [ -n "$deps" ]; then
        printf "${BOLD}Dependencies:${RESET}\n"
        echo "$deps" | while read -r dep; do
            [ -z "$dep" ] && continue
            local dep_title dep_short dep_ref
            dep_ref=${dep##*@}
            dep_title=$(get_task_title "$dep_ref" 2>/dev/null || echo "$dep")
            dep_short=$(git rev-parse --short "$dep_ref" 2>/dev/null || echo "$dep")
            if jq -e --arg n "$dep" '.requirements[]|select(.node==$n and .complete)' <<<"$task_status" >/dev/null; then
                printf "  ${GREEN}✓${RESET} %s - %s\n" "$dep_short" "$dep_title"
            else
                printf "  ${RED}✗${RESET} %s - %s\n" "$dep_short" "$dep_title"
            fi
        done
    fi

    if [ "$(jq -r .complete <<<"$task_status")" = true ]; then
        printf "${GREEN}✓ Task completed${RESET}\n"
    else
        printf "${YELLOW}○ Task pending${RESET}\n"
    fi

    if [ -n "$body" ]; then
        printf "\n${BOLD}── Task body ──${RESET}\n%s\n" "$body"
    fi

    printf "\n${BOLD}Suggested next commands:${RESET}\n"
    printf "  task-dag deps %s        # check dependency readiness (fetches fresh)\n" "$short"
    printf "  task-dag dag %s         # view the DAG neighbourhood\n" "$short"
    printf "  task-dag complete %s    # after committing your implementation\n" "$short"
    printf "  task-dag block %s --reason=\"…\"  # if stalled awaiting a decision/dependency\n" "$short"
    printf "\n${BOLD}Note:${RESET} the assigned task commit is immutable — 'git show %s' now works\n" "$short"
    printf "for body inspection. Live frontier / dependency / blocked state is\n"
    printf "authoritative on origin; always read it via the task-dag commands above.\n"
}

# Command: breakdown - create task breakdown from spec
cmd_breakdown() {
    local parent_sha="" spec_file="" stdin_json=false dry_run=false force=false json=false claim_first=false

    # Claimer identity for any child marked "claim": true in the spec. A
    # self-claimed child is created already-claimed by THIS worker (its
    # tasks/active/<short> ref is published in the same atomic push, and it
    # never gets a pickable tasks/frontier/<short> ref) so no other worker
    # can ever take it — a zero-race-window handoff from "decompose" to
    # "implement it myself". These mirror cmd_claim's env contract so the
    # born-claimed child is attributed to, and later completable by, the
    # same worker. See the "claim" field in --help.
    local claimer="${TASK_DAG_CLAIMER:-${USER:-unknown}}"
    local claimer_host="${TASK_DAG_CLAIMER_HOST:-$(hostname -s 2>/dev/null || echo unknown)}"
    local claimer_ttl_hours="${TASK_DAG_TTL_HOURS:-12}"
    local claimer_pid="${TASK_DAG_CLAIMER_PID:-$PPID}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --spec-file=*) spec_file="${1#*=}"; shift ;;
            --stdin-json) stdin_json=true; shift ;;
            --dry-run) dry_run=true; shift ;;
            --force) force=true; shift ;;
            --json) json=true; shift ;;
            --claim-first) claim_first=true; shift ;;
            --help|-h)
                cat <<'EOF'
Usage: task-dag breakdown <parent-sha> [--spec-file=PATH | --stdin-json]
                         [--dry-run] [--force] [--json] [--claim-first]

Create subtasks (children) of <parent-sha> from a JSON spec, publishing a
tasks/frontier/<short> ref for each so the frontier/claim/complete flow can
pick them up. Each child inherits the parent's Issue:/URL:/Author: metadata.

If <parent-sha> is the pending epic ROOT for an issue, you MUST hold the
orchestration lock first ('task-dag claim-root <issue>'); breakdown then
CONSUMES that lock (deletes tasks/root-active/<issue>) in the SAME atomic
push that publishes the leaves, so two hosts can't decompose one issue and
no root worker can keep acting once leaves exist. --force does NOT bypass
this lock (it only permits a second breakdown despite existing children).

If <parent-sha> is a NON-root task you currently hold a claim on
(tasks/active/<short> owned by your TASK_DAG_CLAIMER identity), breakdown
CONSUMES that active claim in the SAME atomic push that publishes the
children — exactly mirroring root-lock consumption. This lets a worker that
self-continued into a claimed child and then decides to decompose it hand
off cleanly: the parent stops being a claimed leaf the instant its children
exist, so a post-agent claim sweep can't block the (now structural) parent
and transitively stall its children. A FOREIGN active claim on the parent
makes breakdown REFUSE (re-`claim --force` first only if that holder is
dead); an indeterminate origin read also refuses (fail closed).

The DAG is encoded in the git parents of each child commit:
  * first parent  = <parent-sha>            (the breakdown/epic parent)
  * 2nd+ parents  = the child's dependencies (it is "ready" only once all
                    of them are completed, mirroring `deps`/`frontier`)

Spec format (a non-empty JSON array, authored in dependency order):
[
  {
    "title": "Task title",            (required, non-empty, single line)
    "description": "Longer body",     (optional string)
    "dependencies": ["@1", "..."],    (optional; see below)
    "type": "epic|task|leaf",         (optional; default "leaf")
    "status": "pending",              (optional; only "pending" is valid)
    "claim": true                     (optional bool; default false)
  }
]

"claim": true creates that child ALREADY CLAIMED by the caller — its
tasks/active/<short> ref (a claim commit) is published in the same atomic
push and it never gets a pickable tasks/frontier/<short> ref. No other
worker can ever take it (zero race window), so an epic-root worker can
decompose an issue and reserve, in one atomic step, the child(ren) it
will implement itself; it then does the work and `task-dag complete`s
each claimed child. Unmarked children are normal frontier leaves for the
fleet. The claim is attributed to the same identity `claim` would use
(TASK_DAG_CLAIMER / TASK_DAG_CLAIMER_HOST / TASK_DAG_CLAIMER_PID /
TASK_DAG_TTL_HOURS), so the same worker can later complete it and a
janitor can detect it if the worker dies.

Each "dependencies" entry must be a non-empty string, one of:
  * "@N"         — 1-based index of an EARLIER sibling in this same spec
  * "<title>"    — exact title of an EARLIER sibling in this same spec
  * "<sha|ref>"  — any already-existing, resolvable commit/ref

Dependencies must resolve to siblings declared earlier in the array (git
commit parents are immutable, so a child is created after its deps) or to
pre-existing commits; forward/self sibling references are rejected.

Options:
  --spec-file=PATH  read the JSON spec from PATH
  --stdin-json      read the JSON spec from stdin
  --dry-run         validate + print the plan; create/push nothing
  --force           proceed even if <parent-sha> already has live child
                    task refs (otherwise breakdown refuses, to avoid
                    accidentally double-decomposing an epic)
  --json            machine-readable output (each task carries its sha,
                    shortSha, claimed flag, and published ref so a caller
                    can switch to a born-claimed child deterministically)
  --claim-first     born-claim EXACTLY the topologically-first child that has
                    no unmet dependency (the first entry whose dependencies
                    are all empty or already-completed external commits), so
                    a decomposing worker can continue straight into it in the
                    same session. Mutually exclusive with a per-child "claim"
                    in the spec (use one or the other, unambiguously). If NO
                    child is dependency-ready, breakdown ERRORS before any
                    mutation — a breakdown with nothing to continue into is a
                    genuine dependency block, not a silent no-op.

Commits are created locally first and published with a single atomic,
create-only `git push`; if the push fails nothing is left on origin.
Reverse a breakdown by dropping the children (e.g. `task-dag drop <sha>`).
EOF
                return 0
                ;;
            -*)
                echo "Unknown option: $1" >&2
                return 1
                ;;
            *)
                if [ -z "$parent_sha" ]; then
                    parent_sha="$1"
                else
                    echo "Unknown argument: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    if [ -z "$parent_sha" ]; then
        echo "Error: parent SHA required" >&2
        return 1
    fi
    if [ "$stdin_json" = true ] && [ -n "$spec_file" ]; then
        echo "Error: use only one of --spec-file / --stdin-json" >&2
        return 1
    fi
    if ! command -v jq >/dev/null 2>&1; then
        echo "Error: 'jq' is required for breakdown but was not found on PATH" >&2
        return 1
    fi

    parent_sha=$(resolve_sha "$parent_sha") || return 1

    # ── read the spec ────────────────────────────────────────────────
    local spec_json
    if [ "$stdin_json" = true ]; then
        spec_json=$(cat)
    elif [ -n "$spec_file" ]; then
        if [ ! -f "$spec_file" ]; then
            echo "Error: spec file not found: $spec_file" >&2
            return 1
        fi
        spec_json=$(cat "$spec_file")
    else
        echo "Error: provide --spec-file=PATH or --stdin-json (see --help)" >&2
        return 1
    fi

    # ── full schema validation BEFORE any mutation ───────────────────
    # (type/shape of every field; title single-line & non-empty; deps are
    #  non-empty strings; type is a known enum; status, if present, pending)
    if ! printf '%s' "$spec_json" | jq -e '
        type == "array" and length > 0 and all(.[];
            type == "object"
            and has("title") and (.title | type == "string")
                and (.title | length > 0) and (.title | test("[\r\n]") | not)
            and ((has("description") | not) or (.description == null)
                 or (.description | type == "string"))
            and ((has("type") | not)
                 or (.type == "epic" or .type == "task" or .type == "leaf"))
            and ((has("status") | not) or (.status == "pending"))
            and ((has("claim") | not) or (.claim | type == "boolean"))
            and ((has("dependencies") | not)
                 or ((.dependencies | type == "array")
                     and all(.dependencies[]; type == "string" and length > 0)))
        )' >/dev/null 2>&1; then
        echo "Error: invalid spec. Each entry needs a non-empty single-line" >&2
        echo "       'title'; optional 'description' (string), 'type'" >&2
        echo "       (epic|task|leaf), 'status' (pending), 'claim' (bool)," >&2
        echo "       and 'dependencies' (array of non-empty strings). See --help." >&2
        return 1
    fi

    # ── inherit issue / url / author from the parent task commit ─────
    local parent_msg issue_num issue_url author parent_title
    parent_msg=$(parse_commit_metadata "$parent_sha")
    issue_num=$(extract_field "$parent_msg" "Issue" || true)
    issue_url=$(extract_field "$parent_msg" "URL" || true)
    author=$(extract_field "$parent_msg" "Author" || true)
    parent_title=$(get_task_title "$parent_sha")

    local count
    count=$(printf '%s' "$spec_json" | jq 'length')

    # ── pass 1: collect fields + full title→index map (detect dup titles) ──
    local -a titles=() types=() statuses=() descs=() claims=() dep_plans=() out_lines=()
    local -A title_to_idx=()
    local i
    for (( i=0; i<count; i++ )); do
        local title
        title=$(printf '%s' "$spec_json" | jq -r ".[$i].title")
        if [ -n "${title_to_idx[$title]+set}" ]; then
            echo "Error: duplicate sibling title '$title' (siblings are referenced by title)" >&2
            return 1
        fi
        title_to_idx[$title]=$i
        titles[i]="$title"
        types[i]=$(printf '%s' "$spec_json" | jq -r ".[$i].type // \"leaf\"")
        statuses[i]=$(printf '%s' "$spec_json" | jq -r ".[$i].status // \"pending\"")
        descs[i]=$(printf '%s' "$spec_json" | jq -r ".[$i].description // \"\"")
        claims[i]=$(printf '%s' "$spec_json" | jq -r ".[$i].claim // false")
    done

    # ── pass 2: structurally validate every dependency (still no mutation) ──
    # dep_plans[i] is a space-separated list of tokens "idx:<n>" (an earlier
    # sibling, resolved to its sha after creation) or "sha:<full>" (external).
    for (( i=0; i<count; i++ )); do
        local ndeps j depref plan="" disp=""
        ndeps=$(printf '%s' "$spec_json" | jq ".[$i].dependencies // [] | length")
        for (( j=0; j<ndeps; j++ )); do
            depref=$(printf '%s' "$spec_json" | jq -r ".[$i].dependencies[$j]")
            if [[ "$depref" =~ ^@([0-9]+)$ ]]; then
                local idx="${BASH_REMATCH[1]}"
                if (( idx < 1 || idx > i )); then
                    echo "Error: entry $((i+1)) dependency '@$idx' must reference an" >&2
                    echo "       earlier sibling (valid range here: @1..@$i)" >&2
                    return 1
                fi
                plan+=" idx:$((idx-1))"
                disp+="${disp:+,}@$idx"
            elif [ -n "${title_to_idx[$depref]+set}" ]; then
                local sib="${title_to_idx[$depref]}"
                if (( sib >= i )); then
                    echo "Error: entry $((i+1)) dependency '$depref' refers to a sibling" >&2
                    echo "       that is not declared earlier; reorder so deps come first" >&2
                    return 1
                fi
                plan+=" idx:$sib"
                disp+="${disp:+,}$depref"
            else
                local dep_full
                dep_full=$(git rev-parse --verify "${depref}^{commit}" 2>/dev/null) || {
                    echo "Error: entry $((i+1)) dependency '$depref' is not '@N', an earlier" >&2
                    echo "       sibling title, or a resolvable commit/ref" >&2
                    return 1
                }
                plan+=" sha:$dep_full"
                disp+="${disp:+,}${dep_full:0:12}"
            fi
        done
        dep_plans[i]="$plan"
        local deps_str=""
        [ -n "$disp" ] && deps_str=" deps=[$disp]"
        local claim_disp=""
        [ "${claims[i]}" = true ] && claim_disp=" (claimed by ${claimer})"
        out_lines[i]="[${types[i]}] ${titles[i]}${deps_str}${claim_disp}"
    done

    # ── --claim-first: born-claim the topologically-first ready child ─
    # A decomposing worker uses this to continue straight into the first
    # child with no unmet dependency, in the SAME session, instead of
    # stopping after the breakdown (the self-continue-after-breakdown
    # contract). It is mutually exclusive with a per-child "claim":true in the
    # spec (one unambiguous claim source), and it ERRORS *before any mutation*
    # if no child is dependency-ready — a breakdown with nothing to continue
    # into is a genuine dependency block, not a silent no-op. Readiness is
    # evaluated from the dependency PLAN (children don't exist yet): a sibling
    # dependency (idx:) is never satisfied at birth; an external (sha:)
    # dependency counts only if that commit is already a completed task.
    if [ "$claim_first" = true ]; then
        taskdag_consumer_prepare breakdown-claim-first --tip HEAD || return 2
        local ci any_spec_claim=false
        for (( ci=0; ci<count; ci++ )); do
            [ "${claims[ci]}" = true ] && any_spec_claim=true
        done
        if [ "$any_spec_claim" = true ]; then
            echo "Error: --claim-first is mutually exclusive with a per-child claim flag" >&2
            echo "       set in the spec. Use exactly one claim source." >&2
            return 1
        fi
        local first_ready=-1
        for (( ci=0; ci<count; ci++ )); do
            local ready=true token
            for token in ${dep_plans[ci]}; do
                case "$token" in
                    idx:*) ready=false; break ;;
                    sha:*) taskdag_node_complete "task:${TASKDAG_RECON_CUR}@${token#sha:}" || { ready=false; break; } ;;
                esac
            done
            if [ "$ready" = true ]; then first_ready=$ci; break; fi
        done
        if [ "$first_ready" -lt 0 ]; then
            echo "Error: --claim-first found no dependency-ready child to claim (every child" >&2
            echo "       depends on a sibling or an uncompleted task). Author a breakdown with" >&2
            echo "       at least one ready leaf, or treat this as a genuine dependency block." >&2
            return 1
        fi
        claims[first_ready]=true
        # out_lines were built in pass 2 with the pre-claim-first flags.
        out_lines[first_ready]="${out_lines[first_ready]} (claimed by ${claimer})"
    fi

    # ── epic-root orchestration lock (issue #2) ─────────────────────
    # If <parent> is the pending epic ROOT, decomposing it is the
    # orchestration step that the cross-host root lock protects. Require
    # the caller to hold tasks/root-active/<N> and CONSUME it in the same
    # atomic push that publishes the leaves (below), so there is never a
    # window where the leaves exist but the root lock still lets someone
    # "implement the root". --force does NOT bypass this (force only ever
    # meant "allow a second breakdown despite existing children").
    local is_root_breakdown=false root_issue="" root_active_ref="" root_claim_sha=""
    # Non-root recursive breakdown: the parent's OWNED active claim (if any),
    # consumed in the same atomic push as the children (§1e / issue #53).
    local parent_active_ref="" parent_active_sha=""
    if [ "$dry_run" = false ]; then
        # Determine whether <parent> is the pending epic root, FAILING
        # CLOSED on an indeterminate origin lookup: if we cannot tell, we
        # must not silently decompose a root without its lock. (We are
        # about to push to origin anyway, so requiring origin here is fine.)
        local parent_issue parent_pending parent_type rc
        local parent_meta; parent_meta=$(parse_commit_metadata "$parent_sha")
        parent_issue=$(extract_field "$parent_meta" "Issue" 2>/dev/null | sed 's/^#//' || true)
        parent_type=$(extract_field "$parent_meta" "Type" 2>/dev/null || true)
        # Distinguish a top-level epic ROOT from a child/intermediate epic.
        # A root (from create-task-commit.sh) is parented on real repository
        # history; a breakdown-created child epic is parented on another
        # empty-tree TASK commit. Only a root-shaped epic is gated on the
        # orchestration lock — child epics inherit Issue:/Type:epic but their
        # pending/<N> points at the top-level root, not at them, and they
        # decompose freely like any other intermediate task.
        local parent_is_root_shaped=true parent_first
        parent_first=$(get_first_parent "$parent_sha" 2>/dev/null || true)
        if [ -n "$parent_first" ] && is_task_commit "$parent_first"; then
            parent_is_root_shaped=false
        fi
        if [ -n "$parent_issue" ]; then
            parent_pending=$(pending_sha_on_remote_checked "$parent_issue"); rc=$?
            if [ "$rc" = 3 ] && [ "$parent_is_root_shaped" = true ]; then
                echo "Error: cannot verify whether ${parent_sha:0:12} is the epic root for" >&2
                echo "       issue #${parent_issue} (origin unreachable). Refusing to decompose" >&2
                echo "       without confirming the orchestration lock. Retry when online." >&2
                return 4
            fi
            if [ "$rc" = 0 ] && [ "$parent_pending" = "$parent_sha" ]; then
                is_root_breakdown=true
                root_issue="$parent_issue"
            elif [ "$parent_type" = epic ] && [ "$parent_is_root_shaped" = true ]; then
                # The parent IS a top-level epic root (Type: epic, parented
                # on real history) but origin's pending/<N> is either gone
                # (epic closed/unknown, rc 2) or points at a DIFFERENT commit
                # (this root SHA is stale — the issue was re-synced into a
                # newer root). Either way we must NOT fall through to an
                # unlocked "normal" breakdown, which would publish leaves
                # with no root lock held/consumed and resurrect work on a
                # closed/stale root. FAIL CLOSED.
                echo "Error: ${parent_sha:0:12} is an epic root for issue #${parent_issue}, but its" >&2
                if [ "$rc" = 2 ]; then
                    echo "       tasks/pending/${parent_issue} identity is gone on origin (closed/unknown" >&2
                    echo "       issue). Refusing to decompose a retired epic root." >&2
                else
                    echo "       tasks/pending/${parent_issue} now points at ${parent_pending:0:12}, not this root." >&2
                    echo "       Decompose the current root instead of this stale one." >&2
                fi
                return 3
            fi
        fi

        if [ "$is_root_breakdown" = true ]; then
            root_active_ref="refs/heads/tasks/root-active/$root_issue"
            root_claim_sha=$(root_active_sha_on_remote "$root_issue")
            if [ -z "$root_claim_sha" ]; then
                echo "Error: epic root #${root_issue} is not claimed for orchestration." >&2
                echo "       Run 'task-dag claim-root ${root_issue}' before decomposing it" >&2
                echo "       so two hosts cannot decompose the same issue." >&2
                return 1
            fi
            # The held lock must reference THIS root commit AND be owned by
            # the current worker (mirrors leaf `complete` ownership). To
            # take over a foreign/dead lock, re-`claim-root --force` first;
            # `breakdown --force` does NOT steal another worker's lock.
            #
            # FAIL CLOSED throughout: we are about to consume the lock in an
            # atomic push, so we must POSITIVELY confirm ownership first. A
            # fetch failure, an unreadable claim commit, or a claim commit
            # missing its identity fields all refuse — never fall through to
            # the push, which only asserts the lock SHA is unchanged (not
            # that WE hold it) and would otherwise let us consume a foreign
            # lock.
            local rtmp="refs/task-dag-tmp/breakdown-root/$root_issue"
            git update-ref -d "$rtmp" 2>/dev/null || true
            if ! git fetch --quiet --no-tags origin \
                    "+$root_active_ref:$rtmp" 2>/dev/null; then
                echo "Error: cannot read orchestration lock for #${root_issue} (origin" >&2
                echo "       unreachable) — refusing to decompose. Retry when online." >&2
                return 4
            fi
            local fetched_claim_sha
            fetched_claim_sha=$(git rev-parse --verify -q "$rtmp" 2>/dev/null || true)
            if [ -z "$fetched_claim_sha" ] || [ "$fetched_claim_sha" != "$root_claim_sha" ]; then
                git update-ref -d "$rtmp" 2>/dev/null || true
                echo "Error: orchestration lock #${root_issue} changed while verifying" >&2
                echo "       ownership — re-run 'task-dag claim-root ${root_issue}' and retry." >&2
                return 2
            fi
            local rmsg rtask rclaimer rhost me_claimer me_host
            rmsg=$(parse_commit_metadata "$rtmp" 2>/dev/null || true)
            rtask=$(extract_field "$rmsg" "Task-Commit" 2>/dev/null || true)
            rclaimer=$(extract_field "$rmsg" "Claimer" 2>/dev/null || true)
            rhost=$(extract_field "$rmsg" "Claimer-Host" 2>/dev/null || true)
            git update-ref -d "$rtmp" 2>/dev/null || true
            me_claimer="${TASK_DAG_CLAIMER:-${USER:-unknown}}"
            me_host="${TASK_DAG_CLAIMER_HOST:-$(hostname -s 2>/dev/null || echo unknown)}"
            if [ -z "$rtask" ] || [ -z "$rclaimer" ] || [ -z "$rhost" ]; then
                echo "Error: orchestration lock #${root_issue} is malformed (missing owner/" >&2
                echo "       root fields) — refusing to decompose. Re-claim it with" >&2
                echo "       'task-dag claim-root ${root_issue} --force' and retry." >&2
                return 1
            fi
            if [ "$rtask" != "$parent_sha" ]; then
                echo "Error: tasks/root-active/${root_issue} references ${rtask}, not this root ${parent_sha}." >&2
                return 1
            fi
            if [ "$rclaimer" != "$me_claimer" ] || [ "$rhost" != "$me_host" ]; then
                echo "Error: orchestration lock #${root_issue} is held by ${rclaimer}@${rhost}, not you (${me_claimer}@${me_host})." >&2
                echo "       Re-run 'task-dag claim-root ${root_issue} --force' to take it over (only if that holder is dead)." >&2
                return 1
            fi
        fi
    fi

    # ── recursive (non-root) breakdown: verify + consume the parent's OWNED
    #    active claim (§1e / issue #53) ────────────────────────────────
    # A worker that self-continued into a claimed child and now decomposes it
    # must not exit still owning tasks/active/<parent-short>: the post-agent
    # claim sweep would block that (now structural) parent and transitively
    # stall its children. So if the parent carries an active claim OWNED by us,
    # we consume it in the SAME atomic push that publishes the children (below),
    # exactly mirroring root-lock consumption. FAIL CLOSED on an indeterminate
    # origin read; REFUSE a foreign claim (never silently strand/steal it).
    if [ "$dry_run" = false ] && [ "$is_root_breakdown" = false ]; then
        local parent_short2; parent_short2=$(git rev-parse --short "$parent_sha")
        local pa_ref="refs/heads/tasks/active/$parent_short2"
        local pa_sha="" pa_rc=0
        pa_sha=$(remote_ref_sha_checked "$pa_ref") || pa_rc=$?
        if [ "$pa_rc" = 3 ]; then
            echo "Error: cannot read tasks/active/$parent_short2 on origin (indeterminate" >&2
            echo "       transport/auth error). Refusing to decompose without knowing whether" >&2
            echo "       this parent carries a claim to consume. Retry when origin is reachable." >&2
            return 4
        fi
        if [ -n "$pa_sha" ]; then
            # Positively confirm WE own the claim before consuming it (mirror
            # the root block): fetch the claim commit and check its identity.
            local patmp="refs/task-dag-tmp/breakdown-active/$parent_short2"
            git update-ref -d "$patmp" 2>/dev/null || true
            if ! git fetch --quiet --no-tags origin "+$pa_ref:$patmp" 2>/dev/null; then
                echo "Error: cannot read the active claim on ${parent_sha:0:12} (origin" >&2
                echo "       unreachable) — refusing to decompose. Retry when online." >&2
                return 4
            fi
            local pa_fetched; pa_fetched=$(git rev-parse --verify -q "$patmp" 2>/dev/null || true)
            if [ -z "$pa_fetched" ] || [ "$pa_fetched" != "$pa_sha" ]; then
                git update-ref -d "$patmp" 2>/dev/null || true
                echo "Error: the active claim on ${parent_sha:0:12} changed while verifying" >&2
                echo "       ownership — retry." >&2
                return 2
            fi
            local pmsg ptask pclaimer phost pfirst me_c me_h
            pmsg=$(parse_commit_metadata "$patmp" 2>/dev/null || true)
            ptask=$(extract_field "$pmsg" "Task-Commit" 2>/dev/null || true)
            pclaimer=$(extract_field "$pmsg" "Claimer" 2>/dev/null || true)
            phost=$(extract_field "$pmsg" "Claimer-Host" 2>/dev/null || true)
            pfirst=$(get_first_parent "$patmp" 2>/dev/null || true)
            git update-ref -d "$patmp" 2>/dev/null || true
            me_c="${TASK_DAG_CLAIMER:-${USER:-unknown}}"
            me_h="${TASK_DAG_CLAIMER_HOST:-$(hostname -s 2>/dev/null || echo unknown)}"
            # Guard short-sha collision / malformed claim: it must reference
            # THIS parent (by Task-Commit or by first parent).
            if [ "$ptask" != "$parent_sha" ] && [ "$pfirst" != "$parent_sha" ]; then
                echo "Error: tasks/active/$parent_short2 does not reference ${parent_sha:0:12}" >&2
                echo "       (short-sha collision or malformed claim) — refusing to decompose." >&2
                return 1
            fi
            if [ -z "$pclaimer" ] || [ -z "$phost" ]; then
                echo "Error: the active claim on ${parent_sha:0:12} is malformed (missing owner" >&2
                echo "       fields) — refusing to decompose. Re-claim it and retry." >&2
                return 1
            fi
            if [ "$pclaimer" != "$me_c" ] || [ "$phost" != "$me_h" ]; then
                echo "Error: ${parent_sha:0:12} is claimed by ${pclaimer}@${phost}, not you" >&2
                echo "       (${me_c}@${me_h}). Refusing to decompose (would strand a foreign" >&2
                echo "       claim). Re-run 'task-dag claim ${parent_short2} --force' only if that" >&2
                echo "       holder is dead." >&2
                return 1
            fi
            parent_active_ref="$pa_ref"
            parent_active_sha="$pa_sha"
        fi
    fi

    # ── guard: refuse to double-decompose unless --force (skip in dry-run) ─
    if [ "$force" = false ] && [ "$dry_run" = false ]; then
        # Sync remote task refs (and delegated children for this issue) so
        # a stale checkout still sees children — including ACTIVE children,
        # which the old first-parent grep missed (an active ref points at a
        # claim commit whose first parent is the child task, not <parent>).
        # FAIL CLOSED if origin is unreadable: a transient failure must not
        # be read as "no children" and let a second breakdown slip through.
        if ! fetch_root_refs "${root_issue:-${issue_num#\#}}"; then
            echo "Error: cannot reach origin to check for an existing breakdown of" >&2
            echo "       ${parent_sha:0:12} — refusing to decompose. Retry when online." >&2
            return 4
        fi
        local existing_child
        existing_child=$(task_has_children "$parent_sha" || true)
        if [ -n "$existing_child" ]; then
            echo "Error: parent ${parent_sha:0:12} ('${parent_title}') already has at" >&2
            echo "       least one live child task (${existing_child:0:12})." >&2
            echo "       Refusing to create a duplicate breakdown. Re-run with --force" >&2
            echo "       if you really mean to add more children." >&2
            return 1
        fi
    fi

    # ── dry-run: report the plan, mutate nothing ─────────────────────
    if [ "$dry_run" = true ]; then
        if [ "$json" = true ]; then
            printf '%s' "$spec_json" | jq --arg parent "$parent_sha" \
                '{ok:true, dryRun:true, parent:$parent, count:length, tasks:.}'
        else
            printf "${BOLD}Breakdown plan (dry-run) for %s — '%s'${RESET}\n" \
                "${parent_sha:0:12}" "$parent_title"
            for (( i=0; i<count; i++ )); do
                echo "  $((i+1)). ${out_lines[i]}"
            done
            echo "(${count} task(s); nothing created)"
        fi
        return 0
    fi

    # ── create the commit objects (no refs yet → nothing to clean up) ─
    # created_shas[i]   = the child task commit
    # claim_commits[i]  = the claim commit for a self-claimed child (else "")
    local -a created_shas=() claim_commits=() refspecs=() lease_args=()
    for (( i=0; i<count; i++ )); do
        local msg_file
        msg_file=$(mktemp)
        {
            printf 'Task: %s\n\n' "${titles[i]}"
            [ -n "$issue_num" ] && printf 'Issue: %s\n' "$issue_num"
            [ -n "$author" ] && printf 'Author: %s\n' "$author"
            [ -n "$issue_url" ] && printf 'URL: %s\n' "$issue_url"
            printf 'Status: %s\n' "${statuses[i]}"
            printf 'Type: %s\n' "${types[i]}"
            if [ -n "${descs[i]}" ]; then
                printf '\n%s\n' "${descs[i]}"
            fi
        } > "$msg_file"

        local -a parent_args=("-p" "$parent_sha")
        local token
        for token in ${dep_plans[i]}; do
            case "$token" in
                idx:*) parent_args+=("-p" "${created_shas[${token#idx:}]}") ;;
                sha:*) parent_args+=("-p" "${token#sha:}") ;;
            esac
        done

        local child_sha
        child_sha=$(git commit-tree "$EMPTY_TREE" "${parent_args[@]}" -F "$msg_file") || {
            rm -f "$msg_file"
            echo "Error: git commit-tree failed for entry $((i+1)) ('${titles[i]}')" >&2
            return 1
        }
        rm -f "$msg_file"

        created_shas[i]="$child_sha"
        local short_sha
        short_sha=$(git rev-parse --short "$child_sha")
        claim_commits[i]=""
        if [ "${claims[i]}" = true ]; then
            # Born-claimed child: publish tasks/active/<short> (a claim
            # commit) instead of a pickable tasks/frontier/<short> ref, in
            # this same atomic push. The child never exists as a claimable
            # frontier ref, so no other worker can race to take it.
            local claim_commit active_ref
            claim_commit=$(build_claim_commit "$child_sha" "$claimer" \
                "$claimer_host" "$claimer_ttl_hours" \
                "born-claimed at breakdown of ${parent_sha:0:12}" "$claimer_pid") || {
                echo "Error: failed to build claim commit for entry $((i+1)) ('${titles[i]}')" >&2
                return 1
            }
            claim_commits[i]="$claim_commit"
            active_ref="refs/heads/tasks/active/$short_sha"
            refspecs+=("$claim_commit:$active_ref")
            lease_args+=("--force-with-lease=$active_ref:")
        else
            local frontier_ref="refs/heads/tasks/frontier/$short_sha"
            refspecs+=("$child_sha:$frontier_ref")
            lease_args+=("--force-with-lease=$frontier_ref:")
        fi
        out_lines[i]="${short_sha}  ${out_lines[i]}"
    done

    # ── for a ROOT breakdown, CONSUME the orchestration lock in the SAME
    #    atomic push that publishes the leaves. The REAL cross-host mutex is
    #    the --force-with-lease on root-active (it must still be at the SHA
    #    we hold): the leaves can only appear if the lock is still ours, and
    #    the lock disappears the instant the leaves exist — closing the
    #    "implement-after-leaves" window. If the lock was stolen/released
    #    meanwhile, the lease fails and NOTHING is created.
    #
    #    The pending lease + no-op refspec is only a BEST-EFFORT CLIENT-SIDE
    #    stale check, NOT a server-side atomic assertion: git skips sending a
    #    ref that is already up to date, so an unchanged pending may never be
    #    transmitted for the server to verify. That is fine here — an
    #    undecomposed root's pending/<N> is never legitimately moved (it is
    #    deleted only on epic close, after root-active is gone), so there is
    #    no real race for it to catch.
    if [ "$is_root_breakdown" = true ]; then
        local pending_ref="refs/heads/tasks/pending/$root_issue"
        lease_args+=("--force-with-lease=$root_active_ref:$root_claim_sha")
        lease_args+=("--force-with-lease=$pending_ref:$parent_sha")
        refspecs+=("$parent_sha:$pending_ref")   # no-op: best-effort pending-unchanged
        refspecs+=(":$root_active_ref")          # consume the lock
    fi

    # ── for a NON-root recursive breakdown of a parent we hold a claim on,
    #    CONSUME that active claim in the SAME atomic push (§1e). The lease at
    #    the exact claim SHA is the cross-host mutex: the children can only
    #    appear if our claim is still there, and it disappears the instant they
    #    exist — so the (now structural) parent is never left as a claimed leaf
    #    the post-agent sweep could block. If the claim was stolen/released
    #    meanwhile, the lease fails and NOTHING is created.
    if [ -n "$parent_active_ref" ]; then
        lease_args+=("--force-with-lease=$parent_active_ref:$parent_active_sha")
        refspecs+=(":$parent_active_ref")        # consume the parent's claim
    fi

    # ── publish all frontier refs atomically ──────────────────────────
    # Canonical epochs serialize this scheduling mutation with graph,
    # block, claim, reap, and completion decisions by advancing the shared
    # activation authority in the same push.
    local push_output push_rc=0 breakdown_updates='[]' spec ref new old lease
    taskdag_consumer_prepare breakdown-pre-push || return 3
    if [ "$TASKDAG_CONSUMER_MODE" = canonical ]; then
        for spec in "${refspecs[@]}"; do
            new=${spec%%:*}; ref=${spec#*:}; old=""
            for lease in "${lease_args[@]}"; do
                case "$lease" in "--force-with-lease=$ref:"*) old=${lease#"--force-with-lease=$ref:"} ;; esac
            done
            breakdown_updates=$(jq -ncS --argjson u "$breakdown_updates" --arg ref "$ref" --arg old "$old" --arg new "$new" \
                '$u+[{ref:$ref,old:$old,new:$new}] | sort_by(.ref)') || return 3
        done
        taskdag_consumer_fenced_scheduling_push breakdown "$claimer" "$breakdown_updates" || push_rc=$?
        push_output="canonical semantic-generation CAS failed"
    else
        push_output=$(git push --atomic "${lease_args[@]}" origin "${refspecs[@]}" 2>&1) || push_rc=$?
    fi
    if [ "$push_rc" -ne 0 ]; then
        echo "Error: failed to publish task refs to origin (nothing was created" >&2
        echo "       on origin; the local commit objects are unreferenced)." >&2
        if [ "$is_root_breakdown" = true ]; then
            echo "       (If the orchestration lock tasks/root-active/${root_issue} was" >&2
            echo "        released or stolen, re-run 'task-dag claim-root ${root_issue}'.)" >&2
        fi
        echo "$push_output" >&2
        return 4
    fi

    # ── mirror onto local refs so subsequent commands see them ───────
    for (( i=0; i<count; i++ )); do
        local mirror_short
        mirror_short=$(git rev-parse --short "${created_shas[i]}")
        if [ -n "${claim_commits[i]}" ]; then
            git update-ref "refs/heads/tasks/active/$mirror_short" "${claim_commits[i]}"
        else
            git update-ref "refs/heads/tasks/frontier/$mirror_short" "${created_shas[i]}"
        fi
    done
    # Drop the now-consumed local orchestration lock too.
    if [ "$is_root_breakdown" = true ]; then
        git update-ref -d "$root_active_ref" 2>/dev/null || true
    fi
    # Drop the now-consumed local parent active claim (non-root recursion).
    if [ -n "$parent_active_ref" ]; then
        git update-ref -d "$parent_active_ref" 2>/dev/null || true
    fi

    # ── report ───────────────────────────────────────────────────────
    if [ "$json" = true ]; then
        local k task_objs=()
        for (( k=0; k<count; k++ )); do
            local k_claimed=false k_short k_ref
            k_short=$(git rev-parse --short "${created_shas[k]}")
            if [ -n "${claim_commits[k]}" ]; then
                k_claimed=true
                k_ref="tasks/active/$k_short"
            else
                k_ref="tasks/frontier/$k_short"
            fi
            task_objs+=("$(jq -nc --arg sha "${created_shas[k]}" \
                --arg short "$k_short" \
                --argjson claimed "$k_claimed" \
                --arg ref "$k_ref" \
                '{sha:$sha,shortSha:$short,claimed:$claimed,ref:$ref}')")
        done
        # Slurp the per-task objects into the tasks array so the whole
        # result is emitted by jq (compact, authored key order) rather than
        # hand-concatenated. Handle the zero-task case explicitly since
        # `jq -s` on empty input would error.
        if [ "${#task_objs[@]}" -gt 0 ]; then
            printf '%s\n' "${task_objs[@]}" | jq -sc \
                --arg parent "$parent_sha" --argjson count "$count" \
                '{ok:true,parent:$parent,count:$count,tasks:.}'
        else
            jq -nc --arg parent "$parent_sha" --argjson count "$count" \
                '{ok:true,parent:$parent,count:$count,tasks:[]}'
        fi
    else
        printf "${GREEN}✓ Created %s task(s) under %s — '%s'${RESET}\n" \
            "$count" "${parent_sha:0:12}" "$parent_title"
        for (( i=0; i<count; i++ )); do
            echo "  ${out_lines[i]}"
        done
        echo "Run 'task-dag frontier' to see the ready leaves."
    fi
    return 0
}

# Helper: honour the cross-host active-claim mutex before landing a
# completion. Extracted from cmd_complete so BOTH `complete` and
# `complete-historical` enforce the SAME "do not complete a task another
# live worker holds" guard. The claim CAS on origin is the cross-host
# mutex; we record the EXACT active-claim SHA we authorise so the ref
# cleanup deletes only THAT claim (never a concurrent worker's fresh one).
#   $1 = task_sha (full)   $2 = short_sha   $3 = do_force (true|false)
# Prints the authorised active-claim SHA (possibly empty) on stdout for
# the cleanup step to lease against. All diagnostics go to stderr.
# Returns 0 to proceed, 2 to refuse.
verify_task_claim_ownership() {
    local task_sha="$1" short_sha="$2" do_force="$3"
    local verified_active_sha=""
    # Tri-state read so a transport/auth failure FAILS CLOSED rather than
    # masquerading as "unclaimed" (which would let us land work over a live
    # claim we simply couldn't see). --force overrides a known foreign/dead
    # claim, NOT an indeterminate read.
    local active_remote_sha="" read_rc=0
    active_remote_sha=$(remote_ref_sha_checked "refs/heads/tasks/active/$short_sha") || read_rc=$?
    if [ "$read_rc" = 3 ]; then
        echo "Error: cannot read tasks/active/$short_sha on origin (indeterminate transport/auth error); refusing to proceed without knowing the claim state. Retry when origin is reachable." >&2
        return 2
    fi
    if [ -n "$active_remote_sha" ]; then
        local tmp_active="refs/task-dag-tmp/complete-check/$short_sha"
        git update-ref -d "$tmp_active" 2>/dev/null || true
        if git fetch --quiet --no-tags origin \
               "+refs/heads/tasks/active/$short_sha:$tmp_active" 2>/dev/null; then
            local claim_msg claim_taskcommit claim_first_parent claimer claimer_host
            # Each field is `|| true`-guarded: a malformed/legacy claim
            # missing a field must NOT abort under `set -e` (that would
            # both defeat the malformed-ref handling below and leak the
            # temp ref). extract_field/get_first_parent grep internally.
            claim_msg=$(parse_commit_metadata "$tmp_active" 2>/dev/null || true)
            claim_taskcommit=$(extract_field "$claim_msg" "Task-Commit" 2>/dev/null || true)
            claim_first_parent=$(get_first_parent "$tmp_active" 2>/dev/null || true)
            claimer=$(extract_field "$claim_msg" "Claimer" 2>/dev/null || true)
            claimer_host=$(extract_field "$claim_msg" "Claimer-Host" 2>/dev/null || true)
            git update-ref -d "$tmp_active" 2>/dev/null || true

            # Guard against short-SHA collision / malformed active refs:
            # the claim must actually reference THIS task.
            if [ "$claim_taskcommit" != "$task_sha" ] && \
               [ "$claim_first_parent" != "$task_sha" ]; then
                if [ "$do_force" = false ]; then
                    echo "Error: tasks/active/$short_sha does not reference task $task_sha (Task-Commit=${claim_taskcommit:-?}). Refusing; rerun with --force only if you know it is safe." >&2
                    return 2
                fi
            fi

            local me_claimer me_host
            me_claimer="${TASK_DAG_CLAIMER:-${USER:-unknown}}"
            me_host="${TASK_DAG_CLAIMER_HOST:-$(hostname -s 2>/dev/null || echo unknown)}"
            if [ "$claimer" = "$me_claimer" ] && [ "$claimer_host" = "$me_host" ]; then
                verified_active_sha="$active_remote_sha"   # owned by us
            elif [ "$do_force" = true ]; then
                printf '%b\n' "${YELLOW}--force: completing task ${short_sha} claimed by ${claimer:-unknown}@${claimer_host:-unknown} (you are ${me_claimer}@${me_host}).${RESET}" >&2
                verified_active_sha="$active_remote_sha"
            else
                echo "Error: task $short_sha is claimed by ${claimer:-unknown}@${claimer_host:-unknown}, not you (${me_claimer}@${me_host})." >&2
                echo "Refusing to complete another worker's active task. Use --force only if that claim is dead." >&2
                return 2
            fi
        else
            # Fetch of the active claim failed; tmp ref was pre-deleted but
            # clean up defensively in case a partial ref exists.
            git update-ref -d "$tmp_active" 2>/dev/null || true
            if [ "$do_force" = false ]; then
                echo "Error: could not read active claim tasks/active/$short_sha for the ownership check. Rerun with --force to override." >&2
                return 2
            fi
            verified_active_sha="$active_remote_sha"
        fi
    fi
    printf '%s\n' "$verified_active_sha"
    return 0
}

# Reconcile stale scheduling refs from the only durable completion authority:
# canonical completion parentage on origin/master's first-parent spine. This is
# where server reconciliation owns cleanup after durable master completion,
# including an active claim created after that fact landed.
#
# The strict fetch is one atomic local snapshot of master plus all scheduling
# namespaces. Exact observed ref names/OIDs become the cleanup leases; never
# recompute a ref suffix with `git rev-parse --short`, because abbreviation
# length can change as the object database grows or core.abbrev changes.
# Returns non-zero after attempting all independent tasks if fetch, shape
# validation, or a CAS cleanup fails.
reconcile_completed_task_refs() {
    local remote="${1:-origin}"
    local master_ref="refs/remotes/${remote}/master"
    if ! git fetch --quiet --atomic --prune --no-tags "$remote" \
        "+refs/heads/master:${master_ref}" \
        '+refs/heads/tasks/frontier/*:refs/heads/tasks/frontier/*' \
        '+refs/heads/tasks/active/*:refs/heads/tasks/active/*' \
        '+refs/heads/tasks/blocked/*:refs/heads/tasks/blocked/*' \
        '+refs/heads/tasks/blocked-meta/*:refs/heads/tasks/blocked-meta/*'; then
        echo "Error: could not take an authoritative master/task-ref snapshot; completed-ref reconciliation made no changes." >&2
        return 2
    fi

    local -A witness=() frontier_ref=() frontier_oid=() active_ref=() active_oid=()
    local -A blocked_ref=() blocked_oid=() meta_ref=() meta_oid=() invalid_task=() invalid_suffix=() suffix_task=()
    local commit first parent commit_tree first_tree
    while read -r commit first parent; do
        [ -n "$commit" ] && [ -n "$first" ] && [ -n "$parent" ] || continue
        commit_tree=$(git rev-parse "$commit^{tree}" 2>/dev/null || true)
        first_tree=$(git rev-parse "$first^{tree}" 2>/dev/null || true)
        [ -n "$commit_tree" ] && [ "$commit_tree" = "$first_tree" ] || continue
        for parent in $parent; do
            is_task_commit "$parent" || continue
            [ -n "${witness[$parent]:-}" ] || witness["$parent"]="$commit"
        done
    done < <(git rev-list --first-parent --parents "$master_ref" 2>/dev/null)

    local oid ref suffix task task_field existing rc=0
    while read -r oid ref; do
        [ -n "$oid" ] && [ -n "$ref" ] || continue
        task=""
        suffix="${ref##*/}"
        case "$ref" in
            refs/heads/tasks/frontier/*)
                task="$oid"
                if ! is_task_commit "$task" || [[ ! "$suffix" =~ ^[0-9a-f]+$ ]] || [[ "$task" != "$suffix"* ]]; then
                    echo "Error: malformed frontier projection $ref -> $oid; leaving it untouched." >&2
                    is_task_commit "$task" && invalid_task["$task"]=1
                    [[ "$suffix" =~ ^[0-9a-f]+$ ]] && invalid_suffix["$suffix"]=1
                    rc=1; continue
                fi
                existing="${frontier_ref[$task]:-}"
                if [ -n "$existing" ] && [ "$existing" != "$ref" ]; then
                    echo "Error: task $task has conflicting frontier suffixes ($existing, $ref); leaving it untouched." >&2
                    invalid_task["$task"]=1; rc=1; continue
                fi
                existing="${suffix_task[$suffix]:-}"
                if [ -n "$existing" ] && [ "$existing" != "$task" ]; then
                    echo "Error: scheduling suffix $suffix identifies multiple tasks ($existing, $task); leaving them untouched." >&2
                    invalid_suffix["$suffix"]=1; invalid_task["$existing"]=1; invalid_task["$task"]=1; rc=1
                else
                    suffix_task["$suffix"]="$task"
                fi
                frontier_ref["$task"]="$ref"; frontier_oid["$task"]="$oid"
                ;;
            refs/heads/tasks/active/*)
                task=$(get_first_parent "$oid" 2>/dev/null || true)
                task_field=$(extract_field "$(parse_commit_metadata "$oid" 2>/dev/null || true)" "Task-Commit" 2>/dev/null || true)
                if ! is_task_commit "$task" || { [ -n "$task_field" ] && [ "$task_field" != "$task" ]; } \
                   || [[ ! "$suffix" =~ ^[0-9a-f]+$ ]] || [[ "$task" != "$suffix"* ]]; then
                    echo "Error: malformed active projection $ref -> $oid; leaving it untouched." >&2
                    is_task_commit "$task" && invalid_task["$task"]=1
                    [[ "$task_field" =~ ^[0-9a-f]{40}$ ]] && is_task_commit "$task_field" \
                        && invalid_task["$task_field"]=1
                    [[ "$suffix" =~ ^[0-9a-f]+$ ]] && invalid_suffix["$suffix"]=1
                    rc=1; continue
                fi
                existing="${active_ref[$task]:-}"
                if [ -n "$existing" ] && [ "$existing" != "$ref" ]; then
                    echo "Error: task $task has conflicting active suffixes ($existing, $ref); leaving it untouched." >&2
                    invalid_task["$task"]=1; rc=1; continue
                fi
                existing="${suffix_task[$suffix]:-}"
                if [ -n "$existing" ] && [ "$existing" != "$task" ]; then
                    echo "Error: scheduling suffix $suffix identifies multiple tasks ($existing, $task); leaving them untouched." >&2
                    invalid_suffix["$suffix"]=1; invalid_task["$existing"]=1; invalid_task["$task"]=1; rc=1
                else
                    suffix_task["$suffix"]="$task"
                fi
                active_ref["$task"]="$ref"; active_oid["$task"]="$oid"
                ;;
            refs/heads/tasks/blocked/*)
                task="$suffix"
                if [[ ! "$task" =~ ^[0-9a-f]{40}$ ]] || [ "$oid" != "$task" ] || ! is_task_commit "$task"; then
                    echo "Error: malformed blocked projection $ref -> $oid; leaving it untouched." >&2
                    [[ "$task" =~ ^[0-9a-f]{40}$ ]] && is_task_commit "$task" \
                        && invalid_task["$task"]=1
                    is_task_commit "$oid" && invalid_task["$oid"]=1
                    rc=1; continue
                fi
                blocked_ref["$task"]="$ref"; blocked_oid["$task"]="$oid"
                ;;
            refs/heads/tasks/blocked-meta/*)
                task="$suffix"
                task_field=$(extract_field "$(parse_commit_metadata "$oid" 2>/dev/null || true)" "Task-Commit" 2>/dev/null || true)
                local meta_parent
                meta_parent=$(get_first_parent "$oid" 2>/dev/null || true)
                if [[ ! "$task" =~ ^[0-9a-f]{40}$ ]] || [ "$meta_parent" != "$task" ] \
                   || [ "$task_field" != "$task" ] || ! is_task_commit "$task"; then
                    echo "Error: malformed blocked-meta projection $ref -> $oid; leaving it untouched." >&2
                    [[ "$task" =~ ^[0-9a-f]{40}$ ]] && is_task_commit "$task" \
                        && invalid_task["$task"]=1
                    is_task_commit "$meta_parent" && invalid_task["$meta_parent"]=1
                    [[ "$task_field" =~ ^[0-9a-f]{40}$ ]] && is_task_commit "$task_field" \
                        && invalid_task["$task_field"]=1
                    rc=1; continue
                fi
                meta_ref["$task"]="$ref"; meta_oid["$task"]="$oid"
                ;;
        esac
    done < <(git for-each-ref --format='%(objectname) %(refname)' \
        refs/heads/tasks/frontier refs/heads/tasks/active \
        refs/heads/tasks/blocked refs/heads/tasks/blocked-meta)

    local -A candidates=()
    for task in "${!frontier_ref[@]}" "${!active_ref[@]}" "${!blocked_ref[@]}" "${!meta_ref[@]}"; do
        [ -n "$task" ] && candidates["$task"]=1
    done
    for suffix in "${!invalid_suffix[@]}"; do
        for task in "${!candidates[@]}"; do
            [[ "$task" = "$suffix"* ]] && invalid_task["$task"]=1
        done
    done

    local -a leases refs
    local had_block=false short current read_rc cleanup_ok
    for task in "${!candidates[@]}"; do
        [ -n "${witness[$task]:-}" ] || continue
        [ -z "${invalid_task[$task]:-}" ] || continue
        if [ -n "${frontier_ref[$task]:-}" ] && [ -n "${active_ref[$task]:-}" ] \
           && [ "${frontier_ref[$task]##*/}" != "${active_ref[$task]##*/}" ]; then
            echo "Error: completed task $task has conflicting frontier/active suffixes; leaving all its refs untouched." >&2
            rc=1; continue
        fi

        leases=(); refs=(); had_block=false
        for ref in "${frontier_ref[$task]:-}" "${active_ref[$task]:-}" \
                   "${blocked_ref[$task]:-}" "${meta_ref[$task]:-}"; do
            [ -n "$ref" ] || continue
            case "$ref" in
                refs/heads/tasks/frontier/*) oid="${frontier_oid[$task]}" ;;
                refs/heads/tasks/active/*) oid="${active_oid[$task]}" ;;
                refs/heads/tasks/blocked/*) oid="${blocked_oid[$task]}"; had_block=true ;;
                refs/heads/tasks/blocked-meta/*) oid="${meta_oid[$task]}" ;;
            esac
            leases+=("--force-with-lease=$ref:$oid")
            refs+=(":$ref")
        done
        [ "${#refs[@]}" -gt 0 ] || continue

        cleanup_ok=false
        if git push --atomic "$remote" "${leases[@]}" "${refs[@]}" >/dev/null 2>&1; then
            cleanup_ok=true
        else
            # A concurrent idempotent cleaner may have removed every ref after
            # our snapshot. That is success. A replacement OID or an unchanged
            # stale ref is a visible retryable conflict; atomic push semantics
            # guarantee this run did not partially remove the other refs.
            cleanup_ok=true
            for ref in "${frontier_ref[$task]:-}" "${active_ref[$task]:-}" \
                       "${blocked_ref[$task]:-}" "${meta_ref[$task]:-}"; do
                [ -n "$ref" ] || continue
                current=""; read_rc=0
                current=$(remote_ref_sha_checked "$ref") || read_rc=$?
                if [ "$read_rc" = 3 ] || [ -n "$current" ]; then cleanup_ok=false; fi
            done
        fi
        if [ "$cleanup_ok" = true ]; then
            for ref in "${frontier_ref[$task]:-}" "${active_ref[$task]:-}" \
                       "${blocked_ref[$task]:-}" "${meta_ref[$task]:-}"; do
                [ -n "$ref" ] && git update-ref -d "$ref" 2>/dev/null || true
            done
            short="${active_ref[$task]:-}"
            short="${short##*/}"
            if [ -z "$short" ]; then
                short="${frontier_ref[$task]:-}"
                short="${short##*/}"
            fi
            [ -n "$short" ] || short="${task:0:12}"
            echo "Reconciled completed task refs for $short from master witness ${witness[$task]}"
            if [ "$had_block" = true ]; then
                emit_operator_blocked_dispatch complete "$short"
            fi
        else
            echo "Error: CAS cleanup raced or failed for completed task $task; no partial cleanup was accepted." >&2
            rc=1
        fi
    done
    return "$rc"
}

# Helper: build a completion merge's commit message from the task commit's
# metadata and the implementation commit's message. Shared by single
# `complete` and the batch (--leaves) path so both produce identical
# trailers. Encodes NOTHING that the DAG already carries: the impl↔task
# link is the merge's parentage (first parent = impl, second = task), not a
# message tag (docs/DESIGN_PRINCIPLES.md).
#   $1 = task_sha (full)   $2 = base implementation commit message (%B)
build_completion_message() {
    local task_sha="$1" base_message="$2"
    local task_msg issue_num issue_url m
    task_msg=$(parse_commit_metadata "$task_sha")
    issue_num=$(extract_field "$task_msg" "Issue" | sed 's/^#//')
    issue_url=$(extract_field "$task_msg" "URL")
    m="${base_message}

Task-Commit: $task_sha"
    [ -n "$issue_num" ] && m="${m}
Issue: #$issue_num"
    [ -n "$issue_url" ] && m="${m}
URL: $issue_url"
    m="${m}
Status: completed"
    # Related: footer for GitHub auto-linking.
    [ -n "$issue_url" ] && m="${m}

Related: $issue_url"
    printf '%s' "$m"
}

# Command: complete - mark task as complete
cmd_complete() {
    local task_sha=""
    local commit_sha=""
    local leaves_spec=""
    local do_force=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --commit=*) commit_sha="${1#*=}"; shift ;;
            --leaves=*) leaves_spec="${1#*=}"; shift ;;
            --force) do_force=true; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag complete <task-sha> [--commit=SHA] [--force]
       task-dag complete --leaves=<leaf>:<impl>[,<leaf>:<impl>...] [--force]

Mark a task (or several stacked sibling leaves) complete by creating a
completion merge whose FIRST parent is the leaf's implementation commit and
whose second parent is the task commit. Completion is thus a git parent-edge
(see docs/DESIGN_PRINCIPLES.md), never a message tag.

Single-leaf form (default):
  --commit=SHA     Implementation commit to complete against (default:
                   HEAD). SHA must be HEAD, or a DESCENDANT of HEAD (HEAD
                   fast-forwards up to it). SHA must be real work (not an
                   empty task/control/completion commit). If your impl is
                   BEHIND HEAD (you stacked more commits on top of it), use
                   the --leaves form instead — completing it in place would
                   rewrite local history and must be explicit. To link work
                   already on master, use 'complete-historical'.

Batch form (--leaves): complete several sibling leaves implemented as a
  stack of commits in ONE worktree. Each pair is <leaf>:<impl>, where <impl>
  is that leaf's implementation commit (all must be UNPUSHED commits in
  origin/master..HEAD, on a linear chain). task-dag grafts a completion
  merge directly above each impl and replays the commits stacked above, so
  the result is an honest linear graph (base -> S -> M_S -> C' -> M_C) with
  no history left dangling and no message-encoded provenance. This is a
  LOCAL rewrite of your unpushed commits (old tip stays in the reflog);
  the subsequent 'task-dag publish' remains a fast-forward.

Options:
  --force          Complete even if a task's active claim is held by
                   another worker (use only if that claim is known dead).

Safety: 'complete' advances HEAD with 'git update-ref' CAS (never
'git reset --hard'), so uncommitted work is preserved; the batch form only
rewrites commits proven unpushed against a freshly-fetched origin/master;
and it refuses to complete a task another live worker has claimed. It changes
only local HEAD. Publish with exactly 'task-dag publish'; the
server-side reconciler removes scheduling refs after master proves completion.
EOF
                return 0
                ;;
            *)
                if [ -z "$task_sha" ]; then
                    task_sha="$1"
                else
                    echo "Unknown option: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    # Bind this whole completion operation to one activation/facts snapshot.
    # Internal --no-fetch dependency checks reuse it rather than accidentally
    # interpreting an absent local activation ref as a pre-activation epoch.
    taskdag_consumer_prepare complete --tip HEAD || return 2

    # ── Batch form: --leaves routes to the graft-based multi-leaf path ──
    if [ -n "$leaves_spec" ]; then
        if [ -n "$task_sha" ] || [ -n "$commit_sha" ]; then
            echo "Error: --leaves cannot be combined with a positional task SHA or --commit." >&2
            echo "       Use EITHER 'complete <sha> [--commit=..]' OR 'complete --leaves=l:i,l:i'." >&2
            return 1
        fi
        cmd_complete_batch "$leaves_spec" "$do_force"
        return $?
    fi
    
    if [ -z "$task_sha" ]; then
        echo "Error: task SHA required" >&2
        return 1
    fi
    
    task_sha=$(resolve_sha "$task_sha") || return 1
    local short_sha existing_completion
    short_sha=$(git rev-parse --short "$task_sha")
    taskdag_consumer_prepare complete-origin || return 2
    local complete_rc=0
    taskdag_task_is_complete_prepared "$task_sha" || complete_rc=$?
    [ "$complete_rc" -ne 2 ] || return 2
    if [ "$complete_rc" -eq 0 ]; then
        echo "Task $short_sha is already canonically complete (including supersedence); no new completion created."
        return 0
    fi
    existing_completion=$(completion_merge_for_task_at_commit HEAD "$task_sha" 2>/dev/null || true)
    if [ -n "$existing_completion" ]; then
        echo "Task $short_sha already has a local completion at ${existing_completion:0:12}; no new commit created."
        print_completion_push_instruction
        return 0
    fi
    if git fetch --quiet --no-tags origin \
            '+refs/heads/master:refs/remotes/origin/master' >/dev/null 2>&1; then
        existing_completion=$(completion_merge_for_task_at_commit origin/master "$task_sha" 2>/dev/null || true)
        if [ -n "$existing_completion" ]; then
            echo "Task $short_sha is already completed on origin/master at ${existing_completion:0:12}; no new commit created."
            print_completion_push_instruction
            return 0
        fi
    fi

    # ── root-completion guard (issue #2) ─────────────────────────────
    # A decomposed epic root must NOT be completed as if it were an
    # implementation unit: its work lives in the child leaves, and the
    # epic is closed by close-epic/close-completed-issues once those land.
    # Completing the root here would both land empty "root work" and let a
    # root worker keep acting after leaves exist. Run this BEFORE any
    # completion side effects (commit creation / HEAD movement). --force
    # does NOT bypass it (force only overrides another worker's leaf claim).
    local complete_issue="" rc_root=0
    complete_issue=$(task_is_pending_root "$task_sha") || rc_root=$?
    if [ "$rc_root" = 3 ]; then
        # task_is_pending_root could not confirm pending identity on origin
        # (unreachable) and has no local mirror, but the commit is shaped
        # like a top-level epic root. FAIL CLOSED: completing a possibly-
        # decomposed root would land an empty root over live leaves.
        echo "Error: cannot verify whether ${task_sha:0:12} is a live epic root (origin" >&2
        echo "       unreachable and no local pending mirror). Refusing to complete a" >&2
        echo "       possibly-decomposed root. Retry when online." >&2
        return 2
    fi
    if [ -n "$complete_issue" ]; then
        # FAIL CLOSED if origin is unreadable: completing a root is only
        # safe once we have positively confirmed it has NO children, so a
        # transient fetch failure must refuse, not fall through and land an
        # empty root on top of live leaves.
        if ! fetch_root_refs "$complete_issue"; then
            echo "Error: cannot reach origin to verify issue #${complete_issue} root has no" >&2
            echo "       child tasks — refusing to complete the root. Retry when online." >&2
            return 2
        fi
        if task_has_children "$task_sha" >/dev/null; then
            echo "Error: issue #${complete_issue} root has child tasks; complete the leaves" >&2
            echo "       and let the epic close (close-epic), do not complete the root." >&2
            return 2
        fi
    fi

    # Check dependencies
    if ! cmd_deps "$task_sha" --check-complete --no-fetch >/dev/null 2>&1; then
        echo "Error: Dependencies not met for task $task_sha" >&2
        cmd_deps "$task_sha" --no-fetch
        return 2
    fi
    
    # Use provided commit or HEAD
    if [ -z "$commit_sha" ]; then
        commit_sha=$(git rev-parse HEAD)
    else
        commit_sha=$(resolve_sha "$commit_sha") || return 1
    fi

    # The completion must be built on a real implementation commit, never
    # the task commit itself (that would be an empty/tombstone link).
    if [ "$commit_sha" = "$task_sha" ]; then
        echo "Error: --commit cannot be the task commit itself; complete against your implementation commit." >&2
        return 1
    fi

    # ── Ownership guard (do not complete a task another worker holds) ──
    # Honour the cross-host active-claim mutex (shared with
    # complete-historical). Echoes the authorised active-claim SHA for the
    # cleanup step; returns 2 (propagated) to refuse on a foreign claim.
    local verified_active_sha
    verified_active_sha=$(verify_task_claim_ownership "$task_sha" "$short_sha" "$do_force") || return $?

    # ── Validate the implementation commit is REAL work ──────────────
    # Mirror complete-historical's operand guards (stronger than a bare
    # `git diff-tree | grep -q .` check): reject empty-tree task/control
    # commits, and reject any commit that introduces no tree change vs its
    # first parent (a completion/close/tombstone merge). This matters now
    # that we support completing an impl commit behind HEAD: the caller
    # could otherwise point --commit at an empty completion merge and mark
    # a task "done" against no real work.
    if is_task_commit "$commit_sha"; then
        echo "" >&2
        echo "${RED}ERROR: --commit=$commit_sha is itself a task/control commit (empty tree), not real implementation work.${RESET}" >&2
        echo "" >&2
        echo "Commit your code changes first, then run 'task-dag complete' against that commit." >&2
        echo "" >&2
        return 1
    fi
    local impl_tree impl_parent impl_base_tree
    impl_tree=$(git rev-parse "$commit_sha^{tree}") || return 1
    impl_parent=$(get_first_parent "$commit_sha" 2>/dev/null || true)
    if [ -n "$impl_parent" ]; then
        impl_base_tree=$(git rev-parse "$impl_parent^{tree}") || return 1
    else
        impl_base_tree="$EMPTY_TREE"
    fi
    if [ "$impl_tree" = "$impl_base_tree" ]; then
        # Empty commit detected
        echo "" >&2
        echo "${RED}ERROR: Empty commit detected${RESET}" >&2
        echo "" >&2
        echo "The commit you are completing against ($commit_sha) introduces no tree" >&2
        echo "change vs its first parent — it is not a real implementation commit." >&2
        echo "" >&2
        echo "For normal work, 'task-dag complete' must reference a real implementation" >&2
        echo "commit with actual code/file changes. If you are currently implementing" >&2
        echo "this task, commit your code changes first, then run 'task-dag complete'." >&2
        echo "" >&2
        echo "Empty 'tombstone' commits are ONLY for retroactive linking of historical" >&2
        echo "work that predates the task-dag system (see 'complete-historical')." >&2
        echo "" >&2
        return 1
    fi

    # ── Commit-subject style backstop (canon rules/WORKFLOW.md) ──────
    # The commit-msg hook is the primary gate, but it only runs where the
    # hook is installed and can be bypassed. `complete` is the last reliable
    # point to stop a Conventional-Commits subject from being LINKED as task
    # work (the completion merge preserves the impl commit's message). Block
    # live completion here — historical linking (complete-historical) only
    # WARNS, since that work predates the rule and must not be stranded.
    local impl_subject; impl_subject=$(git show -s --format='%s' "$commit_sha")
    if subject_is_conventional_commits "$impl_subject"; then
        printf '%b' "${RED}" >&2
        echo "════════════════════════════════════════════════════════════════════" >&2
        echo " task-dag: refusing to complete against a Conventional-Commits subject" >&2
        echo "════════════════════════════════════════════════════════════════════" >&2
        echo " Impl commit: ${commit_sha:0:12}" >&2
        echo " Subject:     $impl_subject" >&2
        echo "" >&2
        echo " Canon (rules/WORKFLOW.md 'Commit messages') requires a plain," >&2
        echo " capitalized, imperative subject — never a type(scope): prefix." >&2
        echo "   Bad:  feat(helios): add report export" >&2
        echo "   Good: Add report export for Helios" >&2
        echo "" >&2
        echo " Amend the implementation commit's subject, then re-run complete." >&2
        echo " (Use complete-historical only for already-landed historical work.)" >&2
        echo "════════════════════════════════════════════════════════════════════" >&2
        printf '%b' "${RESET}" >&2
        return 1
    fi

    local old_message=$(git log -1 --format='%B' "$commit_sha")
    
    # Warn if commit message looks like a tombstone (starts with tombstone keyword)
    if echo "$old_message" | grep -qiE "^(Task completion tombstone|Tombstone:|Retroactive completion)"; then
        echo "" >&2
        echo "${YELLOW}WARNING: This commit message looks like a tombstone${RESET}" >&2
        echo "" >&2
        echo "Message: $(echo "$old_message" | head -1)" >&2
        echo "" >&2
        echo "Tombstones are only for retroactive linking of historical work." >&2
        echo "If you are actively working on this task, you should NOT create" >&2
        echo "tombstone commits. Use 'task-dag complete' with real implementation commits." >&2
        echo "" >&2
        echo "Press Ctrl-C to abort or Enter to continue anyway..." >&2
        read -r
    fi
    
    # ── Choose the completion base (single-leaf: first parent == impl) ──
    # The completion merge's FIRST parent is always the implementation
    # commit (DAG-native provenance — see docs/DESIGN_PRINCIPLES.md), so
    # single `complete` only handles the two cases where that is possible
    # without rewriting local history:
    #   * impl == HEAD          → merge on HEAD, update-ref HEAD forward
    #   * HEAD ancestor of impl → merge on impl, fast-forward HEAD up to it
    # If the impl is BEHIND HEAD (you stacked more commits on top of it),
    # completing it in place would rewrite local history to keep first
    # parent == impl; that is the batch form's job and must be explicit:
    # use 'complete --leaves=<leaf>:<impl>[,...]'.
    local completion_base current
    current=$(git rev-parse --verify HEAD^{commit}) || return 1
    if [ "$commit_sha" = "$current" ]; then
        completion_base="$current"
    elif git merge-base --is-ancestor "$current" "$commit_sha"; then
        completion_base="$commit_sha"
    elif git merge-base --is-ancestor "$commit_sha" "$current"; then
        echo "Error: --commit=$commit_sha is BEHIND HEAD ($current) — you have commits stacked on top of it." >&2
        echo "Completing it in place would rewrite local history to keep the completion merge's first" >&2
        echo "parent = the impl. Do that explicitly with the batch form, e.g.:" >&2
        echo "    task-dag complete --leaves=${short_sha}:${commit_sha}[,<leaf>:<impl>...]" >&2
        return 1
    else
        echo "Error: --commit=$commit_sha is neither an ancestor nor a descendant of HEAD ($current)." >&2
        echo "Point --commit at a commit in this checkout's history, or check it out in a fresh ephemeral worktree and rerun." >&2
        return 1
    fi

    # Build the completion merge message (Task-Commit/Issue/URL/Status/
    # Related trailers), then create the merge: first parent == impl base,
    # second parent == task commit. Tree == base tree (an empty merge).
    local new_message tree new_commit
    new_message=$(build_completion_message "$task_sha" "$old_message")
    tree=$(git rev-parse "$completion_base^{tree}") || return 1
    new_commit=$(git commit-tree "$tree" -p "$completion_base" -p "$task_sha" -m "$new_message") || return 1
    
    # Advance HEAD non-destructively (NEVER `git reset --hard`, which would
    # wipe uncommitted work in the caller's cwd peer worktree). Print the
    # completion commit only AFTER HEAD is successfully advanced, so a
    # refused/CAS-lost advance never leaves the caller thinking a dangling
    # (unreferenced, GC-able) commit is installed.
    taskdag_consumer_prepare complete-pre-head --tip "$completion_base" || return 2
    taskdag_completion_allowed "$task_sha" || {
        echo "Error: task became complete or its requirements changed before HEAD advance; refusing completion." >&2
        return 2
    }
    advance_head_to_completion "$completion_base" "$new_commit" || return 1

    echo "Created completion commit: $new_commit"

    # Auto-close the parent epic when this completion finishes it.
    #
    # We do NOT close the GitHub issue directly here. The old direct REST
    # PATCH-to-closed (a) bypassed the `Closes-Epic:` trailer gate that
    # close-completed-issues.yml enforces (the gate that exists precisely
    # so an ordinary `complete` attach-merge does NOT prematurely close an
    # in-progress epic — see the #7 incident), and (b) required a
    # GITHUB_TOKEN that worker agents don't carry, so it almost never
    # fired. Instead, maybe_emit_local_epic_close appends the canonical
    # additive Closes-Epic commit to local HEAD for a purely-local,
    # fully-complete epic; the caller's explicit push lets the server workflow
    # close the issue and clean the refs. Epics with cross-repo
    # delegated children still close via `close-epic`.
    local close_rc=0
    maybe_emit_local_epic_close "$task_sha" || close_rc=$?
    if [ "$close_rc" -eq "$TASKDAG_MIGRATION_EXIT" ]; then
        echo "completion recorded; epic close deferred by migration drain"
    elif [ "$close_rc" -ne 0 ]; then
        return "$close_rc"
    fi

    printf "${GREEN}✓ Task completed: %s${RESET}\n" "$(get_task_title "$task_sha")"
    print_completion_push_instruction

    return 0
}

# Helper: recreate commit <c> with a NEW first parent <parent>, preserving
# its tree, author/committer identity + dates, and message. Prints the new
# sha. Refuses if <c> is GPG-signed (reparenting invalidates the signature,
# and silently dropping it is bad provenance — design review). Used by the
# batch graft to replay commits stacked above an implementation commit.
#   $1 = commit to replay   $2 = new first parent
recommit_onto() {
    local c="$1" parent="$2"
    # gpgsig check via pure-bash matching (NOT `git cat-file | grep -q`,
    # which under `set -o pipefail` can return git's SIGPIPE 141 when grep
    # exits early on a match — inverting the result). The commit object has
    # a `gpgsig ` header line iff it is signed.
    local hdr
    hdr=$(git cat-file commit "$c" 2>/dev/null || true)
    # A signed commit has a `gpgsig ` (SHA-1 repos) or `gpgsig-sha256 `
    # (SHA-256 repos) header line; reparenting would silently drop it.
    if [[ $'\n'"$hdr" == *$'\n'"gpgsig "* ]] || [[ $'\n'"$hdr" == *$'\n'"gpgsig-sha256 "* ]]; then
        echo "Error: commit ${c:0:12} is GPG-signed; refusing to reparent it (would drop the signature)." >&2
        return 1
    fi
    local an ae ai cn ce ci
    an=$(git show -s --format=%an "$c"); ae=$(git show -s --format=%ae "$c"); ai=$(git show -s --format=%aI "$c")
    cn=$(git show -s --format=%cn "$c"); ce=$(git show -s --format=%ce "$c"); ci=$(git show -s --format=%cI "$c")
    GIT_AUTHOR_NAME="$an" GIT_AUTHOR_EMAIL="$ae" GIT_AUTHOR_DATE="$ai" \
    GIT_COMMITTER_NAME="$cn" GIT_COMMITTER_EMAIL="$ce" GIT_COMMITTER_DATE="$ci" \
        git commit-tree "$c^{tree}" -p "$parent" -F <(git show -s --format=%B "$c")
}

validate_ops_trailer_value() {
    local label="$1" value="$2"
    if [ -z "$value" ]; then
        echo "Error: $label must not be empty." >&2
        return 1
    fi
    case "$value" in
        *$'\n'*|*$'\r'*)
            echo "Error: $label must be a single line with no CR/LF characters." >&2
            return 1
            ;;
    esac
    if printf '%s' "$value" | LC_ALL=C grep -q '[[:cntrl:]]'; then
        echo "Error: $label must be a single line with no control characters." >&2
        return 1
    fi
    return 0
}

# Command: complete-ops - mark an operations-only leaf complete without an
# implementation commit. This is deliberately separate from `complete`: normal
# task completion still requires a real implementation commit. The durable done
# fact remains git parentage (the task commit is a non-primary parent of a
# master merge); the Ops-* trailers are audit metadata only.
cmd_complete_ops() {
    local task_sha="" evidence="" authorization="" reason="" do_force=false assume_yes=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --evidence) evidence="$2"; shift 2 ;;
            --evidence=*) evidence="${1#*=}"; shift ;;
            --authorization|--authorized-by) authorization="$2"; shift 2 ;;
            --authorization=*|--authorized-by=*) authorization="${1#*=}"; shift ;;
            --reason) reason="$2"; shift 2 ;;
            --reason=*) reason="${1#*=}"; shift ;;
            --yes|-y) assume_yes=true; shift ;;
            --force) do_force=true; shift ;;
            --help|-h)
                cat <<'EOF'
Usage: task-dag complete-ops <task-sha> --evidence <https-url> \
                             --authorization <text-or-url> --yes
                             [--reason "..."] [--force]

Complete an operations-only LEAF whose real work happened out of band and has
no honest implementation commit to link. This command does NOT relax normal
`task-dag complete`: implementation work still needs a real non-empty commit.

The command creates a tool-minted, tree-equal merge on master:
  parent1 = the current origin/master tip (your HEAD must match it)
  parent2 = the leaf task commit
  tree    = parent1's tree

That parent edge is the durable completion fact. Mandatory Ops-* trailers record
audit evidence and authorization so this case is distinguishable from dropped or
irrelevant work.

Guards fail closed: requires explicit --evidence https://... and
--authorization, refuses pending roots / epic tasks / decomposed nodes, checks
dependencies, and enforces active-claim ownership (unless --force). The command
changes only local HEAD. Publish with exactly 'task-dag publish'; the
server-side reconciler then removes frontier/active/blocked refs. Blocked leaves
are allowed and remain blocked until that durable-master reconciliation.
EOF
                return 0
                ;;
            *)
                if [ -z "$task_sha" ]; then
                    task_sha="$1"
                else
                    echo "Unknown option: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    [ -n "$task_sha" ] || { echo "Error: task SHA required" >&2; return 1; }
    validate_ops_trailer_value "--evidence" "$evidence" || return 1
    case "$evidence" in
        https://*) ;;
        *) echo "Error: --evidence must be an https:// URL pointing at durable evidence." >&2; return 1 ;;
    esac
    case "$evidence" in
        *[[:space:]]*) echo "Error: --evidence URL must not contain whitespace." >&2; return 1 ;;
    esac
    validate_ops_trailer_value "--authorization" "$authorization" || return 1
    if [ -n "$reason" ]; then
        validate_ops_trailer_value "--reason" "$reason" || return 1
    fi

    if [ "$assume_yes" != true ]; then
        if [ -t 0 ] && [ -t 1 ]; then
            printf 'Complete ops-only task %s without an implementation commit? [y/N] ' "$task_sha"
            local ans=""
            read -r ans
            case "$ans" in
                y|Y|yes|YES|Yes) ;;
                *) echo "complete-ops: aborted (no confirmation)." >&2; return 1 ;;
            esac
        else
            echo "Error: non-interactive complete-ops callers must pass --yes." >&2
            return 2
        fi
    fi

    _xrepo_ensure_git_identity

    task_sha=$(resolve_sha "$task_sha") || return 1
    local short_sha
    short_sha=$(git rev-parse --short "$task_sha")

    if ! is_task_commit "$task_sha"; then
        echo "Error: $short_sha is not an empty-tree task commit; complete-ops only completes task-dag leaves." >&2
        return 1
    fi

    if ! fetch_task_refs_strict; then
        echo "Error: cannot sync task refs from origin; refusing complete-ops on a partial DAG view." >&2
        return 2
    fi
    if ! git fetch --quiet --no-tags origin '+refs/heads/master:refs/remotes/origin/master' >/dev/null 2>&1; then
        echo "Error: cannot fetch origin/master; refusing complete-ops without an authoritative base." >&2
        return 2
    fi
    local origin_master current_head
    origin_master=$(git rev-parse --verify origin/master) || return 2
    current_head=$(git rev-parse --verify HEAD^{commit}) || return 1
    taskdag_consumer_prepare complete-ops --tip "$origin_master" || return 2
    local complete_rc=0
    taskdag_task_is_complete_prepared "$task_sha" || complete_rc=$?
    [ "$complete_rc" -ne 2 ] || return 2
    if [ "$complete_rc" -eq 0 ]; then
        echo "Task $short_sha is already canonically complete (including supersedence); no ops completion created."
        return 0
    fi

    local task_type
    task_type=$(extract_field "$(parse_commit_metadata "$task_sha")" "Type" 2>/dev/null || true)
    if [ "$task_type" = epic ]; then
        echo "Error: complete-ops is for leaf tasks, not epic tasks. Decompose the epic or use close-ops-epic for an undecomposed ops-only root." >&2
        return 2
    fi

    local complete_issue="" rc_root=0
    complete_issue=$(task_is_pending_root "$task_sha") || rc_root=$?
    if [ "$rc_root" = 3 ]; then
        echo "Error: cannot verify whether ${short_sha} is a live epic root; refusing complete-ops while origin state is indeterminate." >&2
        return 2
    fi
    if [ -n "$complete_issue" ]; then
        echo "Error: ${short_sha} is the pending epic root for issue #${complete_issue}; complete-ops only completes leaves." >&2
        return 2
    fi
    if task_has_structural_children "$task_sha" >/dev/null; then
        echo "Error: ${short_sha} has DAG child tasks; complete the children instead of marking the structural parent done." >&2
        return 2
    fi

    # A strict first-parent completion witness is an idempotent local recovery
    # token. Check it before claim ownership so a replacement claim cannot make
    # an already-prepared local completion fail.
    local local_existing
    local_existing=$(completion_merge_for_task_at_commit HEAD "$task_sha" 2>/dev/null || true)
    if [ -n "$local_existing" ]; then
        echo "Task $short_sha already has a local completion at ${local_existing:0:12}; no new commit created."
        print_completion_push_instruction
        return 0
    fi

    local existing
    existing=$(completion_merge_for_task_at_commit "$origin_master" "$task_sha" 2>/dev/null || true)
    if [ -n "$existing" ]; then
        if ! git log -1 --format='%B' "$existing" \
            | git interpret-trailers --parse 2>/dev/null \
            | grep -qE '^Ops-Completion:[[:space:]]*true$'; then
            echo "Task $short_sha is already completed on origin/master by a non-ops completion (${existing:0:12}); not minting another completion."
        else
            echo "Task $short_sha already has an ops completion on origin/master; no new commit created."
        fi
        print_completion_push_instruction
        return 0
    fi

    local verified_active_sha
    verified_active_sha=$(verify_task_claim_ownership "$task_sha" "$short_sha" "$do_force") || return $?

    if [ "$current_head" != "$origin_master" ]; then
        echo "Error: HEAD must equal freshly-fetched origin/master for complete-ops." >&2
        echo "       Rebase/sync first so the no-code completion cannot publish unrelated local commits." >&2
        return 2
    fi

    if ! deps_satisfied_at_commit "$origin_master" "$task_sha"; then
        echo "Error: Dependencies not met for task $task_sha on origin/master" >&2
        local dep
        while IFS= read -r dep; do
            [ -z "$dep" ] && continue
            if task_is_completed_at_commit "$origin_master" "$dep"; then
                echo "  ✓ ${dep:0:12} completed"
            else
                echo "  ✗ ${dep:0:12} not completed"
            fi
        done < <(get_dep_parents "$task_sha")
        return 2
    fi

    local task_msg issue_num issue_url task_title now claimer host msg_file tree new_commit
    task_msg=$(parse_commit_metadata "$task_sha")
    issue_num=$(extract_field "$task_msg" "Issue" | sed 's/^#//')
    issue_url=$(extract_field "$task_msg" "URL")
    task_title=$(get_task_title "$task_sha")
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    claimer="${TASK_DAG_CLAIMER:-${USER:-unknown}}"
    host="${TASK_DAG_CLAIMER_HOST:-$(hostname -s 2>/dev/null || echo unknown)}"
    validate_ops_trailer_value "Ops-Completed-By" "$claimer" || return 1
    validate_ops_trailer_value "Ops-Completed-Host" "$host" || return 1
    msg_file=$(mktemp)
    {
        printf 'Complete ops-only task %s (no code change)\n' "$short_sha"
        printf '\n'
        printf 'Task "%s" was resolved by an out-of-band operations action.\n' "$task_title"
        printf 'There is intentionally no implementation commit to link; this\n'
        printf 'tree-equal merge records the task commit as a non-primary parent so\n'
        printf 'normal task-dag completion/dependency readers see a durable done fact.\n'
        printf '\n'
        printf 'Task-Commit: %s\n' "$task_sha"
        [ -n "$issue_num" ] && printf 'Issue: #%s\n' "$issue_num"
        [ -n "$issue_url" ] && printf 'URL: %s\n' "$issue_url"
        printf 'Status: completed\n'
        printf 'Ops-Completion: true\n'
        printf 'Ops-Evidence: %s\n' "$evidence"
        printf 'Ops-Authorization: %s\n' "$authorization"
        [ -n "$reason" ] && printf 'Ops-Reason: %s\n' "$reason"
        printf 'Ops-Completed-By: %s\n' "$claimer"
        printf 'Ops-Completed-Host: %s\n' "$host"
        printf 'Ops-Completed-At: %s\n' "$now"
        [ -n "$issue_url" ] && printf 'Related: %s\n' "$issue_url"
    } > "$msg_file"

    tree=$(git rev-parse "${origin_master}^{tree}") || { rm -f "$msg_file"; return 1; }
    new_commit=$(git commit-tree "$tree" -p "$origin_master" -p "$task_sha" -F "$msg_file") || { rm -f "$msg_file"; return 1; }
    rm -f "$msg_file"

    taskdag_consumer_prepare complete-ops-pre-head --tip "$origin_master" || return 2
    taskdag_completion_allowed "$task_sha" || {
        echo "Error: task became complete or its requirements changed before HEAD advance; refusing ops completion." >&2
        return 2
    }
    advance_head_to_completion "$origin_master" "$new_commit" || return 1
    echo "Created ops completion commit: $new_commit"

    local close_rc=0
    maybe_emit_local_epic_close "$task_sha" || close_rc=$?
    if [ "$close_rc" -eq "$TASKDAG_MIGRATION_EXIT" ]; then
        echo "completion recorded; epic close deferred by migration drain"
    elif [ "$close_rc" -ne 0 ]; then return "$close_rc"; fi

    printf "${GREEN}✓ Ops task completed: %s${RESET}\n" "$task_title"
    print_completion_push_instruction
    return 0
}

# Command: complete --leaves — DAG-native BATCH completion of several
# sibling leaves implemented as a stack of commits in ONE worktree.
#
# Each completion merge's FIRST parent is that leaf's implementation commit
# (docs/DESIGN_PRINCIPLES.md); to keep that true for a whole stack, we graft
# a completion merge directly above each impl and REPLAY the commits stacked
# above onto it, producing an honest linear graph:
#     origin/master → S → M_S → C' → M_C → …
# This rewrites LOCAL, UNPUSHED commits only (proven against a freshly
# fetched origin/master); the final tree equals HEAD's, so the worktree/
# index are untouched, the old tip stays in the reflog + a backup ref, and
# the later `task-dag publish` is still a fast-forward.
#   $1 = leaves spec ("<leaf>:<impl>,<leaf>:<impl>,…")
#   $2 = do_force (true|false)
cmd_complete_batch() {
    local spec="$1" do_force="$2"

    # ── parse the spec into parallel arrays ──────────────────────────
    local -a leaves=() impls=()
    local -a _pairs=()
    IFS=',' read -ra _pairs <<< "$spec"
    local pair leaf impl
    for pair in "${_pairs[@]}"; do
        [ -n "$pair" ] || continue
        case "$pair" in
            *:*) leaf="${pair%%:*}"; impl="${pair#*:}" ;;
            *) echo "Error: --leaves entry '$pair' must be '<leaf>:<impl>'." >&2; return 1 ;;
        esac
        if [ -z "$leaf" ] || [ -z "$impl" ]; then
            echo "Error: --leaves entry '$pair' has an empty leaf or impl." >&2; return 1
        fi
        leaves+=("$leaf"); impls+=("$impl")
    done
    local n=${#leaves[@]}
    if [ "$n" -lt 1 ]; then
        echo "Error: --leaves is empty; expected '<leaf>:<impl>[,<leaf>:<impl>...]'." >&2; return 1
    fi

    # ── strict origin/master fetch (authoritative "unpushed" proof) ──
    if ! git fetch --quiet --no-tags origin \
            '+refs/heads/master:refs/remotes/origin/master' >/dev/null 2>&1; then
        echo "Error: could not fetch origin/master; refusing the batch graft (cannot prove the" >&2
        echo "       commits are unpushed). Retry when origin is reachable." >&2
        return 2
    fi
    local origin_master old_head
    origin_master=$(git rev-parse --verify origin/master 2>/dev/null) || {
        echo "Error: origin/master not resolvable; refusing batch graft." >&2; return 2; }
    old_head=$(git rev-parse --verify HEAD^{commit}) || return 1

    # ── resolve leaves + impls to full shas ──────────────────────────
    local -a task_shas=() impl_shas=() short_shas=()
    local i
    for (( i=0; i<n; i++ )); do
        local ts is
        ts=$(resolve_sha "${leaves[i]}") || { echo "Error: cannot resolve leaf '${leaves[i]}'." >&2; return 1; }
        is=$(git rev-parse --verify "${impls[i]}^{commit}" 2>/dev/null) || {
            echo "Error: cannot resolve impl '${impls[i]}' for leaf '${leaves[i]}'." >&2; return 1; }
        task_shas+=("$ts"); impl_shas+=("$is"); short_shas+=("$(git rev-parse --short "$ts")")
    done
    taskdag_consumer_prepare complete-batch-origin --tip "$origin_master" || return 2
    for (( i=0; i<n; i++ )); do
        local complete_rc=0
        taskdag_task_is_complete_prepared "${task_shas[i]}" || complete_rc=$?
        [ "$complete_rc" -ne 2 ] || return 2
        if [ "$complete_rc" -eq 0 ]; then
            echo "Error: leaf ${short_shas[i]} is already canonically complete (including supersedence); refusing the batch." >&2
            return 2
        fi
    done

    # ── de-dupe: distinct leaves AND distinct impls ──────────────────
    local a b
    for (( a=0; a<n; a++ )); do
        for (( b=a+1; b<n; b++ )); do
            if [ "${task_shas[a]}" = "${task_shas[b]}" ]; then
                echo "Error: leaf ${short_shas[a]} is listed twice." >&2; return 1
            fi
            if [ "${impl_shas[a]}" = "${impl_shas[b]}" ]; then
                echo "Error: leaves ${short_shas[a]} and ${short_shas[b]} name the same impl commit" >&2
                echo "       (${impl_shas[a]:0:12}); each leaf needs its own implementation commit." >&2
                return 1
            fi
        done
    done

    # Strict local/durable completion witnesses make reruns no-op before claim
    # checks or stale-HEAD guards. A partial batch remains fail-closed.
    local local_done=0 durable_done=0
    for (( i=0; i<n; i++ )); do
        completion_merge_for_task_at_commit HEAD "${task_shas[i]}" >/dev/null 2>&1 \
            && local_done=$((local_done+1))
        completion_merge_for_task_at_commit "$origin_master" "${task_shas[i]}" >/dev/null 2>&1 \
            && durable_done=$((durable_done+1))
    done
    if [ "$local_done" -eq "$n" ]; then
        echo "All ${n} leaves already have local completions; no new commits created."
        print_completion_push_instruction
        return 0
    elif [ "$local_done" -gt 0 ]; then
        echo "Error: ${local_done}/${n} leaves already have local completions; refusing a partial batch." >&2
        return 2
    fi
    if [ "$durable_done" -eq "$n" ]; then
        echo "All ${n} leaves are already completed on origin/master; no new commits created."
        print_completion_push_instruction
        return 0
    elif [ "$durable_done" -gt 0 ]; then
        echo "Error: ${durable_done}/${n} leaves are already completed on origin/master; refusing a partial batch." >&2
        return 2
    fi

    if ! git merge-base --is-ancestor "$origin_master" "$old_head"; then
        echo "Error: HEAD is not ahead of origin/master; rebase onto origin/master first." >&2
        return 2
    fi

    # ── commit-subject style backstop for EVERY impl before mutation ──
    # Same canon rule as single-leaf complete (rules/WORKFLOW.md). Report
    # ALL offending impl subjects up front so the operator fixes them in one
    # pass, and refuse before any graft/link side effect.
    local -a _bad_subjects=()
    for (( i=0; i<n; i++ )); do
        local _s; _s=$(git show -s --format='%s' "${impl_shas[i]}")
        if subject_is_conventional_commits "$_s"; then
            _bad_subjects+=("${impl_shas[i]:0:12}  $_s")
        fi
    done
    if [ ${#_bad_subjects[@]} -gt 0 ]; then
        printf '%b' "${RED}" >&2
        echo "════════════════════════════════════════════════════════════════════" >&2
        echo " task-dag: refusing --leaves complete — Conventional-Commits subject(s)" >&2
        echo "════════════════════════════════════════════════════════════════════" >&2
        local _b
        for _b in "${_bad_subjects[@]}"; do echo "   • $_b" >&2; done
        echo "" >&2
        echo " Canon (rules/WORKFLOW.md 'Commit messages') requires a plain," >&2
        echo " capitalized, imperative subject — never a type(scope): prefix." >&2
        echo " Amend the offending implementation commit(s) and re-run." >&2
        echo "════════════════════════════════════════════════════════════════════" >&2
        printf '%b' "${RESET}" >&2
        return 1
    fi

    # ── claim-ownership guard for EVERY leaf before any mutation ──────
    local -a verified_active=()
    for (( i=0; i<n; i++ )); do
        local va
        va=$(verify_task_claim_ownership "${task_shas[i]}" "${short_shas[i]}" "$do_force") || return $?
        verified_active+=("$va")
    done

    # ── the replay range origin/master..HEAD must be LINEAR ──────────
    if [ -n "$(git rev-list --min-parents=2 "$origin_master..$old_head" 2>/dev/null)" ]; then
        echo "Error: origin/master..HEAD contains merge commits; the batch graft only rewrites a" >&2
        echo "       LINEAR stack of implementation commits. Complete leaves individually or" >&2
        echo "       resolve manually (do NOT hand-roll ref surgery)." >&2
        return 2
    fi
    local -a chain=()
    mapfile -t chain < <(git rev-list --reverse "$origin_master..$old_head")
    local -A chain_pos=()
    local idx=0 c
    for c in "${chain[@]}"; do chain_pos["$c"]=$idx; idx=$((idx+1)); done

    # ── every impl must be an unpushed range commit doing real work ──
    for (( i=0; i<n; i++ )); do
        if [ -z "${chain_pos[${impl_shas[i]}]+set}" ]; then
            echo "Error: impl ${impl_shas[i]:0:12} (leaf ${short_shas[i]}) is not an unpushed commit in" >&2
            echo "       origin/master..HEAD. If it is already on master, use 'complete-historical';" >&2
            echo "       otherwise point --leaves at the correct implementation commit." >&2
            return 2
        fi
        if is_task_commit "${impl_shas[i]}"; then
            echo "Error: impl ${impl_shas[i]:0:12} (leaf ${short_shas[i]}) is a task/control commit, not real work." >&2
            return 1
        fi
        local it ipar ibt
        it=$(git rev-parse "${impl_shas[i]}^{tree}")
        ipar=$(get_first_parent "${impl_shas[i]}" 2>/dev/null || true)
        if [ -n "$ipar" ]; then ibt=$(git rev-parse "$ipar^{tree}"); else ibt="$EMPTY_TREE"; fi
        if [ "$it" = "$ibt" ]; then
            echo "Error: impl ${impl_shas[i]:0:12} (leaf ${short_shas[i]}) introduces no tree change vs its" >&2
            echo "       first parent; it is not a real implementation commit." >&2
            return 1
        fi
    done

    # ── epic-root guard: a leaf must not be a decomposed epic root ───
    for (( i=0; i<n; i++ )); do
        local ci="" rrc=0
        ci=$(task_is_pending_root "${task_shas[i]}") || rrc=$?
        if [ "$rrc" = 3 ]; then
            echo "Error: cannot verify whether ${short_shas[i]} is an epic root (origin unreachable)." >&2
            return 2
        fi
        if [ -n "$ci" ]; then
            echo "Error: ${short_shas[i]} is the epic ROOT for issue #$ci; --leaves completes leaves, not roots." >&2
            return 2
        fi
    done

    # ── dependency check (design review option b): each leaf's deps must
    #    be satisfied by {already completed} ∪ {earlier in GRAFT order} ──
    local -a order=()
    mapfile -t order < <(
        for (( i=0; i<n; i++ )); do printf '%s %s\n' "${chain_pos[${impl_shas[i]}]}" "$i"; done | sort -n | awk '{print $2}'
    )
    batch_requirements_satisfied() {
        local -A completed_in_batch=()
        local oi dep deps requirements_status dep_complete
        for oi in "${order[@]}"; do
            requirements_status=$(taskdag_task_status_json "task:${TASKDAG_RECON_CUR}@${task_shas[oi]}" --include-claimed) || return 2
            [ "$(jq -r '.complete|not' <<<"$requirements_status")" = true ] || {
                echo "Error: leaf ${short_shas[oi]} became canonically complete; refusing a duplicate completion." >&2
                return 2
            }
            deps=$(jq -c '.requirements[]?' <<<"$requirements_status")
            while IFS= read -r dep; do
                [ -n "$dep" ] || continue
                dep_complete=$(jq -r .complete <<<"$dep")
                dep=$(jq -r .node <<<"$dep")
                [ "$dep_complete" = true ] && continue
                if [[ "$dep" = task:${TASKDAG_RECON_CUR}@* ]] && [ -n "${completed_in_batch[${dep##*@}]+set}" ]; then continue; fi
                echo "Error: leaf ${short_shas[oi]} depends on ${dep}, which is neither already" >&2
                echo "       completed nor an earlier leaf (in graft order) in this batch." >&2
                echo "       Ensure the dependency's impl is stacked BELOW this leaf's impl." >&2
                return 2
            done <<< "$deps"
            completed_in_batch["${task_shas[oi]}"]=1
        done
    }
    batch_requirements_satisfied || return $?

    # ── graft: walk the chain oldest→newest, replaying each commit and
    #    inserting a completion merge immediately above each impl ──────
    local -A impl_idx=()
    for (( i=0; i<n; i++ )); do impl_idx["${impl_shas[i]}"]=$i; done
    local -a merge_for=()
    for (( i=0; i<n; i++ )); do merge_for+=(""); done
    local running="$origin_master"
    for c in "${chain[@]}"; do
        local cnew
        cnew=$(recommit_onto "$c" "$running") || {
            echo "Error: failed to replay commit ${c:0:12} during graft; no refs moved." >&2; return 1; }
        running="$cnew"
        if [ -n "${impl_idx[$c]+set}" ]; then
            local li="${impl_idx[$c]}"
            local msg mtree merge
            msg=$(build_completion_message "${task_shas[li]}" "$(git show -s --format=%B "$c")")
            mtree=$(git rev-parse "$cnew^{tree}")
            merge=$(git commit-tree "$mtree" -p "$cnew" -p "${task_shas[li]}" -m "$msg") || {
                echo "Error: failed to create completion merge for leaf ${short_shas[li]}; no refs moved." >&2; return 1; }
            running="$merge"
            merge_for[li]="$merge"
        fi
    done
    local new_tip="$running"

    # ── assert the graft is a pure reparent (tree unchanged) ─────────
    if [ "$(git rev-parse "$new_tip^{tree}")" != "$(git rev-parse "$old_head^{tree}")" ]; then
        echo "Internal error: grafted tip tree != HEAD tree; refusing to move HEAD (no refs touched)." >&2
        return 1
    fi

    # ── local recovery backup + single CAS advance of HEAD ───────────
    # The backup ref is MANDATORY: no backup, no rewrite. A local non-FF
    # rewrite of unpushed commits must always leave a named recovery ref
    # (belt-and-braces with the reflog) before HEAD moves.
    taskdag_consumer_prepare complete-batch-pre-head --tip "$old_head" || return 2
    batch_requirements_satisfied || return $?
    local backup_ref="refs/task-dag-backup/complete-batch/$(date +%s)-$$-${old_head:0:12}"
    if ! git update-ref -m 'task-dag complete --leaves: backup old HEAD' "$backup_ref" "$old_head" ""; then
        echo "Error: could not create recovery backup ref $backup_ref; refusing to rewrite HEAD (no refs moved)." >&2
        return 1
    fi
    if ! git update-ref -m 'task-dag complete --leaves: graft batch completions' HEAD "$new_tip" "$old_head"; then
        echo "Error: HEAD moved during batch complete; refusing (rerun). No task refs were cleaned." >&2
        git update-ref -d "$backup_ref" 2>/dev/null || true
        return 1
    fi
    printf "${GREEN}✓ Grafted %d completion merge(s) onto their impls; rewrote local unpushed commits.${RESET}\n" "$n"
    printf "  Old tip %s saved at %s (also recoverable via 'git reflog').\n" "${old_head:0:12}" "$backup_ref"

    local close_rc=0
    for (( i=0; i<n; i++ )); do
        maybe_emit_local_epic_close "${task_shas[i]}" || close_rc=$?
        if [ "$close_rc" -eq "$TASKDAG_MIGRATION_EXIT" ]; then
            echo "completion recorded; epic close deferred by migration drain"
            close_rc=0
        elif [ "$close_rc" -ne 0 ]; then return "$close_rc"; fi
    done
    for (( i=0; i<n; i++ )); do
        printf "${GREEN}✓ Task completed: %s${RESET}\n" "$(get_task_title "${task_shas[i]}")"
    done
    print_completion_push_instruction
    return 0
}

# Helper: page the operator (priority 2 / informational audit) that the
# retroactive historical-link path was used. Fail-soft like
# emit_operator_blocked_dispatch: a missing/failed page-dave never undoes
# a successful local link, but we tell the caller loudly so the operator
# can be told by hand.
#   $1=task_sha $2=short_sha $3=hist_sha $4=hist_short $5=link_commit
#   $6=issue_num $7=issue_url $8=task_title
page_retroactive_link() {
    local task_sha="$1" short_sha="$2" hist_sha="$3" hist_short="$4" \
          link_commit="$5" issue_num="$6" issue_url="$7" task_title="$8"

    if ! command -v page-dave >/dev/null 2>&1; then
        printf '%bNote: page-dave not found; the priority-2 retroactive-link audit page was NOT sent. Tell the operator manually that historical commit %s was linked to task %s.%b\n' \
            "$YELLOW" "$hist_short" "$short_sha" "$RESET" >&2
        return 0
    fi

    # owner/repo for building commit links — prefer the issue URL, fall
    # back to the origin remote (handles the github-<repo> SSH aliases).
    local repo=""
    if [ -n "$issue_url" ]; then
        repo=$(printf '%s' "$issue_url" | sed -E 's|https?://github.com/([^/]+/[^/]+)/.*|\1|')
    fi
    if [ -z "$repo" ] || [ "$repo" = "$issue_url" ]; then
        local origin_url
        origin_url=$(git remote get-url origin 2>/dev/null || true)
        repo=$(parse_owner_repo_from_url "$origin_url")
    fi

    local hist_link="$hist_short"
    [ -n "$repo" ] && hist_link="https://github.com/$repo/commit/$hist_sha"

    local msg="RETROACTIVE ADMIN LINK (NOT normal task completion). Repo ${repo:-unknown}: historical commit ${hist_short} was linked after-the-fact to task ${short_sha} \"${task_title}\""
    [ -n "$issue_num" ] && msg="${msg} on issue #${issue_num}"
    msg="${msg}. The link commit ${link_commit:0:12} was created locally and is not yet authoritative or published; scheduling refs are unchanged. The caller was instructed to run task-dag publish. Historical commit: ${hist_link}."
    [ -n "$issue_url" ] && msg="${msg} Issue: ${issue_url}."

    # Flags BEFORE the message (ntfy stops parsing flags after the first
    # positional). Priority 2 = low/informational audit per the operator.
    local pd=(page-dave -p 2 --title "task-dag: retroactive historical commit link" --tags memo)
    [ -n "$issue_url" ] && pd+=(--click "$issue_url")
    if "${pd[@]}" "$msg" >/dev/null 2>&1; then
        printf "${GREEN}✓ Paged operator (priority 2) about the retroactive link${RESET}\n"
    else
        printf '%bNote: page-dave failed; tell the operator manually that historical commit %s was linked to task %s.%b\n' \
            "$YELLOW" "$hist_short" "$short_sha" "$RESET" >&2
    fi
    return 0
}

# Command: complete-historical - retroactively link an ALREADY-LANDED
# historical commit on master to a task, as though it had been completed
# live, WITHOUT rewriting master history.
#
# This is an ADMINISTRATIVE RECOVERY path for the rare case where a worker
# "went rogue"/missed task-dag and landed real work on master without
# linking it to its task. It creates an empty (no file change) link commit
# on top of CURRENT HEAD whose 2nd parent is the task commit (so
# is_task_completed / close-completed-issues treat the task as done exactly
# like a live completion) and that records the real historical commit in a
# Historical-Commit: trailer. It is NOT for normal development — live work
# must use `task-dag complete` at commit time. Every use pages the operator
# (priority 2) for audit.
cmd_complete_historical() {
    local task_sha="" hist_sha="" do_force=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --commit=*) hist_sha="${1#*=}"; shift ;;
            --force) do_force=true; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag complete-historical <task-sha> --commit=<historical-sha> [--force]

ADMINISTRATIVE RECOVERY ONLY. Retroactively link an already-landed
historical commit on master to a task, as though it had been completed
live — WITHOUT rewriting master history. Use ONLY for historically missed
commits (a worker landed real work but never linked it to its task). For
all normal work, use 'task-dag complete' at commit time.

How it works:
  Creates an empty (no file change) link commit on top of CURRENT HEAD
  with the task as its 2nd parent (so the DAG marks the task done) and a
  Historical-Commit: <sha> trailer recording the real work. master history
  is preserved. The command changes only local HEAD; publish with exactly
  'task-dag publish'. The server reconciler cleans task refs only
  after the link is durable on master.

Required:
  <task-sha>        the pending task to mark done
  --commit=<sha>    the real historical implementation commit on master

Options:
  --force           proceed even if another worker holds the task's active
                    claim (only if that claim is known dead)

Guards: HEAD must be at origin/master; the historical commit must be a
real (non-empty) commit that is an ancestor of origin/master; the task
must not already be completed; an undecomposed epic root is refused.

The first successful link creation pages the operator at priority 2 for audit;
idempotent reruns do not page again.
EOF
                return 0 ;;
            *)
                if [ -z "$task_sha" ]; then task_sha="$1"; else
                    echo "Unknown option: $1" >&2; return 1; fi
                shift ;;
        esac
    done

    [ -n "$task_sha" ] || { echo "Error: task SHA required" >&2; return 1; }
    [ -n "$hist_sha" ] || { echo "Error: --commit=<historical-sha> required (the already-landed commit to link)" >&2; return 1; }

    task_sha=$(resolve_sha "$task_sha") || return 1
    hist_sha=$(resolve_sha "$hist_sha") || return 1

    # ── Operand validation ────────────────────────────────────────────
    if ! is_task_commit "$task_sha"; then
        echo "Error: $task_sha is not a task commit (expected an empty-tree task object)." >&2
        return 1
    fi
    if [ "$hist_sha" = "$task_sha" ]; then
        echo "Error: --commit cannot be the task commit itself." >&2
        return 1
    fi
    if is_task_commit "$hist_sha"; then
        echo "Error: --commit=$hist_sha is itself a task/control commit (empty tree), not real historical work." >&2
        return 1
    fi
    # The historical commit must represent REAL work: a tree change vs its
    # first parent (or vs the empty tree for a root commit). This rejects
    # no-diff completion/close/tombstone commits stronger than a bare
    # empty-commit check, and for a merge compares H^1..H (first parent).
    local hist_tree hist_parent hist_base_tree
    hist_tree=$(git rev-parse "$hist_sha^{tree}") || return 1
    hist_parent=$(get_first_parent "$hist_sha" 2>/dev/null || true)
    if [ -n "$hist_parent" ]; then
        hist_base_tree=$(git rev-parse "$hist_parent^{tree}") || return 1
    else
        hist_base_tree="$EMPTY_TREE"
    fi
    if [ "$hist_tree" = "$hist_base_tree" ]; then
        echo "Error: --commit=$hist_sha introduces no tree change vs its first parent; it is not a real historical implementation commit." >&2
        return 1
    fi

    # ── Commit-subject style: WARN only (do not block) ────────────────
    # Historical work predates / bypassed the commit-msg guard; refusing to
    # link it would strand real landed work. Flag it so the operator knows
    # the subject is off-canon, but proceed.
    local hist_subject; hist_subject=$(git show -s --format='%s' "$hist_sha")
    if subject_is_conventional_commits "$hist_subject"; then
        echo "${YELLOW}WARNING: historical commit ${hist_sha:0:12} has a Conventional-Commits subject:${RESET}" >&2
        echo "  $hist_subject" >&2
        echo "  Canon (rules/WORKFLOW.md) wants a plain, capitalized, imperative subject." >&2
        echo "  Linking it anyway (historical work is not rewritten)." >&2
    fi

    # ── Epic-root guard (same as complete): never link an undecomposed
    # root as if it were an implementation unit. ──
    local hist_issue="" rc_root=0
    hist_issue=$(task_is_pending_root "$task_sha") || rc_root=$?
    if [ "$rc_root" = 3 ]; then
        echo "Error: cannot verify whether ${task_sha:0:12} is a live epic root (origin" >&2
        echo "       unreachable and no local pending mirror). Refusing. Retry when online." >&2
        return 2
    fi
    if [ -n "$hist_issue" ]; then
        if ! fetch_root_refs "$hist_issue"; then
            echo "Error: cannot reach origin to verify issue #${hist_issue} root has no child" >&2
            echo "       tasks — refusing. Retry when online." >&2
            return 2
        fi
        if task_has_children "$task_sha" >/dev/null; then
            echo "Error: issue #${hist_issue} root has child tasks; link the leaves, not the root." >&2
            return 2
        fi
    fi

    # ── Dependency guard (same as complete): the task's dependency tasks
    # must themselves be completed/linked. ──
    taskdag_consumer_prepare complete-historical --tip HEAD || return 2
    if ! cmd_deps "$task_sha" --check-complete --no-fetch >/dev/null 2>&1; then
        echo "Error: dependencies not met for task $task_sha (its dependency tasks are not yet completed/linked)." >&2
        cmd_deps "$task_sha" --no-fetch >&2
        return 2
    fi

    # ── Authority: origin/master must be reachable + current, and the
    # historical commit must really be landed on it (fail closed). ──
    if ! git fetch --quiet --no-tags origin master 2>/dev/null; then
        echo "Error: cannot fetch origin master — refusing the historical link (fail closed). Retry when online." >&2
        return 2
    fi
    local origin_master head_sha
    origin_master=$(git rev-parse FETCH_HEAD) || return 1
    head_sha=$(git rev-parse HEAD) || return 1
    taskdag_consumer_prepare complete-historical-origin --tip "$origin_master" || return 2
    local complete_rc=0
    taskdag_task_is_complete_prepared "$task_sha" || complete_rc=$?
    [ "$complete_rc" -ne 2 ] || return 2
    if [ "$complete_rc" -eq 0 ]; then
        echo "Task ${task_sha:0:12} is already canonically complete (including supersedence); no historical link created." >&2
        return 0
    fi

    local local_existing
    local_existing=$(completion_merge_for_task_at_commit HEAD "$task_sha" 2>/dev/null || true)
    if [ -n "$local_existing" ]; then
        echo "Task ${task_sha:0:12} already has a local completion at ${local_existing:0:12}; no new link created." >&2
        print_completion_push_instruction
        return 0
    fi

    local durable_existing
    durable_existing=$(completion_merge_for_task_at_commit "$origin_master" "$task_sha" 2>/dev/null || true)
    if [ -n "$durable_existing" ]; then
        echo "Task ${task_sha:0:12} is already completed on origin/master at ${durable_existing:0:12}; no new link created." >&2
        print_completion_push_instruction
        return 0
    fi

    if [ "$head_sha" != "$origin_master" ]; then
        if git merge-base --is-ancestor "$origin_master" "$head_sha" 2>/dev/null; then
            echo "Error: HEAD ($head_sha) is AHEAD of origin/master ($origin_master)." >&2
            echo "If a previous complete-historical run created a link commit that was never" >&2
            echo "pushed, publish it with 'task-dag publish' instead of rerunning." >&2
            echo "Otherwise reset to origin/master in a fresh checkout and retry." >&2
        else
            echo "Error: HEAD ($head_sha) is not at origin/master ($origin_master)." >&2
            echo "complete-historical must run on a fresh checkout at the master tip; sync and retry." >&2
        fi
        return 2
    fi
    if ! git merge-base --is-ancestor "$hist_sha" "$origin_master" 2>/dev/null; then
        echo "Error: --commit=$hist_sha is not an ancestor of origin/master; it is not landed historical work on master." >&2
        return 2
    fi

    local short_sha
    short_sha=$(git rev-parse --short "$task_sha")

    # ── Honour the cross-host active-claim mutex. A historically-missed
    # task is usually unclaimed, but if a live worker holds it, refuse
    # (unless --force on a known-dead claim). ──
    local verified_active_sha
    verified_active_sha=$(verify_task_claim_ownership "$task_sha" "$short_sha" "$do_force") || return $?

    # ── Build the empty link commit on CURRENT HEAD (master tip). ──
    local issue_num issue_url task_title head_tree hist_short
    local task_msg
    task_msg=$(parse_commit_metadata "$task_sha")
    # Issue/URL are optional (legacy/hand-crafted tasks may lack them);
    # guard so a missing trailer never aborts under set -e/pipefail.
    issue_num=$(extract_field "$task_msg" "Issue" 2>/dev/null | sed 's/^#//' || true)
    issue_url=$(extract_field "$task_msg" "URL" 2>/dev/null || true)
    task_title=$(get_task_title "$task_sha")
    head_tree=$(git rev-parse "HEAD^{tree}") || return 1
    hist_short=$(git rev-parse --short "$hist_sha")

    local link_message="Retroactively link historical commit ${hist_short} to task ${short_sha}

ADMINISTRATIVE RECOVERY ONLY: task-dag missed linking already-landed work.
This empty link commit records, after the fact, that the real work for this
task was done in historical commit ${hist_sha}. Do NOT use this path for
normal live task completion — that must use 'task-dag complete' at commit time.

Task-Commit: $task_sha
Historical-Commit: $hist_sha
Retroactive: true"
    [ -n "$issue_num" ] && link_message="${link_message}
Issue: #$issue_num"
    [ -n "$issue_url" ] && link_message="${link_message}
URL: $issue_url"
    link_message="${link_message}
Status: completed"
    [ -n "$issue_url" ] && link_message="${link_message}

Related: $issue_url"

    local new_commit
    new_commit=$(git commit-tree "$head_tree" -p "$head_sha" -p "$task_sha" -m "$link_message")
    echo "Created retroactive link commit: $new_commit"

    # Pure ref move (base == HEAD, identical tree) — preserves master
    # history and any dirty worktree; no master rewrite.
    taskdag_consumer_prepare complete-historical-pre-head --tip "$head_sha" || return 2
    taskdag_completion_allowed "$task_sha" || {
        echo "Error: task became complete or its requirements changed before HEAD advance; refusing historical completion." >&2
        return 2
    }
    advance_head_to_completion "$head_sha" "$new_commit" || return 1

    # If this link finished a purely-local epic, append the local Closes-Epic
    # commit so the explicit push publishes both facts together.
    local close_rc=0
    maybe_emit_local_epic_close "$task_sha" || close_rc=$?
    if [ "$close_rc" -eq "$TASKDAG_MIGRATION_EXIT" ]; then
        echo "completion recorded; epic close deferred by migration drain"
    elif [ "$close_rc" -ne 0 ]; then return "$close_rc"; fi

    # ── LOUD audit banner ──
    printf '%b\n' "${YELLOW}" >&2
    echo "════════════════════════════════════════════════════════════════════" >&2
    echo " RETROACTIVE HISTORICAL LINK — administrative recovery only" >&2
    echo "════════════════════════════════════════════════════════════════════" >&2
    echo " This path is ONLY for historically missed commits: real work that" >&2
    echo " landed on master without being linked to its task. It is NOT the" >&2
    echo " normal workflow. ALL ongoing development must link work live with" >&2
    echo " 'task-dag complete' at commit time, never with complete-historical." >&2
    echo "" >&2
    echo "   task:               $short_sha  ($task_title)" >&2
    echo "   historical commit:  $hist_short  ($hist_sha)" >&2
    echo "   link commit:        $(git rev-parse --short "$new_commit")  (local; not yet published)" >&2
    [ -n "$issue_url" ] && echo "   issue:              $issue_url" >&2
    echo "════════════════════════════════════════════════════════════════════" >&2
    printf '%b' "${RESET}" >&2

    printf "${GREEN}✓ Retroactively linked task: %s${RESET}\n" "$task_title"

    # Audit page to the operator (priority 2). Fail-soft.
    page_retroactive_link "$task_sha" "$short_sha" "$hist_sha" "$hist_short" \
        "$new_commit" "$issue_num" "$issue_url" "$task_title"

    print_completion_push_instruction
    return 0
}

# Command: validate - validate DAG structure
cmd_validate() {
    local json=false
    local strict=false
    local audit=false
    local repo_opt=""
    local scope=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            # --strict promotes the invariant floor (empty tree + known
            # namespace) over the ENTIRE task/gh ref namespace into hard
            # ERRORS, so it can gate CI / a scheduled fleet audit. --all-refs
            # is an accepted alias (the strict walk is always all-refs).
            --strict|--all-refs) strict=true; shift ;;
            # --closed-issue-audit is the ONLY switch that makes validate go
            # live: it surfaces task refs whose GitHub issue is CONFIRMED
            # CLOSED (the top-level#48 lingering-ref debris). Default validate
            # and --strict stay 100% offline; this flag is strictly opt-in.
            --closed-issue-audit) audit=true; shift ;;
            --repo=*) repo_opt="${1#*=}"; shift ;;
            --help|-h)
                cat <<'EOF'
Usage: task-dag validate [scope] [--strict|--all-refs]
                         [--closed-issue-audit [--repo=owner/repo]] [--json]

Validate task-DAG structure.

Default: light structural checks (empty-tree task commits; frontier refs
are leaf/task-typed). Fully OFFLINE — no network, no gh.

--strict (alias --all-refs): audit EVERY ref under refs/heads/tasks/** and
refs/heads/gh/** against the grandfather-safe invariant floor and FAIL
(exit 3) on any violation:
  • the ref must point at an empty-tree commit, and
  • it must live under a KNOWN namespace.
An unknown namespace is the classic "I did the ref surgery by hand"
mistake — do NOT hand-craft task refs. See docs/INVARIANTS.md.
--strict is also fully OFFLINE and read-only.

--closed-issue-audit: the ONLY mode that goes LIVE. It surfaces (does NOT
delete) the lingering scheduling refs — tasks/frontier/<short>,
tasks/blocked/<sha>, tasks/blocked-meta/<sha> — of tasks whose GitHub issue
is CONFIRMED CLOSED, i.e. exactly what 'task-dag reconcile-closed-issue'
would clean (top-level#48). It:
  • does a strict sync of the task refs and confirms each issue's state
    live via 'gh issue view … --json state' (grouped: one call per unique
    issue), so it never assumes closed;
  • reports a CONFIRMED-CLOSED issue's lingering refs as ERRORS (exit 3),
    so a scheduled fleet audit can gate/page — run reconcile-closed-issue
    to clear them;
  • reports issues whose state could NOT be determined (gh missing/unauth/
    API error) as WARNINGS (coverage gap), never as errors — exit 0 means
    "no confirmed debris found", NOT "proved clean";
  • never reports pending/<N>, root-active/<N>, active/*, delegated/* or
    gh/comments/<N>/<id> refs.
  --repo=owner/repo overrides the repo (default: derived from origin) and
  is valid ONLY with --closed-issue-audit. Requires jq (and gh for the
  live state).

All modes are race-tolerant (a ref whose object vanishes mid-walk is
skipped, not failed) and NEVER mutate origin.
EOF
                return 0
                ;;
            *) scope="$1"; shift ;;
        esac
    done

    # --repo only makes sense for the live audit (it selects which repo's
    # issue state to confirm). Reject it elsewhere rather than silently
    # ignore it, so a mistaken invocation fails loud.
    if [ -n "$repo_opt" ] && [ "$audit" = false ]; then
        echo "Error: --repo is only valid with --closed-issue-audit" >&2
        return 2
    fi

    if [ "$json" = true ]; then require_jq_for_json || return 1; fi
    # The audit's canonical blocked resolution and JSON assembly both need jq
    # even without --json, so require it up front with a clear message.
    if [ "$audit" = true ] && ! command -v jq >/dev/null 2>&1; then
        echo "Error: jq is required for --closed-issue-audit" >&2
        return 2
    fi

    local errors=0
    local warnings=0
    
    if [ "$json" = false ]; then
        printf "${BOLD}Validating task DAG structure...${RESET}\n\n"
    fi
    
    # Check 1: All task commits have empty tree.
    # The data-in-tree refs (the dependency-graph index tasks/v1/graph and the
    # 16 cross-repo mailbox shards tasks/v1/mailbox/00..0f) are the exempt
    # refs — their trees ARE their data (the active edge set / in-flight
    # message set); their shape is audited by the --strict floor (Check 3),
    # not here.
    while read -r sha ref; do
        taskdag_is_graph_ref "$ref" && continue
        taskdag_is_mailbox_ref "$ref" && continue
        taskdag_is_materialisation_ref "$ref" && continue
        taskdag_is_materialisation_producer_ref "$ref" && continue
        taskdag_is_comment_watchdog_ref "$ref" && continue
        taskdag_is_activation_ref "$ref" && continue
        local tree
        tree=$(git rev-parse "$sha^{tree}" 2>/dev/null) || continue
        if [ "$tree" != "$EMPTY_TREE" ]; then
            errors=$((errors + 1))
            [ "$json" = false ] && printf "${RED}✗${RESET} Task $sha ($ref) has non-empty tree\n"
        fi
    done < <(list_task_refs)
    
    # Check 2: Frontier refs point only to leaf-type tasks.
    # NOTE: read from a process substitution (NOT a pipe) so the warnings
    # counter mutated here lives in THIS shell, not a subshell that is
    # discarded when the pipeline ends (the historical counter-loss bug).
    while read -r sha ref; do
        # Blocked tasks are intentionally parked; don't flag their type.
        if is_task_blocked "$sha"; then
            continue
        fi
        local msg type
        # Guard the object read: a frontier ref pointing at a non-commit
        # (blob/tag) or a pruned object must NOT crash validate under
        # `set -e` — skip it here so the strict audit (Check 3) can report
        # it properly instead of the whole command dying with rc=1.
        msg=$(parse_commit_metadata "$sha" 2>/dev/null) || continue
        # Ingested human comments are valid frontier leaves but use the
        # message dialect (`kind: message`) with no `Type:` field — don't
        # flag them as mistyped.
        if extract_field "$msg" "kind" | grep -q '^message$'; then
            continue
        fi
        type=$(extract_field "$msg" "Type")
        if [ "$type" != "leaf" ] && [ "$type" != "task" ]; then
            warnings=$((warnings + 1))
            [ "$json" = false ] && printf "${YELLOW}⚠${RESET} Frontier task $sha is type '$type', expected 'leaf' or 'task'\n"
        fi
    done < <(git for-each-ref refs/heads/tasks/frontier/ --format='%(objectname) %(refname:short)')

    # Check 3 (--strict only): full-namespace invariant-floor audit.
    # Snapshot the refs in a SINGLE for-each-ref so concurrent claim/
    # complete/drop can't make the walk inconsistent, then check each. A
    # ref whose object vanished after the snapshot is skipped (see
    # taskdag_ref_violations), so the gate never flaps under fleet churn.
    if [ "$strict" = true ]; then
        # Walk the WHOLE tasks/ and gh/ namespaces (not just the known
        # sub-namespaces) so a hand-crafted ref at an UNKNOWN path is
        # actually seen and flagged — restricting the snapshot to known
        # namespaces would make the unknown-namespace check dead code.
        local snapshot line vsha vref out activation_authority expected_repository=""
        snapshot=$(git for-each-ref --format='%(objectname) %(refname)' \
            refs/heads/tasks/ refs/heads/gh/)
        activation_authority=$(awk -v ref="$TASKDAG_ACTIVATION_REF" '$2==ref {print $1}' <<<"$snapshot")
        if grep -q " $TASKDAG_MATERIALISATION_REF$" <<<"$snapshot"; then
            expected_repository=$(printf '%s' "$(_xrepo_current_repo_offline 2>/dev/null)" | tr '[:upper:]' '[:lower:]')
            if [ -z "$expected_repository" ]; then
                errors=$((errors + 1))
                [ "$json" = false ] && printf "${RED}✗ cannot resolve current repository for strict materialisation validation${RESET}\n"
            fi
        fi
        while read -r vsha vref; do
            [ -n "$vsha" ] || continue
            out=$(taskdag_ref_violations "$vsha" "$vref" "$activation_authority" "$expected_repository")
            [ -n "$out" ] || continue
            while IFS= read -r line; do
                errors=$((errors + 1))
                [ "$json" = false ] && printf "${RED}%s${RESET}\n" "$line"
            done <<< "$out"
        done <<< "$snapshot"
    fi

    # ── Closed-issue audit (--closed-issue-audit ONLY): LIVE, opt-in ─────
    # Everything above is OFFLINE. Nothing below runs unless the operator
    # explicitly asked for the audit, so plain `validate` / `validate
    # --strict` never touch the network. This mode SURFACES (never deletes)
    # the lingering scheduling refs of CONFIRMED-CLOSED issues; it shares the
    # ONE candidate resolver with reconcile-closed-issue so the two agree.
    local audit_json="null"
    if [ "$audit" = true ]; then
        # Resolve THIS repo: --repo overrides, else derive from origin.
        local a_repo="$repo_opt"
        if [ -z "$a_repo" ]; then
            local a_remote; a_remote=$(git remote get-url origin 2>/dev/null || echo "")
            a_repo=$(parse_owner_repo_from_url "$a_remote")
        fi

        if [ -z "$a_repo" ]; then
            errors=$((errors + 1))
            [ "$json" = false ] && printf "${RED}✗${RESET} closed-issue audit: could not determine owner/repo (pass --repo=owner/repo); audit incomplete\n"
            audit_json=$(jq -nc \
                '{complete:false, repo:null, reason:"repo-undetermined",
                  lingering:[], undetermined:[],
                  counts:{issuesChecked:0, closedWithLingeringRefs:0, lingeringRefs:0, undetermined:0}}')
        elif ! fetch_task_refs_strict 2>/dev/null; then
            # A partial/stale local view could FALSE-CLEAN (miss lingering
            # refs) — the exact bug this audit exists to catch — so a sync
            # failure is a hard audit error, not a warning.
            errors=$((errors + 1))
            [ "$json" = false ] && printf "${RED}✗${RESET} closed-issue audit: could not sync task refs from origin; audit incomplete\n"
            audit_json=$(jq -nc --arg repo "$a_repo" \
                '{complete:false, repo:$repo, reason:"fetch-failed",
                  lingering:[], undetermined:[],
                  counts:{issuesChecked:0, closedWithLingeringRefs:0, lingeringRefs:0, undetermined:0}}')
        else
            local a_rows a_rc=0
            a_rows=$(closed_issue_candidate_rows "$a_repo") || a_rc=$?
            if [ "$a_rc" -ne 0 ]; then
                errors=$((errors + 1))
                [ "$json" = false ] && printf "${RED}✗${RESET} closed-issue audit: could not enumerate task refs ('blocked --json' failed/invalid); audit incomplete\n"
                audit_json=$(jq -nc --arg repo "$a_repo" \
                    '{complete:false, repo:$repo, reason:"enumeration-failed",
                      lingering:[], undetermined:[],
                      counts:{issuesChecked:0, closedWithLingeringRefs:0, lingeringRefs:0, undetermined:0}}')
            else
                # Group candidates by issue so we hit gh at most ONCE per
                # unique issue (rate-limit friendly). Only numeric issues are
                # queryable; a non-numeric/underivable candidate is skipped.
                declare -A A_REFS=() A_SHAS=()
                local cr_repo cr_issue cr_sha cr_ref cr_kind
                while IFS=$'\t' read -r cr_repo cr_issue cr_sha cr_ref cr_kind; do
                    [ -n "$cr_issue" ] || continue
                    A_REFS["$cr_issue"]+="${cr_ref}"$'\n'
                    case " ${A_SHAS[$cr_issue]:-} " in
                        *" $cr_sha "*) ;;
                        *) A_SHAS["$cr_issue"]+="$cr_sha " ;;
                    esac
                done <<< "$a_rows"

                local -a lingering_objs=() undet_objs=()
                local n_issues=0 n_closed=0 n_lref=0 n_undet=0
                local iss st st_rc
                for iss in "${!A_REFS[@]}"; do
                    [[ "$iss" =~ ^[0-9]+$ ]] || continue
                    n_issues=$((n_issues + 1))
                    st_rc=0
                    st=$(issue_state_remote "$a_repo" "$iss") || st_rc=$?
                    if [ "$st_rc" -ne 0 ]; then
                        n_undet=$((n_undet + 1)); warnings=$((warnings + 1))
                        undet_objs+=("$(jq -nc --argjson issue "$iss" \
                            '{issue:$issue, reason:"undetermined-issue-state"}')")
                        [ "$json" = false ] && printf "${YELLOW}⚠${RESET} closed-issue audit: ${a_repo}#${iss} state undetermined (gh missing/unauth/API error); could not check\n"
                        continue
                    fi
                    [ "$st" = "CLOSED" ] || continue
                    # CONFIRMED CLOSED with lingering refs => debris => error.
                    local refs_list refs_json shas_json nrefs
                    refs_list=$(printf '%s' "${A_REFS[$iss]}" | sed '/^$/d')
                    nrefs=$(printf '%s\n' "$refs_list" | grep -c . || true)
                    refs_json=$(printf '%s\n' "$refs_list" | jq -R . | jq -sc 'map(select(length>0))')
                    shas_json=$(printf '%s\n' ${A_SHAS[$iss]:-} | jq -R . | jq -sc 'map(select(length>0))')
                    lingering_objs+=("$(jq -nc --argjson issue "$iss" \
                        --argjson refs "$refs_json" --argjson shas "$shas_json" \
                        '{issue:$issue, state:"CLOSED", refs:$refs, shas:$shas}')")
                    n_closed=$((n_closed + 1))
                    n_lref=$((n_lref + nrefs))
                    errors=$((errors + 1))
                    if [ "$json" = false ]; then
                        printf "${RED}✗${RESET} closed-issue audit: ${a_repo}#${iss} is CLOSED but has %d lingering task ref(s) (run reconcile-closed-issue):\n" "$nrefs"
                        local rl
                        while IFS= read -r rl; do
                            [ -n "$rl" ] && printf "      %s\n" "$rl"
                        done <<< "$refs_list"
                    fi
                done

                local lingering_arr='[]' undet_arr='[]' complete_json=true
                [ "${#lingering_objs[@]}" -gt 0 ] && lingering_arr=$(printf '%s\n' "${lingering_objs[@]}" | jq -sc .)
                [ "${#undet_objs[@]}" -gt 0 ] && undet_arr=$(printf '%s\n' "${undet_objs[@]}" | jq -sc .)
                [ "$n_undet" -gt 0 ] && complete_json=false
                audit_json=$(jq -nc --arg repo "$a_repo" --argjson complete "$complete_json" \
                    --argjson lingering "$lingering_arr" --argjson undet "$undet_arr" \
                    --argjson issues "$n_issues" --argjson closed "$n_closed" \
                    --argjson lrefs "$n_lref" --argjson undetc "$n_undet" \
                    '{complete:$complete, repo:$repo, reason:null,
                      lingering:$lingering, undetermined:$undet,
                      counts:{issuesChecked:$issues, closedWithLingeringRefs:$closed,
                              lingeringRefs:$lrefs, undetermined:$undetc}}')
            fi
        fi
    fi

    if [ "$json" = true ]; then
        local valid=false
        [ "$errors" -eq 0 ] && valid=true
        if [ "$audit" = true ]; then
            jq -nc --argjson errors "$errors" --argjson warnings "$warnings" \
                --argjson strict "$strict" --argjson valid "$valid" \
                --argjson audit "$audit_json" \
                '{errors:$errors,warnings:$warnings,strict:$strict,valid:$valid,closedIssueAudit:$audit}'
        else
            # Preserve the exact pre-existing --json shape when not auditing.
            jq -nc --argjson errors "$errors" --argjson warnings "$warnings" \
                --argjson strict "$strict" --argjson valid "$valid" \
                '{errors:$errors,warnings:$warnings,strict:$strict,valid:$valid}'
        fi
    else
        echo ""
        if [ $errors -eq 0 ]; then
            printf "${GREEN}✓ Validation passed${RESET} ($warnings warnings)\n"
        else
            printf "${RED}✗ Validation failed${RESET} ($errors errors, $warnings warnings)\n"
        fi
    fi
    
    [ $errors -eq 0 ] && return 0 || return 3
}

# True only when the cwd's `origin` remote is a real GitHub remote (URL with
# a github host + scheme). The fleet's checkouts use https://github.com/… or
# the `git@github-<repo>:owner/repo` SSH host aliases ephemeral_checkout
# configures. Fixture tests use a local bare-repo PATH (no scheme), so this
# auto-skips them — the same seam emit_operator_blocked_dispatch relies on to
# stay hermetic. Used to gate the AUTOMATIC completion-comment post (an
# unconditional side-effect of `complete`); the explicit `comment` /
# `issue-update` commands are user-invoked and post regardless.
_is_real_github_origin() {
    local origin_url
    origin_url=$(git remote get-url origin 2>/dev/null || true)
    case "$origin_url" in
        https://github.com/*|http://github.com/*|git@github*:*|ssh://*github*/*|git://*github*/*) return 0 ;;
        *) return 1 ;;
    esac
}

# ─────────────────────────────────────────────────────────────────────
# Resolve a GitHub API token for the sanctioned comment poster(s).
#
# Order: $GITHUB_TOKEN -> $GH_TOKEN -> `gh auth token`. This is the
# load-bearing fix that lets `task-dag comment` (and issue-update /
# complete's progress post) actually work in the worker/agent environment,
# where GITHUB_TOKEN is UNSET and GitHub auth is provided by the `gh` CLI's
# own store (~/.config/gh/hosts.yml). In CI / the materialise-child-epic
# App flow GITHUB_TOKEN *is* set, so it is preferred and `gh` (which may not
# be logged in there) is never consulted. Both gho_/ghs_ tokens work with
# the `Authorization: token …` header. $GH_TOKEN is gh's own convention and
# some CI sets only it.
#
# ⚠ DO NOT "simplify" the posters to `gh api …/comments` / `gh issue
# comment`: the agent runtime prepends a gh-guard shim to PATH that BLOCKS
# `gh` comment writes (github-worker shims/gh, canon rules/WORKFLOW.md), so
# the sanctioned tool would block ITSELF. Posting via curl + a resolved
# token is the design that coexists with that shim — the shim passes
# `gh auth token` through, but blocks comment writes.
#
# Cached in _RESOLVED_GITHUB_TOKEN so a single command (e.g. cmd_comment,
# which does an existence GET then a POST) resolves the token only once.
# ─────────────────────────────────────────────────────────────────────
_RESOLVED_GITHUB_TOKEN=""
_resolve_github_token() {
    if [ -n "$_RESOLVED_GITHUB_TOKEN" ]; then
        printf '%s' "$_RESOLVED_GITHUB_TOKEN"; return 0
    fi
    local tok="${GITHUB_TOKEN:-}"
    [ -z "$tok" ] && tok="${GH_TOKEN:-}"
    if [ -z "$tok" ] && command -v gh >/dev/null 2>&1; then
        tok="$(gh auth token 2>/dev/null || true)"
    fi
    [ -n "$tok" ] || return 1
    _RESOLVED_GITHUB_TOKEN="$tok"
    printf '%s' "$tok"
}

# ─────────────────────────────────────────────────────────────────────
# Shared GitHub-issue comment poster.
#
# _post_issue_comment <owner/repo> <issue-number> <body-with-REAL-newlines>
#
# JSON-encodes the body SAFELY with jq (so arbitrary agent-supplied text —
# quotes, backslashes, real newlines, control chars — cannot break the
# request or inject fields; the old hand-rolled `-d "{\"body\":\"$x\"}"`
# broke on any `"`/`\` in the body and only survived by feeding itself
# controlled `\n`-literal strings), resolves a token via
# _resolve_github_token, POSTs via the GitHub API, and prints the created
# comment's html_url on success. Returns 0 on HTTP 201, else 1 (echoing the
# API error to stderr). This is the ONE place task-dag turns a body into an
# issue comment — every caller (comment / issue-update / complete) routes
# here so encoding, auth, and timeouts are identical.
#
# NOTE: call this in a CONDITION context (`url=$(_post_issue_comment …) ||
# …`, or `if _post_issue_comment …; then`). That disables errexit through
# its body, so a curl failure degrades to the `http_code != 201` error path
# instead of aborting the script — load-bearing for cmd_complete's
# fail-softness. Do NOT invoke it bare under `set -e`.
# ─────────────────────────────────────────────────────────────────────
_post_issue_comment() {
    local repo="$1" issue="$2" body="$3"
    local payload api_url response http_code resp_body token
    if ! command -v jq >/dev/null 2>&1; then
        echo "Error: 'jq' is required to post issue comments but was not found on PATH" >&2
        return 1
    fi
    if ! token="$(_resolve_github_token)"; then
        echo "Error: no GitHub token available. Set GITHUB_TOKEN/GH_TOKEN, or run" >&2
        echo "       'gh auth login' (the worker env authenticates via the gh CLI)." >&2
        return 1
    fi
    payload=$(jq -n --arg b "$body" '{body:$b}') || {
        echo "Error: failed to JSON-encode comment body" >&2
        return 1
    }
    api_url="https://api.github.com/repos/${repo}/issues/${issue}/comments"
    response=$(curl -s --max-time 30 -w $'\n%{http_code}' -X POST "$api_url" \
        -H "Authorization: token ${token}" \
        -H "Accept: application/vnd.github+json" \
        -d "$payload")
    http_code=$(printf '%s' "$response" | tail -n1)
    resp_body=$(printf '%s' "$response" | sed '$d')
    if [ "$http_code" = "201" ]; then
        printf '%s' "$resp_body" | jq -r '.html_url // empty' 2>/dev/null || true
        return 0
    fi
    echo "Error: failed to post comment to ${repo}#${issue} (HTTP ${http_code})" >&2
    printf '%s\n' "$resp_body" >&2
    return 1
}

# Command: comment - post a convention-enforcing comment to a GitHub issue.
#
# THE single sanctioned way for an agent to post an issue comment. It always
# stamps a leading `<!-- task-dag:<kind> -->` marker so the comment-sync
# ingest can never turn it into a phantom pickable task (the comment→task
# dispatch loop). Agents must NOT call `gh issue comment` / the raw API by
# hand — see canon rules/WORKFLOW.md and docs/INVARIANTS.md.
cmd_comment() {
    local target="" kind="" body="" body_file="" repo_opt="" dry_run=false
    local have_body=false have_body_file=false

    # $1 is the flag; require a value arg or fail cleanly (avoids `shift 2`
    # aborting the whole script under `set -u`/pipefail on a dangling flag).
    _need_val() { [ $# -ge 2 ] || { echo "Error: $1 requires a value" >&2; return 2; }; }
    while [ $# -gt 0 ]; do
        case "$1" in
            --kind=*)      kind="${1#*=}"; shift ;;
            --kind)        _need_val "$@" || return 2; kind="$2"; shift 2 ;;
            --body=*)      body="${1#*=}"; have_body=true; shift ;;
            --body)        _need_val "$@" || return 2; body="$2"; have_body=true; shift 2 ;;
            --body-file=*) body_file="${1#*=}"; have_body_file=true; shift ;;
            --body-file)   _need_val "$@" || return 2; body_file="$2"; have_body_file=true; shift 2 ;;
            --issue=*)     target="${1#*=}"; shift ;;
            --issue)       _need_val "$@" || return 2; target="$2"; shift 2 ;;
            --repo=*)      repo_opt="${1#*=}"; shift ;;
            --repo)        _need_val "$@" || return 2; repo_opt="$2"; shift 2 ;;
            --dry-run)     dry_run=true; shift ;;
            --help|-h)
                cat <<'EOF'
Usage: task-dag comment <issue|task-sha> --kind=<status|operator-decision> \
                        (--body=TEXT | --body-file=PATH) [--repo=owner/repo] [--dry-run]

Post a comment to a GitHub issue THROUGH task-dag so it carries the correct
machine marker and can never be mis-ingested as a new task. This is the ONLY
sanctioned way for an agent to comment on a task-managed issue — do NOT call
`gh issue comment` or the raw API by hand.

Target (one of):
  <task-sha>          a task commit; its issue/repo are resolved from metadata
  <N> or #N           an issue number (repo from --repo or the origin remote)
  --issue=N           same as passing N positionally

Kinds (required; fail-closed):
  status              non-actionable progress/handoff note
  operator-decision   a note that needs the operator to read/decide (still
                      non-actionable as a task; pair with `block` + page-dave)
  completion          NOT allowed here — cross-repo completion is emitted only
                      by the automated `Satisfies:` trailer flow.

Body (exactly one of):
  --body=TEXT         inline body
  --body-file=PATH    read body from a file (use --body-file=- to read STDIN).
                      PREFER this for large/multi-line bodies — it avoids the
                      shell-quoting pain of a big inline --body.

The tool stamps the marker; your body must NOT contain a `<!-- task-dag:` marker.
--dry-run prints the resolved target (stderr) and the exact final body (stdout)
and posts nothing. Re-running posts again (no dedup).
EOF
                return 0
                ;;
            -*) echo "Error: unknown option: $1" >&2; return 2 ;;
            *)
                if [ -z "$target" ]; then target="$1"; else
                    echo "Error: unexpected argument: $1" >&2; return 2
                fi
                shift ;;
        esac
    done

    # ---- validate kind (fail-closed) ----
    case "$kind" in
        status|operator-decision) ;;
        completion)
            echo "Error: --kind=completion is not allowed here. Cross-repo completion" >&2
            echo "       is emitted only by the automated 'Satisfies:' trailer flow." >&2
            return 2 ;;
        "")
            echo "Error: --kind is required (status|operator-decision)" >&2
            return 2 ;;
        *)
            echo "Error: unknown --kind '$kind' (expected status|operator-decision)" >&2
            return 2 ;;
    esac

    # ---- resolve target -> repo + issue number ----
    [ -n "$target" ] || { echo "Error: a target issue number or task sha is required" >&2; return 2; }
    local issue_num="" repo="" issue_url=""
    if [[ "$target" =~ ^#?[0-9]+$ ]]; then
        issue_num="${target#\#}"
        repo="$repo_opt"
        if [ -z "$repo" ]; then
            local remote_url
            remote_url=$(git remote get-url origin 2>/dev/null || echo "")
            repo=$(parse_owner_repo_from_url "$remote_url")
        fi
    else
        local task_sha task_msg
        task_sha=$(resolve_sha "$target") || {
            echo "Error: '$target' is neither an issue number nor a resolvable task sha" >&2
            return 2
        }
        task_msg=$(parse_commit_metadata "$task_sha")
        issue_num=$(extract_field "$task_msg" "Issue" | sed 's/^#//')
        issue_url=$(extract_field "$task_msg" "URL")
        if [ -n "$repo_opt" ]; then
            repo="$repo_opt"
        elif [ -n "$issue_url" ]; then
            repo=$(printf '%s' "$issue_url" | sed -E 's|https://github.com/([^/]+/[^/]+)/.*|\1|')
        fi
        [ -n "$issue_num" ] || { echo "Error: task $target has no Issue number" >&2; return 2; }
    fi
    [ -n "$issue_num" ] || { echo "Error: could not determine the issue number" >&2; return 2; }
    [ -n "$repo" ] || { echo "Error: could not determine owner/repo; pass --repo=owner/repo" >&2; return 2; }
    # Fail-closed on anything that would land unsanitized in a GitHub API URL —
    # this is the single sanctioned writer, so keep it strict.
    [[ "$issue_num" =~ ^[0-9]+$ ]] || { echo "Error: resolved issue '$issue_num' is not a number" >&2; return 2; }
    [[ "$repo" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]] || { echo "Error: resolved repo '$repo' is not owner/repo" >&2; return 2; }

    # ---- read + normalize body ----
    if [ "$have_body" = true ] && [ "$have_body_file" = true ]; then
        echo "Error: pass exactly one of --body / --body-file" >&2; return 2
    fi
    if [ "$have_body" = false ] && [ "$have_body_file" = false ]; then
        echo "Error: a body is required (--body=TEXT or --body-file=PATH)" >&2; return 2
    fi
    local raw
    if [ "$have_body_file" = true ]; then
        if [ "$body_file" = "-" ]; then
            # Reading STDIN interactively would hang; agent runners feed
            # /dev/null (caught by the empty-body check), but guard a TTY.
            [ -t 0 ] && { echo "Error: --body-file=- but STDIN is a TTY (pipe/heredoc the body)" >&2; return 2; }
            raw=$(cat)   # read body from STDIN
        else
            [ -r "$body_file" ] || { echo "Error: cannot read body file: $body_file" >&2; return 2; }
            raw=$(cat "$body_file")
        fi
    else
        raw="$body"
    fi

    # Normalize: strip a UTF-8 BOM, CRLF/CR -> LF, drop leading blank lines.
    # Command substitution strips trailing newlines, so trailing blank lines
    # go too. The result is the body that will sit BELOW the marker line.
    local normalized
    normalized=$(printf '%s' "$raw" | tr -d '\r' | sed '1s/^\xEF\xBB\xBF//' | sed '/./,$!d')

    if [ -z "$(printf '%s' "$normalized" | tr -d '[:space:]')" ]; then
        echo "Error: comment body is empty (whitespace-only) after normalization" >&2; return 2
    fi
    # Reject any embedded task-dag marker (space/case-flexible) — the tool is the
    # single writer of the marker; one marker per comment.
    if printf '%s' "$normalized" | grep -qiE '<!--[[:space:]]*task-dag:'; then
        echo "Error: body may not contain a '<!-- task-dag:' marker — the tool stamps" >&2
        echo "       the marker itself (one marker per comment, one writer)." >&2
        return 2
    fi

    # ---- stamp marker + assemble final body (marker ALWAYS physical line 1) ----
    local marker
    case "$kind" in
        status)            marker="<!-- task-dag:status -->" ;;
        operator-decision) marker="<!-- task-dag:operator-decision -->" ;;
    esac
    local final
    final=$(printf '%s\n\n%s\n' "$marker" "$normalized")

    # GitHub rejects comments over 65536 chars; fail before the API does.
    if [ "${#final}" -gt 65536 ]; then
        echo "Error: final comment body is ${#final} chars (>65536 GitHub limit)." >&2
        echo "       Shorten it, or publish the detail as a one-off and link it (see" >&2
        echo "       agent-kb/runbooks/publish-long-output-one-off.md)." >&2
        return 2
    fi

    if [ "$dry_run" = true ]; then
        echo "[dry-run] would post to ${repo}#${issue_num} (kind=${kind})" >&2
        printf '%s\n' "$final"
        return 0
    fi

    # Resolve in THIS (main) shell so the _RESOLVED_GITHUB_TOKEN cache is
    # populated for the _post_issue_comment subshell below — one `gh auth
    # token`, not two (existence GET + POST).
    if ! _resolve_github_token >/dev/null; then
        echo "Error: no GitHub token available. Set GITHUB_TOKEN/GH_TOKEN, or run" >&2
        echo "       'gh auth login' (the worker env authenticates via the gh CLI)." >&2
        return 1
    fi
    local token="$_RESOLVED_GITHUB_TOKEN"

    # Confirm the issue exists before posting (catches a wrong bare number
    # or wrong repo before we write to the wrong place). Authenticated so
    # private repos resolve and we are not rate-limited to 60/hr/IP.
    # `|| check_code=000` keeps a curl failure (DNS, timeout) from aborting
    # the whole script under errexit — it degrades to the not-reachable path.
    local check_code
    check_code=$(curl -s --max-time 30 -o /dev/null -w '%{http_code}' \
        -H "Authorization: token ${token}" \
        -H "Accept: application/vnd.github+json" \
        "https://api.github.com/repos/${repo}/issues/${issue_num}") || check_code="000"
    if [ "$check_code" != "200" ]; then
        echo "Error: issue ${repo}#${issue_num} not reachable (HTTP ${check_code})" >&2
        return 1
    fi

    # Show the resolved target before writing (a bare number with no --repo
    # resolves from the CWD's origin; this makes a wrong-repo mistake visible
    # instead of silently posting to the wrong issue).
    echo "Posting ${kind} comment to ${repo}#${issue_num} …" >&2

    local url
    url=$(_post_issue_comment "$repo" "$issue_num" "$final") || return 1
    printf "${GREEN}✓ Posted %s comment to %s#%s${RESET}\n" "$kind" "$repo" "$issue_num"
    [ -n "$url" ] && echo "$url"
    return 0
}

# Command: issue-update - update GitHub issue with task progress
cmd_issue_update() {
    local task_sha=""
    local status=""
    local dry_run=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status=*) status="${1#*=}"; shift ;;
            --dry-run) dry_run=true; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag issue-update <task-sha> [--status=completed|blocked|in-progress] [--dry-run]

Update GitHub issue with task progress.

Options:
  --status=STATUS    Task status (completed, blocked, in-progress)
  --dry-run          Print what would be done without making API calls
EOF
                return 0
                ;;
            *)
                if [ -z "$task_sha" ]; then
                    task_sha="$1"
                else
                    echo "Unknown option: $1" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done
    
    if [ -z "$task_sha" ]; then
        echo "Error: task SHA required" >&2
        return 1
    fi
    
    task_sha=$(resolve_sha "$task_sha") || return 1
    
    local task_msg=$(parse_commit_metadata "$task_sha")
    local issue_num=$(extract_field "$task_msg" "Issue" | sed 's/^#//')
    local issue_url=$(extract_field "$task_msg" "URL")
    local task_title=$(get_task_title "$task_sha")
    local short_sha=$(git rev-parse --short "$task_sha")
    
    if [ -z "$issue_num" ]; then
        echo "Error: Task has no Issue number" >&2
        return 1
    fi
    
    # Extract repo from issue URL or git remote
    local repo=""
    if [ -n "$issue_url" ]; then
        repo=$(echo "$issue_url" | sed -E 's|https://github.com/([^/]+/[^/]+)/.*|\1|')
    else
        # Try to get owner/repo from the origin remote URL (handles the
        # github-<repo> SSH host aliases prepared/ephemeral worktrees use).
        local remote_url=$(git remote get-url origin 2>/dev/null || echo "")
        repo=$(parse_owner_repo_from_url "$remote_url")
    fi
    
    if [ -z "$repo" ]; then
        echo "Error: Could not determine GitHub repository" >&2
        return 1
    fi
    
    # Determine status message. The `<!-- task-dag:status -->` marker MUST be
    # physical line 1 so the comment-sync ingest skips this agent-generated
    # status post instead of turning it into a new pickable frontier task
    # (which would create a worker dispatch loop). Build with REAL newlines:
    # the body goes through _post_issue_comment's jq encoder, so literal `\n`
    # two-char sequences would render verbatim in the comment.
    local status_msg="${status:-pending}"
    local status_line
    case "$status_msg" in
        completed)   status_line="✓ Status: **Completed**" ;;
        blocked)     status_line="⚠️ Status: **Blocked**" ;;
        in-progress) status_line="🔄 Status: **In Progress**" ;;
        *)           status_line="Status: $status_msg" ;;
    esac
    local comment_body
    comment_body=$(printf '%s\n%s\n\n%s' \
        "<!-- task-dag:status -->" \
        "Task [\`$short_sha\`](${issue_url:-https://github.com/$repo/issues/$issue_num}) **$task_title**" \
        "$status_line")

    if [ "$dry_run" = true ]; then
        echo "Would post to issue #$issue_num in $repo:"
        echo "$comment_body"
        return 0
    fi

    # Single sanctioned poster: safe jq encoding + token resolution
    # (GITHUB_TOKEN/GH_TOKEN/`gh auth token`) + timeout, all in one place.
    local url
    url=$(_post_issue_comment "$repo" "$issue_num" "$comment_body") || return 1
    printf "${GREEN}✓ Posted status comment to %s#%s${RESET}\n" "$repo" "$issue_num"
    [ -n "$url" ] && echo "$url"
    return 0
}

# ── Operator-blocked dashboard event emitter ──────────────────────────
# After a block/unblock/complete/drop changes a BLOCKED ref, POST a
# repository_dispatch to the dashboard repo so the operator-blocked #29
# "one-stop shop" dashboard rebuilds within seconds. This is the latency
# path the operator approved (the dashboard workflow's schedule is only a
# self-healing backstop; see virusdave/top-level#29 and the epic plan).
#
# Best-effort by design: the leased ref push above is the source of truth,
# so a missing/failed dispatch only means the change shows up on the next
# scheduled rebuild instead of within seconds — it must NEVER abort the
# command or change its exit status (fail-soft, with a clear note). Uses the
# ambient authenticated `gh` (the worker host's GitHub auth), the same
# mechanism the CLI already uses for its other GitHub API calls; no App
# private key is distributed to workers.
#
# Safe in the fixture tests automatically: they use a local bare-repo
# origin, and this fires only for a real network GitHub remote. Override
# with TASK_DAG_DASHBOARD_DISPATCH_REPO (unset = default virusdave/top-level;
# empty = disabled).
emit_operator_blocked_dispatch() {
    local action="$1"            # block|unblock|complete|drop (observability)
    local source_sha="${2:-}"
    local repo="${TASK_DAG_DASHBOARD_DISPATCH_REPO-virusdave/top-level}"
    [ -n "$repo" ] || return 0   # explicitly disabled

    local origin_url
    origin_url=$(git remote get-url origin 2>/dev/null || true)
    # Only fire from a real GitHub remote. The fleet's checkouts use either
    # https://github.com/... or the `git@github-<repo>:owner/repo` SSH host
    # ALIASES that ephemeral_checkout configures (e.g. git@github-task-dag:),
    # so we match a github host with a URL scheme — which also auto-skips the
    # fixture tests (their origin is a local bare-repo PATH, no scheme). A
    # test seam (TASK_DAG_DASHBOARD_DISPATCH_FORCE=1, default off) bypasses
    # this gate so the firing path can be exercised against a local origin.
    if [ "${TASK_DAG_DASHBOARD_DISPATCH_FORCE:-0}" != "1" ]; then
        case "$origin_url" in
            https://github.com/*|http://github.com/*|git@github*:*|ssh://*github*/*|git://*github*/*) : ;;
            *) return 0 ;;
        esac
    fi

    if ! command -v gh >/dev/null 2>&1; then
        printf "%bNote: gh not found; skipped the #29 dashboard refresh (it will update on the next scheduled rebuild).%b\n" "$YELLOW" "$RESET" >&2
        return 0
    fi

    # owner/repo of the repo the change happened in, for log/debug only.
    local source_repo
    source_repo=$(parse_owner_repo_from_url "$origin_url")

    # Cap the call so a network stall never hangs the worker (timeout is
    # optional — degrade to a direct call if coreutils timeout is absent).
    local runner=(gh)
    command -v timeout >/dev/null 2>&1 && runner=(timeout 15 gh)

    if "${runner[@]}" api -X POST "repos/$repo/dispatches" \
            -f event_type=operator-blocked-changed \
            -f "client_payload[action]=$action" \
            -f "client_payload[source_repo]=$source_repo" \
            -f "client_payload[task]=$source_sha" >/dev/null 2>&1; then
        return 0
    fi
    printf "%bNote: could not trigger the #29 dashboard refresh (it will still update on the next scheduled rebuild).%b\n" "$YELLOW" "$RESET" >&2
    return 0
}

# Command: block - park a task so workers won't pick it up (but it's not closed)
cmd_block() {
    local task_sha="" reason="" request_url="" kind=""
    local kind_set=false reason_set=false request_url_set=false
    local on_nodes=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reason=*) reason="${1#*=}"; reason_set=true; shift ;;
            --request-url=*) request_url="${1#*=}"; request_url_set=true; shift ;;
            --on)
                [ $# -ge 2 ] || { echo "Error: --on requires a <node> value" >&2; return 1; }
                on_nodes+=("$2"); shift 2 ;;
            --on=*) on_nodes+=("${1#*=}"); shift ;;
            --operator)
                if [ "$kind_set" = true ] && [ "$kind" != "operator" ]; then
                    echo "Error: --operator and --downstream are mutually exclusive" >&2; return 1; fi
                kind="operator"; kind_set=true; shift ;;
            --downstream)
                if [ "$kind_set" = true ] && [ "$kind" != "downstream" ]; then
                    echo "Error: --operator and --downstream are mutually exclusive" >&2; return 1; fi
                kind="downstream"; kind_set=true; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag block <sha> [--operator|--downstream] [--reason="..."]
                            [--request-url=URL] [--on <node> ...]

Mark a task BLOCKED. It stays in the DAG and is listable (task-dag
blocked), but workers will NOT pick it up. Use this when a task is
stalled awaiting operator input or a downstream dependency, instead of
repeatedly posting status comments (which get ingested as new pickable
tasks and create a worker dispatch loop).

Classification (drives the operator-blocked #29 dashboard):
  --operator     parked awaiting operator action/decision (DEFAULT)
  --downstream   parked awaiting a downstream/delegated dependency

Durable metadata (recorded at refs/heads/tasks/blocked-meta/<sha>):
  --reason="..."     why it is parked (shown on the dashboard)
  --request-url=URL  link to the exact comment/decision the operator needs

Downstream dependency edge (issue #13 north-star; --on implies
--downstream, and is rejected with --operator):
  --on <node>        the task REQUIRES <node> to complete before it is
                     ready — DUAL-WRITE: in addition to the legacy blocked
                     overlay, mint a \`requires\` edge (from=this task,
                     to=<node>) in this repo's graph index tasks/v1/graph,
                     so the dependency is machine-readable. Repeatable for
                     several downstream deps (requires = ALL). Nodes are full
                     canonical addresses: task:<owner>/<repo>@<hex> or
                     issue:<owner>/<repo>#<N>. (Automatic auto-revive of the
                     block when every --on edge is satisfied is the separate
                     reconciler-backstop sibling task; today the block stays
                     manual — 'task-dag unblock <sha>' clears it.)

The blocked overlay ref (refs/heads/tasks/blocked/<sha>) is unchanged;
the metadata is additive side data and is cleared by unblock/complete/
drop. Re-running block updates the metadata idempotently (preserving the
original block time/actor). Reverse with 'task-dag unblock <sha>'.
EOF
                return 0 ;;
            *)
                if [ -z "$task_sha" ]; then task_sha="$1"; else
                    echo "Unknown option: $1" >&2; return 1; fi
                shift ;;
        esac
    done
    [ -n "$task_sha" ] || { echo "Error: task SHA required" >&2; return 1; }
    task_sha=$(resolve_sha "$task_sha") || return 1

    # --on <node> is a DOWNSTREAM-dependency block: it implies --downstream and
    # conflicts with --operator. Validate the edge prerequisites UP FRONT (a
    # bad node or an unresolvable current repo must never leave a block parked
    # with no edge to auto-revive it later): normalize every --on node and
    # resolve this repo (the edge's FROM repo) before we touch any ref.
    local edge_from_repo="" cnode_on=()
    if [ "${#on_nodes[@]}" -gt 0 ]; then
        if [ "$kind_set" = true ] && [ "$kind" = "operator" ]; then
            echo "Error: --on (a downstream dependency) is incompatible with --operator" >&2; return 1; fi
        kind="downstream"; kind_set=true
        edge_from_repo=$(taskdag_current_repo 2>/dev/null || true)
        [ -n "$edge_from_repo" ] || { echo "Error: --on needs this repo's canonical owner/repo to mint the edge; set TASKDAG_CURRENT_REPO or 'git config taskdag.current-repo owner/repo'" >&2; return 1; }
        local on n
        for on in "${on_nodes[@]}"; do
            n=$(taskdag_normalize_node "$on") || { echo "Error: invalid --on node: $on (use task:<owner>/<repo>@<hex> or issue:<owner>/<repo>#<N>)" >&2; return 1; }
            cnode_on+=("$n")
        done
    fi

    local blocked_ref meta_ref
    blocked_ref=$(blocked_ref_for "$task_sha")
    meta_ref=$(blocked_meta_ref_for "$task_sha")

    # Sync the overlay+meta from origin first so we (a) preserve the most
    # recent remote block time/actor/reason on a re-block and (b) don't act
    # on a stale local ref that origin has already unblocked (--prune drops
    # it). Mirrors `claim`, which also fetches before mutating.
    fetch_task_refs

    local already_blocked=false
    is_task_blocked "$task_sha" && already_blocked=true

    # Identity/time of the parking. On a re-block we PRESERVE the original
    # block time/actor/host (read from the existing meta) so the operation
    # is idempotent, and we preserve any prior classification/reason/url
    # the caller did not re-specify (so a bare re-block never silently
    # drops earlier context).
    local now actor host
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    actor="${TASK_DAG_CLAIMER:-${USER:-unknown}}"
    host="${TASK_DAG_CLAIMER_HOST:-$(hostname -s 2>/dev/null || echo unknown)}"

    if has_blocked_meta "$task_sha"; then
        local prev
        prev=$(read_blocked_meta_field "$task_sha" "Blocked-At"); [ -n "$prev" ] && now="$prev"
        prev=$(read_blocked_meta_field "$task_sha" "Blocked-By"); [ -n "$prev" ] && actor="$prev"
        prev=$(read_blocked_meta_field "$task_sha" "Blocked-Host"); [ -n "$prev" ] && host="$prev"
        if [ "$kind_set" = false ]; then
            prev=$(read_blocked_meta_field "$task_sha" "Blocker-Kind"); [ -n "$prev" ] && kind="$prev"
        fi
        if [ "$reason_set" = false ]; then
            reason=$(read_blocked_meta_field "$task_sha" "Reason")
        fi
        if [ "$request_url_set" = false ]; then
            request_url=$(read_blocked_meta_field "$task_sha" "Request-URL")
        fi
    fi
    # Default classification: operator action. The #29 dashboard exists to
    # surface operator blockers, and `block` is canonically paired with
    # `page-dave` once for an operator stall; a purely downstream-dependency
    # block opts out with --downstream.
    [ -n "$kind" ] || kind="operator"

    # Derive the source repo/issue/url from the task commit itself so the
    # dashboard can link back without reparsing commit bodies.
    local repo issue source_url
    IFS=$'\t' read -r repo issue source_url < <(derive_task_origin "$task_sha")

    local new_meta
    new_meta=$(build_blocked_meta_commit "$task_sha" "$kind" "$reason" "$request_url" \
        "$repo" "$issue" "$source_url" "$actor" "$host" "$now")

    # ── Push overlay + meta to origin atomically, leased ───────────────
    # The meta ref is a MUTABLE side ref: a refined re-block (new kind /
    # reason / url) builds a SIBLING commit of the old meta, so a plain
    # push would be a non-fast-forward update and silently rejected.
    # Lease each ref to the exact value origin has right now, push the
    # object SHAs, and only move the LOCAL refs after origin confirms — so
    # a concurrent unblock/re-block can never be clobbered, and we never
    # report success when origin was not updated (fail loud per canon).
    local remote_blocked remote_meta lease_args=() refspecs=()
    remote_blocked=$(git ls-remote origin "$blocked_ref" 2>/dev/null | awk '{print $1; exit}')
    remote_meta=$(git ls-remote origin "$meta_ref" 2>/dev/null | awk '{print $1; exit}')

    if [ -n "$remote_blocked" ]; then
        if [ "$remote_blocked" != "$task_sha" ]; then
            echo "Error: $blocked_ref points at $remote_blocked, not task $task_sha (collision?). Refusing to block." >&2
            return 3
        fi
        lease_args+=("--force-with-lease=$blocked_ref:$remote_blocked")
    fi
    refspecs+=("$task_sha:$blocked_ref")
    if [ -n "$remote_meta" ]; then
        lease_args+=("--force-with-lease=$meta_ref:$remote_meta")
    fi
    refspecs+=("$new_meta:$meta_ref")

    local block_push_rc=0 block_updates
    taskdag_consumer_prepare block-pre-cas || return 3
    if [ "$TASKDAG_CONSUMER_MODE" = canonical ]; then
        block_updates=$(jq -ncS \
            --arg br "$blocked_ref" --arg bo "$remote_blocked" --arg bn "$task_sha" \
            --arg mr "$meta_ref" --arg mo "$remote_meta" --arg mn "$new_meta" \
            '[{ref:$br,old:$bo,new:$bn},{ref:$mr,old:$mo,new:$mn}] | sort_by(.ref)') || return 3
        taskdag_consumer_fenced_scheduling_push block "$actor" "$block_updates" || block_push_rc=$?
    else
        git push --atomic origin "${lease_args[@]}" "${refspecs[@]}" 2>/dev/null || block_push_rc=$?
    fi
    if [ "$block_push_rc" -eq 0 ]; then
        # Origin is authoritative now — sync local refs to match.
        git update-ref "$blocked_ref" "$task_sha"
        git update-ref "$meta_ref" "$new_meta"
        if [ "$already_blocked" = true ]; then
            printf "${GREEN}✓ Updated block metadata:${RESET} %s\n" "$(get_task_title "$task_sha")"
        else
            printf "${GREEN}✓ Blocked task:${RESET} %s\n" "$(get_task_title "$task_sha")"
        fi
        echo "  Kind: $kind"
        [ -n "$reason" ] && echo "  Reason: $reason"
        [ -n "$request_url" ] && echo "  Request: $request_url"
        emit_operator_blocked_dispatch block "$(git rev-parse --short "$task_sha")"

        # DUAL-WRITE (issue #13): with --on, ALSO mint a `requires` edge from
        # this task to each downstream node in the per-repo graph index. The
        # legacy blocked overlay (pushed above) still drives behavior; the
        # edge is the machine-readable dependency the reconciler will later
        # use to auto-revive. Edges come AFTER the authoritative block push so
        # a failed edge leaves the safer state (task parked). Each edge is
        # idempotent by edge-id, so a rerun of the SAME command converges.
        if [ "${#cnode_on[@]}" -gt 0 ]; then
            local from_node="task:${edge_from_repo}@${task_sha}" on erc=0
            for on in "${cnode_on[@]}"; do
                _cmd_dep_add --from "$from_node" --to "$on" --relation requires \
                    --reason "block --downstream: $(git rev-parse --short "$task_sha") awaits ${on}" || erc=$?
            done
            if [ "$erc" -ne 0 ]; then
                printf "${RED}✗ Task is BLOCKED, but a downstream dependency edge write failed.${RESET}\n" >&2
                echo "  Re-run the same 'task-dag block ... --on ...' to converge the edge (idempotent)." >&2
                return 5
            fi
        fi
        return 0
    fi

    # Push failed (a lease mismatch = origin changed under us, or network).
    # The task is NOT durably parked, so do NOT update local refs or claim
    # success — another worker could still pick it up. Resync and report.
    printf "${RED}✗ Failed to block %s on origin (it changed under us, or push failed).${RESET}\n" "$(get_task_title "$task_sha")" >&2
    echo "Re-run 'task-dag block $(git rev-parse --short "$task_sha")' after checking 'task-dag blocked'." >&2
    fetch_task_refs
    return 4
}

# Command: unblock - make a previously-blocked task pickable again
cmd_unblock() {
    local task_sha=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) echo "Usage: task-dag unblock <sha>"; return 0 ;;
            *)
                if [ -z "$task_sha" ]; then task_sha="$1"; else
                    echo "Unknown option: $1" >&2; return 1; fi
                shift ;;
        esac
    done
    [ -n "$task_sha" ] || { echo "Error: task SHA required" >&2; return 1; }
    task_sha=$(resolve_sha "$task_sha") || return 1

    local blocked_ref meta_ref
    blocked_ref=$(blocked_ref_for "$task_sha")
    meta_ref=$(blocked_meta_ref_for "$task_sha")
    # Sync from origin so a fresh checkout sees the parked state (and a
    # remotely-resolved one is pruned) before deciding it is "not blocked".
    fetch_task_refs
    if ! is_task_blocked "$task_sha" && ! has_blocked_meta "$task_sha"; then
        printf "${YELLOW}Task is not blocked:${RESET} %s\n" "$(get_task_title "$task_sha")"
        return 0
    fi

    # Overlay semantics: deleting the blocked ref restores whatever
    # pickability the task already had (its pending/frontier ref is
    # untouched by block/unblock). The blocked-meta side data is cleared
    # in lockstep so a revived task carries no stale "why parked" record.
    #
    # Each remote deletion is LEASED to the exact value origin has now, so
    # a concurrent re-block/refinement (which moves the meta ref to a new
    # sibling commit) is never silently clobbered: a lease mismatch fails
    # the push instead. We push deletions only for refs that exist (a
    # legacy block has no meta ref; an interrupted block may have only one).
    local remote_blocked remote_meta lease_args=() refspecs=()
    remote_blocked=$(git ls-remote origin "$blocked_ref" 2>/dev/null | awk '{print $1; exit}')
    remote_meta=$(git ls-remote origin "$meta_ref" 2>/dev/null | awk '{print $1; exit}')
    if [ -n "$remote_blocked" ]; then
        lease_args+=("--force-with-lease=$blocked_ref:$remote_blocked")
        refspecs+=(":$blocked_ref")
    fi
    if [ -n "$remote_meta" ]; then
        lease_args+=("--force-with-lease=$meta_ref:$remote_meta")
        refspecs+=(":$meta_ref")
    fi

    local unblock_push_rc=0 unblock_updates='[]'
    taskdag_consumer_prepare unblock-pre-cas || return 3
    if [ "${#refspecs[@]}" -gt 0 ]; then
        if [ "$TASKDAG_CONSUMER_MODE" = canonical ]; then
            [ -n "$remote_blocked" ] && unblock_updates=$(jq -ncS --argjson u "$unblock_updates" --arg ref "$blocked_ref" --arg old "$remote_blocked" '$u+[{ref:$ref,old:$old,new:""}]')
            [ -n "$remote_meta" ] && unblock_updates=$(jq -ncS --argjson u "$unblock_updates" --arg ref "$meta_ref" --arg old "$remote_meta" '$u+[{ref:$ref,old:$old,new:""}]')
            taskdag_consumer_fenced_scheduling_push unblock "${TASK_DAG_CLAIMER:-unblock}" "$unblock_updates" || unblock_push_rc=$?
        else
            git push --atomic origin "${lease_args[@]}" "${refspecs[@]}" 2>/dev/null || unblock_push_rc=$?
        fi
    fi
    if [ "$unblock_push_rc" -eq 0 ]; then
        git show-ref --verify --quiet "$blocked_ref" && git update-ref -d "$blocked_ref"
        git show-ref --verify --quiet "$meta_ref" && git update-ref -d "$meta_ref"
        printf "${GREEN}✓ Unblocked task:${RESET} %s\n" "$(get_task_title "$task_sha")"
        emit_operator_blocked_dispatch unblock "$(git rev-parse --short "$task_sha")"
        return 0
    fi
    printf "${RED}✗ Failed to unblock %s on origin (it changed under us, or push failed).${RESET}\n" "$(get_task_title "$task_sha")" >&2
    echo "Re-check with 'task-dag blocked' and retry." >&2
    fetch_task_refs
    return 4
}

# Helper: emit a JSON string literal (with surrounding quotes) for an
# arbitrary value, escaped per RFC 8259. Prefers jq when present (handles
# every control char); falls back to pure-bash escaping of the cases the
# blocked-meta overlay can actually contain. Used so `blocked --json` is
# safe for a dashboard to consume without reparsing commit bodies.
json_escape() {
    local s="$1"
    if command -v jq >/dev/null 2>&1; then
        printf '%s' "$s" | jq -Rs .
        return
    fi
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\t'/\\t}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\n'/\\n}"
    printf '"%s"' "$s"
}

# Helper: emit a JSON string for a non-empty value, else the literal null.
json_str_or_null() {
    if [ -n "$1" ]; then json_escape "$1"; else printf 'null'; fi
}

# Helper: emit a bare JSON integer iff the value is all digits, else null.
# Fields like `issue` and `claimerPid` come from commit/ref metadata; a
# malformed value (e.g. `Issue: #41abc`) must NOT be interpolated raw or it
# recreates the "invalid JSON -> dispatcher skips the whole repo" outage.
json_int_or_null() {
    if [[ "${1:-}" =~ ^(0|[1-9][0-9]*)$ ]]; then printf '%s' "$1"; else printf 'null'; fi
}

# Helper: emit a bare JSON number (integer or decimal) iff well-formed,
# else null. Used for metadata like `ttlHours`. Rejects leading-zero
# forms (e.g. 007, 01.5) that jq tolerates but strict JSON parsers reject.
json_number_or_null() {
    if [[ "${1:-}" =~ ^(0|[1-9][0-9]*)([.][0-9]+)?$ ]]; then printf '%s' "$1"; else printf 'null'; fi
}

# Helper: read newline-separated raw values on stdin and emit a compact
# JSON array of escaped strings ([] when empty). `awk NF` drops blank
# lines so an empty input yields [] rather than the [""] the old
# hand-rolled `while read` + trailing-comma-strip produced.
json_str_array() {
    awk 'NF' | { command -v jq >/dev/null 2>&1 \
        && jq -R . | jq -sc . \
        || { printf '['; local first=1 line; while IFS= read -r line; do
                 [ "$first" = 1 ] || printf ','; first=0; json_escape "$line";
             done; printf ']'; }; }
}

# Preflight guard for commands whose --json result objects are emitted with
# direct `jq -nc` (claim/release/claim-root/release-root/reap/breakdown/
# validate). Those emitters have NO pure-bash fallback, and several run
# AFTER a push / update-ref side effect — so a missing jq would otherwise
# complete the git mutation and then die 127 mid-emit. Call this right after
# argument parsing (before any side effect) when --json is requested so we
# fail LOUD and early instead.
require_jq_for_json() {
    if ! command -v jq >/dev/null 2>&1; then
        echo "Error: jq is required for --json output" >&2
        return 1
    fi
}

# Command: blocked - list parked (blocked) tasks
cmd_blocked() {
    local json=false issue_filter="" do_fetch=true kind_filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            --issue=*) issue_filter="${1#*=}"; shift ;;
            --no-fetch) do_fetch=false; shift ;;
            --kind=*) kind_filter="${1#*=}"; shift ;;
            --operator) kind_filter="operator"; shift ;;
            --downstream) kind_filter="downstream"; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag blocked [--issue=N] [--json] [--no-fetch]
                        [--kind=operator|downstream|unknown | --operator | --downstream]

List parked (blocked) tasks. --json emits one enriched object per task
for the operator-blocked #29 dashboard, with fields derived from the
blocked-meta overlay so the dashboard never has to reparse commit bodies:

  sha, shortSha, title, issue, repo, issueUrl, kind, reason,
  requestUrl, blockedAt, blockedBy, hasMeta

Legacy blocks (overlay ref but no blocked-meta side ref) report
kind "unknown" with best-effort repo/issue/issueUrl derived from the
task commit and null reason/requestUrl/blockedAt/blockedBy.

Filtering: --operator / --downstream / --kind=<k> restrict the listing
to a single blocker kind (use --kind=unknown for legacy blocks).
EOF
                return 0 ;;
            *) echo "Unknown option: $1" >&2; return 1 ;;
        esac
    done
    case "$kind_filter" in
        ""|operator|downstream|unknown) ;;
        *) echo "Error: --kind must be operator, downstream, or unknown" >&2; return 1 ;;
    esac

    # Sync the blocked overlay from origin so a fresh checkout sees parked
    # tasks (the local refs are otherwise empty). Pass --no-fetch offline.
    if [ "$do_fetch" = true ]; then
        fetch_task_refs
    fi

    if [ "$json" = true ]; then
        echo "["
    else
        printf "${BOLD}%-12s %-50s %-12s %-10s${RESET}\n" "SHA" "TITLE" "ISSUE" "KIND"
        printf "%-12s %-50s %-12s %-10s\n" "$(printf '%.12s' '============')" "$(printf '%.50s' '==================================================')" "$(printf '%.12s' '============')" "$(printf '%.10s' '==========')"
    fi

    local first=true
    git for-each-ref refs/heads/tasks/blocked/ --format='%(objectname)' | while read sha; do
        local short_sha=$(git rev-parse --short "$sha")
        local title=$(get_task_title "$sha")
        local msg=$(parse_commit_metadata "$sha")
        # Tasks use "Issue: #N"; ingested comment nodes use YAML "issue:\n number:".
        local issue=$(extract_field "$msg" "Issue" | sed 's/^#//')
        if [ -z "$issue" ]; then
            issue=$(echo "$msg" | awk '/^issue:[[:space:]]*$/{f=1;next} f&&/number:/{sub(/^[[:space:]]*number:[[:space:]]*/,"");print;exit}')
        fi
        if [ -n "$issue_filter" ] && [ "$issue" != "$issue_filter" ]; then
            continue
        fi

        # Enrich from the blocked-meta overlay so a dashboard never has to
        # reparse commit bodies. A legacy block (overlay ref, no meta ref)
        # is kind "unknown" with best-effort origin from the task commit.
        local kind reason request_url blocked_at blocked_by repo source_url has_meta
        if has_blocked_meta "$sha"; then
            has_meta=true
            kind=$(read_blocked_meta_field "$sha" "Blocker-Kind"); kind="${kind:-unknown}"
            reason=$(read_blocked_meta_field "$sha" "Reason")
            request_url=$(read_blocked_meta_field "$sha" "Request-URL")
            blocked_at=$(read_blocked_meta_field "$sha" "Blocked-At")
            blocked_by=$(read_blocked_meta_field "$sha" "Blocked-By")
            repo=$(read_blocked_meta_field "$sha" "Repo")
            source_url=$(read_blocked_meta_field "$sha" "Source-URL")
            local meta_issue; meta_issue=$(read_blocked_meta_field "$sha" "Issue"); meta_issue="${meta_issue#\#}"
            [ -n "$meta_issue" ] && issue="$meta_issue"
        else
            has_meta=false
            kind="unknown"
            reason=""; request_url=""; blocked_at=""; blocked_by=""
            local origin; origin=$(derive_task_origin "$sha")
            repo=$(printf '%s' "$origin" | cut -f1)
            local derived_issue; derived_issue=$(printf '%s' "$origin" | cut -f2)
            source_url=$(printf '%s' "$origin" | cut -f3)
            [ -z "$issue" ] && [ -n "$derived_issue" ] && issue="$derived_issue"
        fi

        if [ -n "$kind_filter" ] && [ "$kind" != "$kind_filter" ]; then
            continue
        fi

        if [ "$json" = true ]; then
            [ "$first" = false ] && echo ","
            printf '    {"sha": %s, "shortSha": %s, "title": %s, "issue": %s, "repo": %s, "issueUrl": %s, "kind": %s, "reason": %s, "requestUrl": %s, "blockedAt": %s, "blockedBy": %s, "hasMeta": %s}' \
                "$(json_escape "$sha")" "$(json_escape "$short_sha")" "$(json_escape "$title")" \
                "$(json_int_or_null "$issue")" "$(json_str_or_null "$repo")" "$(json_str_or_null "$source_url")" \
                "$(json_escape "$kind")" "$(json_str_or_null "$reason")" "$(json_str_or_null "$request_url")" \
                "$(json_str_or_null "$blocked_at")" "$(json_str_or_null "$blocked_by")" "$has_meta"
            first=false
        else
            printf "%-12s %-50s %-12s %-10s\n" "$short_sha" "${title:0:50}" "${issue:+#$issue}" "$kind"
        fi
    done

    if [ "$json" = true ]; then
        echo ""
        echo "]"
    fi
    return 0
}

# Command: drop - housecleaning; remove an orphaned/irrelevant task from the
# pickable and blocked sets (does NOT rewrite history or close anything).
cmd_drop() {
    local task_sha="" yes=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --yes|-y) yes=true; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag drop <sha> [--yes]

Housecleaning: remove an orphaned or no-longer-relevant task from the
pickable/blocked sets. Deletes its frontier / blocked / active refs both
locally and on origin.

It deliberately does NOT delete:
  - the epic 'tasks/pending/<N>' ref (epic identity),
  - the 'gh/comments/<N>/<id>' provenance ref (kept so the source
    comment is never re-ingested into a new task),
and it never rewrites history. The underlying commit remains reachable,
so a drop is reversible by recreating the ref.

Requires --yes when stdin is not a TTY.
EOF
                return 0 ;;
            *)
                if [ -z "$task_sha" ]; then task_sha="$1"; else
                    echo "Unknown option: $1" >&2; return 1; fi
                shift ;;
        esac
    done
    [ -n "$task_sha" ] || { echo "Error: task SHA required" >&2; return 1; }
    task_sha=$(resolve_sha "$task_sha") || return 1

    local short_sha; short_sha=$(git rev-parse --short "$task_sha")
    local title; title=$(get_task_title "$task_sha")

    if [ "$yes" = false ]; then
        if [ -t 0 ]; then
            printf "About to drop task refs for %s (%s).\n" "$short_sha" "$title"
            printf "Press Ctrl-C to abort or Enter to continue..."
            read -r
        else
            echo "Error: refusing to drop without --yes in non-interactive mode" >&2
            return 1
        fi
    fi

    # Track whether we actually removed the blocked OVERLAY ref from origin,
    # so we refresh the operator #29 dashboard only when the drop changed
    # what it shows (the dashboard scans origin; a local-only or
    # never-blocked drop changes nothing).
    local blocked_ref_d; blocked_ref_d=$(blocked_ref_for "$task_sha")
    local dropped_cleared_remote_block=false

    local r
    for r in "refs/heads/tasks/frontier/$short_sha" \
             "$blocked_ref_d" \
             "$(blocked_meta_ref_for "$task_sha")" \
             "refs/heads/tasks/active/$short_sha"; do
        if git show-ref --verify --quiet "$r"; then
            git update-ref -d "$r" && echo "Deleted local $r"
        fi
        if git ls-remote --exit-code origin "$r" >/dev/null 2>&1; then
            if git push origin --delete "${r#refs/heads/}" 2>/dev/null; then
                echo "Deleted remote ${r#refs/heads/}"
                if [ "$r" = "$blocked_ref_d" ]; then dropped_cleared_remote_block=true; fi
            fi
        fi
    done

    printf "${GREEN}✓ Dropped task refs:${RESET} %s\n" "$title"
    if [ "$dropped_cleared_remote_block" = true ]; then
        emit_operator_blocked_dispatch drop "$short_sha"
    fi
    return 0
}

# Tri-state origin ref probe for reconcile-closed-issue: prints the ref's
# CURRENT origin SHA on stdout (empty when absent). Return:
#   0 -> present (sha on stdout)
#   2 -> cleanly absent (no matching ref on origin)
#   3 -> transport/auth error (undetermined — caller must NOT treat as absent)
# `git ls-remote --exit-code` returns 2 when nothing matches, 0 on a hit,
# and other codes on a transport/auth failure, so a network hiccup can never
# masquerade as "ref already gone" (which would let a real delete failure
# pass as a clean no-op).
_reconcile_remote_ref_sha() {
    local ref="$1" out rc=0
    out=$(git ls-remote --exit-code origin "$ref" 2>/dev/null) || rc=$?
    case "$rc" in
        0) printf '%s\n' "$out" | awk '{print $1; exit}'; return 0 ;;
        2) return 2 ;;
        *) return 3 ;;
    esac
}

# ─────────────────────────────────────────────────────────────────────
# Shared closed-issue candidate enumeration (ONE resolution path).
#
# Emit the lingering scheduling refs (frontier/<short>, blocked/<sha>,
# blocked-meta/<sha>) of the tasks that resolve to <target_repo> (and,
# optionally, a single <issue_filter>). This is the SINGLE (repo,issue)->
# task resolution both `reconcile-closed-issue` (which deletes them) and
# `validate --closed-issue-audit` (which only reports them) consume, so the
# two can never drift and neither re-parses commit bodies ad hoc.
#
#   args:   <target_repo owner/repo> [issue_filter]
#   stdout: TSV rows  <repo>\t<issue>\t<task_sha>\t<refname>\t<kind>
#             kind ∈ frontier | blocked | blocked-meta
#             <repo> is the task's DERIVED repo ("" when underivable)
#   return: 0 on success; 1 if the canonical blocked enumeration failed
#           (invalid/failed `blocked --json`). Callers MUST treat a non-zero
#           return as an ERROR, never as an empty candidate set (an
#           incomplete view is the exact bug this machinery exists to fix).
#
# Preconditions: the caller has already synced the task refs it cares about
# (this is a PURE, read-only local walk — it never fetches or mutates), and
# jq is available (the blocked resolution goes through `blocked --json`).
# It resolves ONLY (repo, issue) associations — it never touches
# tasks/pending/<N>, tasks/root-active/<N>, tasks/active/*, tasks/delegated/*
# or the gh/comments/<N>/<id> provenance refs.
#
# Repo filter (identical to reconcile): a task whose derived repo is empty
# matches any target repo; a cross-repo `Repo:` block referencing the same
# issue number in a DIFFERENT repo is NOT a match.
closed_issue_candidate_rows() {
    local target_repo="$1" issue_filter="${2:-}"

    # FRONTIER: scan the ref namespace directly (NOT cmd_frontier, which hides
    # blocked/not-ready/claimed rows) so no lingering frontier ref is missed.
    local objsha refname derived d_repo d_issue
    while IFS=$'\t' read -r objsha refname; do
        [ -n "$objsha" ] || continue
        # Race-tolerant: a ref whose object vanished mid-walk is skipped, not
        # fatal (mirrors validate's Check 2/3 discipline under set -e).
        derived=$(derive_task_origin "$objsha" 2>/dev/null) || continue
        d_repo=$(printf '%s' "$derived" | cut -f1)
        d_issue=$(printf '%s' "$derived" | cut -f2)
        [ -n "$d_issue" ] || continue
        [ -z "$issue_filter" ] || [ "$d_issue" = "$issue_filter" ] || continue
        [ -z "$d_repo" ] || [ "$d_repo" = "$target_repo" ] || continue
        printf '%s\t%s\t%s\t%s\tfrontier\n' "$d_repo" "$d_issue" "$objsha" "$refname"
    done < <(git for-each-ref refs/heads/tasks/frontier/ --format='%(objectname)%09%(refname)')

    # BLOCKED: canonical `blocked --json` resolution (meta-overridden issue +
    # derived repo). A CLI failure / invalid JSON is LOUD (return 1), never
    # coerced into an empty list.
    local blocked_json cli_rc=0
    blocked_json=$(cmd_blocked --json --no-fetch 2>/dev/null) || cli_rc=$?
    if [ "$cli_rc" -ne 0 ] || ! printf '%s' "$blocked_json" | jq -e . >/dev/null 2>&1; then
        return 1
    fi
    # Emit blocked (+ blocked-meta when present) rows for each matching task.
    # Only refs that actually exist locally (after the caller's strict sync)
    # are reported, so the audit lists ACTUAL lingering refs, never inferred
    # ones. A blocked task always has its overlay ref (blocked --json reads
    # it); the blocked-meta side ref is optional (legacy blocks lack it).
    local bsha bissue brepo bref bmref
    while IFS=$'\t' read -r brepo bissue bsha; do
        [ -n "$bsha" ] || continue
        bref="refs/heads/tasks/blocked/$bsha"
        if git show-ref --verify --quiet "$bref" 2>/dev/null; then
            printf '%s\t%s\t%s\t%s\tblocked\n' "$brepo" "$bissue" "$bsha" "$bref"
        fi
        bmref="refs/heads/tasks/blocked-meta/$bsha"
        if git show-ref --verify --quiet "$bmref" 2>/dev/null; then
            printf '%s\t%s\t%s\t%s\tblocked-meta\n' "$brepo" "$bissue" "$bsha" "$bmref"
        fi
    done < <(printf '%s' "$blocked_json" | jq -r \
        --arg repo "$target_repo" --arg issf "$issue_filter" '
        .[]
        | select((.issue // null) != null)
        | select(($issf == "") or ((.issue|tostring) == $issf))
        | select((.repo // "") == "" or (.repo == $repo))
        | [ (.repo // ""), (.issue|tostring), .sha ] | @tsv')

    return 0
}

# Command: reconcile-closed-issue - drop the lingering scheduling refs
# (tasks/frontier/<short>, tasks/blocked/<full-sha>, tasks/blocked-meta/
# <full-sha>) left behind by tasks whose GitHub issue is CONFIRMED CLOSED.
#
# The github-worker dispatcher only prunes the LOCAL refs when it observes a
# task's issue CLOSED; the authoritative origin refs survive and re-
# materialise on every fetch, so a closed-issue task clutters the frontier
# and the operator dashboards forever (top-level#48). The existing sweep
# (.github/scripts/cleanup-closed-issue-task-refs.sh) only fires on the bot
# `Closes-Epic:` push path and only enumerates BLOCKED tasks; this command
# also catches pickable FRONTIER-only tasks and can be run manually or from
# an `issues:[closed]` workflow.
#
# FAIL-SAFE: nothing is mutated unless gh confirms the issue is CLOSED, and
# nothing is deleted under any uncertainty. Deletes honour the frontier-
# first + --force-with-lease discipline proven in the cleanup script, so a
# concurrent breakdown that re-pointed a short-sha ref is never clobbered
# and no pickable window opens. It never touches tasks/pending/<N>,
# tasks/root-active/<N>, tasks/active/*, tasks/delegated/*, or the
# gh/comments/<N>/<id> provenance refs.
cmd_reconcile_closed_issue() {
    local issue="" repo_opt="" dry_run=false json=false yes=false
    local -a hint_shas=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) dry_run=true; shift ;;
            --json) json=true; shift ;;
            --yes|-y) yes=true; shift ;;
            --repo=*) repo_opt="${1#*=}"; shift ;;
            --hint-sha=*) hint_shas+=("${1#*=}"); shift ;;
            --hint-sha)
                [ $# -ge 2 ] || { echo "Error: --hint-sha requires a value" >&2; return 2; }
                hint_shas+=("$2"); shift 2 ;;
            --help|-h)
                cat <<EOF
Usage: task-dag reconcile-closed-issue <issue> [--repo=owner/repo]
                                       [--dry-run] [--json] [--yes]
                                       [--hint-sha=<task-sha> ...]

Reconcile the task-dag scheduling refs for a CONFIRMED-CLOSED GitHub issue:
delete the lingering tasks/frontier/<short>, tasks/blocked/<full-sha> and
tasks/blocked-meta/<full-sha> refs of every task that resolves to
(this repo, <issue>), so a closed-issue task stops cluttering the frontier
and the operator-blocked #29 dashboard and stops reappearing on git fetch.

FAIL-SAFE — never acts under uncertainty:
  * The issue state is confirmed live via 'gh issue view … --json state'.
    - CLOSED                -> reconcile.
    - any other state (OPEN)-> clean no-op, exit 0.
    - undetermined (gh missing/unauth/API error) -> no-op + report for
      manual review, exit 3.
  * A cross-repo block (Repo: other/repo referencing this issue number) is
    NOT a match and is left alone.
  * Deletes are frontier-FIRST under a --force-with-lease on the observed
    SHA; the blocked overlay is removed only once its frontier is confirmed
    clear (no zombie-dispatch window) and only when origin still points it
    at the expected task SHA.

It NEVER deletes tasks/pending/<N> (epic identity), tasks/root-active/<N>,
tasks/active/* (a live claim self-cleans on complete), tasks/delegated/*,
or gh/comments/<N>/<id> (comment provenance).

Options:
  --repo=owner/repo  Override the repo (default: derived from origin).
  --dry-run          Report exactly what WOULD be removed; delete no origin
                     refs. (Local task refs may still be synced to build an
                     authoritative report.)
  --json             Machine-readable output (removed SHAs/refs, skipped
                     items with reasons, and summary counts).
  --yes, -y          Required for a non-dry run when stdin is not a TTY.
  --hint-sha=SHA     Also clean this exact task SHA's frontier/blocked/meta
                     refs after the issue is confirmed CLOSED and the SHA is
                     verified to resolve to that same issue. This preserves
                     the epic-close belt-and-braces path: hinted refs are
                     still attempted if candidate enumeration fails, but the
                     command exits non-zero so the incomplete sweep is loud.

Idempotent: a second run over an already-clean issue is a successful no-op.
Reverse a mistaken reconcile from the emitted audit record (recreate the
ref from the retained task SHA + pending/provenance refs).
EOF
                return 0 ;;
            -*) echo "Unknown option: $1" >&2; return 2 ;;
            *) if [ -z "$issue" ]; then issue="$1"; else
                   echo "Unknown argument: $1" >&2; return 2; fi; shift ;;
        esac
    done

    [ -n "$issue" ] || { echo "Error: <issue> is required" >&2; return 2; }
    [[ "$issue" =~ ^[0-9]+$ ]] || { echo "Error: <issue> must be numeric, got: $issue" >&2; return 2; }
    local hint
    for hint in "${hint_shas[@]}"; do
        [[ "$hint" =~ ^[0-9a-fA-F]{40}$ ]] || {
            echo "Error: --hint-sha must be a full 40-hex task SHA, got: $hint" >&2
            return 2
        }
    done
    if [ -n "$repo_opt" ] && [[ ! "$repo_opt" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]]; then
        echo "Error: --repo must be owner/repo, got: $repo_opt" >&2
        return 2
    fi
    taskdag_migration_guard projection || return $?
    if [ "$json" = true ]; then require_jq_for_json || return 2; fi

    # Resolve THIS repo (owner/repo): --repo overrides, else derive from the
    # origin remote (handles aliased ephemeral SSH remotes).
    local repo="$repo_opt"
    if [ -z "$repo" ]; then
        local remote_url; remote_url=$(git remote get-url origin 2>/dev/null || echo "")
        repo=$(parse_owner_repo_from_url "$remote_url")
    fi
    [ -n "$repo" ] || { echo "Error: could not determine owner/repo; pass --repo=owner/repo" >&2; return 2; }

    # A small JSON summary emitter for the early-exit (no-mutation) paths.
    _rci_emit_summary() {
        local ok="$1" state_json="$2" reason="$3" errors="$4"
        jq -nc --argjson issue "$issue" --arg repo "$repo" \
            --argjson ok "$ok" --argjson state "$state_json" \
            --arg reason "$reason" --argjson dry "$dry_run" \
            --argjson errors "$errors" \
            '{ok:$ok, issue:$issue, repo:$repo, state:$state, dryRun:$dry,
              reason:$reason, removed:[], skipped:[],
              counts:{targets:0, removed:0, skipped:0, errors:$errors}}'
    }

    # ── 1. Confirm the issue is CLOSED (fail-safe) ───────────────────────
    local state st_rc=0
    state=$(issue_state_remote "$repo" "$issue") || st_rc=$?
    if [ "$st_rc" -ne 0 ]; then
        # Undetermined: gh missing/unauth/API error. Never assume closed.
        if [ "$json" = true ]; then
            _rci_emit_summary false null "undetermined-issue-state" 1
        else
            echo "Error: could not determine GitHub state of ${repo}#${issue}" >&2
            echo "       (gh missing/unauthenticated/API error); refusing to reconcile." >&2
            echo "       Surfaced for manual review." >&2
        fi
        return 3
    fi
    if [ "$state" != "CLOSED" ]; then
        if [ "$json" = true ]; then
            _rci_emit_summary true "$(json_escape "$state")" "issue-not-closed" 0
        else
            echo "Issue ${repo}#${issue} is ${state}, not CLOSED — nothing to reconcile."
        fi
        return 0
    fi

    # Non-dry mutations require --yes when not attached to a TTY (mirror drop).
    if [ "$dry_run" = false ] && [ "$yes" = false ] && [ ! -t 0 ]; then
        echo "Error: refusing to reconcile without --yes in non-interactive mode" >&2
        return 2
    fi

    # ── 2. Enumerate target task SHAs resolving to (repo, issue) ─────────
    # Sync the task refs so a fresh checkout sees them. Fail LOUD on a fetch
    # failure: an incomplete local view could silently skip lingering refs
    # (the exact bug this command exists to fix).
    local pre_delete_errors=0 pre_delete_reason=""
    if ! fetch_task_refs_strict 2>/dev/null; then
        if [ "${#hint_shas[@]}" -eq 0 ]; then
            if [ "$json" = true ]; then
                _rci_emit_summary false '"CLOSED"' "fetch-failed" 1
            else
                echo "Error: could not sync task refs from origin; refusing to reconcile" >&2
                echo "       (incomplete view could miss lingering refs)." >&2
            fi
            return 3
        fi
        pre_delete_errors=$((pre_delete_errors + 1))
        pre_delete_reason="fetch-failed"
        if [ "$json" = false ]; then
            echo "Error: could not sync task refs from origin; candidate enumeration incomplete." >&2
            echo "       Attempting hinted task ref cleanup only; final exit will be non-zero." >&2
        fi
    fi

    # Enumerate the target task SHAs resolving to (repo, issue) via the ONE
    # shared candidate resolver (direct frontier scan + canonical
    # `blocked --json`), so reconcile and `validate --closed-issue-audit`
    # never drift. A non-zero return means the blocked enumeration failed —
    # LOUD, never coerced into an empty set (an incomplete view could
    # silently skip lingering refs, the exact bug this command exists to fix).
    local cand_rows="" cand_rc=0
    if [ "$pre_delete_reason" != "fetch-failed" ]; then
        cand_rows=$(closed_issue_candidate_rows "$repo" "$issue") || cand_rc=$?
        if [ "$cand_rc" -ne 0 ]; then
            if [ "${#hint_shas[@]}" -eq 0 ]; then
                if [ "$json" = true ]; then
                    _rci_emit_summary false '"CLOSED"' "blocked-enumeration-failed" 1
                else
                    echo "Error: could not enumerate task refs for ${repo}#${issue}" >&2
                    echo "       ('task-dag blocked --json' failed or produced invalid JSON);" >&2
                    echo "       refusing to reconcile with an incomplete view." >&2
                fi
                return 3
            fi
            pre_delete_errors=$((pre_delete_errors + 1))
            pre_delete_reason="blocked-enumeration-failed"
            if [ "$json" = false ]; then
                echo "Error: could not enumerate task refs for ${repo}#${issue}" >&2
                echo "       Attempting hinted task ref cleanup only; final exit will be non-zero." >&2
            fi
        fi
    fi
    declare -A TARGETS=()
    local _cr_repo _cr_issue _cr_sha _cr_ref _cr_kind
    while IFS=$'\t' read -r _cr_repo _cr_issue _cr_sha _cr_ref _cr_kind; do
        [ -n "$_cr_sha" ] && TARGETS["$_cr_sha"]=1
    done <<< "$cand_rows"
    for hint in "${hint_shas[@]}"; do
        [ -n "$hint" ] || continue
        local hint_lc="${hint,,}" hint_origin hint_repo hint_issue
        if ! git cat-file -e "$hint_lc^{commit}" 2>/dev/null || ! is_task_commit "$hint_lc"; then
            echo "Error: --hint-sha $hint_lc is not a locally available task commit; refusing hinted cleanup" >&2
            return 2
        fi
        hint_origin=$(derive_task_origin "$hint_lc" 2>/dev/null || true)
        hint_repo=$(printf '%s' "$hint_origin" | cut -f1)
        hint_issue=$(printf '%s' "$hint_origin" | cut -f2)
        if [ "$hint_issue" != "$issue" ] || { [ -n "$hint_repo" ] && [ "$hint_repo" != "$repo" ]; }; then
            echo "Error: --hint-sha $hint_lc resolves to ${hint_repo:-<unknown>}#${hint_issue:-<none>}, not ${repo}#${issue}; refusing hinted cleanup" >&2
            return 2
        fi
        TARGETS["$hint_lc"]=1
    done

    # ── 3. Re-confirm CLOSED right before the first mutation ─────────────
    # Cannot make issue-state and ref-deletion atomic, but a second check
    # after enumeration shrinks the closed->reopened race. Skip for dry-run
    # (it mutates nothing).
    if [ "$dry_run" = false ]; then
        local recheck rc2=0
        recheck=$(issue_state_remote "$repo" "$issue") || rc2=$?
        if [ "$rc2" -ne 0 ]; then
            if [ "$json" = true ]; then
                _rci_emit_summary false null "undetermined-issue-state-recheck" 1
            else
                echo "Error: issue ${repo}#${issue} state became undetermined before mutating; aborting." >&2
            fi
            return 3
        fi
        if [ "$recheck" != "CLOSED" ]; then
            if [ "$json" = true ]; then
                _rci_emit_summary true "$(json_escape "$recheck")" "issue-reopened-before-mutation" 0
            else
                echo "Issue ${repo}#${issue} is now ${recheck} (reopened before mutation) — no-op."
            fi
            return 0
        fi
    fi

    # ── 4. Delete per target, frontier-FIRST, origin-authoritative ───────
    # Snapshot origin's frontier listing ONCE (a big sweep is not O(tasks)
    # round-trips). A frontier ref created AFTER this snapshot is invisible
    # here (the lease only guards refs in the snapshot); re-running heals it.
    local frontier_listing
    if ! frontier_listing=$(git ls-remote origin 'refs/heads/tasks/frontier/*' 2>/dev/null); then
        if [ "$json" = true ]; then
            _rci_emit_summary false '"CLOSED"' "frontier-listing-failed" 1
        else
            echo "Error: could not list frontier refs from origin; refusing to delete any" >&2
            echo "       blocked overlay (would risk zombie dispatch)." >&2
        fi
        return 3
    fi

    local -a removed_objs=() skipped_objs=()
    local n_removed=0 n_skipped=0 n_errors="$pre_delete_errors" n_targets=0
    if [ -n "$pre_delete_reason" ]; then
        skipped_objs+=("$(jq -nc --arg reason "$pre_delete_reason" \
            '{sha:null, shortSha:null, reason:$reason}')")
        n_skipped=$((n_skipped + 1))
    fi

    local target
    for target in "${!TARGETS[@]}"; do
        n_targets=$((n_targets + 1))
        local short; short=$(git rev-parse --short "$target" 2>/dev/null || echo "${target:0:12}")
        local -a refs_removed=()
        local frontier_clear=true

        # 4a. Delete every frontier ref pointing at THIS target, leased to
        # the exact sha we observed, so a concurrent breakdown that re-
        # pointed a short-sha ref at a DIFFERENT task is never clobbered.
        local fsha fref
        while read -r fsha fref; do
            [ -n "$fref" ] || continue
            [ "$fsha" = "$target" ] || continue
            if [ "$dry_run" = true ]; then
                refs_removed+=("$fref"); continue
            fi
            if git push origin --force-with-lease="$fref:$fsha" ":$fref" 2>/dev/null; then
                refs_removed+=("$fref")
                if git show-ref --verify --quiet "refs/heads/${fref#refs/heads/}" 2>/dev/null; then
                    git update-ref -d "refs/heads/${fref#refs/heads/}" 2>/dev/null || true
                fi
                continue
            fi
            # Lease failed: re-probe origin. Gone or re-pointed elsewhere =>
            # not ours (success); still at target => genuine failure that
            # leaves the pickable window open, so skip the blocked delete.
            local now
            if ! now=$(git ls-remote origin "$fref" 2>/dev/null | awk '{print $1; exit}'); then
                echo "Error: could not re-query origin for $fref" >&2
                frontier_clear=false; continue
            fi
            if [ -z "$now" ] || [ "$now" != "$target" ]; then
                : # gone or re-pointed elsewhere — not ours, treated as clear
            else
                echo "Error: failed to lease-delete $fref (still points at $short)" >&2
                frontier_clear=false
            fi
        done <<< "$frontier_listing"

        if [ "$frontier_clear" = false ]; then
            skipped_objs+=("$(jq -nc --arg sha "$target" --arg short "$short" \
                '{sha:$sha, shortSha:$short, reason:"frontier-not-clear"}')")
            n_skipped=$((n_skipped + 1)); n_errors=$((n_errors + 1))
            continue
        fi

        # 4b. Blocked overlay: delete only once frontier is confirmed clear,
        # and only if origin still points the overlay at THIS task SHA (its
        # name embeds the full sha, so a mismatch is an invariant violation).
        local bref="refs/heads/tasks/blocked/$target"
        local bref_now brc=0
        bref_now=$(_reconcile_remote_ref_sha "$bref") || brc=$?
        case "$brc" in
            0)
                if [ "$bref_now" = "$target" ]; then
                    if [ "$dry_run" = true ]; then
                        refs_removed+=("$bref")
                    elif git push origin --force-with-lease="$bref:$bref_now" ":${bref#refs/heads/}" 2>/dev/null; then
                        refs_removed+=("$bref")
                        if git show-ref --verify --quiet "$bref" 2>/dev/null; then
                            git update-ref -d "$bref" 2>/dev/null || true
                        fi
                    else
                        echo "Error: failed to lease-delete $bref" >&2
                        n_errors=$((n_errors + 1))
                    fi
                else
                    echo "Error: $bref points at ${bref_now:0:12}, not $short — invariant violation, skipping" >&2
                    n_errors=$((n_errors + 1))
                fi ;;
            2) : ;;  # cleanly absent — nothing to do (idempotent)
            *)
                echo "Error: could not query origin for $bref; refusing to treat it as absent" >&2
                n_errors=$((n_errors + 1)) ;;
        esac

        # 4c. Blocked-meta side ref: a DISTINCT descriptive commit, so lease
        # to its own observed SHA (not the task SHA).
        local bmref="refs/heads/tasks/blocked-meta/$target"
        local bmref_now bmrc=0
        bmref_now=$(_reconcile_remote_ref_sha "$bmref") || bmrc=$?
        case "$bmrc" in
            0)
                if [ "$dry_run" = true ]; then
                    refs_removed+=("$bmref")
                elif git push origin --force-with-lease="$bmref:$bmref_now" ":${bmref#refs/heads/}" 2>/dev/null; then
                    refs_removed+=("$bmref")
                    if git show-ref --verify --quiet "$bmref" 2>/dev/null; then
                        git update-ref -d "$bmref" 2>/dev/null || true
                    fi
                else
                    echo "Error: failed to lease-delete $bmref" >&2
                    n_errors=$((n_errors + 1))
                fi ;;
            2) : ;;  # cleanly absent
            *)
                echo "Error: could not query origin for $bmref; refusing to treat it as absent" >&2
                n_errors=$((n_errors + 1)) ;;
        esac

        if [ "${#refs_removed[@]}" -gt 0 ]; then
            local refs_json
            refs_json=$(printf '%s\n' "${refs_removed[@]}" | jq -R . | jq -sc .)
            removed_objs+=("$(jq -nc --arg sha "$target" --arg short "$short" \
                --argjson refs "$refs_json" \
                '{sha:$sha, shortSha:$short, refs:$refs}')")
            n_removed=$((n_removed + 1))
        fi
    done

    # ── 5. Report ────────────────────────────────────────────────────────
    if [ "$json" = true ]; then
        local removed_arr='[]' skipped_arr='[]'
        [ "${#removed_objs[@]}" -gt 0 ] && removed_arr=$(printf '%s\n' "${removed_objs[@]}" | jq -sc .)
        [ "${#skipped_objs[@]}" -gt 0 ] && skipped_arr=$(printf '%s\n' "${skipped_objs[@]}" | jq -sc .)
        local ok_json=true; [ "$n_errors" -gt 0 ] && ok_json=false
        jq -nc --argjson issue "$issue" --arg repo "$repo" \
            --argjson ok "$ok_json" --argjson dry "$dry_run" \
            --argjson removed "$removed_arr" --argjson skipped "$skipped_arr" \
            --argjson targets "$n_targets" --argjson nrem "$n_removed" \
            --argjson nskip "$n_skipped" --argjson nerr "$n_errors" \
            '{ok:$ok, issue:$issue, repo:$repo, state:"CLOSED", dryRun:$dry,
              removed:$removed, skipped:$skipped,
              counts:{targets:$targets, removed:$nrem, skipped:$nskip, errors:$nerr}}'
    else
        local verb="Reconciled"; [ "$dry_run" = true ] && verb="[dry-run] would reconcile"
        if [ "$n_targets" -eq 0 ]; then
            echo "$verb ${repo}#${issue}: no lingering task refs — already clean."
        else
            printf "%s ${repo}#${issue}: %d task(s), %d removed, %d skipped, %d error(s).\n" \
                "$verb" "$n_targets" "$n_removed" "$n_skipped" "$n_errors"
            local o
            for o in "${removed_objs[@]:-}"; do
                [ -n "$o" ] || continue
                printf '  removed %s: %s\n' \
                    "$(printf '%s' "$o" | jq -r .shortSha)" \
                    "$(printf '%s' "$o" | jq -r '.refs | join(", ")')"
            done
            for o in "${skipped_objs[@]:-}"; do
                [ -n "$o" ] || continue
                printf '  skipped %s (%s)\n' \
                    "$(printf '%s' "$o" | jq -r .shortSha)" \
                    "$(printf '%s' "$o" | jq -r .reason)"
            done
        fi
    fi

    [ "$n_errors" -eq 0 ] || return 1
    return 0
}

# Main dispatch
main() {
    if [ $# -eq 0 ]; then
        cmd_help
        return 0
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        help|--help|-h) cmd_help ;;
        --version|-v) echo "task-dag v${VERSION}" ;;
        migration-status)
            if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
