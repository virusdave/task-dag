        show) cmd_show "$@" ;;
        deps) cmd_deps "$@" ;;
        dag) cmd_dag "$@" ;;
        context) cmd_context "$@" ;;
        breakdown) cmd_breakdown "$@" ;;
        complete) cmd_complete "$@" ;;
        complete-ops) cmd_complete_ops "$@" ;;
        complete-historical) cmd_complete_historical "$@" ;;
        publish) cmd_publish "$@" ;;
        block) cmd_block "$@" ;;
        unblock) cmd_unblock "$@" ;;
        blocked) cmd_blocked "$@" ;;
        drop) cmd_drop "$@" ;;
        reconcile-closed-issue) cmd_reconcile_closed_issue "$@" ;;
