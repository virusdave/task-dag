            echo "Run 'task-dag help' for usage" >&2
            return 1
            ;;
    esac
}

# Source extension modules (cross-repo coordination, etc.)
# Located at scripts/task-dag.d/*.sh relative to this script.
__task_dag_self="${BASH_SOURCE[0]}"
__task_dag_dir="$(cd "$(dirname "$__task_dag_self")" && pwd)"
if [ -d "${__task_dag_dir}/task-dag.d" ]; then
    for __ext in "${__task_dag_dir}/task-dag.d"/*.sh; do
        # shellcheck disable=SC1090
        [ -f "$__ext" ] && source "$__ext"
    done
    unset __ext
fi
unset __task_dag_self __task_dag_dir

# Command: check-workflow - validate recent commits follow task-dag convention
cmd_check_workflow() {
    local count=10
    local json=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --count=*) count="${1#*=}"; shift ;;
            --json) json=true; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag check-workflow [--count=N] [--json]

Check recent commits for proper task-dag workflow compliance.

Warns about:
- Empty commits that look like tombstones (should use task-dag complete on real commits)
- Commits referencing tasks without proper parent linkage
- Work commits that should be linked to tasks

Options:
  --count=N    Number of recent commits to check (default: 10)
  --json       Output in JSON format
EOF
                return 0
                ;;
            *) echo "Unknown option: $1" >&2; return 1 ;;
        esac
    done
    
    local warnings=0
    
    if [ "$json" = false ]; then
        printf "${BOLD}Checking last $count commits for workflow compliance...${RESET}\n\n"
    fi
    
    # Check recent commits
    git log -$count --format='%H %s' | while read sha subject; do
        local tree=$(git rev-parse "$sha^{tree}")
        local parents=$(git rev-list --parents -1 "$sha" | awk '{print NF-1}')
        local body=$(git log -1 --format='%B' "$sha")
        
        # Check for empty tombstone commits (should be rare)
        if [ "$tree" = "$(git hash-object -t tree /dev/null)" ]; then
            if echo "$subject" | grep -qi "tombstone"; then
                # Expected tombstone for retroactive fix
                :
            else
                warnings=$((warnings + 1))
                [ "$json" = false ] && printf "${YELLOW}⚠${RESET} %s: Empty commit (possible incorrect tombstone)\n" "$(git rev-parse --short "$sha")"
            fi
        fi
        
        # Check for Task-Commit without task parent
        if echo "$body" | grep -q "^Task-Commit:"; then
            local has_task_parent=false
            git rev-list --parents -1 "$sha" | awk '{for(i=3;i<=NF;i++) print $i}' | while read parent; do
                local parent_tree=$(git rev-parse "$parent^{tree}" 2>/dev/null || echo "")
                if [ "$parent_tree" = "$(git hash-object -t tree /dev/null)" ]; then
                    has_task_parent=true
                fi
            done
            
            if [ "$has_task_parent" != "true" ] && [ "$parents" -le 1 ]; then
                warnings=$((warnings + 1))
                [ "$json" = false ] && printf "${YELLOW}⚠${RESET} %s: Has Task-Commit but no task parent\n" "$(git rev-parse --short "$sha")"
            fi
        fi
    done
    
    if [ "$json" = false ]; then
        echo ""
        if [ $warnings -eq 0 ]; then
            printf "${GREEN}✓ All commits follow workflow convention${RESET}\n"
        else
            printf "${YELLOW}⚠ Found $warnings potential workflow violations${RESET}\n"
            echo ""
            echo "Reminder: Use 'task-dag complete <task-sha>' on real work commits"
            echo "Tombstones are ONLY for retroactive fixes of pre-CLI commits"
        fi
    fi
    
    return 0
}

# Command: guard-commit-message — refuse a hand-written commit that either
# (a) uses a Conventional-Commits subject prefix (canon requires a plain,
# capitalized, imperative subject — see top-level rules/WORKFLOW.md "Commit
# messages"), or (b) carries task-dag control-plane markers. This is the
# canonical check behind the per-repo `commit-msg` hook
# (docs/DESIGN_PRINCIPLES.md → "Commit-message guard").
# Rationale for (b): EVERY task-dag control commit (task/claim/blocked-meta/
# completion merge/close merge/historical link — see
# docs/INVARIANTS.md "Per-kind commit shapes") is built with
# `git commit-tree`, which BYPASSES git hooks. So any of these markers
# appearing in a hook-visible `git commit` means a human/agent is
# hand-crafting a task-impacting commit instead of going through the tooling
# (the exact footgun behind the fabricated Task-Commit in
# FreshlyBakedNYC/automation@53c9e712b). The marker→tooling map below is the
# SINGLE SOURCE OF TRUTH; the hook must call this, never re-encode it.
#
# Deliberately NOT flagged: cross-repo trailers a normal implementation
# commit legitimately carries by hand — Satisfies:, Phase:,
# Materialise-Child-Epic:, Amp-Thread-ID:, Co-authored-by:.

# ─────────────────────────────────────────────────────────────────────
# guard-pre-push: the body of a repo `pre-push` hook. Enforces exactly ONE
# invariant — do not push plain implementation work to master while you
# still hold an UNRESOLVED task-dag claim in THIS repo (i.e. you skipped
# `task-dag complete`, the footgun behind the lost-parentage race the whole
# top-level#45 fix targets). Everything else passes:
#   • cross-repo `Satisfies:`-linked plain commits (no active claim here);
#   • ordinary maintenance pushes (no active claim here);
#   • properly-completed pushes (tip is a completion/close shape, and/or the
#     claim's active ref is gone / the task is already linked in the pushed
#     history).
# Fail-OPEN, like the commit-msg hook: this is a dev-side convenience gate,
# not an adversary fence. Anything we cannot evaluate with confidence (no
# claimer identity, unreachable objects, shallow clones, non-origin remote)
# ALLOWS the push with a loud stderr note.
# ─────────────────────────────────────────────────────────────────────

# Helper: does the git range contain >=1 REAL implementation commit (not an
# empty-tree task/control commit, not a completion/link/close shape)?
range_has_impl_commit() {
    local range="$1" c
    while IFS= read -r c; do
        [ -n "$c" ] || continue
        is_task_commit "$c" && continue
        is_sanctioned_tip_commit "$c" && continue
        return 0
    done < <(git rev-list "$range" 2>/dev/null)
    return 1
}

# Helper: print the short-shas of active claims OWNED by (claimer,host[,pid])
# whose task is NOT already linked in <tip>'s history (space-separated). An
# owned+unresolved claim means "you hold this task in flight and haven't
# completed it as of the commit you're pushing".
owned_unresolved_active_claims() {
    local claimer="$1" host="$2" tip="$3"
    local sha ref msg cl chost cpid tsk out=""
    while IFS=' ' read -r sha ref; do
        [ -n "$ref" ] || continue
        msg=$(git log -1 --format='%B' "$sha" 2>/dev/null) || continue
        cl=$(extract_field "$msg" "Claimer")
        chost=$(extract_field "$msg" "Claimer-Host")
        [ "$cl" = "$claimer" ] || continue
        [ "$chost" = "$host" ] || continue
        # Optional PID narrowing (only when BOTH sides present): a different
        # pid means a different session's claim, not mine.
        if [ -n "${TASK_DAG_CLAIMER_PID:-}" ]; then
            cpid=$(extract_field "$msg" "Claimer-PID")
            if [ -n "$cpid" ] && [ "$cpid" != "$TASK_DAG_CLAIMER_PID" ]; then
                continue
            fi
        fi
        tsk=$(get_first_parent "$sha" 2>/dev/null || true)
        [ -n "$tsk" ] || continue
        taskdag_node_complete "task:${TASKDAG_RECON_CUR}@${tsk}" && continue
        out+="${ref##refs/heads/tasks/active/} "
    done < <(git for-each-ref refs/heads/tasks/active/ --format='%(objectname) %(refname)')
    printf '%s' "$out"
}

sanctioned_tip_requirements_satisfied() {
    local tip=$1 first second issue status close_count
    is_sanctioned_tip_commit "$tip" || return 1
    first=$(get_first_parent "$tip") || return 2
    second=$(get_parents "$tip" | sed -n '2p')
    taskdag_consumer_prepare sanctioned-tip --tip "$first" || return 2
    close_count=$(git log -1 --format='%B' "$tip" | grep -cE '^Closes-Epic:[[:space:]]*#[0-9]+[[:space:]]*$' || true)
    if [ "$close_count" -eq 1 ]; then
        issue=$(git log -1 --format='%B' "$tip" | sed -nE 's/^Closes-Epic:[[:space:]]*#([0-9]+)[[:space:]]*$/\1/p')
        [ "$(git rev-parse --verify -q "refs/heads/tasks/pending/${issue}^{commit}" 2>/dev/null || true)" = "$second" ] || return 1
        status=$(taskdag_root_status_json "task:${TASKDAG_RECON_CUR}@${second}" "$issue") || return 2
        [ "$(jq -r '.complete and (.blocked|not) and .requirementsSatisfied' <<<"$status")" = true ] || return 1
    else
        status=$(taskdag_task_status_json "task:${TASKDAG_RECON_CUR}@${second}" --include-claimed) || return 2
        [ "$(jq -r '(.complete|not) and .requirementsSatisfied' <<<"$status")" = true ] || return 1
    fi
}

_taskdag_publish_evidence() { # candidate attempt structured-result
    local tip=$1 attempt=$2 result=$3
    jq -r --arg candidate "$tip" --arg attempt "$attempt" '
      (.updates | map(select(.ref=="refs/heads/master")) | first) as $master |
      (if .readback==null then "unavailable" else "coherent" end) as $readbackState |
      (if .readback==null then "unknown" else ((.readback.targets | map(select(.ref=="refs/heads/master")) | first | .oid) // "absent") end) as $observedMaster |
      "Publication evidence: candidate=\($candidate) attempt=\($attempt) classification=\(.outcome) push-exit=\(.push.exit) readback=\($readbackState)",
      "Publication evidence: master-before=\($master.old // "unknown") master-candidate=\($master.new // $candidate) master-observed=\($observedMaster)",
      "Publication evidence: authority-before=\((.authority.expected | select(length>0)) // "unknown") authority-observed=\((.authority.observed | select(length>0)) // "unknown") authority-guard=\((.authority.guard | select(length>0)) // "unknown")",
      "Recovery command: task-dag publish \($candidate)"
    ' <<<"$result" >&2
}

_taskdag_publish_attempt() { # immutable completion candidate, 1-based attempt
    local tip=$1 attempt=$2 old first updates rc=0 close_issue close_root outcome diagnostic
    first=$(get_first_parent "$tip") || return 2
    # Observe current master before validating the candidate. A retry after an
    # accepted-but-ambiguous publish is success even if close cleanup already
    # removed pending/N. Otherwise the current master must be contained in the
    # candidate's first-parent history; never lease a newer unrelated master
    # and force-replace it with a stale completion.
    taskdag_consumer_prepare publish-current || return 2
    old=$TASKDAG_CONSUMER_MASTER_TIP
    if git merge-base --is-ancestor "$tip" "$old" 2>/dev/null; then
        echo "Canonical task-dag completion is already present on origin/master: $tip"
        return 0
    fi
    git merge-base --is-ancestor "$old" "$first" 2>/dev/null || {
        echo "Error: origin/master advanced outside this completion's first-parent history; rebase and recreate it." >&2
        return 2
    }
    sanctioned_tip_requirements_satisfied "$tip" || {
        echo "Error: tip is not an exact canonical completion/close, or its canonical requirements changed." >&2
        return 2
    }
    close_issue=$(git log -1 --format=%B "$tip" | sed -nE 's/^Closes-Epic:[[:space:]]*#([1-9][0-9]*)[[:space:]]*$/\1/p')
    if [ -n "$close_issue" ]; then
        close_root=$(git rev-parse "$tip^2") || return 2
        TASKDAG_MATERIALISATION_VALIDATED_TIP=""
        taskdag_materialisation_authority_durable "$close_issue" "$close_root" || {
            echo "Error: materialisation authority changed or is incomplete; refusing close publication." >&2
            return 3
        }
        [ -n "$TASKDAG_MATERIALISATION_VALIDATED_TIP" ] || return 3
    fi
    old=$TASKDAG_CONSUMER_MASTER_TIP
    if git merge-base --is-ancestor "$tip" "$old" 2>/dev/null; then
        echo "Canonical task-dag completion is already present on origin/master: $tip"
        return 0
    fi
    git merge-base --is-ancestor "$old" "$first" 2>/dev/null || {
        echo "Error: origin/master advanced while validating this completion; rebase and recreate it." >&2
        return 2
    }
    if [ "$TASKDAG_CONSUMER_MODE" = legacy ]; then
        if declare -F _xrepo_watchdog_fence >/dev/null 2>&1; then _xrepo_watchdog_fence || return 3; fi
        git push origin "$tip:refs/heads/master"
        return $?
    fi
    # Reservations and closes both advance the shared activation guard. A
    # reservation after this readback and this close therefore cannot both win
    # the same semantic generation; the loser must revalidate current state.
    updates=$(jq -ncS --arg ref refs/heads/master --arg old "$old" --arg new "$tip" '[{ref:$ref,old:$old,new:$new}]') || return 2
    if declare -F _xrepo_watchdog_fence >/dev/null 2>&1; then _xrepo_watchdog_fence || return 3; fi
    export TASKDAG_FENCED_PUBLISH=1
    TASKDAG_ACTIVATION_FENCED_PUSH_RESULT=''
    taskdag_consumer_fenced_scheduling_push publish-completion "${TASK_DAG_CLAIMER:-publisher}" "$updates" || rc=$?
    unset TASKDAG_FENCED_PUBLISH
    [ "$rc" -eq 0 ] || {
        if ! jq -e 'type=="object" and .schema==1 and (.outcome=="authority-contention" or .outcome=="target-changed" or .outcome=="rejected-no-effect" or .outcome=="indeterminate")' \
          <<<"$TASKDAG_ACTIVATION_FENCED_PUSH_RESULT" >/dev/null 2>&1; then
            echo "Publication evidence: candidate=$tip attempt=$attempt classification=unavailable push-exit=unknown readback=unknown" >&2
            echo "Publication evidence: master-before=unknown master-candidate=$tip master-observed=unknown" >&2
            echo "Publication evidence: authority-before=unknown authority-observed=unknown authority-guard=unknown" >&2
            echo "Recovery command: task-dag publish $tip" >&2
            echo "Error: completion publication failed before a trustworthy remote outcome was available. Nothing is proven about remote effect; do not recreate or retry automatically. Inspect origin/master and activation authority before using the recovery command." >&2
            return "$rc"
        fi
        outcome=$(jq -r .outcome <<<"$TASKDAG_ACTIVATION_FENCED_PUSH_RESULT") || return 2
        diagnostic=$(jq -r .push.diagnostic <<<"$TASKDAG_ACTIVATION_FENCED_PUSH_RESULT") || return 2
        _taskdag_publish_evidence "$tip" "$attempt" "$TASKDAG_ACTIVATION_FENCED_PUSH_RESULT" || return 2
        [ -z "$diagnostic" ] || printf 'Git push diagnostic (sanitized): %s\n' "$diagnostic" >&2
        case "$outcome" in
            authority-contention)
                # Internal-only status consumed by cmd_publish's bounded loop.
                return 75
                ;;
            target-changed)
                echo "Error: origin/master is now neither the expected old tip nor the exact completion candidate. Prior application is unknown; do not retry or recreate automatically. Inspect whether current master contains the candidate, then run publish again to determine whether it is present, still valid, or must be recreated." >&2
                ;;
            rejected-no-effect)
                echo "Error: completion publication was rejected with confirmed no remote effect. The exact candidate may be retried after fixing the reported transport, authentication, or hook rejection; do not recreate it solely for this failure." >&2
                ;;
            indeterminate)
                echo "Error: completion publication outcome is indeterminate. Remote effect is unknown; do not recreate or retry automatically. Inspect origin/master and activation authority, then retry this exact candidate only if it is not already present." >&2
                ;;
        esac
        return "$rc"
    }
    git update-ref refs/remotes/origin/master "$tip" 2>/dev/null || true
    echo "Published canonical task-dag completion to origin/master: $tip"
}

cmd_publish() {
    local tip retry=0 rc
    case "${1:-}" in
        -h|--help)
            cat <<'EOF'
Usage: task-dag publish [<completion-or-close-tip>]

Validate and publish one exact local completion/close candidate. In an
activated repository, master and activation authority move atomically.

Ordinary activation-authority contention is retried with the shared bounded
CAS budget and fresh validation before every attempt. Other outcomes stop:
  target changed       Inspect current master; prior application is unknown.
  rejected/no effect   Fix the rejection, then retry the exact candidate.
  indeterminate        Inspect master and activation authority before retrying.

Never recreate a completion merely because publication failed. A fresh
publish of the exact candidate converges if it is already present and reports
when changed ancestry or requirements really require a rebase/recreation.
EOF
            return 0
            ;;
        "") tip=HEAD ;;
        *) tip=$1; [ "$#" -eq 1 ] || { echo "Usage: task-dag publish [<completion-or-close-tip>]" >&2; return 2; } ;;
    esac
    tip=$(git rev-parse --verify "${tip}^{commit}") || return 2
    [[ "$TASKDAG_CAS_MAX_ATTEMPTS" =~ ^[0-9]+$ ]] || { echo "Error: TASKDAG_CAS_MAX_ATTEMPTS must be a non-negative integer" >&2; return 2; }
    while :; do
        if _taskdag_publish_attempt "$tip" "$((retry+1))"; then
            return 0
        else
            rc=$?
        fi
        [ "$rc" -eq 75 ] || return "$rc"
        if [ "$retry" -ge "$TASKDAG_CAS_MAX_ATTEMPTS" ]; then
            echo "Error: completion publication candidate=$tip exhausted ${TASKDAG_CAS_MAX_ATTEMPTS} retries after $((retry+1)) fenced attempts under proven activation-authority contention. Every failed attempt left origin/master unchanged. Recovery command: task-dag publish $tip. Recreate only if fresh validation reports changed requirements or master ancestry." >&2
            return 3
        fi
        retry=$((retry+1))
        echo "Activation authority advanced during completion publication; revalidating the same candidate before bounded retry ${retry}/${TASKDAG_CAS_MAX_ATTEMPTS}." >&2
        taskdag_cas_sleep "$retry" || return 2
    done
}

cmd_guard_pre_push() {
    if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        cat <<EOF
Usage: task-dag guard-pre-push [<remote-name> <remote-url>]

Body of a repo 'pre-push' hook. Git invokes the hook as
'pre-push <remote-name> <remote-url>' with one line per ref update on stdin:
  <local-ref> SP <local-sha> SP <remote-ref> SP <remote-sha>

Refuses (exit 1) a push that lands PLAIN implementation work on master while
you still hold an unresolved task-dag claim in this repo — i.e. you skipped
'task-dag complete'. All other pushes pass (cross-repo Satisfies: work,
maintenance commits, and properly-completed pushes). A prepared-worker master
push fails closed when its task semantics cannot be evaluated. Wire it up as:

    exec task-dag guard-pre-push "\$@"

Exit codes: 0 = allow, 1 = rejected (complete before pushing).
EOF
        return 0
    fi

    local remote_name="${1:-}"

    # Non-origin remote: task refs are origin-scoped, so we can't reason about
    # claims. Allow with a note.
    if [ -n "$remote_name" ] && [ "$remote_name" != "origin" ]; then
        echo "[pre-push] remote '$remote_name' is not origin; skipping the task-dag complete-before-push guard." >&2
        return 0
    fi

    # Identity applies only to the plain-work/owned-claim check. Semantic tips
    # are classified for every origin/master push so activated raw completion
    # publication cannot bypass the generation fence when identity is unset.
    local claimer="${TASK_DAG_CLAIMER:-}"
    local claimer_host="${TASK_DAG_CLAIMER_HOST:-$(hostname -s 2>/dev/null || echo unknown)}"

    local blocked=0
    local local_ref local_sha remote_ref remote_sha
    while read -r local_ref local_sha remote_ref remote_sha; do
        [ -n "${local_ref:-}" ] || continue
        [ "$remote_ref" = "refs/heads/master" ] || continue
        # master deletion (local_sha all zeros) — not our concern.
        case "$local_sha" in *[!0]*) : ;; *) continue ;; esac

        local local_commit
        local_commit=$(git rev-parse --verify "${local_sha}^{commit}" 2>/dev/null) || {
            echo "[pre-push] cannot resolve pushed object ${local_sha}; refusing (fail closed)." >&2
            blocked=1
            continue
        }

        # First push of master (remote_sha all zeros): don't scan all history.
        local remote_commit
        case "$remote_sha" in
            *[!0]*)
                remote_commit=$(git rev-parse --verify "${remote_sha}^{commit}" 2>/dev/null) || {
                    echo "[pre-push] remote base ${remote_sha} unavailable (shallow clone?); refusing (fail closed)." >&2
                    blocked=1
                    continue
                }
                ;;
            *)
                echo "[pre-push] first push of master has no semantic base; refusing prepared-worker push." >&2
                blocked=1
                continue
                ;;
        esac

        # Classify semantic tips before the implementation-range shortcut:
        # ops, historical, and close-only publications may add no code.
        if is_sanctioned_tip_commit "$local_commit"; then
            if ! sanctioned_tip_requirements_satisfied "$local_commit"; then
                echo "[pre-push] completion/close shape or canonical requirements changed; refusing stale publication." >&2
                blocked=1
                continue
            fi
            if [ "$TASKDAG_CONSUMER_MODE" = canonical ] && [ "${TASKDAG_FENCED_PUBLISH:-}" != 1 ]; then
                echo "[pre-push] canonical epochs require 'task-dag publish' so master and the semantic generation advance atomically." >&2
                blocked=1
                continue
            fi
            continue
        fi
        # Only care about a non-semantic push if it adds implementation work.
        if ! range_has_impl_commit "${remote_commit}..${local_commit}"; then continue; fi
        if ! taskdag_consumer_prepare guard-pre-push --tip "$local_commit"; then
            echo "[pre-push] cannot attest canonical task semantics; refusing this master push (fail closed)." >&2
            blocked=1
            continue
        fi
        # Plain-impl tip: only a violation if I hold an unresolved claim here.
        if [ -z "$claimer" ]; then
            echo "[pre-push] TASK_DAG_CLAIMER unset; skipping the owned-claim check for plain work." >&2
            continue
        fi
        local held
        held=$(owned_unresolved_active_claims "$claimer" "$claimer_host" "$local_commit")
        if [ -n "$held" ]; then
            blocked=1
            printf '%b' "${RED}" >&2
            echo "════════════════════════════════════════════════════════════════════" >&2
            echo " task-dag: refusing to push implementation work before 'task-dag complete'" >&2
            echo "════════════════════════════════════════════════════════════════════" >&2
            echo " You are pushing a plain implementation commit to master, but you still" >&2
            echo " hold an unresolved task-dag claim in this repo:" >&2
            echo "" >&2
            local t
            for t in $held; do echo "   • tasks/active/$t" >&2; done
            echo "" >&2
            echo " Canon finalize order (rules/WORKFLOW.md): commit → git fetch → rebase" >&2
            echo " origin/master → 'task-dag complete <sha>' (builds the completion MERGE" >&2
            echo " locally) → push. Pushing first races another landing commit and forces" >&2
            echo " a 'complete-historical' recovery that encodes the task↔commit link only" >&2
            echo " in a trailer, losing the queryable git parentage." >&2
            echo "" >&2
            echo " Run 'task-dag complete' for the task(s) above, then push again." >&2
            echo " Do NOT bypass with 'git push --no-verify'." >&2
            echo "════════════════════════════════════════════════════════════════════" >&2
            printf '%b' "${RESET}" >&2
        fi
    done

    [ "$blocked" -eq 0 ]
}

cmd_guard_message() {
    local msg_file="" from_stdin=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stdin) from_stdin=true; shift ;;
            --file=*) msg_file="${1#*=}"; shift ;;
            --help|-h)
                cat <<EOF
Usage: task-dag guard-commit-message <message-file>
       task-dag guard-commit-message --file=<message-file>
       task-dag guard-commit-message --stdin

Exit non-zero if the commit message either (a) has a Conventional-Commits
subject prefix (feat:, fix(scope):, chore!:, …) — canon requires a plain,
capitalized, imperative subject (rules/WORKFLOW.md 'Commit messages'),
(b) uses GitHub-native close/fix/resolve keywords with an issue reference,
which would bypass task-dag's epic-close projection, or (c) names task-dag
control-plane content that only the tooling may emit
(Task: subject, Type:, Task-Commit:, Status: completed/pending, Closes-Epic:,
Historical-Commit:, Retroactive:, Blocked-Meta:). The control-plane commits
are all built with 'git commit-tree' (which bypasses hooks), so those markers
only ever appear in a manual 'git commit' — i.e. someone is hand-crafting a
task-impacting commit. Intended as the body of a repo 'commit-msg' hook:

    exec task-dag guard-commit-message "\$1"

Exit codes: 0 = clean (allow), 1 = rejected (Conventional-Commits subject
or a reserved control-plane marker), 2 = usage error.
EOF
                return 0 ;;
            -*) echo "Unknown option: $1" >&2; return 2 ;;
            *) if [ -z "$msg_file" ]; then msg_file="$1"; else echo "Unknown argument: $1" >&2; return 2; fi; shift ;;
        esac
    done

    local raw
    if [ -n "$msg_file" ]; then
        [ -f "$msg_file" ] || { echo "Error: commit-message file not found: $msg_file" >&2; return 2; }
        raw=$(cat "$msg_file")
    elif [ "$from_stdin" = true ]; then
        raw=$(cat)
    else
        echo "Error: provide a commit-message file (positional or --file=), or --stdin." >&2
        return 2
    fi

    # Ignore git's comment lines (default '#'); honour a single-char
    # core.commentChar override. 'auto' or multi-char → fall back to '#'.
    # Compare the first char literally (never build a regex from cc — a
    # regex-special value like ']' or '\' would corrupt the filter and,
    # under the '|| true' below, silently fail open).
    local cc; cc=$(git config core.commentChar 2>/dev/null || true)
    [ ${#cc} -eq 1 ] || cc='#'
    local scan; scan=$(awk -v cc="$cc" 'substr($0,1,1) != cc' <<<"$raw")

    local -a hits=()
    # Use a here-string + read for the subject (no producer pipe that can
    # SIGPIPE→141 under 'set -o pipefail' on a long message).
    local subject=""
    while IFS= read -r subject; do
        case "$subject" in ""|[[:space:]]*) [ -z "${subject//[[:space:]]/}" ] && continue ;; esac
        break
    done <<<"$scan"
    case "$subject" in
        Task:*) hits+=("subject 'Task:'  → task commits are minted by 'task-dag breakdown' (or the issue→task workflow), never by hand") ;;
    esac
    # Canon commit-style (rules/WORKFLOW.md "Commit messages"): the subject is
    # a plain, capitalized, imperative sentence — NEVER a Conventional-Commits
    # `type(scope):` prefix (feat:, fix(mss):, chore!:, seo(faq):, …). This is
    # a distinct failure from the control-plane markers above, so it gets its
    # own message and short-circuits. Match only the high-signal pattern: a
    # leading lowercase word (optionally `(scope)` and/or `!`) immediately
    # followed by `: `. Capitalized subjects, `fixup!`/`squash!` (no colon),
    # and `word://…` (no space after the colon) never match.
    if subject_is_conventional_commits "$subject"; then
        printf '%b' "${RED}" >&2
        echo "════════════════════════════════════════════════════════════════════" >&2
        echo " task-dag: refusing a Conventional-Commits commit subject" >&2
        echo "════════════════════════════════════════════════════════════════════" >&2
        echo " Subject: $subject" >&2
        echo "" >&2
        echo " Canon (rules/WORKFLOW.md 'Commit messages') requires a plain," >&2
        echo " capitalized, imperative sentence — never a type(scope): prefix." >&2
        echo "   Bad:  feat(helios): add report export" >&2
        echo "   Good: Add report export for Helios" >&2
        echo "" >&2
        echo " Amend the subject and retry. Do NOT bypass with 'git commit --no-verify'." >&2
        echo "════════════════════════════════════════════════════════════════════" >&2
        printf '%b' "${RESET}" >&2
        return 1
    fi
    # here-string (not a pipe) so an early 'grep -q' exit can't SIGPIPE a
    # producer and flip a real match into a pipefail non-match.
    _gm_has() { grep -qiE "$1" <<<"$scan"; }
    _gm_has '^Task-Commit:'                          && hits+=("Task-Commit:       → the impl↔task link is the completion MERGE's parentage; use 'task-dag complete'")
    _gm_has '^Status:[[:space:]]*(completed|pending)([[:space:]]|$)' && hits+=("Status: …          → task lifecycle is set by 'task-dag complete' / 'breakdown', not a hand-written trailer")
    _gm_has '^Ops-(Completion|Evidence|Authorization|Reason|Completed-By|Completed-Host|Completed-At):' && hits+=("Ops-* trailers   → no-code ops completions are minted by 'task-dag complete-ops', never by hand")
    _gm_has '^Closes-Epic:'                          && hits+=("Closes-Epic:       → epics are closed by 'task-dag close-epic' / 'close-ops-epic'")
    _gm_has '^Historical-Commit:'                    && hits+=("Historical-Commit: → retroactive links use 'task-dag complete-historical'")
    _gm_has '^Retroactive:[[:space:]]*true'          && hits+=("Retroactive: true  → use 'task-dag complete-historical'")
    _gm_has '^Blocked-Meta:'                         && hits+=("Blocked-Meta:      → blocking is done by 'task-dag block'")
    _gm_has '^Type:[[:space:]]*(epic|task|leaf)([[:space:]]|$)' && hits+=("Type: …            → task commits are minted by tooling ('task-dag breakdown')")
    _gm_has '^(Materialise-Child-Epic|Materialize-Child-Epic|Child-Epic-Title|Child-Epic-Body-File|Child-Epic-Slug|Parent-Issue|Delegation-Note|Satisfies|Phase):' && hits+=("Legacy producer metadata → legacy semantic writers are disabled during migration drain")
    _gm_has '(^|[^[:alnum:]_-])(close|closes|closed|fix|fixes|fixed|resolve|resolves|resolved)[[:space:]]+([-[:alnum:]_.]+/[-[:alnum:]_.]+)?#[1-9][0-9]*([^0-9]|$)' && hits+=("GitHub close keyword → use task-dag close/complete flows; native close/fix/resolve keywords bypass projection")

    [ ${#hits[@]} -eq 0 ] && return 0

    printf '%b' "${RED}" >&2
    echo "════════════════════════════════════════════════════════════════════" >&2
    echo " task-dag: refusing a HAND-WRITTEN task-impacting commit" >&2
    echo "════════════════════════════════════════════════════════════════════" >&2
    echo " This commit message carries task-dag control-plane content that ONLY" >&2
    echo " the tooling may produce (it builds such commits with 'git commit-tree'," >&2
    echo " which is why this hook never fires on legitimate task-dag commits):" >&2
    echo "" >&2
    local h
    for h in "${hits[@]}"; do echo "   • $h" >&2; done
    echo "" >&2
    echo " Task semantics live in the git DAG/refs, created via the CLI — never by" >&2
    echo " hand-writing these trailers (see docs/DESIGN_PRINCIPLES.md). Re-run the" >&2
    echo " right 'task-dag' subcommand above. If this is real implementation work," >&2
    echo " drop the trailer(s) and commit normally, then link it with the CLI." >&2
    echo " Do NOT bypass this with 'git commit --no-verify'." >&2
    echo "════════════════════════════════════════════════════════════════════" >&2
    printf '%b' "${RESET}" >&2
    return 1
}

# Execute (must be the final statement so all functions, including those
# in dead-code section above and any sourced extensions, are registered).
main "$@"
