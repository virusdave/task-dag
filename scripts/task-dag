        graph-converge) cmd_graph_converge "$@" ;;
        migrate-legacy-edges) cmd_migrate_legacy_edges "$@" ;;
        dep) cmd_dep "$@" ;;
        mailbox) cmd_mailbox "$@" ;;
        supersede) cmd_supersede "$@" ;;
        materialise-batch) cmd_materialise_batch "$@" ;;
        materialise-child) cmd_materialise_child "$@" ;;
        materialise-census) cmd_materialise_census "$@" ;;
        materialise-census-capture) cmd_materialise_census_capture "$@" ;;
