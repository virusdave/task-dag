#!/usr/bin/env bash
# task-dag commit-message guard (canonical, repo-agnostic).
#
# Refuses a HAND-WRITTEN commit whose message carries task-dag control-plane
# markers (Task: subject, Type:, Task-Commit:, Status: completed/pending,
# Closes-Epic:, Historical-Commit:, Retroactive:, Blocked-Meta:). task-dag's
# own control commits are built with `git commit-tree`, which BYPASSES git
# hooks, so this only ever fires on a manual `git commit` — i.e. someone is
# hand-crafting a task-impacting commit instead of using the CLI (the footgun
# behind FreshlyBakedNYC/automation@53c9e712b; see docs/DESIGN_PRINCIPLES.md).
#
# This hook DELEGATES the check to the canonical `task-dag guard-commit-message`
# so the marker→tooling knowledge lives in exactly one place. It is IDENTICAL
# across every cohort repo — copy it verbatim into each repo's hooks dir.
#
# Enable (per clone; git will not auto-activate a committed hooks dir):
#     git config core.hooksPath .githooks
#
# The goal is to reliably stop an agent from ACCIDENTALLY doing this by hand,
# not to stop a determined adversary. Do NOT bypass with `git commit --no-verify`.
set -euo pipefail

msg_file="$1"

# Locate the canonical CLI without re-encoding any of its logic:
#   1. explicit override (TASK_DAG_BIN)
#   2. task-dag on PATH
#   3. scripts/task-dag inside this repo (the task-dag repo itself)
td="${TASK_DAG_BIN:-}"
if [ -z "$td" ]; then
  if command -v task-dag >/dev/null 2>&1; then
    td="$(command -v task-dag)"
  else
    root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [ -n "$root" ] && [ -x "$root/scripts/task-dag" ]; then
      td="$root/scripts/task-dag"
    fi
  fi
fi

if [ -z "$td" ]; then
  # Fail OPEN (with a loud note) when the CLI is unavailable: this is a
  # dev-side convenience gate, and bricking every commit in a CLI-less
  # checkout would just push people to --no-verify. Set TASK_DAG_BIN to
  # enforce in such environments.
  echo "[commit-msg] task-dag CLI not found; skipping the task-dag commit-message guard (set TASK_DAG_BIN to enforce)." >&2
  exit 0
fi

exec "$td" guard-commit-message "$msg_file"
